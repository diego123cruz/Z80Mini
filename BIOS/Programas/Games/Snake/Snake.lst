8229: 29      	    add hl,hl
822A: 9F      	    sbc a,a
822B: E62D    	    and %00101101
822D: AD      	    xor l
822E: 6F      	    ld l,a
822F: 224F82  	    ld (seed2),hl
8232: 09      	    add hl,bc
8233: C9      	    ret
              	
