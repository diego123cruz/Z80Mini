007E:         	VTELA_X     .EQU    $7E ; Tela virtal 
003E:         	VTELA_Y     .EQU    $3E ; Tela virtal
              	
81C9:         	randomHL:
              	    ; 3F = 126/2
              	    ; 1F = 62/2
81C9: CDDF81  	    CALL prng16
81CC: 7C      	    LD A, H
81CD: E67D    	    AND VTELA_X-1
81CF: FE00    	    CP 0
81D1: CAC981  	    JP Z, randomHL
81D4: 67      	    LD H, A
              	
81D5: 7D      	    LD A, L
81D6: E63D    	    AND VTELA_Y-1
81D8: FE00    	    CP 0
81DA: CAC981  	    JP Z, randomHL
81DD: 6F      	    LD L, A
81DE: C9      	    RET
              	
              	
81DF:         	prng16:
              	; Site: https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Random
              	;Inputs:
              	;   (seed1) contains a 16-bit seed value
              	;   (seed2) contains a NON-ZERO 16-bit seed value
              	;Outputs:
              	;   HL is the result
              	;   BC is the result of the LCG, so not that great of quality
              	;   DE is preserved
              	;Destroys:
              	;   AF
              	;cycle: 4,294,901,760 (almost 4.3 billion)
              	;160cc
              	;26 bytes
81DF: 2AF981  	    ld hl,(seed1)
81E2: 44      	    ld b,h
81E3: 4D      	    ld c,l
81E4: 29      	    add hl,hl
81E5: 29      	    add hl,hl
81E6: 2C      	    inc l
81E7: 09      	    add hl,bc
81E8: 22F981  	    ld (seed1),hl
81EB: 2AFB81  	    ld hl,(seed2)
81EE: 29      	    add hl,hl
81EF: 9F      	    sbc a,a
81F0: E62D    	    and %00101101
81F2: AD      	    xor l
81F3: 6F      	    ld l,a
81F4: 22FB81  	    ld (seed2),hl
81F7: 09      	    add hl,bc
81F8: C9      	    ret
              	
              	
81F9: D204    	seed1       .dw 1234
81FB: 3D22    	seed2       .dw 8765
              	
81FD: 00      	count       .db 0x00    
              	
81FE: 00      	fruit_x     .db 0x00
81FF: 00      	fruit_y     .db 0x00
              	
8200: 00      	box_x:    .db 0x00
8201: 00      	box_y:    .db 0x00
              	
8202: 00      	box2_x:    .db 0x00
8203: 00      	box2_y:    .db 0x00
              	    
8204: 0A      	player_x: .db 0x0A
8205: 0A      	player_y: .db 0x0A
              	
8206: 50726573	msg_start      .db "Press START",0
820A: 73205354	
820E: 41525400	
8212: 47414D45	msg_gameover   .db "GAMEOVER ",0
8216: 4F564552	
821A: 2000    	
821C: 00      	gameover    .db $00
              	
821D: FFFE7C7F	imageR: .db 0xFF, 0xFE, 0x7C, 0x7F, 0x7F, 0x7C, 0xFE, 0xFF
