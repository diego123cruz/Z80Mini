81CE:         	randomHL:
              	    ; 3F = 126/2
              	    ; 1F = 62/2
81CE: CDE481  	    CALL prng16
81D1: 7C      	    LD A, H
81D2: E67D    	    AND VTELA_X-1
81D4: FE00    	    CP 0
81D6: CACE81  	    JP Z, randomHL
81D9: 67      	    LD H, A
              	
81DA: 7D      	    LD A, L
81DB: E63D    	    AND VTELA_Y-1
81DD: FE00    	    CP 0
81DF: CACE81  	    JP Z, randomHL
81E2: 6F      	    LD L, A
81E3: C9      	    RET
              	
              	
81E4:         	prng16:
              	; Site: https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Random
              	;Inputs:
              	;   (seed1) contains a 16-bit seed value
              	;   (seed2) contains a NON-ZERO 16-bit seed value
              	;Outputs:
              	;   HL is the result
              	;   BC is the result of the LCG, so not that great of quality
              	;   DE is preserved
              	;Destroys:
              	;   AF
              	;cycle: 4,294,901,760 (almost 4.3 billion)
              	;160cc
              	;26 bytes
81E4: 2AFE81  	    ld hl,(seed1)
81E7: 44      	    ld b,h
81E8: 4D      	    ld c,l
81E9: 29      	    add hl,hl
81EA: 29      	    add hl,hl
81EB: 2C      	    inc l
81EC: 09      	    add hl,bc
81ED: 22FE81  	    ld (seed1),hl
81F0: 2A0082  	    ld hl,(seed2)
81F3: 29      	    add hl,hl
81F4: 9F      	    sbc a,a
81F5: E62D    	    and %00101101
81F7: AD      	    xor l
81F8: 6F      	    ld l,a
81F9: 220082  	    ld (seed2),hl
81FC: 09      	    add hl,bc
81FD: C9      	    ret
              	
              	
81FE: D204    	seed1       .dw 1234
8200: 3D22    	seed2       .dw 8765
              	
8202: 00      	count       .db 0x00    
              	
8203: 00      	fruit_x     .db 0x00
8204: 00      	fruit_y     .db 0x00
              	
8205: 00      	box_x:    .db 0x00
8206: 00      	box_y:    .db 0x00
              	
8207: 00      	box2_x:    .db 0x00
8208: 00      	box2_y:    .db 0x00
              	    
8209: 0A      	player_x: .db 0x0A
820A: 0A      	player_y: .db 0x0A
              	
820B: 50726573	msg_start      .db "Press START",0
820F: 73205354	
8213: 41525400	
8217: 47414D45	msg_gameover   .db "GAMEOVER ",0
821B: 4F564552	
821F: 2000    	
8221: 00      	gameover    .db $00
              	
8222: FFFE7C7F	imageR: .db 0xFF, 0xFE, 0x7C, 0x7F, 0x7F, 0x7C, 0xFE, 0xFF
8226: 7F7CFEFF	
822A: C3FFFFFF	imageD: .db 0xC3, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xDB, 0x99
822E: FFFFDB99	
8232: 1C1C1408	player: .db 0x1C, 0x1C, 0x14, 0x08, 0x3E, 0x08, 0x08, 0x36
8236: 3E080836	


