              	; zasm: assemble "Main.asm"
              	; date: 2026-06-13 22:27:08
              	; --------------------------------------


              	#include "../Z80MiniAPI.asm"
              	;   API Z80Mini:
0100:         	delay500ms          equ     0x0100  ;   Delay 500ms
0103:         	delay               equ     0x0103  ;   On entry: DE = Delay time in milliseconds
0106:         	I2C_Open            equ     0x0106  ;   On entry: A = Device address (bit zero is read flag)
0109:         	I2C_Close           equ     0x0109  ;   Close
010C:         	I2C_Read            equ     0x010C  ;   On exit: If successful A = data byte and Z flagged
010F:         	I2C_Write           equ     0x010F  ;   On entry: A = Data byte, or Address byte (bit zero is read flag)
0112:         	keyboardIsEsc       equ     0x0112  ;   Verifica se ESC foi precionada. On exit: If press A = CTRLC and NZ flagged
0115:         	keyboardWaitA       equ     0x0115  ;   Aguarda tecla, letra em A. (BC DE HL preserved)
0118:         	keyboardA           equ     0x0118  ;   Lê teclado, Se tecla Carry=1. Letra em A. (BC DE HL preserved)
011B:         	setDefaultSerialA   equ     0x011B  ;   Seta terminal padrao porta A, Quando reinicia volta para A.
011E:         	setDefaultSerialB   equ     0x011E  ;   Seta terminal padrao porta B (P2), Quando reinicia volta para A.
0121:         	serialPrintA        equ     0x0121  ;   Imprime char in A no terminal setado.
0124:         	serialInputA        equ     0x0124  ;   Aguarda receber char no terminal setado. Retorno em A.
0127:         	serialPrintStr      equ     0x0127  ;   Imprime string (HL) terminado em 0 no terminal setado. MAX 128 chars. MODIFIES : A,B,C
012A:         	serialCRLF          equ     0x012A  ;   Imprime CR e LF no terminal setado.
012D:         	serialHexA          equ     0x012D  ;   Imprime byte em A no formato HEX, no terminal setado. Ex: 'D' = 44
0130:         	serialHexHL         equ     0x0130  ;   Imprime HL como 4 digitos hexadecimais, no terminal setado. Ex: HL=$80FF -> imprime "80FF"
0133:         	serialInHexA        equ     0x0133  ;   Pegar 2 caracteres ASCII (0-9 A-F), do terminal setado e converte em um byte em A. SEM ECHO
0136:         	serialInHexHL       equ     0x0136  ;   Pegar 4 caracteres ASCII (0-9 A-F), do terminal setado e converte em HL. SEM ECHO
              	
0139:         	initLCD             equ     0x0139  ;   Inicializa GLCD
013C:         	clearGBUF           equ     0x013C  ;   Limpa buffer da memoria de grafico. Precisa do plotToLCD para refletir no lcd.
013F:         	clearGrLCD          equ     0x013F  ;   Limpa memoria grafico do GLCD. Sem o plotToLCD.
0142:         	clearTxtLCD         equ     0x0142  ;   Limpar caracteres do LCD
0145:         	setGrMode           equ     0x0145  ;   Seta modo Grafico. 128x64
0148:         	setTxtMode          equ     0x0148  ;   Seta mode Text. 16x4 equivalente
014B:         	drawBox             equ     0x014B  ;   Desenha caixa. Entradas: BC = X0,Y0 - DE = X1,Y1    Destroys: HL
014E:         	drawLine            equ     0x014E  ;   Desenha linha.  Entradas: BC = X0,Y0 - DE = X1,Y1
0151:         	drawCircle          equ     0x0151  ;   Desenha circulo. Entradas BC = xm,ym (Ponro do Meio) - E = radius
0154:         	drawPixel           equ     0x0154  ;   Desenha um pixel em X Y.  Entrada B = column/X (0-127), C = row/Y (0-63)   Destroys: HL
0157:         	fillBox             equ     0x0157  ;   Desenha caixa preenchida. Entradas: BC = X0,Y0 - DE = X1,Y1    Destroys: HL
015A:         	fillCircle          equ     0x015A  ;   Desenha circulo preenchido. Entradas BC = xm,ym (Ponro do Meio) - E = radius
015D:         	plotToLCD           equ     0x015D  ;   Rotina principal de desenho. Move GBUF para o LCD e limpa o buffer ou não (setBufClear, setBufNoClear).  Destroys: ALL
0160:         	printString         equ     0x0160  ;   Imprimir texto ASCII em uma determinada linha. Entradas: A = 0 a 3 Número da linha. .db "String" na próxima linha, terminar com 0
0163:         	printChars          equ     0x0163  ;   (Ver detalhes) Imprimir caracteres na posição X,Y. Entrada B = coluna/X (0-7), C = linha/Y (0-3). HL = Endereço inicial do texto a ser exibido, termina com 0
0166:         	setInt38            equ     0x0166  ;   Seta vetor de interrupcao int38. Entradas HL = RST38_ADDR
0169:         	setint66            equ     0x0169  ;   Seta vetor de interrupcao int66. Entradas HL = RST66_ADDR
016C:         	setBufClear         equ     0x016C  ;   Configura limpeza do buffer após a saída para o LCD e vai para clearGBUF.
016F:         	setBufNoClear       equ     0x016F  ;   Configura para não limpar o buffer após a saída para o LCD.
0172:         	clearPixel          equ     0x0172  ;   Limpa um pixel X Y.  Input B = column/X (0-127), C = row/Y (0-63)    Destroy HL
0175:         	flipPixel           equ     0x0175  ;   Inverte um pixel X Y.  Input B = column/X (0-127), C = row/Y (0-63)    Destroy HL
0178:         	drawGraphic         equ     0x0178  ;   Desenha no buffer. Entrada: A = número ASCII ou se A=0 Então  HL = Endereço dos dados gráficos. B = largura do gráfico em pixels (1-128). C = altura do gráfico em pixels (1-64). Destroy: ALL
017B:         	invGraphic          equ     0x017B  ;   Altera a flag de desenho inverso. (não inverte grafico atual) Destroy A
017E:         	initTerminal        equ     0x017E  ;   Inicializa o Terminal GLCD. Cursor 0,0 e limpa buffer.
0181:         	sendCharToLCD       equ     0x0181  ;   Envia ou manipula caracteres ASCII para a tela GLCD (Terminal). Entrada: A = caractere ASCII a ser enviado para a tela GLCD. A = somente cursor desenhado.
0184:         	sendStringToLCD     equ     0x0184  ;   Imprime string no terminal GLCD. DE = inicio da string. A = caractere para parar a impressão. A impressão para e retorna quando um CR é impresso. Destroy ALL
0187:         	sendRegToLCD        equ     0x0187  ;   Imprime byte em A no formato HEX, no GLCD. Ex: 'D' = 44
018A:         	sendHLToLCD         equ     0x018A  ;   Imprime HL como 4 digitos hexadecimais, no GLCD. Ex: HL=$80FF -> imprime "80FF"
018D:         	setCursor           equ     0x018D  ;   Define a posição do cursor gráfico. Entradas: BC = X,Y onde X = 0..127, Y = 0..63   Destroy A
0190:         	getCursor           equ     0x0190  ;   Obter a posição do cursor. Saídas: BC = X,Y onde X = 0..127, Y = 0..63
0193:         	displayCursor       equ     0x0193  ;   Exibir Cursor. Entrada: A = 0, Ativar cursor, A = diferente de zero, Desativar cursor.
0196:         	autoLF              equ     0x0196  ;   Avanço de linha automático quando o cursor atinge o final da linha (Terminal). Entrada: A = 0, Avanço de linha automático; A = diferente de zero, Sem avanço de linha automático. Padrao LIGADO.
0199:         	underline           equ     0x0199  ;   Exibir sublinhado no caractere (Terminal). O estado inicial é sem sublinhado. Chamar esta rotina irá ALTERAR/DESLIGAR o sinalizador de sublinhado.
019C:         	plotAlways          equ     0x019C  ;   Quando sendCharToLCD é chamado, Atualiza GLCD ou não. Se Desativado plotToLCD deve ser chamado atualizar o GLCD. Entrada: A=0, Plotar sempre; A>0, Não plotar. O padrão é Plotar sempre.
0294:         	resetCollisionPixel equ     0x0294  ;   Limpa flag de colisao
0299:         	checkCollisionPixel equ     0x0299  ;   Check se um pixel ja estava ligado quando tenta ligar. JP Z, SEM_COLISAO. JP NZ, COLISAO.
              	
              	
              	
              	
              	; -----------------------------------------------------------------------------
              	; PORTS
              	; -----------------------------------------------------------------------------
0070:         	GLCD_INST           .EQU    $70
0071:         	GLCD_DATA           .EQU    $71
              	
0040:         	KEYBOARD		    .EQU	$40
              	
              	; ============================================================
              	; KEYMAPS
              	; ============================================================
              	
              	;	$FF - Capsloock
              	;	$FE - Shift left
              	;	$FD - Ctrl left
              	;	$FC - Windows
              	;	$FB - Alt left
              	;	$FA - Alt Gr    (Load intel hex - Serial A)
              	;	$F9 - LUZ   (CALL 8000H)
              	;	$F8 - Shift Right   (Display Scroll UP)
              	;	$F7 - Ctrl Right    (Display Scroll DOWN)
              	;	$F6 - Fn
              	
              	; -------- Constantes gerais --------
000D:         	CR:       EQU   0DH
000A:         	LF:       EQU   0AH
0008:         	BKS:      EQU   08H
007F:         	DEL:      EQU   7FH
001B:         	ESC:      EQU   1BH
0020:         	SPACE:    EQU   20H
0000:         	NUL:      EQU   00H
000C:         	FF:       EQU   0CH                 ; Form Feed -> Limpa lcd
              	
              	; -----------------------------------------------------------------------------
              	; SIO/2 - SERIAL
              	; -----------------------------------------------------------------------------
0000:         	SIOA_D:   EQU   $00
0002:         	SIOA_C:   EQU   $02
0001:         	SIOB_D:   EQU   $01   ; Conector P2
0003:         	SIOB_C:   EQU   $03   ; Conector P2
              	
              	
              	
              	;       TESTES
              	;
              	;       ATW "wifiName,WifiSenha"
              	;
              	;       ATD "bbs.retrocampus.com"
              	;
              	
              	
0200:         	SER_BUFSIZE     .EQU  $200    ; 512 bytes
0080:         	SER_FULLSIZE    .EQU  $80
0005:         	SER_EMPTYSIZE   .EQU  5
              	
0003:         	PLOT_EVERY  EQU  3      ; plota a cada N chars recebidos
8000:         	        org $8000
              	
              	;------------------------------------------------------------------------------
              	; Inicializacao
              	;------------------------------------------------------------------------------
8000:         	inicio:
              	        ; Initialise SIO/2 B - Printer (P2 conector)
8000: 3E04    	        LD      A,$04
8002: D303    	        OUT     (SIOB_C),A
8004: 3EC4    	        LD      A,$C4
8006: D303    	        OUT     (SIOB_C),A
              	
8008: 3E03    	        LD      A,$03
800A: D303    	        OUT     (SIOB_C),A
800C: 3EE1    	        LD      A,$E1
800E: D303    	        OUT     (SIOB_C),A
              	
8010: 3E05    	        LD      A,$05
8012: D303    	        OUT     (SIOB_C),A
8014: 3E68    	        LD      A,$68
8016: D303    	        OUT     (SIOB_C),A
              	
              	        ; WR1 = interrupção em todos os caracteres recebidos
8018: 3E01    	        LD      A,1
801A: D303    	        OUT     (SIOB_C),A
801C: 3E18    	        LD      A,%00011000
801E: D303    	        OUT     (SIOB_C),A
              	
              	        ; Inicializa buffer serial B
8020: 210000  	        LD      HL,$0000
8023: 221B83  	        LD      (serBBufUsed),HL
8026: 211781  	        LD      HL,serBBuf
8029: 221783  	        LD      (serBInPtr),HL
802C: 221983  	        LD      (serBRdPtr),HL
              	
              	
802F: AF      	        XOR     A
8030: 321D83  	        LD      (plotCounter), A
              	
8033: 210008  	        LD HL, $0800
8036: 221E83  	        LD (tick), HL
              	
              	
              	        ; Configura serial B como padrao
8039: CD1E01  	        CALL    setDefaultSerialB
              	
              	        ; Configura ISR serial B via INT38
803C: 215980  	        LD      HL,serialInt
803F: CD6601  	        CALL    setInt38
8042: ED56    	        IM      1
8044: FB      	        EI
              	
8045: 3E0C    	        LD      A,FF
8047: CD8101  	        CALL    sendCharToLCD
              	
804A: 110C81  	        LD      DE,msg
804D: CD8401  	        CALL    sendStringToLCD
              	
              	;------------------------------------------------------------------------------
              	; Loop principal — le byte do buffer e exibe no LCD
              	;------------------------------------------------------------------------------
8050:         	LOOP:
8050: CD8C80  	        CALL    coninB        ; pega do buffer se tiver, le teclado se tecla e retorna
8053: CDE180  	        CALL    PUTCHAR       ; mostra no display
8056: C35080  	        JP      LOOP
              	
              	;------------------------------------------------------------------------------
              	; ISR Serial B
              	; O trampolim em $0038 faz PUSH HL antes de saltar aqui,
              	; por isso o primeiro POP HL é obrigatório para desfazer esse push.
              	;------------------------------------------------------------------------------
8059:         	serialInt:
8059: E1      	        POP     HL              ; desfaz PUSH HL do trampolim em $0038
              	
805A: F5      	        PUSH    AF
805B: E5      	        PUSH    HL
805C: C5      	        PUSH    BC
              	
805D:         	serialIntB:
              	        ; Grava na posição atual, incrementa depois
805D: 2A1783  	        LD      HL,(serBInPtr)
8060: DB01    	        IN      A,(SIOB_D)      ; lê byte UMA vez
8062: 77      	        LD      (HL),A          ; grava no buffer
              	
              	        ; Avança serBInPtr com wrap por comparação de endereço
8063: 23      	        INC     HL
8064: 011783  	        LD      BC,serBBuf + SER_BUFSIZE
8067: 7C      	        LD      A,H
8068: B8      	        CP      B
8069: 2007    	        JR      NZ,notBWrap
806B: 7D      	        LD      A,L
806C: B9      	        CP      C
806D: 2003    	        JR      NZ,notBWrap
806F: 211781  	        LD      HL,serBBuf      ; wrap: volta ao início
8072:         	notBWrap:
8072: 221783  	        LD      (serBInPtr),HL
              	
              	        ; Incrementa contador (16 bits)
8075: 2A1B83  	        LD      HL,(serBBufUsed)
8078: 23      	        INC     HL
8079: 221B83  	        LD      (serBBufUsed),HL
              	
807C: C1      	        POP     BC
807D: E1      	        POP     HL
807E: F1      	        POP     AF
807F: FB      	        EI
8080: ED4D    	        RETI
              	
8082:         	updateDisplay:
8082: CD5D01  	        call plotToLCD
8085: 210008  	        LD HL, $0800
8088: 221E83  	        LD (tick), HL
808B: C9      	        ret
              	
              	
              	;------------------------------------------------------------------------------
              	; coninB — aguarda e retorna um byte do buffer serial B em A
              	; Também verifica teclado: se tecla pressionada, chama getLine
              	;------------------------------------------------------------------------------
808C:         	coninB:
808C:         	waitForCharB:
808C: CD1801  	        CALL    keyboardA
808F: DCC980  	        CALL    C, keyboardSend       ; tecla pressionada: envia linha via serial
              	
              	        ;tick para atualizar o display
8092: 2A1E83  	        ld HL, (tick)
8095: 2B      	        dec HL
8096: 221E83  	        LD (tick), HL
8099: 7C      	        ld a, h
809A: B5      	        or l
809B: FE00    	        cp 0
809D: CC8280  	        call z, updateDisplay
              	
              	        ; Verifica se buffer tem dados (16 bits)
80A0: 2A1B83  	        LD      HL,(serBBufUsed)
80A3: 7C      	        LD      A,H
80A4: B5      	        OR      L
80A5: 28E5    	        JR      Z,waitForCharB  ; vazio, aguarda
              	
              	        ; Lê byte na posição atual de leitura
80A7: 2A1983  	        LD      HL,(serBRdPtr)
80AA: 7E      	        LD      A,(HL)          ; lê o byte
80AB: F5      	        PUSH    AF              ; preserva byte lido
              	
              	        ; Avança serBRdPtr com wrap
80AC: 23      	        INC     HL
80AD: 011783  	        LD      BC,serBBuf + SER_BUFSIZE
80B0: 7C      	        LD      A,H
80B1: B8      	        CP      B
80B2: 2007    	        JR      NZ,notRdWrapB
80B4: 7D      	        LD      A,L
80B5: B9      	        CP      C
80B6: 2003    	        JR      NZ,notRdWrapB
80B8: 211781  	        LD      HL,serBBuf      ; wrap: volta ao início
80BB:         	notRdWrapB:
80BB: F3      	        DI
80BC: 221983  	        LD      (serBRdPtr),HL
              	
              	        ; Decrementa contador (16 bits)
80BF: 2A1B83  	        LD      HL,(serBBufUsed)
80C2: 2B      	        DEC     HL
80C3: 221B83  	        LD      (serBBufUsed),HL
80C6: FB      	        EI
              	
80C7: F1      	        POP     AF              ; byte lido de volta em A
80C8: C9      	        RET
              	
              	;------------------------------------------------------------------------------
              	; getLine — captura linha do teclado e envia pela serial
              	;------------------------------------------------------------------------------
80C9:         	keyboardSend:
80C9: CD1501  	        call keyboardWaitA              ; pega char do teclado
80CC: FEF8    	        CP  $F8                         ; UP key
80CE: 280D    	        JR  Z, keyboardSendDispOnly     ; Só manda para o display (comando scroll tela)
80D0: FEF7    	        CP  $F7                         ; DOWN key
80D2: 2809    	        JR  Z, keyboardSendDispOnly     ; Só manda para o display (comando scroll tela)
80D4: CD2101  	        call serialPrintA               ; envia direto pra serial, sem buffer..
80D7: 3E03    	        LD A, PLOT_EVERY                ; forca mostrar
80D9: 321D83  	        LD (plotCounter), A             ; força atualizar display
80DC: C9      	        ret                             ; retorna
80DD:         	keyboardSendDispOnly:
80DD: CD8101  	        CALL    sendCharToLCD           ; manda para o display
80E0: C9      	        RET                             ; retorna
              	
              	;------------------------------------------------------------------------------
              	; PUTCHAR — exibe o caractere em A no LCD e atualiza display
              	;------------------------------------------------------------------------------
80E1:         	PUTCHAR:
80E1: C5      	        PUSH    BC
80E2: D5      	        PUSH    DE
80E3: E5      	        PUSH    HL
              	
80E4: F5      	        PUSH    AF
80E5: 3E01    	        LD      A, 1
80E7: CD9C01  	        CALL    plotAlways      ; desativa plot automático
80EA: F1      	        POP     AF
              	
80EB: CD8101  	        CALL    sendCharToLCD   ; só grava no buffer, não plota
              	
              	        ; Força plot se for CR
80EE: FE0D    	        CP      CR
80F0: 280F    	        JR      Z, PUTCHARdoPlot
80F2: FE0A    	        CP      LF
80F4: 280B    	        JR      Z, PUTCHARdoPlot
              	
              	        ; Incrementa contador
80F6: 3A1D83  	        LD      A, (plotCounter)
80F9: 3C      	        INC     A
80FA: 321D83  	        LD      (plotCounter), A
80FD: FE03    	        CP      PLOT_EVERY
80FF: 3807    	        JR      C, PUTCHARskip        ; ainda não chegou em N
              	
8101:         	PUTCHARdoPlot:
8101: AF      	        XOR     A
8102: 321D83  	        LD      (plotCounter), A
8105: CD8280  	        CALL    updateDisplay
              	
8108:         	PUTCHARskip:
8108: E1      	        POP     HL
8109: D1      	        POP     DE
810A: C1      	        POP     BC
810B: C9      	        RET
              	
              	;------------------------------------------------------------------------------
              	; Dados
              	;------------------------------------------------------------------------------
810C: 5465726D	msg:    db      "Term v0.1", CR, 0
8110: 2076302E	
8114: 310D00  	
              	
              	;------------------------------------------------------------------------------
              	; RAM
              	;------------------------------------------------------------------------------
8117: FFFFFFFF	serBBuf:        .ds     SER_BUFSIZE
811B: FF...   	
8317: FFFF    	serBInPtr:      .ds     2
8319: FFFF    	serBRdPtr:      .ds     2
831B: FFFF    	serBBufUsed:    .ds     2
831D: FF      	plotCounter:    .ds     1
831E: FFFF    	tick:           .ds     2


