              	; --------------------------------------
              	; zasm: assemble "Main.asm"
              	; date: 2026-06-09 23:43:22
              	; --------------------------------------


              	;   API Z80Mini:
0100:         	delay500ms          equ     0x0100  ;   Delay 500ms
0103:         	delay               equ     0x0103  ;   On entry: DE = Delay time in milliseconds
0106:         	I2C_Open            equ     0x0106  ;   On entry: A = Device address (bit zero is read flag)
0109:         	I2C_Close           equ     0x0109  ;   Close
010C:         	I2C_Read            equ     0x010C  ;   On exit: If successful A = data byte and Z flagged
010F:         	I2C_Write           equ     0x010F  ;   On entry: A = Data byte, or Address byte (bit zero is read flag)
0112:         	keyboardIsEsc       equ     0x0112  ;   Verifica se ESC foi precionada. On exit: If press A = CTRLC and NZ flagged
0115:         	keyboardWaitA       equ     0x0115  ;   Aguarda tecla, letra em A. (BC DE HL preserved)
0118:         	keyboardA           equ     0x0118  ;   Lê teclado, Se tecla Carry=1. Letra em A. (BC DE HL preserved)
011B:         	setDefaultSerialA   equ     0x011B  ;   Seta terminal padrao porta A, Quando reinicia volta para A.
011E:         	setDefaultSerialB   equ     0x011E  ;   Seta terminal padrao porta B (P2), Quando reinicia volta para A.
0121:         	serialPrintA        equ     0x0121  ;   Imprime char in A no terminal setado.
0124:         	serialInputA        equ     0x0124  ;   Aguarda receber char no terminal setado. Retorno em A.
0127:         	serialPrintStr      equ     0x0127  ;   Imprime string (HL) terminado em 0 no terminal setado. MAX 128 chars. MODIFIES : A,B,C
012A:         	serialCRLF          equ     0x012A  ;   Imprime CR e LF no terminal setado.
012D:         	serialHexA          equ     0x012D  ;   Imprime byte em A no formato HEX, no terminal setado. Ex: 'D' = 44
0130:         	serialHexHL         equ     0x0130  ;   Imprime HL como 4 digitos hexadecimais, no terminal setado. Ex: HL=$80FF -> imprime "80FF"
0133:         	serialInHexA        equ     0x0133  ;   Pegar 2 caracteres ASCII (0-9 A-F), do terminal setado e converte em um byte em A. SEM ECHO
0136:         	serialInHexHL       equ     0x0136  ;   Pegar 4 caracteres ASCII (0-9 A-F), do terminal setado e converte em HL. SEM ECHO
              	
0139:         	initLCD             equ     0x0139  ;   Inicializa GLCD
013C:         	clearGBUF           equ     0x013C  ;   Limpa buffer da memoria de grafico. Precisa do plotToLCD para refletir no lcd.
013F:         	clearGrLCD          equ     0x013F  ;   Limpa memoria grafico do GLCD. Sem o plotToLCD.
0142:         	clearTxtLCD         equ     0x0142  ;   Limpar caracteres do LCD
0145:         	setGrMode           equ     0x0145  ;   Seta modo Grafico. 128x64
0148:         	setTxtMode          equ     0x0148  ;   Seta mode Text. 16x4 equivalente
014B:         	drawBox             equ     0x014B  ;   Desenha caixa. Entradas: BC = X0,Y0 - DE = X1,Y1    Destroys: HL
014E:         	drawLine            equ     0x014E  ;   Desenha linha.  Entradas: BC = X0,Y0 - DE = X1,Y1
0151:         	drawCircle          equ     0x0151  ;   Desenha circulo. Entradas BC = xm,ym (Ponro do Meio) - E = radius
0154:         	drawPixel           equ     0x0154  ;   Desenha um pixel em X Y.  Entrada B = column/X (0-127), C = row/Y (0-63)   Destroys: HL
0157:         	fillBox             equ     0x0157  ;   Desenha caixa preenchida. Entradas: BC = X0,Y0 - DE = X1,Y1    Destroys: HL
015A:         	fillCircle          equ     0x015A  ;   Desenha circulo preenchido. Entradas BC = xm,ym (Ponro do Meio) - E = radius
015D:         	plotToLCD           equ     0x015D  ;   Rotina principal de desenho. Move GBUF para o LCD e limpa o buffer ou não (setBufClear, setBufNoClear).  Destroys: ALL
0160:         	printString         equ     0x0160  ;   Imprimir texto ASCII em uma determinada linha. Entradas: A = 0 a 3 Número da linha. .db "String" na próxima linha, terminar com 0
0163:         	printChars          equ     0x0163  ;   (Ver detalhes) Imprimir caracteres na posição X,Y. Entrada B = coluna/X (0-7), C = linha/Y (0-3). HL = Endereço inicial do texto a ser exibido, termina com 0
0166:         	setInt38            equ     0x0166  ;   Seta vetor de interrupcao int38. Entradas HL = RST38_ADDR
0169:         	setint66            equ     0x0169  ;   Seta vetor de interrupcao int66. Entradas HL = RST66_ADDR
016C:         	setBufClear         equ     0x016C  ;   Configura limpeza do buffer após a saída para o LCD e vai para clearGBUF.
016F:         	setBufNoClear       equ     0x016F  ;   Configura para não limpar o buffer após a saída para o LCD.
0172:         	clearPixel          equ     0x0172  ;   Limpa um pixel X Y.  Input B = column/X (0-127), C = row/Y (0-63)    Destroy HL
0175:         	flipPixel           equ     0x0175  ;   Inverte um pixel X Y.  Input B = column/X (0-127), C = row/Y (0-63)    Destroy HL
0178:         	drawGraphic         equ     0x0178  ;   Desenha no buffer. Entrada: A = número ASCII ou se A=0 Então  HL = Endereço dos dados gráficos. B = largura do gráfico em pixels (1-128). C = altura do gráfico em pixels (1-64). Destroy: ALL
017B:         	invGraphic          equ     0x017B  ;   Altera a flag de desenho inverso. (não inverte grafico atual) Destroy A
017E:         	initTerminal        equ     0x017E  ;   Inicializa o Terminal GLCD. Cursor 0,0 e limpa buffer.
0181:         	sendCharToLCD       equ     0x0181  ;   Envia ou manipula caracteres ASCII para a tela GLCD (Terminal). Entrada: A = caractere ASCII a ser enviado para a tela GLCD. A = somente cursor desenhado.
0184:         	sendStringToLCD     equ     0x0184  ;   Imprime string no terminal GLCD. DE = inicio da string. A = caractere para parar a impressão. A impressão para e retorna quando um CR é impresso. Destroy ALL
0187:         	sendRegToLCD        equ     0x0187  ;   Imprime byte em A no formato HEX, no GLCD. Ex: 'D' = 44
018A:         	sendHLToLCD         equ     0x018A  ;   Imprime HL como 4 digitos hexadecimais, no GLCD. Ex: HL=$80FF -> imprime "80FF"
018D:         	setCursor           equ     0x018D  ;   Define a posição do cursor gráfico. Entradas: BC = X,Y onde X = 0..127, Y = 0..63   Destroy A
0190:         	getCursor           equ     0x0190  ;   Obter a posição do cursor. Saídas: BC = X,Y onde X = 0..127, Y = 0..63
0193:         	displayCursor       equ     0x0193  ;   Exibir Cursor. Entrada: A = 0, Ativar cursor, A = diferente de zero, Desativar cursor.
0196:         	autoLF              equ     0x0196  ;   Avanço de linha automático quando o cursor atinge o final da linha (Terminal). Entrada: A = 0, Avanço de linha automático; A = diferente de zero, Sem avanço de linha automático. Padrao LIGADO.
0199:         	underline           equ     0x0199  ;   Exibir sublinhado no caractere (Terminal). O estado inicial é sem sublinhado. Chamar esta rotina irá ALTERAR/DESLIGAR o sinalizador de sublinhado.
019C:         	plotAlways          equ     0x019C  ;   Quando sendCharToLCD é chamado, Atualiza GLCD ou não. Se Desativado plotToLCD deve ser chamado atualizar o GLCD. Entrada: A=0, Plotar sempre; A>0, Não plotar. O padrão é Plotar sempre.
              	
              	
              	
              	; ============================================================
              	;  LCD 40x2 via I2C - Z80 Assembly
              	;  Sintaxe: ZASM
              	;  Módulo I2C: PCF8574 @ $4E
              	;  Controlador LCD: HD44780 compatível, modo 4 bits
              	
              	;
              	;  Pinagem PCF8574 -> HD44780:
              	;    P0 = RS  (0=cmd, 1=dado)
              	;    P1 = RW  (sempre 0)
              	;    P2 = EN  (pulso de enable)
              	;    P3 = BL  (backlight, sempre 1)
              	;    P4 = DB4
              	;    P5 = DB5
              	;    P6 = DB6
              	;    P7 = DB7
              	;
              	;  DDRAM LCD 40x2:
              	;    Linha 1: $00..$27  (Set DDRAM = $80..$A7)
              	;    Linha 2: $40..$67  (Set DDRAM = $C0..$E7)
              	; ============================================================
              	
              	
004E:         	LCD_I2C     equ  $4E
              	
              	; bits PCF8574
0008:         	BL          equ  $08            ; P3 backlight
0004:         	EN          equ  $04            ; P2 enable
0001:         	RS_DAT      equ  $01            ; P0 RS=1 dado
              	
              	; comandos HD44780
0001:         	CMD_CLEAR   equ  $01
0006:         	CMD_ENTRY   equ  $06
000C:         	CMD_DISP_ON equ  $0C
0028:         	CMD_FUNC4   equ  $28
0080:         	CMD_L1      equ  $80            ; DDRAM linha 1 col 0
00C0:         	CMD_L2      equ  $C0            ; DDRAM linha 2 col 0
              	
              	; ============================================================
8000:         	            .org $8000
              	
              	; ============================================================
              	;  MAIN
              	; ============================================================
8000:         	MAIN:
8000: CD7180  	            call LCD_Init
              	
8003: 3E80    	            ld   a, CMD_L1
8005: CDBD80  	            call LCD_SetPos
8008: 211E80  	            ld   hl, STR_L1
800B: CDDE80  	            call LCD_Print
              	
800E: 3EC0    	            ld   a, CMD_L2
8010: CDBD80  	            call LCD_SetPos
8013: 214780  	            ld   hl, STR_L2
8016: CDDE80  	            call LCD_Print
              	
              	            ;Vai para monitor
8019: C30000  	            jp 0
              	
801C:         	LOOP:
801C: 18FE    	            jr   LOOP
              	
              	; ============================================================
              	;  Strings terminadas em $00
              	; ============================================================
801E:         	STR_L1:
801E: 20205A38	            .text "  Z80 + LCD 40x2 I2C  PCF8574 @ 0x4E    "
8022: 30202B20	
8026: 4C434420	
802A: 34307832	
802E: 20493243	
8032: 20205043	
8036: 46383537	
803A: 34204020	
803E: 30783445	
8042: 20202020	
8046: 00      	            .byte 0
8047:         	STR_L2:
8047: 20204844	            .text "  HD44780  4-bit mode  Assembly  ZASM    "
804B: 34343738	
804F: 30202034	
8053: 2D626974	
8057: 206D6F64	
805B: 65202041	
805F: 7373656D	
8063: 626C7920	
8067: 205A4153	
806B: 4D202020	
806F: 20      	
8070: 00      	            .byte 0
              	
              	; ============================================================
              	;  LCD_Init — inicializa HD44780 em modo 4 bits
              	; ============================================================
8071:         	LCD_Init:
8071: 113200  	            ld   de, 50         ; >40ms power-on
8074: CD0301  	            call delay
              	
              	            ; reset por software: 3x nibble $3 (simula 8-bit)
8077: CDEB80  	            call RESET_PULSE
807A: 110500  	            ld   de, 5
807D: CD0301  	            call delay
              	
8080: CDEB80  	            call RESET_PULSE
8083: 110100  	            ld   de, 1
8086: CD0301  	            call delay
              	
8089: CDEB80  	            call RESET_PULSE
808C: 110100  	            ld   de, 1
808F: CD0301  	            call delay
              	
              	            ; entra em modo 4 bits
8092: 3E20    	            ld   a, $20
8094: CDFB80  	            call NIB_CMD
8097: 110100  	            ld   de, 1
809A: CD0301  	            call delay
              	
              	            ; configuração em 4 bits
809D: 3E28    	            ld   a, CMD_FUNC4   ; Function Set: 4-bit, 2 linhas, 5x8
809F: CD2181  	            call CMD4
              	
80A2: 3E08    	            ld   a, $08         ; Display OFF
80A4: CD2181  	            call CMD4
              	
80A7: 3E01    	            ld   a, CMD_CLEAR   ; Clear Display
80A9: CD2181  	            call CMD4
80AC: 110200  	            ld   de, 2          ; >1.6ms
80AF: CD0301  	            call delay
              	
80B2: 3E06    	            ld   a, CMD_ENTRY   ; Entry Mode
80B4: CD2181  	            call CMD4
              	
80B7: 3E0C    	            ld   a, CMD_DISP_ON ; Display ON, cursor OFF
80B9: CD2181  	            call CMD4
              	
80BC: C9      	            ret
              	
              	; ============================================================
              	;  LCD_SetPos — posiciona cursor pelo endereço DDRAM
              	;  Entrada: A = endereço (ex: CMD_L1 + coluna)
              	; ============================================================
80BD:         	LCD_SetPos:
80BD: F680    	            or   $80            ; bit 7 = Set DDRAM Address
80BF: CD2181  	            call CMD4
80C2: C9      	            ret
              	
              	; ============================================================
              	;  LCD_GotoXY — posiciona por coluna e linha
              	;  Entrada: H = coluna (0..39), L = linha (0 ou 1)
              	; ============================================================
80C3:         	LCD_GotoXY:
80C3: 7D      	            ld   a, l
80C4: B7      	            or   a
80C5: 3E00    	            ld   a, $00
80C7: 2802    	            jr   z, GXY_SET
80C9: 3E40    	            ld   a, $40         ; linha 2 base
80CB:         	GXY_SET:
80CB: 84      	            add  a, h
80CC: F680    	            or   $80
80CE: CD2181  	            call CMD4
80D1: C9      	            ret
              	
              	; ============================================================
              	;  LCD_Clear
              	; ============================================================
80D2:         	LCD_Clear:
80D2: 3E01    	            ld   a, CMD_CLEAR
80D4: CD2181  	            call CMD4
80D7: 110200  	            ld   de, 2
80DA: CD0301  	            call delay
80DD: C9      	            ret
              	
              	; ============================================================
              	;  LCD_Print — imprime string terminada em $00
              	;  Entrada: HL = ponteiro
              	; ============================================================
80DE:         	LCD_Print:
80DE: 7E      	            ld   a, (hl)
80DF: B7      	            or   a
80E0: C8      	            ret  z
80E1: CDE780  	            call LCD_Char
80E4: 23      	            inc  hl
80E5: 18F7    	            jr   LCD_Print
              	
              	; ============================================================
              	;  LCD_Char — imprime um caractere
              	;  Entrada: A = ASCII
              	; ============================================================
80E7:         	LCD_Char:
80E7: CD3481  	            call DAT4
80EA: C9      	            ret
              	
              	; ============================================================
              	;  RESET_PULSE — pulso nibble $3 em modo 8-bit
              	;  Byte: $30 | BL = $38, com EN = $3C
              	; ============================================================
80EB:         	RESET_PULSE:
80EB: 3E38    	            ld   a, $38         ; nibble $3 | BL,  EN=0
80ED: CD4781  	            call PCF_Send
80F0: 3E3C    	            ld   a, $3C         ; nibble $3 | BL | EN
80F2: CD4781  	            call PCF_Send
80F5: 3E38    	            ld   a, $38         ; nibble $3 | BL,  EN=0
80F7: CD4781  	            call PCF_Send
80FA: C9      	            ret
              	
              	; ============================================================
              	;  NIB_CMD — envia nibble alto de A como COMANDO (RS=0)
              	;  Entrada: A = nibble nos bits 7-4  (bits 3-0 = 0)
              	; ============================================================
80FB:         	NIB_CMD:
80FB: E6F0    	            and  $F0
80FD: F608    	            or   BL             ; + backlight, RS=0, EN=0
80FF: CD4781  	            call PCF_Send
8102: F604    	            or   EN             ; EN=1
8104: CD4781  	            call PCF_Send
8107: EE04    	            xor  EN             ; EN=0
8109: CD4781  	            call PCF_Send
810C: C9      	            ret
              	
              	; ============================================================
              	;  NIB_DAT — envia nibble alto de A como DADO (RS=1)
              	;  Entrada: A = nibble nos bits 7-4  (bits 3-0 = 0)
              	; ============================================================
810D:         	NIB_DAT:
810D: E6F0    	            and  $F0
810F: F608    	            or   BL             ; + backlight
8111: F601    	            or   RS_DAT         ; RS=1, EN=0
8113: CD4781  	            call PCF_Send
8116: F604    	            or   EN             ; EN=1
8118: CD4781  	            call PCF_Send
811B: EE04    	            xor  EN             ; EN=0
811D: CD4781  	            call PCF_Send
8120: C9      	            ret
              	
              	; ============================================================
              	;  CMD4 — envia byte de COMANDO em modo 4-bit (RS=0)
              	;  Entrada: A = byte de comando
              	; ============================================================
8121:         	CMD4:
8121: C5      	            push bc
8122: 47      	            ld   b, a
              	
8123: E6F0    	            and  $F0            ; nibble alto
8125: CDFB80  	            call NIB_CMD
              	
8128: 78      	            ld   a, b           ; nibble baixo → bits 7-4
8129: 07      	            rlca
812A: 07      	            rlca
812B: 07      	            rlca
812C: 07      	            rlca
812D: E6F0    	            and  $F0
812F: CDFB80  	            call NIB_CMD
              	
8132: C1      	            pop  bc
8133: C9      	            ret
              	
              	; ============================================================
              	;  DAT4 — envia byte de DADO em modo 4-bit (RS=1)
              	;  Entrada: A = byte de dado (ASCII)
              	; ============================================================
8134:         	DAT4:
8134: C5      	            push bc
8135: 47      	            ld   b, a
              	
8136: E6F0    	            and  $F0            ; nibble alto
8138: CD0D81  	            call NIB_DAT
              	
813B: 78      	            ld   a, b           ; nibble baixo → bits 7-4
813C: 07      	            rlca
813D: 07      	            rlca
813E: 07      	            rlca
813F: 07      	            rlca
8140: E6F0    	            and  $F0
8142: CD0D81  	            call NIB_DAT
              	
8145: C1      	            pop  bc
8146: C9      	            ret
              	
              	; ============================================================
              	;  PCF_Send — envia 1 byte ao PCF8574 via I2C
              	;  Entrada:  A = byte
              	;  Preserva: AF BC DE HL
              	; ============================================================
8147:         	PCF_Send:
8147: F5      	            push af
8148: C5      	            push bc
8149: D5      	            push de
814A: E5      	            push hl
              	
814B: 47      	            ld   b, a           ; guarda byte em B
              	                                ; ROM preserva BC → B está seguro
              	
814C: 3E4E    	            ld   a, LCD_I2C
814E: CD0601  	            call I2C_Open       ; START + endereço
              	
8151: 78      	            ld   a, b           ; recupera byte
8152: CD0F01  	            call I2C_Write      ; envia
              	
8155: CD0901  	            call I2C_Close      ; STOP
              	
8158: E1      	            pop  hl
8159: D1      	            pop  de
815A: C1      	            pop  bc
815B: F1      	            pop  af
815C: C9      	            ret
              	
              	; ============================================================
              	;  LCD_PrintNum8 — imprime número 0-255 em decimal
              	;  Entrada: A = número
              	; ============================================================
815D:         	LCD_PrintNum8:
815D: C5      	            push bc
815E: D5      	            push de
815F: 4F      	            ld   c, a
8160: 0600    	            ld   b, 0           ; flag zero-suppress
              	
8162: 1664    	            ld   d, 100
8164: CD7581  	            call DIGIT
8167: 160A    	            ld   d, 10
8169: CD7581  	            call DIGIT
              	
816C: 79      	            ld   a, c           ; unidades (sempre imprime)
816D: C630    	            add  a, '0'
816F: CD3481  	            call DAT4
              	
8172: D1      	            pop  de
8173: C1      	            pop  bc
8174: C9      	            ret
              	
8175:         	DIGIT:
8175: 79      	            ld   a, c
8176: 1E00    	            ld   e, 0
8178:         	DG_LOOP:
8178: BA      	            cp   d
8179: 3804    	            jr   c, DG_DONE
817B: 92      	            sub  d
817C: 1C      	            inc  e
817D: 18F9    	            jr   DG_LOOP
817F:         	DG_DONE:
817F: 4F      	            ld   c, a
8180: 7B      	            ld   a, e
8181: B7      	            or   a
8182: 2808    	            jr   z, DG_ZERO
8184: 0601    	            ld   b, 1
8186: C630    	            add  a, '0'
8188: CD3481  	            call DAT4
818B: C9      	            ret
818C:         	DG_ZERO:
818C: 78      	            ld   a, b
818D: B7      	            or   a
818E: C8      	            ret  z
818F: 3E30    	            ld   a, '0'
8191: CD3481  	            call DAT4
8194: C9      	            ret
              	
              	; ============================================================
              	            .end MAIN


; +++ segments +++

