1C47: 3E03    	    LD A, ERR_TOUT
1C49: B7      	    OR A
1C4A: C9      	    RET
              	
              	
              	
              	; FS_ALLOC_PG: Aloca primeira pagina livre (>=2) no bitmap
              	;   Registradores: B=pagina, C=bit_index, D=byte_bitmap, E=byte_index, HL=ptr
              	;   On exit: A=pagina (NZ=ok)   A=0 (Z=sem espaco)
1C4B:         	FS_ALLOC_PG:
              	    ; Le os 16 bytes do bitmap para PG_BUF
1C4B: 110100  	    LD DE, $0001
1C4E: 2136FC  	    LD HL, PG_BUF
1C51: 011000  	    LD BC, 16
1C54: CD5B18  	    CALL I2C_MemRd
1C57: C0      	    RET NZ
              	
1C58: 0602    	    LD B, 2                 ; B = pagina corrente
              	
1C5A:         	FS_AP_LOOP:
1C5A: 78      	    LD A, B
1C5B: E607    	    AND $07
1C5D: 4F      	    LD C, A                 ; C = bit_index
              	
1C5E: 78      	    LD A, B
1C5F: CB3F    	    SRL A
1C61: CB3F    	    SRL A
1C63: CB3F    	    SRL A
1C65: 5F      	    LD E, A                 ; E = byte_index
              	
1C66: 2136FC  	    LD HL, PG_BUF
1C69: 1600    	    LD D, 0
1C6B: 19      	    ADD HL, DE
1C6C: 56      	    LD D, (HL)              ; D = byte do bitmap
              	
1C6D: 3E01    	    LD A, 1
1C6F:         	FS_AP_TBIT:
1C6F: 0D      	    DEC C
1C70: FA761C  	    JP M, FS_AP_TBIT_DONE
1C73: 07      	    RLCA
1C74: 18F9    	    JR FS_AP_TBIT
1C76:         	FS_AP_TBIT_DONE:
1C76: A2      	    AND D                   ; 0=ocupado, !=0=livre
1C77: 2008    	    JR NZ, FS_AP_FOUND
              	
1C79: 04      	    INC B
1C7A: 78      	    LD A, B
1C7B: FE80    	    CP 128
1C7D: 38DB    	    JR C, FS_AP_LOOP
1C7F: AF      	    XOR A                   ; Z = sem espaco
1C80: C9      	    RET
              	
1C81:         	FS_AP_FOUND:
              	    ; B = pagina livre. Salva bit_index e byte_index.
1C81: 78      	    LD A, B
1C82: E607    	    AND $07
1C84: 3235FC  	    LD (FS_BMPADDR+1), A    ; bit_index
              	
1C87: 78      	    LD A, B
1C88: CB3F    	    SRL A
1C8A: CB3F    	    SRL A
1C8C: CB3F    	    SRL A
1C8E: 5F      	    LD E, A                 ; E = byte_index
              	
              	    ; HL = PG_BUF + byte_index
1C8F: 2136FC  	    LD HL, PG_BUF
1C92: 1600    	    LD D, 0
1C94: 19      	    ADD HL, DE
              	
              	    ; Mascara = ~(1 << bit_index) para zerar o bit
1C95: 3A35FC  	    LD A, (FS_BMPADDR+1)
1C98: 4F      	    LD C, A
1C99: 3E01    	    LD A, 1
1C9B:         	FS_AP_MKSHL:
1C9B: 0D      	    DEC C
1C9C: FAA21C  	    JP M, FS_AP_MKINV
1C9F: 07      	    RLCA
1CA0: 18F9    	    JR FS_AP_MKSHL
1CA2:         	FS_AP_MKINV:
1CA2: 2F      	    CPL                     ; ~mascara
              	
1CA3: A6      	    AND (HL)
1CA4: 77      	    LD (HL), A              ; atualiza PG_BUF
              	
              	    ; Salva numero da pagina antes do LD BC,1 destruir B
1CA5: 78      	    LD A, B
1CA6: 3234FC  	    LD (FS_BMPADDR), A
              	
              	    ; Grava byte atualizado na EEPROM: addr = byte_index + 1
1CA9: 1600    	    LD D, 0
1CAB: 1C      	    INC E                   ; E = byte_index + 1
1CAC: 010100  	    LD BC, 1
1CAF: CD9318  	    CALL I2C_MemWr
1CB2: C0      	    RET NZ
              	
1CB3: 3A34FC  	    LD A, (FS_BMPADDR)      ; A = pagina alocada
1CB6: B7      	    OR A                    ; NZ = sucesso
1CB7: C9      	    RET
              	
              	; FS_FREE_PG: Libera pagina A no bitmap (seta bit = 1)
              	;   On exit: Z=OK  NZ=erro I2C
1CB8:         	FS_FREE_PG:
1CB8: C5      	    PUSH BC
1CB9: D5      	    PUSH DE
1CBA: E5      	    PUSH HL
1CBB: F5      	    PUSH AF                 ; salva numero da pagina
              	
              	    ; bit_index = pagina mod 8
1CBC: E607    	    AND $07
1CBE: 4F      	    LD C, A                 ; C = bit_index
              	
              	    ; byte_index = pagina / 8 → endereco EEPROM = byte_index + 1
1CBF: F1      	    POP AF
1CC0: F5      	    PUSH AF
1CC1: CB3F    	    SRL A
1CC3: CB3F    	    SRL A
1CC5: CB3F    	    SRL A                   ; A = byte_index
1CC7: 3C      	    INC A                   ; A = endereco EEPROM (1..16)
1CC8: 3234FC  	    LD (FS_BMPADDR), A      ; salva endereco
              	
              	    ; Le byte atual do bitmap
              	    ; ATENCAO: LD BC,1 vai sobrescrever C (bit_index)!
              	    ; Salva C na RAM antes.
1CCB: 79      	    LD A, C
1CCC: 3235FC  	    LD (FS_BMPADDR+1), A    ; salva bit_index em FS_BMPADDR+1
              	
1CCF: 3A34FC  	    LD A, (FS_BMPADDR)
1CD2: 5F      	    LD E, A
1CD3: 1600    	    LD D, 0
1CD5: 212DFC  	    LD HL, FS_TMP1
1CD8: 010100  	    LD BC, 1
1CDB: CD5B18  	    CALL I2C_MemRd
1CDE: C2071D  	    JP NZ, FS_FP_ERR
              	
              	    ; Recupera bit_index
1CE1: 3A35FC  	    LD A, (FS_BMPADDR+1)
1CE4: 4F      	    LD C, A                 ; C = bit_index restaurado
              	
              	    ; Constroi mascara = 1 << bit_index
1CE5: 3E01    	    LD A, 1
1CE7:         	FS_FP_SHL:
1CE7: 0D      	    DEC C
1CE8: FAEE1C  	    JP M, FS_FP_OR
1CEB: 07      	    RLCA
1CEC: 18F9    	    JR FS_FP_SHL
              	
1CEE:         	FS_FP_OR:
1CEE: 47      	    LD B, A
1CEF: 3A2DFC  	    LD A, (FS_TMP1)
1CF2: B0      	    OR B                    ; seta o bit (marca pagina como livre)
1CF3: 322DFC  	    LD (FS_TMP1), A
              	
              	    ; Grava
1CF6: 3A34FC  	    LD A, (FS_BMPADDR)
1CF9: 5F      	    LD E, A
1CFA: 1600    	    LD D, 0
1CFC: 212DFC  	    LD HL, FS_TMP1
1CFF: 010100  	    LD BC, 1
1D02: CD9318  	    CALL I2C_MemWr
1D05: 1808    	    JR FS_FP_DONE
              	
1D07:         	FS_FP_ERR:
1D07: F1      	    POP AF
1D08: E1      	    POP HL
1D09: D1      	    POP DE
1D0A: C1      	    POP BC
1D0B: 3E01    	    LD A, 1
1D0D: B7      	    OR A
1D0E: C9      	    RET
              	
1D0F:         	FS_FP_DONE:
1D0F: F1      	    POP AF
1D10: E1      	    POP HL
1D11: D1      	    POP DE
1D12: C1      	    POP BC
1D13: C9      	    RET
              	
              	; FS_FREE_CHAIN: Libera cadeia de paginas a partir da pagina A
              	;   On exit: Z=OK  NZ=erro
1D14:         	FS_FREE_CHAIN:
1D14: B7      	    OR A
1D15: C8      	    RET Z
              	
1D16:         	FS_FC_LP:
1D16: 3234FC  	    LD (FS_BMPADDR), A      ; salva pagina corrente
              	
              	    ; Primeiro le o next page (antes de liberar)
1D19: 57      	    LD D, A
1D1A: 1E00    	    LD E, 0
1D1C: 212DFC  	    LD HL, FS_TMP1
1D1F: 010100  	    LD BC, 1
1D22: CD5B18  	    CALL I2C_MemRd
1D25: 201C    	    JR NZ, FS_FC_ERR
              	
              	    ; Salva next page no stack (FS_FREE_PG vai usar FS_BMPADDR/+1)
1D27: 3A2DFC  	    LD A, (FS_TMP1)
1D2A: F5      	    PUSH AF                 ; [1] next page
              	
              	    ; Pequeno delay para o barramento I2C se estabilizar entre as operacoes
              	    ; Abre e fecha a EEPROM ate receber ACK (write cycle polling)
1D2B:         	FS_FC_WAIT:
1D2B: 3EAE    	    LD A, $AE
1D2D: CD5717  	    CALL I2C_Open
1D30: CD5E17  	    CALL I2C_Close
1D33: 20F6    	    JR NZ, FS_FC_WAIT       ; aguarda EEPROM pronta
              	
              	    ; Libera a pagina
1D35: 3A34FC  	    LD A, (FS_BMPADDR)
1D38: CDB81C  	    CALL FS_FREE_PG
1D3B: 2010    	    JR NZ, FS_FC_ERR2
              	
1D3D: F1      	    POP AF                  ; [1] A = next page
1D3E: B7      	    OR A
1D3F: 20D5    	    JR NZ, FS_FC_LP         ; continua na proxima pagina
              	
1D41: AF      	    XOR A
1D42: C9      	    RET
              	
1D43:         	FS_FC_ERR:
1D43: 21581D  	    LD HL, str_fc_err
1D46: CD8403  	    CALL PUTS
1D49: 3E01    	    LD A, 1
1D4B: B7      	    OR A
1D4C: C9      	    RET
1D4D:         	FS_FC_ERR2:
1D4D: F1      	    POP AF                  ; [1]
1D4E: 21581D  	    LD HL, str_fc_err
1D51: CD8403  	    CALL PUTS
1D54: 3E01    	    LD A, 1
1D56: B7      	    OR A
1D57: C9      	    RET
              	
1D58: 46432045	str_fc_err:  .TEXT "FC ERRO!"
1D5C: 52524F21	
1D60: 0D0A00  	             .DB CR, LF, 0
              	
              	
              	
              	; FS_WRITE_PG: Grava pagina A com dados de FS_TMPRAM
              	;   Grava min(FS_TMPSZ, 255) bytes. Atualiza FS_TMPRAM e FS_TMPSZ.
              	;   byte 0 da pagina = $00 (next=fim; FS_SET_NEXT corrige se necessario)
              	;   On exit: Z=OK  NZ=erro
              	;   Preserva: BC DE HL
1D63:         	FS_WRITE_PG:
1D63: C5      	    PUSH BC
1D64: D5      	    PUSH DE
1D65: E5      	    PUSH HL
1D66: F5      	    PUSH AF                 ; A = numero da pagina
              	
              	    ; Calcula quantos bytes gravar: min(FS_TMPSZ, 255)
1D67: 2A2EFC  	    LD HL, (FS_TMPSZ)
1D6A: 7C      	    LD A, H
1D6B: B7      	    OR A
1D6C: 2005    	    JR NZ, FS_WP_USE255     ; HL >= 256: usa 255
1D6E: 7D      	    LD A, L
1D6F: FEFF    	    CP FS_DATAPG            ; L < 255?
1D71: 3804    	    JR C, FS_WP_USELT       ; sim: usa L
1D73:         	FS_WP_USE255:
1D73: 0EFF    	    LD C, FS_DATAPG         ; C = 255
1D75: 1801    	    JR FS_WP_COPY
1D77:         	FS_WP_USELT:
1D77: 4D      	    LD C, L                 ; C = L (< 255)
              	
1D78:         	FS_WP_COPY:
              	    ; C = bytes a gravar (1..255). Salva em D para nao perder.
1D78: 51      	    LD D, C                 ; D = bytes a gravar
              	
              	    ; Monta PG_BUF[0..$FF]:
              	    ;   [0]    = $00 (next page, sera corrigido por FS_SET_NEXT)
              	    ;   [1..C] = dados da RAM
              	    ;   [C+1..$FF] = $FF (padding)
1D79: 2136FC  	    LD HL, PG_BUF
1D7C: 3600    	    LD (HL), $00            ; byte 0 = next = $00
1D7E: 23      	    INC HL                  ; HL = PG_BUF + 1
              	
              	    ; Copia D bytes de FS_TMPRAM para PG_BUF+1
              	    ; Usa IX como ponteiro de origem (LD BC,(nn) pode nao funcionar no zasm)
1D7F: DD2A30FC	    LD IX, (FS_TMPRAM)      ; IX = ponteiro RAM origem
1D83: 5A      	    LD E, D                 ; E = contador de copia
1D84:         	FS_WP_CPLOOP:
1D84: DD7E00  	    LD A, (IX+0)            ; le da RAM origem
1D87: 77      	    LD (HL), A              ; grava no PG_BUF
1D88: DD23    	    INC IX
1D8A: 23      	    INC HL
1D8B: 1D      	    DEC E
1D8C: 20F6    	    JR NZ, FS_WP_CPLOOP
              	
              	    ; Padding $FF ate completar 256 bytes (posicoes D+1 a 255)
              	    ; Bytes de padding = 255 - D
1D8E: 3EFF    	    LD A, FS_DATAPG         ; 255
1D90: 92      	    SUB D                   ; A = 255 - D (bytes de padding)
1D91: 2807    	    JR Z, FS_WP_NOPAD       ; sem padding (D=255, pagina cheia)
1D93: 5F      	    LD E, A
1D94:         	FS_WP_PADLOOP:
1D94: 36FF    	    LD (HL), $FF
1D96: 23      	    INC HL
1D97: 1D      	    DEC E
1D98: 20FA    	    JR NZ, FS_WP_PADLOOP
1D9A:         	FS_WP_NOPAD:
              	
              	    ; Grava PG_BUF inteiro (256 bytes) na EEPROM
              	    ; Endereco EEPROM = pagina * 256 (D = pagina, E = 0)
1D9A: F1      	    POP AF                  ; A = numero da pagina
1D9B: F5      	    PUSH AF
1D9C: 57      	    LD D, A
1D9D: 1E00    	    LD E, 0
1D9F: 2136FC  	    LD HL, PG_BUF
1DA2: 010001  	    LD BC, 256
1DA5: CD9318  	    CALL I2C_MemWr
1DA8: C2D51D  	    JP NZ, FS_WP_ERR
              	
              	    ; Atualiza FS_TMPRAM += D_bytes_gravados
1DAB: F1      	    POP AF                  ; A = pagina (descarta)
1DAC: E1      	    POP HL                  ; restaura HL original
1DAD: D1      	    POP DE                  ; restaura DE original
1DAE: C1      	    POP BC                  ; restaura BC original
              	
              	    ; Recalcula com D = bytes gravados
              	    ; D foi preservado? Nao — foi sobrescrito por LD D, A (pagina).
              	    ; Usamos FS_TMPSZ antes e depois para calcular o que foi gravado:
              	    ; bytes_gravados = min(TMPSZ_antes, 255)
              	    ; Mais simples: relemos FS_TMPSZ e FS_TMPRAM e atualizamos
              	    ; Mas D foi sobrescrito... precisamos salvar D antes do I2C_MemWr.
              	    ; SOLUCAO: salvar D (bytes) em FS_TMP1 antes de gravar.
              	    ; Para nao refatorar todo o fluxo acima, usamos um truque:
              	    ; bytes_gravados = FS_TMPSZ se < 255, ou 255 se >= 255.
              	    ; Recalcula de FS_TMPSZ:
1DAF: 2A2EFC  	    LD HL, (FS_TMPSZ)
1DB2: 7C      	    LD A, H
1DB3: B7      	    OR A
1DB4: 2005    	    JR NZ, FS_WP_UPD255
1DB6: 7D      	    LD A, L
1DB7: FEFF    	    CP FS_DATAPG
1DB9: 3805    	    JR C, FS_WP_UPDLT
1DBB:         	FS_WP_UPD255:
1DBB: 01FF00  	    LD BC, FS_DATAPG        ; bytes gravados = 255
1DBE: 1803    	    JR FS_WP_UPDATE
1DC0:         	FS_WP_UPDLT:
1DC0: 0600    	    LD B, 0
1DC2: 4D      	    LD C, L                 ; bytes gravados = L
              	
1DC3:         	FS_WP_UPDATE:
              	    ; FS_TMPRAM += BC
1DC3: 2A30FC  	    LD HL, (FS_TMPRAM)
1DC6: 09      	    ADD HL, BC
1DC7: 2230FC  	    LD (FS_TMPRAM), HL
              	    ; FS_TMPSZ -= BC
1DCA: 2A2EFC  	    LD HL, (FS_TMPSZ)
1DCD: B7      	    OR A                    ; limpa carry
1DCE: ED42    	    SBC HL, BC
1DD0: 222EFC  	    LD (FS_TMPSZ), HL
1DD3: AF      	    XOR A                   ; Z = sucesso
1DD4: C9      	    RET
              	
1DD5:         	FS_WP_ERR:
1DD5: F1      	    POP AF
1DD6: E1      	    POP HL
1DD7: D1      	    POP DE
1DD8: C1      	    POP BC
1DD9: 3E01    	    LD A, 1
1DDB: B7      	    OR A
1DDC: C9      	    RET
              	
              	; FS_SET_NEXT: Escreve byte 0 da pagina A com valor B
              	;   On exit: Z=OK  NZ=erro
1DDD:         	FS_SET_NEXT:
1DDD: C5      	    PUSH BC
1DDE: D5      	    PUSH DE
1DDF: E5      	    PUSH HL
1DE0: 57      	    LD D, A
1DE1: 1E00    	    LD E, 0
1DE3: 78      	    LD A, B
1DE4: 322DFC  	    LD (FS_TMP1), A
1DE7: 212DFC  	    LD HL, FS_TMP1
1DEA: 010100  	    LD BC, 1
1DED: CD9318  	    CALL I2C_MemWr
1DF0: E1      	    POP HL
1DF1: D1      	    POP DE
1DF2: C1      	    POP BC
1DF3: C9      	    RET
              	
              	
              	
              	; FS_FIND_NAME: Busca FS_NAMBUF no diretorio
              	;   On exit: Z=encontrado (FS_CUR=idx, FS_WRKBUF=entrada)
