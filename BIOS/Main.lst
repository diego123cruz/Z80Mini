              	#include "IHEX.asm"
              	
              	
1566:         	loadInit:
1566: 3EFF    	    LD A, $FF
1568: 32FCFB  	    LD (LOAD_FIRST_FLAG), A
              	
156B: 212A17  	    LD HL, MSG_LOAD_HELP
156E: CDCB16  	    CALL SERIAL_A_PRINT_STRING
              	
1571: 112C17  	    LD DE, MSG_LOAD_HELP_LCD
1574: CD6207  	    CALL sendStringToLCD
              	
1577:         	loopHexLoad:
1577: CDB00F  	    CALL RXDATA
              	
157A: FE3A    	    CP   ':'	; ":"?
157C: 20F9    		JR   NZ, loopHexLoad ; Aguarda :
              	
              	    ; Só inicializa o flag se for a primeira linha do carregamento
157E: 3AFCFB  		LD   A, (LOAD_FIRST_FLAG)
1581: FEFF    		CP   $FF                    ; $FF = virgem / sessão nova
1583: 2005    		JR   NZ, monitor_do_load    ; já está no meio de um carregamento
1585: 3E01    		LD   A, $01
1587: 32FCFB  		LD   (LOAD_FIRST_FLAG), A   ; sinaliza: próximo LOAD é o primeiro
              	
158A:         	monitor_do_load:
158A: CD9B15  		CALL    LOAD
158D: CDD416  		CALL SERIAL_A_TXCRLF
1590: C37715  	    JP loopHexLoad
              	
              	
1593:         	CALL_IHEX:
1593: 216202  		LD HL, MAIN_LOOP
1596: E5      		PUSH HL
1597: CD6615  		CALL loadInit
159A: C9      		RET
              	
              	;------------------------------------------------------------------------------
              	; LOAD Intel Hex format file from the console.
              	; [Intel Hex Format is:
              	; 1) Colon (Frame 0)
              	; 2) Record Length Field (Frames 1 and 2)
              	; 3) Load Address Field (Frames 3,4,5,6)
              	; 4) Record Type Field (Frames 7 and 8)
              	; 5) Data Field (Frames 9 to 9+2*(Record Length)-1
              	; 6) Checksum Field - Sum of all byte values from Record Length to and 
              	;   including Checksum Field = 0 ]
              	;------------------------------------------------------------------------------	
159B:         	LOAD:
159B: 1E00    			LD   E,0	        ; Zera checksum
159D: CD7916  			CALL GET2	        ; Record Length -> D
15A0: 57      			LD   D,A
15A1: CD7916  			CALL GET2	        ; Endereco High -> H
15A4: 67      			LD   H,A
15A5: CD7916  			CALL GET2	        ; Endereco Low -> L
15A8: 6F      			LD   L,A
15A9: CD7916  			CALL GET2	        ; Record Type -> A
15AC: FE01    			CP   $01	        ; EOF record?
15AE: 2009    			JR   NZ,LOAD2	    ; Nao: processa dados
              	
              			; --- Record tipo 01: EOF ---
15B0: CD7916  			CALL GET2	        ; Consome checksum do EOF
15B3: 7B      			LD   A,E
15B4: A7      			AND  A
15B5: 2839    			JR   Z,LOAD00       ; Checksum OK: imprime resumo
15B7: 1829    			JR   LOADERR        ; Checksum falhou
              	
              			; --- Record tipo 00: Dados ---
15B9:         	LOAD2:
              			; Salva endereco inicial apenas na primeira linha
15B9: 3AFCFB  			LD   A, (LOAD_FIRST_FLAG)
15BC: FE01    			CP   $01                    ; e a primeira linha?
15BE: 2008    			JR   NZ, LOAD2_SKIP
15C0: 3E00    			LD   A, $00
15C2: 32FCFB  			LD   (LOAD_FIRST_FLAG), A   ; limpa flag
15C5: 22FDFB  			LD   (LOAD_START_ADDR), HL  ; salva endereco inicial
              	
15C8:         	LOAD2_SKIP:
15C8: 7A      			LD   A,D	        ; Contador de bytes da linha
15C9: A7      			AND  A
15CA: 280D    			JR   Z,LOAD3
              	
15CC: CD7916  			CALL GET2	        ; Le proximo byte
15CF: 77      			LD   (HL),A	        ; Grava na memoria
15D0: 23      			INC  HL
15D1: 3E2E    			LD   A,'.'
15D3: CD830F  			CALL OUTCH
15D6: 15      			DEC  D
15D7: 18EF    			JR   LOAD2_SKIP     ; (continua pelo loop sem re-checar o flag)
              	
15D9:         	LOAD3:
15D9: 22FFFB  			LD   (LOAD_END_ADDR), HL    ; Atualiza endereco final (apos ultimo byte)
15DC: CD7916  			CALL GET2	                ; Consome checksum da linha
15DF: 7B      			LD   A,E
15E0: A7      			AND  A
15E1: C8      			RET  Z                      ; Checksum OK: volta pro monitor
              	
15E2:         	LOADERR:
15E2: 21DF16  			LD   HL,CKSUMERR
15E5: CDCB16  			CALL SERIAL_A_PRINT_STRING
              	
              	        ;LCD
15E8: 11DF16  	        LD   DE, CKSUMERR
15EB: CD6207  	        CALL sendStringToLCD
              	
15EE: E1      	        POP HL
              	
15EF: C9      			RET
              	
15F0:         	LOAD00:
              			; --- Imprime resumo do carregamento ---
15F0: 21F016  			LD   HL, LDETXT
15F3: CDCB16  			CALL SERIAL_A_PRINT_STRING
              	
15F6: 210F17  			LD   HL, msg_load_start
15F9: CDCB16  			CALL SERIAL_A_PRINT_STRING
15FC: 2AFDFB  			LD   HL, (LOAD_START_ADDR)
15FF: CDA316  			CALL SERIAL_A_PRINT_HL_HEX
1602: CDD416  			CALL SERIAL_A_TXCRLF
              	
1605: 211817  			LD   HL, msg_load_end
1608: CDCB16  			CALL SERIAL_A_PRINT_STRING
160B: 2AFFFB  			LD   HL, (LOAD_END_ADDR)
160E: 2B      			DEC  HL                     ; aponta para o ultimo byte gravado
160F: CDA316  			CALL SERIAL_A_PRINT_HL_HEX
1612: CDD416  			CALL SERIAL_A_TXCRLF
              	
1615: 212117  			LD   HL, msg_load_total
1618: CDCB16  			CALL SERIAL_A_PRINT_STRING
161B: ED5BFDFB			LD   DE, (LOAD_START_ADDR)
161F: 2AFFFB  			LD   HL, (LOAD_END_ADDR)
1622: B7      			OR   A                      ; limpa carry flag
1623: ED52    			SBC  HL, DE                 ; HL = total de bytes
1625: CDA316  			CALL SERIAL_A_PRINT_HL_HEX
1628: CDD416  			CALL SERIAL_A_TXCRLF
              	
              	        ; Mostra status no lcd
162B: 110917  	        LD   DE, LDETXTLCD
162E: CD6207  	        CALL sendStringToLCD
              	
1631: 110F17  	        LD   DE, msg_load_start
1634: 3E00    	        LD   A, 0
1636: CD6207  			CALL sendStringToLCD
1639: 2AFDFB  			LD   HL, (LOAD_START_ADDR)
163C: CDA607  			CALL sendHLToLCD
163F: CDA703  			CALL CRLF
              	
1642: 111817  			LD   DE, msg_load_end
1645: 3E00    	        LD   A, 0
1647: CD6207  			CALL sendStringToLCD
164A: 2AFFFB  			LD   HL, (LOAD_END_ADDR)
164D: 2B      			DEC  HL                     ; aponta para o ultimo byte gravado
164E: CDA607  			CALL sendHLToLCD
1651: CDA703  			CALL CRLF
              	
1654: 112117  			LD   DE, msg_load_total
1657: 3E00    	        LD   A, 0
1659: CD6207  			CALL sendStringToLCD
165C: ED5BFDFB			LD   DE, (LOAD_START_ADDR)
1660: 2AFFFB  			LD   HL, (LOAD_END_ADDR)
1663: B7      			OR   A                      ; limpa carry flag
1664: ED52    			SBC  HL, DE                 ; HL = total de bytes
1666: CDA607  			CALL sendHLToLCD
              	
1669: CDA703  	        CALL CRLF
              	
166C: E1      	        POP HL 
166D: C9      			RET
              	
              	
              	
              	
              	;------------------------------------------------------------------------------
              	; Get a character from the console, must be $20-$7F to be valid (no control characters)
              	; <Ctrl-c> and <SPACE> breaks with the Zero Flag set
              	;------------------------------------------------------------------------------	
166E: CD890F  	GETCHR_S:	CALL INCH	; RX a Character
1671: FE03    			CP   $03	; <ctrl-c> User break?
1673: C8      			RET  Z			
1674: FE20    			CP   $20	; <space> or better?
1676: 38F6    			JR   C,GETCHR_S	; Do it again until we get something usable
1678: C9      			RET
              	
              	;------------------------------------------------------------------------------
              	; Gets two ASCII characters from the console (assuming them to be HEX 0-9 A-F)
              	; Moves them into B and C, converts them into a byte value in A and updates a
              	; Checksum value in E
              	;------------------------------------------------------------------------------
1679: CD6E16  	GET2:   CALL GETCHR_S	; Get us a valid character to work with
167C: 47      			LD   B,A	; Load it in B
167D: CD6E16  			CALL GETCHR_S	; Get us another character
1680: 4F      			LD   C,A	; load it in C
1681: CD8A16  			CALL BCTOA	; Convert ASCII to byte
1684: 4F      			LD   C,A	; Build the checksum
1685: 7B      			LD   A,E
1686: 91      			SUB  C		; The checksum should always equal zero when checked
1687: 5F      			LD   E,A	; Save the checksum back where it came from
1688: 79      			LD   A,C	; Retrieve the byte and go back
1689: C9      			RET
              	
              	;------------------------------------------------------------------------------
              	; Convert ASCII characters in B C registers to a byte value in A
              	;------------------------------------------------------------------------------
168A: 78      	BCTOA		LD   A,B	; Move the hi order byte to A
168B: D630    			SUB  $30	; Take it down from Ascii
168D: FE0A    			CP   $0A	; Are we in the 0-9 range here?
168F: 3802    			JR   C,BCTOA1	; If so, get the next nybble
1691: D607    			SUB  $07	; But if A-F, take it down some more
1693: 07      	BCTOA1		RLCA		; Rotate the nybble from low to high
1694: 07      			RLCA		; One bit at a time
1695: 07      			RLCA		; Until we
1696: 07      			RLCA		; Get there with it
1697: 47      			LD   B,A	; Save the converted high nybble
1698: 79      			LD   A,C	; Now get the low order byte
1699: D630    			SUB  $30	; Convert it down from Ascii
169B: FE0A    			CP   $0A	; 0-9 at this point?
169D: 3802    			JR   C,BCTOA2	; Good enough then, but
169F: D607    			SUB  $07	; Take off 7 more if it's A-F
16A1: 80      	BCTOA2		ADD  A,B	; Add in the high order nybble
16A2: C9      			RET
              	
              	;------------------------------------------------------------------------------
              	; Imprime HL como 4 digitos hexadecimais
              	; Ex: HL=$80FF -> imprime "80FF"
              	;------------------------------------------------------------------------------
16A3:         	SERIAL_A_PRINT_HL_HEX:
16A3: 7C      			LD   A, H
16A4: CDAC16  			CALL SERIAL_A_PRINT_A_HEX
16A7: 7D      			LD   A, L
16A8: CDAC16  			CALL SERIAL_A_PRINT_A_HEX
16AB: C9      			RET
              	
              	
              	;------------------------------------------------------------------------------
