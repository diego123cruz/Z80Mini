019F:         	NADA:
019F: C9      	    RET
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	; ============================================================
              	; KEYMAPS
              	; ============================================================
              	
              	;	$FF - Capsloock
              	;	$FE - Shift left
              	;	$FD - Ctrl left
              	;	$FC - Windows
              	;	$FB - Alt left
              	;	$FA - Alt Gr    (Load intel hex - Serial A)
              	;	$F9 - LUZ   (CALL 8000H)
              	;	$F8 - Shift Right   (Display Scroll UP)
              	;	$F7 - Ctrl Right    (Display Scroll DOWN)
              	;	$F6 - Fn
              	;	$F5 - 
              	;	$F4 - 
              	
01A0:         	KEYMAP_NORMAL:
01A0: 1B09FFFE	    DB  $1B,  $09,  $FF,  $FE,  $FD,  $FC,  $FB,  $20
01A4: FDFCFB20	
01A8: 3171615C	    DB   '1', 'q',  'a',  '\',  $00,  $FA,  $F6,  $F9
01AC: 00FAF6F9	
01B0: 33656478	    DB   '3', 'e',  'd',  'x',  ',',  'l',  'o',  '9'
01B4: 2C6C6F39	
01B8: 34726663	    DB   '4', 'r',  'f',  'c',  '.',  'ç',  'p',  '0'
01BC: 2EE77030	
01C0: 36796862	    DB   '6', 'y',  'h',  'b',  $F8,  $F7,  0x0D, 0x08
01C4: F8F70D08	
01C8: 35746776	    DB   '5', 't',  'g',  'v',  ';',  '~', 	'`',  '-'
01CC: 3B7E602D	
01D0: 37756A6E	    DB   '7', 'u',  'j',  'n',  '/',  ']',  '[',  '='
01D4: 2F5D5B3D	
01D8: 3277737A	    DB   '2', 'w',  's',  'z',  'm',  'k',  'i',  '8'
01DC: 6D6B6938	
              	    
01E0:         	KEYMAP_SHIFT:
01E0: 1B09FFFE	    DB  $1B,  $09,  $FF,  $FE,  $FD,  $FC,  $FB,  $20
01E4: FDFCFB20	
01E8: 2151417C	    DB   '!', 'Q',  'A',  '|',  $00,  $FA,  $F6,  $F9
01EC: 00FAF6F9	
01F0: 23454458	    DB   '#', 'E',  'D',  'X',  '<',  'L',  'O',  '('
01F4: 3C4C4F28	
01F8: 24524643	    DB   '$', 'R',  'F',  'C',  '>',  'Ç',  'P',  ')'
01FC: 3EC75029	
0200: A8594842	    DB   '¨', 'Y',  'H',  'B',  $F8,  $F7,  0x0D, 0x08
0204: F8F70D08	
0208: 25544756	    DB   '%', 'T',  'G',  'V',  ':',  '^', 	$22,  '_'
020C: 3A5E225F	
0210: 26554A4E	    DB   '&', 'U',  'J',  'N',  '?',  '}',  '{',  '+'
0214: 3F7D7B2B	
0218: 4057535A	    DB   '@', 'W',  'S',  'Z',  'M',  'K',  'I',  '*'
021C: 4D4B492A	
              	
              	
0220:         	INICIO:
              	    ; Set defult I2C device addess: 24LC256 (Copy from/to Mem)
0220: 3EA0    	    LD A, EEDRIVE_A
0222: 32FDFB  	    LD (I2CA_BLOCK), A        
              	
              	    ;CALL FS_CHK_SIG
              	    ;JP Z, INICIO1
              	    ;LD HL, str_notfmt
              	    ;CALL PUTS
0225:         	INICIO1:
              	
0225: 31F0FF  	    LD SP, SYSTEM_SP
              	
0228: 116400  	    LD DE, $0064 ; 100ms
022B: CD7B02  	    CALL H_Delay
              	
              	    ;Init Serial
022E: CD2D0F  	    CALL initSerial
              	
              	    ;Init Teclado
0231: 3EFF    	    LD      A, 0xFF
0233: D340    	    OUT     (KEYBOARD), A           ; Todas as colunas desativadas
              	
              	    ; Init LCD
0235: CDB206  	    CALL initTerminal
0238: CD0704  	    CALL setGrMode
023B: CDAD06  	    CALL setBufNoClear
              	
              	
              	    ; Show init string
023E: 010000  	    LD BC, $0000
0241: CD9F07  	    CALL setCursor
0244: 11CA1F  	    LD DE, WELLCOME_LCD
              	    ; set cursor ON
0247: 3E00    	    LD A, 0
0249: 3294FB  	    LD (CURSOR_ON), A
              	    ; send cursor
024C: CD4F07  	    CALL sendStringToLCD
              	
              	
024F:         	MAIN_LOOP:
024F: CD5B02  	    CALL showCurrentDriver
              	
0252: CD7712  	    CALL GETLINE             ; Lê linha em LINEBUF
0255: CDC80F  	    CALL PARSE_CMD           ; Interpreta e executa
              	
0258: C34F02  	    JP      MAIN_LOOP
              	
              	
025B:         	showCurrentDriver:
025B: 3AFDFB  	    LD A, (I2CA_BLOCK)
025E: FEA0    	    CP EEDRIVE_A  ; Drive A
0260: 2805    	    JR Z, showDriveA
0262: FEAE    	    CP EEDRIVE_B  ; Drive B
0264: 2808    	    JR Z, showDriveB
0266: C9      	    RET
0267:         	showDriveA:
0267: 3E41    	    LD A, 'A'
0269: CDDF06  	    CALL sendCharToLCD
026C: 1807    	    JR showCursor
026E:         	showDriveB:
026E: 3E42    	    LD A, 'B'
0270: CDDF06  	    CALL sendCharToLCD
0273: 1800    	    JR showCursor
0275:         	showCursor:
0275: 3E3A    	    LD A, ':'
0277: CDDF06  	    CALL sendCharToLCD
027A: C9      	    RET
              	
              	
              	
              	
              	; **********************************************************************
              	; Delay by DE milliseconds
              	;   On entry: DE = Delay time in milliseconds
              	;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved
027B: F5      	H_Delay:    PUSH AF
027C: C5      	            PUSH BC
027D: D5      	            PUSH DE
              	; 1 ms loop, DE times...        ;[=36]   [=29]    Overhead for each 1ms
027E: 011A01  	LoopDE:    LD   BC, kDelayCnt   ;[10]    [9]
              	; Inner loop, BC times...       ;[=26]   [=20]    Loop time in Tcycles
0281: 0B      	LoopBC:    DEC  BC             ;[6]     [4]
0282: 79      	            LD   A,C            ;[4]     [4]
0283: B0      	            OR   B              ;[4]     [4]
0284: C28102  	            JP   NZ,LoopBC     ;[12/7]  [8/6] 
              	; Have we looped once for each millisecond requested?
0287: 1B      	            DEC  DE             ;[6]     [4]
0288: 7B      	            LD   A,E            ;[4]     [4]
0289: B2      	            OR   D              ;[4]     [4]
028A: 20F2    	            JR   NZ, LoopDE     ;[12/7]  [8/6]
028C: D1      	            POP  DE
028D: C1      	            POP  BC
028E: F1      	            POP  AF
028F: C9      	            RET
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	#include "TECLADO.asm"
0016:         	DB_OUTER    EQU     22          ; iterações externas
00F0:         	DB_INNER    EQU     240         ; iterações DJNZ internas
              	
              	
              	; -----------------------------------------------------------------------------
              	;   Check break key (Basic)
              	;       On exit: If press A = CTRLC and NZ flagged
              	;       BC DE HL preserved
              	; -----------------------------------------------------------------------------
0290:         	CHKKEY:
0290: 3EFE    	    LD      A, 0xFE             ; Máscara: bit 0 baixo = col 0
0292: D340    	    OUT     (KEYBOARD), A       ; Ativa coluna B
0294: 00      	    NOP                         ; ~270 ns de estabilização
0295: 00      	    NOP
0296: 00      	    NOP
0297: 00      	    NOP
0298: DB40    	    IN      A, (KEYBOARD)       ; Lê linhas
029A: 2F      	    CPL                         ; Pull-up: inverte (pressionado = 1)
029B: FE01    	    CP 1
029D: C2A502  	    jp nz, GRET
02A0: 3E03    		LD  A, CTRLC
02A2: FE00    		CP	0
02A4: C9      		RET
02A5:         	GRET:
02A5: 3E00    		LD  A, 0
02A7: FE00    		CP 0
02A9: C9      		RET
              	
              	
              	;   CONIN: Lê um teclado → A
              	;       On exit: A = KEY
              	;       BC DE HL preserved
              	;       loop until key is pressed 
02AA:         	CONIN:
02AA: C5      	    PUSH BC
02AB: D5      	    PUSH DE
02AC: E5      	    PUSH HL
02AD: CDED02  	    CALL readKeyboarWaitPressA
02B0: E1      	    POP HL
02B1: D1      	    POP DE
02B2: C1      	    POP BC
02B3: C9      	    RET
              	
              	
              	
              	;   CONIN: Lê um teclado → A
              	;       On exit: A = KEY
              	;       BC DE HL preserved
              	;       sem loop, Carry=1 se tecla
02B4:         	CONIN_NOT_LOOP:
02B4: C5      	    PUSH BC
02B5: D5      	    PUSH DE
02B6: E5      	    PUSH HL
02B7: CDBE02  	    CALL readKeyboarPressA
02BA: E1      	    POP HL
02BB: D1      	    POP DE
02BC: C1      	    POP BC
02BD: C9      	    RET
              	
              	
02BE:         	readKeyboarPressA;
02BE: AF      	    XOR A
02BF: 329EFB  	    LD (MEN_SHIFT), A ; reset shift
02C2: CD2B03  	    CALL    SCAN_MATRIX
02C5: D0      	    RET      NC
02C6: CDD102  	    CALl GetKeycode
02C9: CDD702  	    CALL checkShiftKey
02CC: 3A9FFB  	    LD A, (KEY_PRESS)
02CF: 37      	    SCF  ; Carry = 1
02D0: C9      	    RET
              	
              	
              	
              	; A = col*8 + row  (0x00 – 0x3F)
02D1:         	GetKeycode:
              	    ; --- Tecla confirmada: calcula keycode ---
              	    ; col*8 + row  (0x00 – 0x3F)
02D1: 78      	    LD      A, B                ; B = coluna
02D2: 87      	    ADD     A, A                ; ×2
02D3: 87      	    ADD     A, A                ; ×4
02D4: 87      	    ADD     A, A                ; ×8
02D5: 81      	    ADD     A, C                ; + linha (C) = keycode
02D6: C9      	    RET
              	
              	
              	; Verifica se shift e recupera ascii
              	;   Salva tecla em KEY_PRESS
02D7:         	checkShiftKey:
              	    ; Verifica Shift
02D7: 5F      	    LD E, A
02D8: 21A001  	    LD HL, KEYMAP_NORMAL
02DB: 3A9EFB  	    LD A, (MEN_SHIFT)
02DE: FE01    	    CP 1
02E0: C2E602  	    JP NZ, NO_SHIFT
02E3: 21E001  	    LD HL, KEYMAP_SHIFT
02E6:         	NO_SHIFT:
02E6: CD2603  	    CALL 	DO_LOOKUP	; pega tecla
02E9: 329FFB  	    LD (KEY_PRESS), A
02EC: C9      	    RET
              	
              	
              	
              	; LER TECLADO
              	; Aguarda até uma teclad for pressionada e retorna em A
02ED:         	readKeyboarWaitPressA:
02ED: CD2B03  	    CALL    SCAN_MATRIX
02F0: D2ED02  	    JP      NC, readKeyboarWaitPressA       ; Nenhuma tecla, continua
              	
              	    ; --- Primeira leitura positiva: aguarda debounce ---
02F3: CD1A03  	    CALL    DEBOUNCE
              	
              	    ; --- Confirma que a tecla ainda está pressionada ---
02F6: AF      	    XOR A
02F7: 329EFB  	    LD (MEN_SHIFT), A ; reset shift
02FA: CD2B03  	    CALL    SCAN_MATRIX
02FD: D2ED02  	    JP      NC, readKeyboarWaitPressA       ; Foi ruído, descarta
              	
0300: CDD102  	    CALL GetKeycode
              	    
0303: CDD702  	    CALL checkShiftKey
              	    
              	    ; --- Aguarda soltar + debounce de release ---
0306:         	WAIT_RELEASE:
0306: CD2B03  	    CALL    SCAN_MATRIX
0309: DA0603  	    JP      C, WAIT_RELEASE     ; Ainda pressionada
030C: CD1A03  	    CALL    DEBOUNCE            ; Debounce do soltar
030F: CD2B03  	    CALL    SCAN_MATRIX
0312: DA0603  	    JP      C, WAIT_RELEASE     ; Bounce no release, volta a esperar
              	
0315: 3A9FFB  	    LD A, (KEY_PRESS)
0318: B7      	    OR A
0319: C9      	    RET
              	
              	
              	
              	
              	
              	
              	; ============================================================
              	; DEBOUNCE  –  espera ~10 ms (calibrado para 7.3728 MHz)
              	;   Usa DE como contador, preserva BC
              	;   T-states totais ≈ 69.080  →  ~9.36 ms
              	; ============================================================
031A:         	DEBOUNCE:
031A: C5      	    PUSH    BC
031B: 0616    	    LD      B, DB_OUTER         ; B = contador externo
031D:         	DB_OUTER_LOOP:
031D: 0EF0    	    LD      C, DB_INNER         ; C = contador interno
031F:         	DB_INNER_LOOP:
031F: 0D      	    DEC     C                   ; 4 T
0320: 20FD    	    JR      NZ, DB_INNER_LOOP   ; 12 T (não salta) / 7 T (salta)
0322: 10F9    	    DJNZ    DB_OUTER_LOOP       ; 13 T (não salta) / 8 T (salta)
0324: C1      	    POP     BC
0325: C9      	    RET
              	
              	
              	; Pega char in table
0326:         	DO_LOOKUP:
0326: 1600    	    LD      D, 0
0328: 19      	    ADD     HL, DE
0329: 7E      	    LD      A, (HL)
032A: C9      	    RET
              	
              	
              	; ============================================================
              	; SCAN_MATRIX
              	;   Varre 8 colunas, uma por vez (bit baixo = ativo)
              	;   Saída: B = col (0-7), C = row (0-7), Carry=1 se tecla
              	; ============================================================
032B:         	SCAN_MATRIX:
032B: 0600    	    LD      B, 0                ; Coluna atual
032D: 16FE    	    LD      D, 0xFE             ; Máscara: bit 0 baixo = col 0
032F:         	SCAN_COL:
032F: 7A      	    LD      A, D
0330: D340    	    OUT     (KEYBOARD), A       ; Ativa coluna B
0332: 00      	    NOP                         ; ~270 ns de estabilização
0333: 00      	    NOP
0334: 00      	    NOP
0335: 00      	    NOP
0336: DB40    	    IN      A, (KEYBOARD)       ; Lê linhas
0338: 2F      	    CPL                         ; Pull-up: inverte (pressionado = 1)
              	    
              	    ; SHIFT
0339: F5      	    PUSH AF
033A: 7A      	    LD A, D
033B: FEFE    	    CP $FE
033D: C25003  	    JP NZ, FIM
0340: F1      	    POP AF
0341: F5      	    PUSH AF
0342: FE08    	    CP $08
0344: C25003  	    JP NZ, FIM
0347: 3E01    	    LD A, 1
0349: 329EFB  	    LD (MEN_SHIFT), A
034C: F1      	    POP AF
034D: 3E00    	    LD A, 0
034F: F5      	    PUSH AF
              	    
0350:         	FIM:
0350: F1      		POP AF
              	    
0351: E6FF    	    AND     0xFF
0353: 280E    	    JR      Z, NEXT_COL         ; Nenhuma linha nesta coluna
              	    
              	    ; Encontrou linha — identifica bit
0355: 0E00    	    LD      C, 0
0357:         	FIND_ROW:
0357: 1F      	    RRA
0358: 3803    	    JR      C, ROW_FOUND
035A: 0C      	    INC     C
035B: 18FA    	    JR      FIND_ROW
              	
035D:         	ROW_FOUND:
035D: 3EFF    	    LD      A, 0xFF
035F: D340    	    OUT     (KEYBOARD), A           ; Desativa colunas
0361: 37      	    SCF                         ; Carry = 1
0362: C9      	    RET
              	
0363:         	NEXT_COL:
0363: 04      	    INC     B
0364: 78      	    LD      A, B
0365: FE08    	    CP      8
0367: 2809    	    JR      Z, SCAN_NONE        ; Todas varridas, nada encontrado
              	
              	    ; Rotaciona máscara para próxima coluna
0369: 7A      	    LD      A, D
036A: 37      	    SCF
036B: CB17    	    RL      A                   ; Desloca bit baixo para esquerda
036D: F601    	    OR      0x01                ; Garante que o bit 0 volta alto (inativo)
036F: 57      	    LD      D, A
0370: 18BD    	    JR      SCAN_COL
              	
0372:         	SCAN_NONE:
0372: 3EFF    	    LD      A, 0xFF
0374: D340    	    OUT     (KEYBOARD), A
0376: B7      	    OR      A                   ; Limpa Carry
0377: C9      	    RET
              	
              	
              	    
              	    
              	    
              	#include "GLCD.asm"
              	; Graphical LCD 128 x 64 Library
              	; ------------------------------
              	; By B. Chiha May-2023
              	; Modificações para funcionar no Z80 Mini - 2026
              	;
              	; This is a native Z80 Graphics library to be used with 128x64 Graphical LCD Screens
              	;
              	; There are a few variants of these LCD screens, but they must all must use the ST7920
              	; LCD Controller.  The LCD Screen that I used is the QC12864B.  This screen has two
              	; ST7921 Panels (128 x 32) stacked one above the other.
              	;
              	; These screens have DDRAM (Graphics) and CGRAM (Text) areas.  Both RAM areas can 
              	; be displayed at the same time.
              	;
              	; The Pinout for the QC12864B board is as follows:
              	;
              	; Pin	Name	Desc                    Serial  Parallel
              	; ---   ----    -------------           ------  -------------
              	; 1     VSS     Ground                  GND     GND
              	; 2     VDD     Power                   5v      5v
              	; 3     V0      Contrast                N/A     N/A
              	; 4     D/I     IR/DR (CS)              5v      A7
              	; 5     R/W     R/W (SID)               D0      RD (inverted)
              	; 6     E       Enable (SCLK)           D1      Port 7 (inverted)
              	; 7     DB0     Data                    N/A     D0
              	; 8     DB1     Data                    N/A     D1
              	; 9     DB2     Data                    N/A     D2
              	; 10    DB3     Data                    N/A     D3
              	; 11    DB4     Data                    N/A     D4
              	; 12    DB5     Data                    N/A     D5
              	; 13    DB6     Data                    N/A     D6
              	; 14    DB7     Data                    N/A     D7
              	; 15    PSB     Serial/Para             GND     5v
              	; 16    NC
              	; 17    RST     Reset                   RST     RST
              	; 18    VEE     LCD Drive               N/A     N/A
              	; 19    A       Backlight               5v/NC   5v/NC
              	; 20    K       Backlight               GND/NC  GND/NC
              	;
              	;
              	        
              	        
              	; Modifiable values.  Thse three values can be modified to suit your own set up
              	; GLCD_INST and GLCD_DATA are the output ports to send an Instruction or Data value.
              	; V_DELAY_US is the minimum delay needed for a command to be processed by the
              	; LCD board.  If only some of the data is being sent, make this value larger
              	        
              	;Port 7 on TEC is connected to LCD Enable (Pin 6)
              	;A7 is connected to Register select (Pin 4).  (A7=0 for Instruction, A7=1 for Data)
0010:         	V_DELAY_US: .equ $0010   ;Delay for 76us on your system
              	
              	; Dont need to modify anything else below.
00F8:         	UP:     .equ $F8                 ; Up Arrow
00F7:         	DN:     .equ $F7                 ; Down Arrow
000C:         	FF:     .equ 0CH                 ; Form Feed
008F:         	CURSOR: .equ 8FH                 ; Cursor
              	        
              	
              	
              	
              	
              	; --- CONOUT: Envia byte em A ---
0378:         	PUTCHAR:
0378:         	CONOUT:
0378: F5      	        PUSH AF
0379: C5      	        PUSH BC
037A: D5      	        PUSH DE
037B: E5      	        PUSH HL
037C: CDDF06  	        CALL sendCharToLCD
037F: E1      	        POP HL
0380: D1      	        POP DE
0381: C1      	        POP BC
0382: F1      	        POP AF
0383: C9      	        RET
              	
              	
              	; --- PUTS: Envia string terminada em NUL apontada por HL ---
0384:         	PUTS:
0384: F5      	        PUSH AF
0385: C5      	        PUSH BC
0386: D5      	        PUSH DE
0387: E5      	        PUSH HL
0388: 545D    	        LD DE, HL
038A: 3E00    	        LD A, NUL
038C: CD4F07  	        CALL sendStringToLCD
038F: E1      	        POP HL
0390: D1      	        POP DE
0391: C1      	        POP BC
0392: F1      	        POP AF
0393: C9      	        RET
              	
              	; --- CRLF: Envia CR+LF ---
0394:         	CRLF:
0394: 3E0D    	        LD   A, CR
0396: CD7803  	        CALL PUTCHAR
0399: C9      	        RET
              	
              	
              	
              	; Initialise LCD
039A:         	initLCD:
039A: 212909  	        LD HL, INIT_BASIC       ;POINT HL TO LCD INITIALIZE TABLE
039D: 0604    	        LD B, 04H               ;B=4 BYTES
039F:         	NEXT_CMD:
039F: 7E      	        LD A, (HL)
03A0: D370    	        OUT (GLCD_INST), A
03A2: CD9C06  	        CALL delayUS
03A5: 23      	        INC HL
03A6: 10F7    	        DJNZ NEXT_CMD
03A8: 114001  	        LD DE, 0140H            ;1.6 ms
03AB: CD9F06  	        CALL delayMS
              	        
03AE: 2180F7  	        LD HL,GBUF              ;Set viewport
03B1: 2280FB  	        LD (VPORT),HL           ;to GBUF
              	
03B4: CDC703  	        CALL clearGrLCD
              	        
              	; Clears the Graphics Memory Buffer
03B7:         	clearGBUF:
03B7: 2A80FB  	        LD HL, (VPORT)
03BA: ED5B80FB	        LD DE, (VPORT)
03BE: 13      	        INC DE
03BF: AF      	        XOR A
03C0: 77      	        LD (HL), A
03C1: 01FF03  	        LD BC, 03FFH
03C4: EDB0    	        LDIR
03C6: C9      	        RET
              	        
              	; Clears the Graphics LCD Buffer
03C7:         	clearGrLCD:
03C7: CD0704  	        CALL setGrMode
03CA: 0E00    	        LD C, 00H
03CC:         	CLR_X:
03CC: 3E80    	        LD A, 80H
03CE: B1      	        OR C
03CF: D370    	        OUT (GLCD_INST), A
03D1: CD9C06  	        CALL delayUS
03D4: 3E80    	        LD A, 80H
03D6: D370    	        OUT (GLCD_INST), A
03D8: CD9C06  	        CALL delayUS
03DB: AF      	        XOR A                   ;Clear Byte
03DC: 0610    	        LD B, 10H
03DE:         	CLR_Y:
03DE: D371    	        OUT (GLCD_DATA), A
03E0: CD9C06  	        CALL delayUS
03E3: D371    	        OUT (GLCD_DATA), A
03E5: CD9C06  	        CALL delayUS
03E8: 10F4    	        DJNZ CLR_Y
03EA: 0C      	        INC C
03EB: 79      	        LD A, C
03EC: FE20    	        CP 20H
03EE: 20DC    	        JR NZ, CLR_X        
03F0: C9      	        RET
              	
              	; Clears the ASCII Text LCD
03F1:         	clearTxtLCD:
03F1: CD1504  	        CALL setTxtMode
03F4: 3E80    	        LD A, 80H
03F6: D370    	        OUT (GLCD_INST), A
03F8: CD9C06  	        CALL delayUS
03FB: 0640    	        LD B, 40H
03FD:         	CLR_ROWS:
03FD: 3E20    	        LD A,  " "
03FF: D371    	        OUT (GLCD_DATA), A
0401: CD9C06  	        CALL delayUS
0404: 10F7    	        DJNZ CLR_ROWS
0406: C9      	        RET
              	        
              	; Set Graphics Mode
0407:         	setGrMode:
0407: 3E34    	        LD A, 34H
0409: D370    	        OUT (GLCD_INST), A
040B: CD9C06  	        CALL delayUS
040E: 3E36    	        LD A, 36H
0410: D370    	        OUT (GLCD_INST), A
0412: C39C06  	        JP delayUS
              	        
              	; Set Text Mode
0415:         	setTxtMode:
0415: 3E30    	        LD A, 30H
0417: D370    	        OUT (GLCD_INST), A
0419: C39C06  	        JP delayUS
              	        
              	;Draw Box
              	;Inputs: BC = X0,Y0
              	;        DE = X1,Y1
              	;Destroys: HL
041C:         	drawBox:
041C: C5      	        PUSH BC
041D:         	TOP:
041D: CDD705  	        CALL drawPixel
0420: 7A      	        LD A, D
0421: 04      	        INC B
0422: B8      	        CP B
0423: 30F8    	        JR NC, TOP
0425: C1      	        POP BC
              	        
0426: C5      	        PUSH BC
0427: 4B      	        LD C, E
0428:         	BOTTOM:
0428: CDD705  	        CALL drawPixel
042B: 7A      	        LD A, D
042C: 04      	        INC B
042D: B8      	        CP B
042E: 30F8    	        JR NC, BOTTOM
0430: C1      	        POP BC
              	        
0431: C5      	        PUSH BC
0432:         	B_LEFT:
0432: CDD705  	        CALL drawPixel
0435: 7B      	        LD A, E
0436: 0C      	        INC C
0437: B9      	        CP C
0438: 30F8    	        JR NC, B_LEFT
043A: C1      	        POP BC
              	        
043B: C5      	        PUSH BC
043C: 42      	        LD B, D
043D:         	B_RIGHT:
043D: CDD705  	        CALL drawPixel
0440: 7B      	        LD A, E
0441: 0C      	        INC C
0442: B9      	        CP C
0443: 30F8    	        JR NC, B_RIGHT
0445: C1      	        POP BC
0446: C9      	        RET
              	        
              	;Fill Box
              	;Draws vertical lines from X0,Y0 to X0,Y1 and increase X0 to X1 until X0=X1
              	;Inputs: BC = X0,Y0
              	;        DE = X1,Y1
              	;Destroys: HL
0447:         	fillBox:
0447: C5      	        PUSH BC
0448:         	NEXT_PIXEL:
0448: CDD705  	        CALL drawPixel
044B: 7B      	        LD A, E
044C: 0C      	        INC C
044D: B9      	        CP C
044E: 30F8    	        JR NC, NEXT_PIXEL
0450: C1      	        POP BC
0451: 7A      	        LD A, D
0452: 04      	        INC B
0453: B8      	        CP B
0454: 30F1    	        JR NC, fillBox
0456: C9      	        RET
              	        
              	;Draw a line between two points using Bresenham Line Algorithm
              	; void plotLine(int x0, int y0, int x1, int y1)
              	; {
              	;    int dx =  abs(x1-x0), sx = x0<x1 ? 1 : -1;
              	;    int dy = -abs(y1-y0), sy = y0<y1 ? 1 : -1;
              	;    int err = dx+dy, e2; /* error value e_xy */
              	        
              	;    for(;;){  /* loop */
              	;       setPixel(x0,y0);
              	;       if (x0==x1 && y0==y1) break;
              	;       e2 = 2*err;
              	;       if (e2 >= dy) { err += dy; x0 += sx; } /* e_xy+e_x > 0 */
              	;       if (e2 <= dx) { err += dx; y0 += sy; } /* e_xy+e_y < 0 */
              	;    }
              	; }
              	;Inputs: BC = X0,Y0
              	;        DE = X1,Y1
0457:         	drawLine:
              	;check that points are in range
0457: 79      	        LD A, C
0458: FE40    	        CP 40H
045A: D0      	        RET NC
045B: 78      	        LD A, B
045C: FE80    	        CP 80H
045E: D0      	        RET NC
045F: 7B      	        LD A, E
0460: FE40    	        CP 40H
0462: D0      	        RET NC
0463: 7A      	        LD A, D
0464: FE80    	        CP 80H
0466: D0      	        RET NC
              	        
              	;sx = x0<x1 ? 1 : -1
0467: 2601    	        LD H, 01H
0469: 78      	        LD A, B
046A: BA      	        CP D
046B: 3802    	        JR C, $ + 4
046D: 26FF    	        LD H, 0FFH
046F: 7C      	        LD A, H
0470: 3286FB  	        LD (SX), A
              	        
              	;sy = y0<y1 ? 1 : -1
0473: 2601    	        LD H, 01H
0475: 79      	        LD A, C
0476: BB      	        CP E
0477: 3802    	        JR C, $ + 4
0479: 26FF    	        LD H, 0FFH
047B: 7C      	        LD A, H
047C: 3287FB  	        LD (SY), A
              	        
047F: ED5384FB	        ld (ENDPT), DE
              	        
              	;dx =  abs(x1-x0)
0483: C5      	        PUSH BC
0484: 6A      	        LD L, D
0485: 2600    	        LD H, 0
0487: 48      	        LD C, B
0488: 0600    	        LD B, 0
048A: B7      	        OR A
048B: ED42    	        SBC HL, BC
048D: CDF804  	        CALL ABSHL
0490: 2288FB  	        LD (DX), HL
0493: C1      	        POP BC
              	        
              	;dy = -abs(y1-y0)
0494: C5      	        PUSH BC
0495: 6B      	        LD L, E
0496: 2600    	        LD H, 0
0498: 0600    	        LD B, 0
049A: B7      	        OR A
049B: ED42    	        SBC HL, BC
049D: CDF804  	        CALL ABSHL
04A0: AF      	        XOR A
04A1: 95      	        SUB L
04A2: 6F      	        LD L, A
04A3: 9F      	        SBC A, A
04A4: 94      	        SUB H
04A5: 67      	        LD H, A
04A6: 228AFB  	        LD (DY), HL
04A9: C1      	        POP BC
              	        
              	;err = dx+dy,
04AA: ED5B88FB	        LD DE, (DX)
04AE: 19      	        ADD HL, DE
04AF: 228CFB  	        LD (ERR), HL
              	        
04B2:         	LINE_LOOP:
              	;setPixel(x0,y0)
04B2: CDD705  	        CALL drawPixel
              	        
              	;if (x0==x1 && y0==y1) break;
04B5: 3A85FB  	        LD A, (ENDPT + 1)
04B8: B8      	        CP B
04B9: 2005    	        JR NZ, $ + 7
04BB: 3A84FB  	        LD A, (ENDPT)
04BE: B9      	        CP C
04BF: C8      	        RET Z
              	        
              	;e2 = 2*err;
04C0: 2A8CFB  	        LD HL, (ERR)
04C3: 29      	        ADD HL, HL              ;E2
              	        
              	;if (e2 >= dy)  err += dy; x0 += sx;
04C4: ED5B8AFB	        LD DE, (DY)
04C8: B7      	        OR A
04C9: ED52    	        SBC HL, DE
04CB: 19      	        ADD HL, DE
04CC: FADD04  	        JP M, LL2
              	        
04CF: E5      	        PUSH HL
04D0: 2A8CFB  	        LD HL, (ERR)
04D3: 19      	        ADD HL, DE
04D4: 228CFB  	        LD (ERR), HL
04D7: 3A86FB  	        LD A, (SX)
04DA: 80      	        ADD A, B
04DB: 47      	        LD B, A
04DC: E1      	        POP HL
              	        
04DD:         	LL2:
              	;if (e2 <= dx)  err += dx; y0 += sy;
04DD: ED5B88FB	        LD DE, (DX)
04E1: B7      	        OR A
