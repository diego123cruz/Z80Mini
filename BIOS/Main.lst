10A7: 32FDFB  	    LD (I2CA_BLOCK), A
10AA: C9      	    RET
              	
              	; ============================================================
              	;  CHANGE_DRIVE_B  -  Altera drive para device B - EEDRIVE_B
              	; ============================================================
