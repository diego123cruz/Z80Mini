1D85: 3E01    	    LD A, 1
1D87: B7      	    OR A
1D88: C9      	    RET
              	
1D89: 46432045	str_fc_err:  .TEXT "FC ERRO!"
1D8D: 52524F21	
1D91: 0D0A00  	             .DB CR, LF, 0
              	
              	
              	
              	; FS_WRITE_PG: Grava pagina A com dados de FS_TMPRAM
              	;   Grava min(FS_TMPSZ, 255) bytes. Atualiza FS_TMPRAM e FS_TMPSZ.
              	;   byte 0 da pagina = $00 (next=fim; FS_SET_NEXT corrige se necessario)
              	;   On exit: Z=OK  NZ=erro
              	;   Preserva: BC DE HL
1D94:         	FS_WRITE_PG:
1D94: C5      	    PUSH BC
1D95: D5      	    PUSH DE
1D96: E5      	    PUSH HL
1D97: F5      	    PUSH AF                 ; A = numero da pagina
              	
              	    ; Calcula quantos bytes gravar: min(FS_TMPSZ, 255)
1D98: 2A32FC  	    LD HL, (FS_TMPSZ)
1D9B: 7C      	    LD A, H
1D9C: B7      	    OR A
1D9D: 2005    	    JR NZ, FS_WP_USE255     ; HL >= 256: usa 255
1D9F: 7D      	    LD A, L
1DA0: FEFF    	    CP FS_DATAPG            ; L < 255?
1DA2: 3804    	    JR C, FS_WP_USELT       ; sim: usa L
1DA4:         	FS_WP_USE255:
1DA4: 0EFF    	    LD C, FS_DATAPG         ; C = 255
1DA6: 1801    	    JR FS_WP_COPY
1DA8:         	FS_WP_USELT:
1DA8: 4D      	    LD C, L                 ; C = L (< 255)
              	
1DA9:         	FS_WP_COPY:
              	    ; C = bytes a gravar (1..255). Salva em D para nao perder.
1DA9: 51      	    LD D, C                 ; D = bytes a gravar
              	
              	    ; Monta PG_BUF[0..$FF]:
              	    ;   [0]    = $00 (next page, sera corrigido por FS_SET_NEXT)
              	    ;   [1..C] = dados da RAM
              	    ;   [C+1..$FF] = $FF (padding)
1DAA: 213AFC  	    LD HL, PG_BUF
1DAD: 3600    	    LD (HL), $00            ; byte 0 = next = $00
1DAF: 23      	    INC HL                  ; HL = PG_BUF + 1
              	
              	    ; Copia D bytes de FS_TMPRAM para PG_BUF+1
              	    ; Usa IX como ponteiro de origem (LD BC,(nn) pode nao funcionar no zasm)
1DB0: DD2A34FC	    LD IX, (FS_TMPRAM)      ; IX = ponteiro RAM origem
1DB4: 5A      	    LD E, D                 ; E = contador de copia
1DB5:         	FS_WP_CPLOOP:
1DB5: DD7E00  	    LD A, (IX+0)            ; le da RAM origem
1DB8: 77      	    LD (HL), A              ; grava no PG_BUF
1DB9: DD23    	    INC IX
1DBB: 23      	    INC HL
1DBC: 1D      	    DEC E
1DBD: 20F6    	    JR NZ, FS_WP_CPLOOP
              	
              	    ; Padding $FF ate completar 256 bytes (posicoes D+1 a 255)
              	    ; Bytes de padding = 255 - D
1DBF: 3EFF    	    LD A, FS_DATAPG         ; 255
1DC1: 92      	    SUB D                   ; A = 255 - D (bytes de padding)
1DC2: 2807    	    JR Z, FS_WP_NOPAD       ; sem padding (D=255, pagina cheia)
1DC4: 5F      	    LD E, A
1DC5:         	FS_WP_PADLOOP:
1DC5: 36FF    	    LD (HL), $FF
1DC7: 23      	    INC HL
1DC8: 1D      	    DEC E
1DC9: 20FA    	    JR NZ, FS_WP_PADLOOP
1DCB:         	FS_WP_NOPAD:
              	
              	    ; Grava PG_BUF inteiro (256 bytes) na EEPROM
              	    ; Endereco EEPROM = pagina * 256 (D = pagina, E = 0)
1DCB: F1      	    POP AF                  ; A = numero da pagina
1DCC: F5      	    PUSH AF
1DCD: 57      	    LD D, A
1DCE: 1E00    	    LD E, 0
1DD0: 213AFC  	    LD HL, PG_BUF
1DD3: 010001  	    LD BC, 256
1DD6: CDC418  	    CALL I2C_MemWr
1DD9: C2061E  	    JP NZ, FS_WP_ERR
              	
              	    ; Atualiza FS_TMPRAM += D_bytes_gravados
1DDC: F1      	    POP AF                  ; A = pagina (descarta)
1DDD: E1      	    POP HL                  ; restaura HL original
1DDE: D1      	    POP DE                  ; restaura DE original
1DDF: C1      	    POP BC                  ; restaura BC original
              	
              	    ; Recalcula com D = bytes gravados
              	    ; D foi preservado? Nao — foi sobrescrito por LD D, A (pagina).
              	    ; Usamos FS_TMPSZ antes e depois para calcular o que foi gravado:
              	    ; bytes_gravados = min(TMPSZ_antes, 255)
              	    ; Mais simples: relemos FS_TMPSZ e FS_TMPRAM e atualizamos
              	    ; Mas D foi sobrescrito... precisamos salvar D antes do I2C_MemWr.
              	    ; SOLUCAO: salvar D (bytes) em FS_TMP1 antes de gravar.
              	    ; Para nao refatorar todo o fluxo acima, usamos um truque:
              	    ; bytes_gravados = FS_TMPSZ se < 255, ou 255 se >= 255.
              	    ; Recalcula de FS_TMPSZ:
1DE0: 2A32FC  	    LD HL, (FS_TMPSZ)
1DE3: 7C      	    LD A, H
1DE4: B7      	    OR A
1DE5: 2005    	    JR NZ, FS_WP_UPD255
1DE7: 7D      	    LD A, L
1DE8: FEFF    	    CP FS_DATAPG
1DEA: 3805    	    JR C, FS_WP_UPDLT
1DEC:         	FS_WP_UPD255:
1DEC: 01FF00  	    LD BC, FS_DATAPG        ; bytes gravados = 255
1DEF: 1803    	    JR FS_WP_UPDATE
1DF1:         	FS_WP_UPDLT:
1DF1: 0600    	    LD B, 0
1DF3: 4D      	    LD C, L                 ; bytes gravados = L
              	
1DF4:         	FS_WP_UPDATE:
              	    ; FS_TMPRAM += BC
1DF4: 2A34FC  	    LD HL, (FS_TMPRAM)
1DF7: 09      	    ADD HL, BC
1DF8: 2234FC  	    LD (FS_TMPRAM), HL
              	    ; FS_TMPSZ -= BC
1DFB: 2A32FC  	    LD HL, (FS_TMPSZ)
1DFE: B7      	    OR A                    ; limpa carry
1DFF: ED42    	    SBC HL, BC
1E01: 2232FC  	    LD (FS_TMPSZ), HL
1E04: AF      	    XOR A                   ; Z = sucesso
1E05: C9      	    RET
              	
1E06:         	FS_WP_ERR:
1E06: F1      	    POP AF
1E07: E1      	    POP HL
1E08: D1      	    POP DE
1E09: C1      	    POP BC
1E0A: 3E01    	    LD A, 1
1E0C: B7      	    OR A
1E0D: C9      	    RET
              	
              	; FS_SET_NEXT: Escreve byte 0 da pagina A com valor B
              	;   On exit: Z=OK  NZ=erro
1E0E:         	FS_SET_NEXT:
1E0E: C5      	    PUSH BC
1E0F: D5      	    PUSH DE
1E10: E5      	    PUSH HL
1E11: 57      	    LD D, A
1E12: 1E00    	    LD E, 0
1E14: 78      	    LD A, B
1E15: 3231FC  	    LD (FS_TMP1), A
1E18: 2131FC  	    LD HL, FS_TMP1
1E1B: 010100  	    LD BC, 1
1E1E: CDC418  	    CALL I2C_MemWr
1E21: E1      	    POP HL
1E22: D1      	    POP DE
1E23: C1      	    POP BC
1E24: C9      	    RET
              	
              	
              	
              	; FS_FIND_NAME: Busca FS_NAMBUF no diretorio
              	;   On exit: Z=encontrado (FS_CUR=idx, FS_WRKBUF=entrada)
              	;            NZ=nao encontrado
1E25:         	FS_FIND_NAME:
1E25: AF      	    XOR A
1E26: 3206FC  	    LD (FS_CUR), A
1E29: 0608    	    LD B, FS_MAXFILES
1E2B:         	FS_FN_LP:
1E2B: C5      	    PUSH BC
1E2C: CD1B1C  	    CALL FS_RD_ENTRY
1E2F: C25E1E  	    JP NZ, FS_FN_ERR
1E32: 3A14FC  	    LD A, (FS_WRKBUF + FS_O_FLAGS)
1E35: FE01    	    CP FS_FLAG_USED
1E37: 2017    	    JR NZ, FS_FN_NXT
1E39: 2127FC  	    LD HL, FS_NAMBUF
1E3C: 1107FC  	    LD DE, FS_WRKBUF + FS_O_NAME
1E3F: 0E08    	    LD C, FS_NAME_SZ
1E41:         	FS_FN_CMP:
1E41: 7E      	    LD   A, (HL)
1E42: 47      	    LD   B, A
1E43: 1A      	    LD   A, (DE)
1E44: B8      	    CP   B
1E45: C2501E  	    JP  NZ, FS_FN_NXT
1E48: 23      	    INC HL
1E49: 13      	    INC DE
1E4A: 0D      	    DEC C
1E4B: 20F4    	    JR NZ, FS_FN_CMP
1E4D: C1      	    POP BC
1E4E: AF      	    XOR A
1E4F: C9      	    RET
1E50:         	FS_FN_NXT:
1E50: 3A06FC  	    LD A, (FS_CUR)
1E53: 3C      	    INC A
1E54: 3206FC  	    LD (FS_CUR), A
1E57: C1      	    POP BC
1E58: 10D1    	    DJNZ FS_FN_LP
1E5A: 3E01    	    LD A, 1
1E5C: B7      	    OR A
1E5D: C9      	    RET
1E5E:         	FS_FN_ERR:
