1253: 11C714  	            LD   DE, MSG_HELP_L14
1256: CD4F07  	            CALL sendStringToLCD
              	
1259: 11D914  	            LD   DE, MSG_HELP_L15
125C: CD4F07  	            CALL sendStringToLCD
              	
125F: 11EB14  	            LD   DE, MSG_HELP_L16
1262: CD4F07  	            CALL sendStringToLCD
              	
1265: 11FE14  	            LD   DE, MSG_HELP_L17
