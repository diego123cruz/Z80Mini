              	; Generate stop condition
17DC: CDE817  	            CALL I2C_SCL_HI     ;SCL high  (SCL hi, SDA lo)
17DF: CDF617  	            CALL I2C_SDA_HI     ;SDA low   (SCL hi, SDA hi)
17E2: AF      	            XOR  A              ;Return success A=0 and Z flagged
17E3: C9      	            RET
              	
              	
              	; **********************************************************************
              	; I2C bus simple I/O functions
