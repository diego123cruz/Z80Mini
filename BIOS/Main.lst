              	; --------------------------------------
              	; zasm: assemble "Main.asm"
              	; date: 2026-05-30 14:13:13
              	; --------------------------------------


              	; Z80Mini   -   Maio de 2026
              	
              	; Sistema Monitor basico v1
              	;
              	; Z80 @7.372800Mhz
              	; ROM 32Kb @28C256      0000-7FFF
              	; RAM 32kb @62256       8000-FFFF
              	;
              	; Teclado Mecânico :) Custom    -   0x40 (Read/Write)
              	; I2C EEPROM (Drivers A: B: etc...)
              	; I2C RTC - ricoh223    -   0x64
              	; I2C Display 4x 7seg, Leds(5), Sons   -   0x0E
              	; In/Out generic    -   0xC0 (Read/Write)
              	; Leds  -   0x10
              	; GLCD 128x64   -   0x70
              	; USB-SERIAL SIO/2 A    -   0x00
              	; P2-SERIAL (Printer) SIO/2 B   -   0x00
              	;
              	;
              	; Compilação: zasm --z80 -w -u --bin  Main.asm
              	;
              	;
              	;   Comandos suportados:
              	;       H / ?       -   Mostra menu de ajuda, listando os comandos.
              	;       CLS         -   Limpa a tela lcd.
              	;       IHEX        -   Aguarda recebimento intel hex via serial_A (USB-SERIAL) Ex: :0C800000CDF4.........
              	;       OUT         -   Escreve byte na saida. (OUT 10 01) Liga led 1 da porta 0x10
              	;       IN          -   Lê byte da entrada. (IN 0c) Lê byte da entrada 0xC0
              	;       JUMP        -   Desvia PC para endereço. (JUMP 8000)
              	;       CALL        -   Salva monitor como retorno e desvia para endereço. (CALL 8000) o programa pode use RET e voltar para o Monitor.
              	;       DUMP        -   Mostra 40 bytes a partir do endereço atual da ram. (DUMP 8000)
              	;       WRITE       -   Escreve bytes a partir do endereço. (WRITE 8000) Linha vazia para inserção.
              	;       EDIT        -   Edita bytes a partir do endereço. (EDIT 8000) Linha vazia não alterar valor atual, "." para edição.
              	;       I2CLIST     -   Lista dispositivos i2c conectados no barramento.
              	;       FORMAT      -   Formata eeprom no drive atual.
              	;       DIR         -   Lista arquivos do driver atual.
              	;       LOAD        -   Carrega arquivo do drive atual. (LOAD NAME)
              	;       EXEC        -   Carrega e execulta arquivo do drive atual. (EXEC NAME)
              	;       DEL         -   Deleta arquivo no drive atual. (DEL NAME)
              	;       SAVE        -   Salva arquivo no drive atual. Name max 8 chars. (SAVE NAME RAM_ADDR_XXXX SIZE_XXXX) -> save blink 8000 004f
              	;       
              	;
              	;   API Z80Mini:
              	;       delay500ms          equ     0x0100  ;   Delay 500ms
              	;       delay               equ     0x0103  ;   On entry: DE = Delay time in milliseconds
              	;       I2C_Open            equ     0x0106  ;   On entry: A = Device address (bit zero is read flag)
              	;       I2C_Close           equ     0x0109  ;   Close
              	;       I2C_Read            equ     0x010C  ;   On exit: If successful A = data byte and Z flagged
              	;       I2C_Write           equ     0x010F  ;   On entry: A = Data byte, or Address byte (bit zero is read flag)
              	;       keyboardIsEsc       equ     0x0112  ;   Verifica se ESC foi precionada. On exit: If press A = CTRLC and NZ flagged
              	;       keyboardWaitA       equ     0x0115  ;   Aguarda tecla, letra em A. (BC DE HL preserved)
              	;       keyboardA           equ     0x0118  ;   Lê teclado, Se tecla Carry=1. Letra em A. (BC DE HL preserved)
              	;       setDefaultSerialA   equ     0x011B  ;   Seta terminal padrao porta A, Quando reinicia volta para A.
              	;       setDefaultSerialB   equ     0x011E  ;   Seta terminal padrao porta B (P2), Quando reinicia volta para A.
              	;       serialPrintA        equ     0x0121  ;   Imprime char in A no terminal setado.
              	;       serialInputA        equ     0x0124  ;   Aguarda receber char no terminal setado. Retorno em A.
              	;       serialPrintStr      equ     0x0127  ;   Imprime string (HL) terminado em 0 no terminal setado. MAX 128 chars. MODIFIES : A,B,C
              	;       serialCRLF          equ     0x012A  ;   Imprime CR e LF no terminal setado.
              	;       serialHexA          equ     0x012D  ;   Imprime byte em A no formato HEX, no terminal setado. Ex: 'D' = 44
              	;       serialHexHL         equ     0x0130  ;   Imprime HL como 4 digitos hexadecimais, no terminal setado. Ex: HL=$80FF -> imprime "80FF"
              	;       serialInHexA        equ     0x0133  ;   Pegar 2 caracteres ASCII (0-9 A-F), do terminal setado e converte em um byte em A. SEM ECHO
              	;       serialInHexHL       equ     0x0136  ;   Pegar 4 caracteres ASCII (0-9 A-F), do terminal setado e converte em HL. SEM ECHO
              	
              	;       initLCD             equ     0x0139  ;   Inicializa GLCD
              	;       clearGBUF           equ     0x013C  ;   Limpa buffer da memoria de grafico. Precisa do plotToLCD para refletir no lcd.
              	;       clearGrLCD          equ     0x013F  ;   Limpa memoria grafico do GLCD. Sem o plotToLCD.
              	;       clearTxtLCD         equ     0x0142  ;   Limpar caracteres do LCD
              	;       setGrMode           equ     0x0145  ;   Seta modo Grafico. 128x64
              	;       setTxtMode          equ     0x0148  ;   Seta mode Text. 16x4 equivalente
              	;       drawBox             equ     0x014B  ;   Desenha caixa. Entradas: BC = X0,Y0 - DE = X1,Y1    Destroys: HL
              	;       drawLine            equ     0x014E  ;   Desenha linha.  Entradas: BC = X0,Y0 - DE = X1,Y1
              	;       drawCircle          equ     0x0151  ;   Desenha circulo. Entradas BC = xm,ym (Ponro do Meio) - E = radius
              	;       drawPixel           equ     0x0154  ;   Desenha um pixel em X Y.  Entrada B = column/X (0-127), C = row/Y (0-63)   Destroys: HL
              	;       fillBox             equ     0x0157  ;   Desenha caixa preenchida. Entradas: BC = X0,Y0 - DE = X1,Y1    Destroys: HL
              	;       fillCircle          equ     0x015A  ;   Desenha circulo preenchido. Entradas BC = xm,ym (Ponro do Meio) - E = radius
              	;       plotToLCD           equ     0x015D  ;   Rotina principal de desenho. Move GBUF para o LCD e limpa o buffer ou não (setBufClear, setBufNoClear).  Destroys: ALL
              	;       printString         equ     0x0160  ;   Imprimir texto ASCII em uma determinada linha. Entradas: A = 0 a 3 Número da linha. .db "String" na próxima linha, terminar com 0
              	;       printChars          equ     0x0163  ;   (Ver detalhes) Imprimir caracteres na posição X,Y. Entrada B = coluna/X (0-7), C = linha/Y (0-3). HL = Endereço inicial do texto a ser exibido, termina com 0
              	;       setInt38            equ     0x0166  ;   Seta vetor de interrupcao int38. Entradas HL = RST38_ADDR
              	;       setint66            equ     0x0169  ;   Seta vetor de interrupcao int66. Entradas HL = RST66_ADDR
              	;       setBufClear         equ     0x016C  ;   Configura limpeza do buffer após a saída para o LCD e vai para clearGBUF.
              	;       setBufNoClear       equ     0x016F  ;   Configura para não limpar o buffer após a saída para o LCD.
              	;       clearPixel          equ     0x0172  ;   Limpa um pixel X Y.  Input B = column/X (0-127), C = row/Y (0-63)    Destroy HL
              	;       flipPixel           equ     0x0175  ;   Inverte um pixel X Y.  Input B = column/X (0-127), C = row/Y (0-63)    Destroy HL
              	;       drawGraphic         equ     0x0178  ;   Desenha no buffer. Entrada: A = número ASCII ou se A=0 Então  HL = Endereço dos dados gráficos. B = largura do gráfico em pixels (1-128). C = altura do gráfico em pixels (1-64). Destroy: ALL
              	;       invGraphic          equ     0x017B  ;   Altera a flag de desenho inverso. (não inverte grafico atual) Destroy A
              	;       initTerminal        equ     0x017E  ;   Inicializa o Terminal GLCD. Cursor 0,0 e limpa buffer.
              	;       sendCharToLCD       equ     0x0181  ;   Envia ou manipula caracteres ASCII para a tela GLCD (Terminal). Entrada: A = caractere ASCII a ser enviado para a tela GLCD. A = somente cursor desenhado.
              	;       sendStringToLCD     equ     0x0184  ;   Imprime string no terminal GLCD. DE = inicio da string. A = caractere para parar a impressão. A impressão para e retorna quando um CR é impresso. Destroy ALL
              	;       sendRegToLCD        equ     0x0187  ;   Imprime byte em A no formato HEX, no GLCD. Ex: 'D' = 44
              	;       sendHLToLCD         equ     0x018A  ;   Imprime HL como 4 digitos hexadecimais, no GLCD. Ex: HL=$80FF -> imprime "80FF"
              	;       setCursor           equ     0x018D  ;   Define a posição do cursor gráfico. Entradas: BC = X,Y onde X = 0..127, Y = 0..63   Destroy A
              	;       getCursor           equ     0x0190  ;   Obter a posição do cursor. Saídas: BC = X,Y onde X = 0..127, Y = 0..63
              	;       displayCursor       equ     0x0193  ;   Exibir Cursor. Entrada: A = 0, Ativar cursor, A = diferente de zero, Desativar cursor.
              	;       autoLF              equ     0x0196  ;   Avanço de linha automático quando o cursor atinge o final da linha (Terminal). Entrada: A = 0, Avanço de linha automático; A = diferente de zero, Sem avanço de linha automático. Padrao LIGADO.
              	;       underline           equ     0x0199  ;   Exibir sublinhado no caractere (Terminal). O estado inicial é sem sublinhado. Chamar esta rotina irá ALTERAR/DESLIGAR o sinalizador de sublinhado.
              	;       plotAlways          equ     0x019C  ;   Quando sendCharToLCD é chamado, Atualiza GLCD ou não. Se Desativado plotToLCD deve ser chamado atualizar o GLCD. Entrada: A=0, Plotar sempre; A>0, Não plotar. O padrão é Plotar sempre.
              	
              	
              	
              	; -----------------------------------------------------------------------------
              	; H_Delay CONFIG
              	; -----------------------------------------------------------------------------
708000:         	kCPUClock:          .EQU 7372800       ;CPU clock speed in Hz
0024:         	kDelayOH:           .EQU 36             ;Overhead for each 1ms in Tcycles
001A:         	kDelayLP:           .EQU 26             ;Inner loop time in Tcycles
1CCC:         	kDelayTA:           .EQU kCPUClock / 1000 ;CPU clock cycles per millisecond
1CA8:         	kDelayTB:           .EQU kDelayTA - kDelayOH  ;Cycles required for inner loop
011A:         	kDelayCnt:          .EQU kDelayTB / kDelayLP  ;Loop counter for inner loop
              	
              	
              	; -----------------------------------------------------------------------------
              	; SYSTEM SETTINGS
              	; -----------------------------------------------------------------------------
FFF0:         	SYSTEM_SP:	        .EQU 	$FFF0	;INITIAL STACK POINTER
              	
              	; -----------------------------------------------------------------------------
              	; SIO/2 - SERIAL
              	; -----------------------------------------------------------------------------
0000:         	SIOA_D		        .EQU	$00
0002:         	SIOA_C		        .EQU	$02
0001:         	SIOB_D		        .EQU	$01 ; Conector P2
0003:         	SIOB_C		        .EQU	$03 ; Conector P2
              	
              	
              	; -----------------------------------------------------------------------------
              	; I2C SETTINGS
              	; -----------------------------------------------------------------------------
2710:         	TIMEOUT:        .EQU    10000      ; Timeout loop counter
00A0:         	EEDRIVE_A       .EQU    $A0        ; Drive A
00AE:         	EEDRIVE_B       .EQU    $AE        ; Drive B
              	
              	; -----------------------------------------------------------------------------
              	; PORTS
              	; -----------------------------------------------------------------------------
0070:         	GLCD_INST           .EQU    $70
0071:         	GLCD_DATA           .EQU    $71
              	
0040:         	KEYBOARD		    .EQU	$40
              	
              	
              	
              	
0008:         	BKSP:   EQU 08H                 ; Back space 08H
0009:         	TAB:    EQU 09H                 ; Horizontal TAB
000A:         	LF:     EQU 0AH                 ; Line feed
000C:         	CS:     EQU 0CH                 ; Clear screen
000D:         	CR:     EQU 0DH                 ; Carriage return
0020:         	SPACE:  EQU 20H                 ; Space
008F:         	CURSOR: EQU 8FH                 ; Cursor
              	
              	
              	
0000:         	    .ORG $0000
0000: C32A02  	    JP INICIO
              	
              	    .ORG $0008
0008: C38B03  	RST08:	JP	CONOUT
              	
              	    .ORG $0010
0010: C3BD02  	RST10:	JP	CONIN
              	
              	    .ORG 0018H ; check break - BASIC
0018: C3A302  	RST18   JP CHKKEY
              	
              	
              		.ORG	0038H
0038: E5      		PUSH	HL
0039: 2A00F0  		LD	HL,(RST38)
003C: E9      		JP	(HL)
              	
              	;
              	; RESTART 66H NMI VECTOR
              	; SAME AS ABOVE BUT NMI CANNOT BE DISABLED.
              	;
              		.ORG	0066H
0066: E5      		PUSH	HL
0067: 2A02F0  		LD	HL,(RST66)
006A: E9      		JP	(HL)
              	
              	
              	    .ORG $0100
              	    ;   Delay
0100: C3911F  	    JP DELAY_500MS
0103: C38E02  	    JP H_Delay
              	    ;   I2C
0106: C36C17  	    JP I2C_Open
0109: C37317  	    JP I2C_Close
010C: C3B317  	    JP I2C_Read
010F: C37617  	    JP I2C_Write
              	    ;   Keyboard
0112: C3A302  	    JP CHKKEY
0115: C3BD02  	    JP CONIN
0118: C3C702  	    JP CONIN_NOT_LOOP
              	    ;   Serial
011B: C39A1F  	    JP SET_DEFAULT_SERIAL_A
011E: C3A71F  	    JP SET_DEFAULT_SERIAL_B
0121: C3830F  	    JP OUTCH
0124: C3890F  	    JP INCH
0127: C38F0F  	    JP SNDSTR
012A: C3D416  	    JP SERIAL_A_TXCRLF
012D: C3AC16  	    JP SERIAL_A_PRINT_A_HEX
0130: C3A316  	    JP SERIAL_A_PRINT_HL_HEX
0133: C3B41F  	    JP SERIAL_GET_HEX_A
0136: C3C01F  	    JP SERIAL_GET_HEX_HL
              	    ;   GLCD
0139: C3AD03  	    JP initLCD
013C: C3CA03  	    JP clearGBUF
013F: C3DA03  	    JP clearGrLCD
0142: C30404  	    JP clearTxtLCD
0145: C31A04  	    JP setGrMode
0148: C32804  	    JP setTxtMode
014B: C32F04  	    JP drawBox
014E: C36A04  	    JP drawLine
0151: C31505  	    JP drawCircle
0154: C3EA05  	    JP drawPixel
0157: C35A04  	    JP fillBox
015A: C3DC05  	    JP fillCircle
015D: C33D06  	    JP plotToLCD
0160: C37006  	    JP printString
0163: C39106  	    JP printChars
0166: C39F01  	    JP SET_INT38
0169: C3A301  	    JP SET_INT66
016C: C3B806  	    JP setBufClear
016F: C3C006  	    JP setBufNoClear
0172: C3FB05  	    JP clearPixel
0175: C30D06  	    JP flipPixel
0178: C38F08  	    JP drawGraphic
017B: C37708  	    JP invGraphic
017E: C3C506  	    JP initTerminal
0181: C3F206  	    JP sendCharToLCD
0184: C36207  	    JP sendStringToLCD
0187: C38907  	    JP sendRegToLCD
018A: C3A607  	    JP sendHLToLCD
018D: C3B207  	    JP setCursor
0190: C36808  	    JP getCursor
0193: C36D08  	    JP displayCursor
0196: C38708  	    JP autoLF
0199: C37F08  	    JP underline
019C: C38B08  	    JP plotAlways
              	
              	
019F:         	SET_INT38:
019F: 2200F0  	    LD (RST38), HL
01A2: C9      	    RET
              	
01A3:         	SET_INT66:
01A3: 2202F0  	    LD (RST66), HL
01A6: C9      	    RET
              	
              	; exemplo de uso de interrupcao
              	; IM 1
              	; EI
              	; RETI
01A7:         	INT_DEFAULT:
01A7: E1      	    POP HL ; sempre usar o POP HL
              	    ; faz alguma coisa
              	    ; EI
01A8: ED4D    	    RETI
              	
              	
              	
              	
              	
              	
              	
              	; ============================================================
              	; KEYMAPS
              	; ============================================================
              	
              	;	$FF - Capsloock
              	;	$FE - Shift left
              	;	$FD - Ctrl left
              	;	$FC - Windows
              	;	$FB - Alt left
              	;	$FA - Alt Gr    (Load intel hex - Serial A)
              	;	$F9 - LUZ   (CALL 8000H)
              	;	$F8 - Shift Right   (Display Scroll UP)
              	;	$F7 - Ctrl Right    (Display Scroll DOWN)
              	;	$F6 - Fn
              	;	$F5 - 
              	;	$F4 - 
              	
01AA:         	KEYMAP_NORMAL:
01AA: 1B09FFFE	    DB  $1B,  $09,  $FF,  $FE,  $FD,  $FC,  $FB,  $20
01AE: FDFCFB20	
01B2: 3171615C	    DB   '1', 'q',  'a',  '\',  $00,  $FA,  $F6,  $F9
01B6: 00FAF6F9	
01BA: 33656478	    DB   '3', 'e',  'd',  'x',  ',',  'l',  'o',  '9'
01BE: 2C6C6F39	
01C2: 34726663	    DB   '4', 'r',  'f',  'c',  '.',  'ç',  'p',  '0'
01C6: 2EE77030	
01CA: 36796862	    DB   '6', 'y',  'h',  'b',  $F8,  $F7,  0x0D, 0x08
01CE: F8F70D08	
01D2: 35746776	    DB   '5', 't',  'g',  'v',  ';',  '~', 	'`',  '-'
01D6: 3B7E602D	
01DA: 37756A6E	    DB   '7', 'u',  'j',  'n',  '/',  ']',  '[',  '='
01DE: 2F5D5B3D	
01E2: 3277737A	    DB   '2', 'w',  's',  'z',  'm',  'k',  'i',  '8'
01E6: 6D6B6938	
              	    
01EA:         	KEYMAP_SHIFT:
01EA: 1B09FFFE	    DB  $1B,  $09,  $FF,  $FE,  $FD,  $FC,  $FB,  $20
01EE: FDFCFB20	
01F2: 2151417C	    DB   '!', 'Q',  'A',  '|',  $00,  $FA,  $F6,  $F9
01F6: 00FAF6F9	
01FA: 23454458	    DB   '#', 'E',  'D',  'X',  '<',  'L',  'O',  '('
01FE: 3C4C4F28	
0202: 24524643	    DB   '$', 'R',  'F',  'C',  '>',  'Ç',  'P',  ')'
0206: 3EC75029	
020A: A8594842	    DB   '¨', 'Y',  'H',  'B',  $F8,  $F7,  0x0D, 0x08
020E: F8F70D08	
0212: 25544756	    DB   '%', 'T',  'G',  'V',  ':',  '^', 	$22,  '_'
0216: 3A5E225F	
021A: 26554A4E	    DB   '&', 'U',  'J',  'N',  '?',  '}',  '{',  '+'
021E: 3F7D7B2B	
0222: 4057535A	    DB   '@', 'W',  'S',  'Z',  'M',  'K',  'I',  '*'
0226: 4D4B492A	
              	
              	
022A:         	INICIO:
022A: 21A701  	    LD HL, INT_DEFAULT
022D: 2200F0  	    LD (RST38), HL
0230: 2202F0  	    LD (RST66), HL
              	
              	    ; Set defult I2C device addess: 24LC256 (Copy from/to Mem)
0233: 3EA0    	    LD A, EEDRIVE_A
0235: 3201FC  	    LD (I2CA_BLOCK), A        
              	
              	    ;CALL FS_CHK_SIG
              	    ;JP Z, INICIO1
              	    ;LD HL, str_notfmt
              	    ;CALL PUTS
0238:         	INICIO1:
              	
0238: 31F0FF  	    LD SP, SYSTEM_SP
              	
023B: 116400  	    LD DE, $0064 ; 100ms
023E: CD8E02  	    CALL H_Delay
              	
              	    ;Init Serial
0241: CD400F  	    CALL initSerial
              	
              	    ;Init Teclado
0244: 3EFF    	    LD      A, 0xFF
0246: D340    	    OUT     (KEYBOARD), A           ; Todas as colunas desativadas
              	
              	    ; Init LCD
0248: CDC506  	    CALL initTerminal
024B: CD1A04  	    CALL setGrMode
024E: CDC006  	    CALL setBufNoClear
              	
              	
              	    ; Show init string
0251: 010000  	    LD BC, $0000
0254: CDB207  	    CALL setCursor
0257: 11DF1F  	    LD DE, WELLCOME_LCD
              	    ; set cursor ON
025A: 3E00    	    LD A, 0
025C: 3298FB  	    LD (CURSOR_ON), A
              	    ; send cursor
025F: CD6207  	    CALL sendStringToLCD
              	
              	
0262:         	MAIN_LOOP:
0262: CD6E02  	    CALL showCurrentDriver
              	
0265: CD8912  	    CALL GETLINE             ; Lê linha em LINEBUF
0268: CDDB0F  	    CALL PARSE_CMD           ; Interpreta e executa
              	
026B: C36202  	    JP      MAIN_LOOP
              	
              	
026E:         	showCurrentDriver:
026E: 3A01FC  	    LD A, (I2CA_BLOCK)
0271: FEA0    	    CP EEDRIVE_A  ; Drive A
0273: 2805    	    JR Z, showDriveA
0275: FEAE    	    CP EEDRIVE_B  ; Drive B
0277: 2808    	    JR Z, showDriveB
0279: C9      	    RET
027A:         	showDriveA:
027A: 3E41    	    LD A, 'A'
027C: CDF206  	    CALL sendCharToLCD
027F: 1807    	    JR showCursor
0281:         	showDriveB:
0281: 3E42    	    LD A, 'B'
0283: CDF206  	    CALL sendCharToLCD
0286: 1800    	    JR showCursor
0288:         	showCursor:
0288: 3E3A    	    LD A, ':'
028A: CDF206  	    CALL sendCharToLCD
028D: C9      	    RET
              	
              	
              	
              	
              	; **********************************************************************
              	; Delay by DE milliseconds
              	;   On entry: DE = Delay time in milliseconds
              	;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved
028E: F5      	H_Delay:    PUSH AF
028F: C5      	            PUSH BC
0290: D5      	            PUSH DE
              	; 1 ms loop, DE times...        ;[=36]   [=29]    Overhead for each 1ms
0291: 011A01  	LoopDE:    LD   BC, kDelayCnt   ;[10]    [9]
              	; Inner loop, BC times...       ;[=26]   [=20]    Loop time in Tcycles
0294: 0B      	LoopBC:    DEC  BC             ;[6]     [4]
0295: 79      	            LD   A,C            ;[4]     [4]
0296: B0      	            OR   B              ;[4]     [4]
0297: C29402  	            JP   NZ,LoopBC     ;[12/7]  [8/6] 
              	; Have we looped once for each millisecond requested?
029A: 1B      	            DEC  DE             ;[6]     [4]
029B: 7B      	            LD   A,E            ;[4]     [4]
029C: B2      	            OR   D              ;[4]     [4]
029D: 20F2    	            JR   NZ, LoopDE     ;[12/7]  [8/6]
029F: D1      	            POP  DE
02A0: C1      	            POP  BC
02A1: F1      	            POP  AF
02A2: C9      	            RET
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	#include "TECLADO.asm"
0016:         	DB_OUTER    EQU     22          ; iterações externas
00F0:         	DB_INNER    EQU     240         ; iterações DJNZ internas
              	
              	
              	; -----------------------------------------------------------------------------
              	;   Check break key (Basic)
              	;       On exit: If press A = CTRLC and NZ flagged
              	;       BC DE HL preserved
              	; -----------------------------------------------------------------------------
02A3:         	CHKKEY:
02A3: 3EFE    	    LD      A, 0xFE             ; Máscara: bit 0 baixo = col 0
02A5: D340    	    OUT     (KEYBOARD), A       ; Ativa coluna B
02A7: 00      	    NOP                         ; ~270 ns de estabilização
02A8: 00      	    NOP
02A9: 00      	    NOP
02AA: 00      	    NOP
02AB: DB40    	    IN      A, (KEYBOARD)       ; Lê linhas
02AD: 2F      	    CPL                         ; Pull-up: inverte (pressionado = 1)
02AE: FE01    	    CP 1
02B0: C2B802  	    jp nz, GRET
02B3: 3E03    		LD  A, CTRLC
02B5: FE00    		CP	0
02B7: C9      		RET
02B8:         	GRET:
02B8: 3E00    		LD  A, 0
02BA: FE00    		CP 0
02BC: C9      		RET
              	
              	
              	;   CONIN: Lê um teclado → A
              	;       On exit: A = KEY
              	;       BC DE HL preserved
              	;       loop until key is pressed 
02BD:         	CONIN:
02BD: C5      	    PUSH BC
02BE: D5      	    PUSH DE
02BF: E5      	    PUSH HL
02C0: CD0003  	    CALL readKeyboarWaitPressA
02C3: E1      	    POP HL
02C4: D1      	    POP DE
02C5: C1      	    POP BC
02C6: C9      	    RET
              	
              	
              	
              	;   CONIN: Lê um teclado → A
              	;       On exit: A = KEY
              	;       BC DE HL preserved
              	;       sem loop, Carry=1 se tecla
02C7:         	CONIN_NOT_LOOP:
02C7: C5      	    PUSH BC
02C8: D5      	    PUSH DE
02C9: E5      	    PUSH HL
02CA: CDD102  	    CALL readKeyboarPressA
02CD: E1      	    POP HL
02CE: D1      	    POP DE
02CF: C1      	    POP BC
02D0: C9      	    RET
              	
              	
02D1:         	readKeyboarPressA;
02D1: AF      	    XOR A
02D2: 32A2FB  	    LD (MEN_SHIFT), A ; reset shift
02D5: CD3E03  	    CALL    SCAN_MATRIX
02D8: D0      	    RET      NC
02D9: CDE402  	    CALl GetKeycode
02DC: CDEA02  	    CALL checkShiftKey
02DF: 3AA3FB  	    LD A, (KEY_PRESS)
02E2: 37      	    SCF  ; Carry = 1
02E3: C9      	    RET
              	
              	
              	
              	; A = col*8 + row  (0x00 – 0x3F)
02E4:         	GetKeycode:
              	    ; --- Tecla confirmada: calcula keycode ---
              	    ; col*8 + row  (0x00 – 0x3F)
02E4: 78      	    LD      A, B                ; B = coluna
02E5: 87      	    ADD     A, A                ; ×2
02E6: 87      	    ADD     A, A                ; ×4
02E7: 87      	    ADD     A, A                ; ×8
02E8: 81      	    ADD     A, C                ; + linha (C) = keycode
02E9: C9      	    RET
              	
              	
              	; Verifica se shift e recupera ascii
              	;   Salva tecla em KEY_PRESS
02EA:         	checkShiftKey:
              	    ; Verifica Shift
02EA: 5F      	    LD E, A
02EB: 21AA01  	    LD HL, KEYMAP_NORMAL
02EE: 3AA2FB  	    LD A, (MEN_SHIFT)
02F1: FE01    	    CP 1
02F3: C2F902  	    JP NZ, NO_SHIFT
02F6: 21EA01  	    LD HL, KEYMAP_SHIFT
02F9:         	NO_SHIFT:
02F9: CD3903  	    CALL 	DO_LOOKUP	; pega tecla
02FC: 32A3FB  	    LD (KEY_PRESS), A
02FF: C9      	    RET
              	
              	
              	
              	; LER TECLADO
              	; Aguarda até uma teclad for pressionada e retorna em A
0300:         	readKeyboarWaitPressA:
0300: CD3E03  	    CALL    SCAN_MATRIX
0303: D20003  	    JP      NC, readKeyboarWaitPressA       ; Nenhuma tecla, continua
              	
              	    ; --- Primeira leitura positiva: aguarda debounce ---
0306: CD2D03  	    CALL    DEBOUNCE
              	
              	    ; --- Confirma que a tecla ainda está pressionada ---
0309: AF      	    XOR A
030A: 32A2FB  	    LD (MEN_SHIFT), A ; reset shift
030D: CD3E03  	    CALL    SCAN_MATRIX
0310: D20003  	    JP      NC, readKeyboarWaitPressA       ; Foi ruído, descarta
              	
0313: CDE402  	    CALL GetKeycode
              	    
0316: CDEA02  	    CALL checkShiftKey
              	    
              	    ; --- Aguarda soltar + debounce de release ---
0319:         	WAIT_RELEASE:
0319: CD3E03  	    CALL    SCAN_MATRIX
031C: DA1903  	    JP      C, WAIT_RELEASE     ; Ainda pressionada
031F: CD2D03  	    CALL    DEBOUNCE            ; Debounce do soltar
0322: CD3E03  	    CALL    SCAN_MATRIX
0325: DA1903  	    JP      C, WAIT_RELEASE     ; Bounce no release, volta a esperar
              	
0328: 3AA3FB  	    LD A, (KEY_PRESS)
032B: B7      	    OR A
032C: C9      	    RET
              	
              	
              	
              	
              	
              	
              	; ============================================================
              	; DEBOUNCE  –  espera ~10 ms (calibrado para 7.3728 MHz)
              	;   Usa DE como contador, preserva BC
              	;   T-states totais ≈ 69.080  →  ~9.36 ms
              	; ============================================================
032D:         	DEBOUNCE:
032D: C5      	    PUSH    BC
032E: 0616    	    LD      B, DB_OUTER         ; B = contador externo
0330:         	DB_OUTER_LOOP:
0330: 0EF0    	    LD      C, DB_INNER         ; C = contador interno
0332:         	DB_INNER_LOOP:
0332: 0D      	    DEC     C                   ; 4 T
0333: 20FD    	    JR      NZ, DB_INNER_LOOP   ; 12 T (não salta) / 7 T (salta)
0335: 10F9    	    DJNZ    DB_OUTER_LOOP       ; 13 T (não salta) / 8 T (salta)
0337: C1      	    POP     BC
0338: C9      	    RET
              	
              	
              	; Pega char in table
0339:         	DO_LOOKUP:
0339: 1600    	    LD      D, 0
033B: 19      	    ADD     HL, DE
033C: 7E      	    LD      A, (HL)
033D: C9      	    RET
              	
              	
              	; ============================================================
              	; SCAN_MATRIX
              	;   Varre 8 colunas, uma por vez (bit baixo = ativo)
              	;   Saída: B = col (0-7), C = row (0-7), Carry=1 se tecla
              	; ============================================================
033E:         	SCAN_MATRIX:
033E: 0600    	    LD      B, 0                ; Coluna atual
0340: 16FE    	    LD      D, 0xFE             ; Máscara: bit 0 baixo = col 0
0342:         	SCAN_COL:
0342: 7A      	    LD      A, D
0343: D340    	    OUT     (KEYBOARD), A       ; Ativa coluna B
0345: 00      	    NOP                         ; ~270 ns de estabilização
0346: 00      	    NOP
0347: 00      	    NOP
0348: 00      	    NOP
0349: DB40    	    IN      A, (KEYBOARD)       ; Lê linhas
034B: 2F      	    CPL                         ; Pull-up: inverte (pressionado = 1)
              	    
              	    ; SHIFT
034C: F5      	    PUSH AF
034D: 7A      	    LD A, D
034E: FEFE    	    CP $FE
0350: C26303  	    JP NZ, FIM
0353: F1      	    POP AF
0354: F5      	    PUSH AF
0355: FE08    	    CP $08
0357: C26303  	    JP NZ, FIM
035A: 3E01    	    LD A, 1
035C: 32A2FB  	    LD (MEN_SHIFT), A
035F: F1      	    POP AF
0360: 3E00    	    LD A, 0
0362: F5      	    PUSH AF
              	    
0363:         	FIM:
0363: F1      		POP AF
              	    
0364: E6FF    	    AND     0xFF
0366: 280E    	    JR      Z, NEXT_COL         ; Nenhuma linha nesta coluna
              	    
              	    ; Encontrou linha — identifica bit
0368: 0E00    	    LD      C, 0
036A:         	FIND_ROW:
036A: 1F      	    RRA
036B: 3803    	    JR      C, ROW_FOUND
036D: 0C      	    INC     C
036E: 18FA    	    JR      FIND_ROW
              	
0370:         	ROW_FOUND:
0370: 3EFF    	    LD      A, 0xFF
0372: D340    	    OUT     (KEYBOARD), A           ; Desativa colunas
0374: 37      	    SCF                         ; Carry = 1
0375: C9      	    RET
              	
0376:         	NEXT_COL:
0376: 04      	    INC     B
0377: 78      	    LD      A, B
0378: FE08    	    CP      8
037A: 2809    	    JR      Z, SCAN_NONE        ; Todas varridas, nada encontrado
              	
              	    ; Rotaciona máscara para próxima coluna
037C: 7A      	    LD      A, D
037D: 37      	    SCF
037E: CB17    	    RL      A                   ; Desloca bit baixo para esquerda
0380: F601    	    OR      0x01                ; Garante que o bit 0 volta alto (inativo)
0382: 57      	    LD      D, A
0383: 18BD    	    JR      SCAN_COL
              	
0385:         	SCAN_NONE:
0385: 3EFF    	    LD      A, 0xFF
0387: D340    	    OUT     (KEYBOARD), A
0389: B7      	    OR      A                   ; Limpa Carry
038A: C9      	    RET
              	
              	
              	    
              	    
              	    
              	#include "GLCD.asm"
              	; Graphical LCD 128 x 64 Library
              	; ------------------------------
              	; By B. Chiha May-2023
              	; Modificações para funcionar no Z80 Mini - 2026
              	;
              	; This is a native Z80 Graphics library to be used with 128x64 Graphical LCD Screens
              	;
              	; There are a few variants of these LCD screens, but they must all must use the ST7920
              	; LCD Controller.  The LCD Screen that I used is the QC12864B.  This screen has two
              	; ST7921 Panels (128 x 32) stacked one above the other.
              	;
              	; These screens have DDRAM (Graphics) and CGRAM (Text) areas.  Both RAM areas can 
              	; be displayed at the same time.
              	;
              	; The Pinout for the QC12864B board is as follows:
              	;
              	; Pin	Name	Desc                    Serial  Parallel
              	; ---   ----    -------------           ------  -------------
              	; 1     VSS     Ground                  GND     GND
              	; 2     VDD     Power                   5v      5v
              	; 3     V0      Contrast                N/A     N/A
              	; 4     D/I     IR/DR (CS)              5v      A7
              	; 5     R/W     R/W (SID)               D0      RD (inverted)
              	; 6     E       Enable (SCLK)           D1      Port 7 (inverted)
              	; 7     DB0     Data                    N/A     D0
              	; 8     DB1     Data                    N/A     D1
              	; 9     DB2     Data                    N/A     D2
              	; 10    DB3     Data                    N/A     D3
              	; 11    DB4     Data                    N/A     D4
              	; 12    DB5     Data                    N/A     D5
              	; 13    DB6     Data                    N/A     D6
              	; 14    DB7     Data                    N/A     D7
              	; 15    PSB     Serial/Para             GND     5v
              	; 16    NC
              	; 17    RST     Reset                   RST     RST
              	; 18    VEE     LCD Drive               N/A     N/A
              	; 19    A       Backlight               5v/NC   5v/NC
              	; 20    K       Backlight               GND/NC  GND/NC
              	;
              	;
              	        
              	        
              	; Modifiable values.  Thse three values can be modified to suit your own set up
              	; GLCD_INST and GLCD_DATA are the output ports to send an Instruction or Data value.
              	; V_DELAY_US is the minimum delay needed for a command to be processed by the
              	; LCD board.  If only some of the data is being sent, make this value larger
              	        
              	;Port 7 on TEC is connected to LCD Enable (Pin 6)
              	;A7 is connected to Register select (Pin 4).  (A7=0 for Instruction, A7=1 for Data)
0010:         	V_DELAY_US: .equ $0010   ;Delay for 76us on your system
              	
              	; Dont need to modify anything else below.
00F8:         	UP:     .equ $F8                 ; Up Arrow
00F7:         	DN:     .equ $F7                 ; Down Arrow
000C:         	FF:     .equ 0CH                 ; Form Feed
008F:         	CURSOR: .equ 8FH                 ; Cursor
              	        
              	
              	
              	
              	
              	; --- CONOUT: Envia byte em A ---
038B:         	PUTCHAR:
038B:         	CONOUT:
038B: F5      	        PUSH AF
038C: C5      	        PUSH BC
038D: D5      	        PUSH DE
038E: E5      	        PUSH HL
038F: CDF206  	        CALL sendCharToLCD
0392: E1      	        POP HL
0393: D1      	        POP DE
0394: C1      	        POP BC
0395: F1      	        POP AF
0396: C9      	        RET
              	
              	
              	; --- PUTS: Envia string terminada em NUL apontada por HL ---
0397:         	PUTS:
0397: F5      	        PUSH AF
0398: C5      	        PUSH BC
0399: D5      	        PUSH DE
039A: E5      	        PUSH HL
039B: 545D    	        LD DE, HL
039D: 3E00    	        LD A, NUL
039F: CD6207  	        CALL sendStringToLCD
03A2: E1      	        POP HL
03A3: D1      	        POP DE
03A4: C1      	        POP BC
03A5: F1      	        POP AF
03A6: C9      	        RET
              	
              	; --- CRLF: Envia CR+LF ---
03A7:         	CRLF:
03A7: 3E0D    	        LD   A, CR
03A9: CD8B03  	        CALL PUTCHAR
03AC: C9      	        RET
              	
              	
              	
              	; Initialise LCD
03AD:         	initLCD:
03AD: 213C09  	        LD HL, INIT_BASIC       ;POINT HL TO LCD INITIALIZE TABLE
03B0: 0604    	        LD B, 04H               ;B=4 BYTES
03B2:         	NEXT_CMD:
03B2: 7E      	        LD A, (HL)
03B3: D370    	        OUT (GLCD_INST), A
03B5: CDAF06  	        CALL delayUS
03B8: 23      	        INC HL
03B9: 10F7    	        DJNZ NEXT_CMD
03BB: 114001  	        LD DE, 0140H            ;1.6 ms
03BE: CDB206  	        CALL delayMS
              	        
03C1: 2184F7  	        LD HL,GBUF              ;Set viewport
03C4: 2284FB  	        LD (VPORT),HL           ;to GBUF
              	
03C7: CDDA03  	        CALL clearGrLCD
              	        
              	; Clears the Graphics Memory Buffer
03CA:         	clearGBUF:
03CA: 2A84FB  	        LD HL, (VPORT)
03CD: ED5B84FB	        LD DE, (VPORT)
03D1: 13      	        INC DE
03D2: AF      	        XOR A
03D3: 77      	        LD (HL), A
03D4: 01FF03  	        LD BC, 03FFH
03D7: EDB0    	        LDIR
03D9: C9      	        RET
              	        
              	; Clears the Graphics LCD Buffer
03DA:         	clearGrLCD:
03DA: CD1A04  	        CALL setGrMode
03DD: 0E00    	        LD C, 00H
03DF:         	CLR_X:
03DF: 3E80    	        LD A, 80H
03E1: B1      	        OR C
03E2: D370    	        OUT (GLCD_INST), A
03E4: CDAF06  	        CALL delayUS
03E7: 3E80    	        LD A, 80H
03E9: D370    	        OUT (GLCD_INST), A
03EB: CDAF06  	        CALL delayUS
03EE: AF      	        XOR A                   ;Clear Byte
03EF: 0610    	        LD B, 10H
03F1:         	CLR_Y:
03F1: D371    	        OUT (GLCD_DATA), A
03F3: CDAF06  	        CALL delayUS
03F6: D371    	        OUT (GLCD_DATA), A
03F8: CDAF06  	        CALL delayUS
03FB: 10F4    	        DJNZ CLR_Y
03FD: 0C      	        INC C
03FE: 79      	        LD A, C
03FF: FE20    	        CP 20H
0401: 20DC    	        JR NZ, CLR_X        
0403: C9      	        RET
              	
              	; Clears the ASCII Text LCD
0404:         	clearTxtLCD:
0404: CD2804  	        CALL setTxtMode
0407: 3E80    	        LD A, 80H
0409: D370    	        OUT (GLCD_INST), A
040B: CDAF06  	        CALL delayUS
040E: 0640    	        LD B, 40H
0410:         	CLR_ROWS:
0410: 3E20    	        LD A,  " "
0412: D371    	        OUT (GLCD_DATA), A
0414: CDAF06  	        CALL delayUS
0417: 10F7    	        DJNZ CLR_ROWS
0419: C9      	        RET
              	        
              	; Set Graphics Mode
041A:         	setGrMode:
041A: 3E34    	        LD A, 34H
041C: D370    	        OUT (GLCD_INST), A
041E: CDAF06  	        CALL delayUS
0421: 3E36    	        LD A, 36H
0423: D370    	        OUT (GLCD_INST), A
0425: C3AF06  	        JP delayUS
              	        
              	; Set Text Mode
0428:         	setTxtMode:
0428: 3E30    	        LD A, 30H
042A: D370    	        OUT (GLCD_INST), A
042C: C3AF06  	        JP delayUS
              	        
              	;Draw Box
              	;Inputs: BC = X0,Y0
              	;        DE = X1,Y1
              	;Destroys: HL
042F:         	drawBox:
042F: C5      	        PUSH BC
0430:         	TOP:
0430: CDEA05  	        CALL drawPixel
0433: 7A      	        LD A, D
0434: 04      	        INC B
0435: B8      	        CP B
0436: 30F8    	        JR NC, TOP
0438: C1      	        POP BC
              	        
0439: C5      	        PUSH BC
043A: 4B      	        LD C, E
043B:         	BOTTOM:
043B: CDEA05  	        CALL drawPixel
043E: 7A      	        LD A, D
043F: 04      	        INC B
0440: B8      	        CP B
0441: 30F8    	        JR NC, BOTTOM
0443: C1      	        POP BC
              	        
0444: C5      	        PUSH BC
0445:         	B_LEFT:
0445: CDEA05  	        CALL drawPixel
0448: 7B      	        LD A, E
0449: 0C      	        INC C
044A: B9      	        CP C
044B: 30F8    	        JR NC, B_LEFT
044D: C1      	        POP BC
              	        
044E: C5      	        PUSH BC
044F: 42      	        LD B, D
0450:         	B_RIGHT:
0450: CDEA05  	        CALL drawPixel
0453: 7B      	        LD A, E
0454: 0C      	        INC C
0455: B9      	        CP C
0456: 30F8    	        JR NC, B_RIGHT
0458: C1      	        POP BC
0459: C9      	        RET
              	        
              	;Fill Box
              	;Draws vertical lines from X0,Y0 to X0,Y1 and increase X0 to X1 until X0=X1
              	;Inputs: BC = X0,Y0
              	;        DE = X1,Y1
              	;Destroys: HL
045A:         	fillBox:
045A: C5      	        PUSH BC
045B:         	NEXT_PIXEL:
045B: CDEA05  	        CALL drawPixel
045E: 7B      	        LD A, E
045F: 0C      	        INC C
0460: B9      	        CP C
0461: 30F8    	        JR NC, NEXT_PIXEL
0463: C1      	        POP BC
0464: 7A      	        LD A, D
0465: 04      	        INC B
0466: B8      	        CP B
0467: 30F1    	        JR NC, fillBox
0469: C9      	        RET
              	        
              	;Draw a line between two points using Bresenham Line Algorithm
              	; void plotLine(int x0, int y0, int x1, int y1)
              	; {
              	;    int dx =  abs(x1-x0), sx = x0<x1 ? 1 : -1;
              	;    int dy = -abs(y1-y0), sy = y0<y1 ? 1 : -1;
              	;    int err = dx+dy, e2; /* error value e_xy */
              	        
              	;    for(;;){  /* loop */
              	;       setPixel(x0,y0);
              	;       if (x0==x1 && y0==y1) break;
              	;       e2 = 2*err;
              	;       if (e2 >= dy) { err += dy; x0 += sx; } /* e_xy+e_x > 0 */
              	;       if (e2 <= dx) { err += dx; y0 += sy; } /* e_xy+e_y < 0 */
              	;    }
              	; }
              	;Inputs: BC = X0,Y0
              	;        DE = X1,Y1
046A:         	drawLine:
              	;check that points are in range
046A: 79      	        LD A, C
046B: FE40    	        CP 40H
046D: D0      	        RET NC
046E: 78      	        LD A, B
046F: FE80    	        CP 80H
0471: D0      	        RET NC
0472: 7B      	        LD A, E
0473: FE40    	        CP 40H
0475: D0      	        RET NC
0476: 7A      	        LD A, D
0477: FE80    	        CP 80H
0479: D0      	        RET NC
              	        
              	;sx = x0<x1 ? 1 : -1
047A: 2601    	        LD H, 01H
047C: 78      	        LD A, B
047D: BA      	        CP D
047E: 3802    	        JR C, $ + 4
0480: 26FF    	        LD H, 0FFH
0482: 7C      	        LD A, H
0483: 328AFB  	        LD (SX), A
              	        
              	;sy = y0<y1 ? 1 : -1
0486: 2601    	        LD H, 01H
0488: 79      	        LD A, C
0489: BB      	        CP E
048A: 3802    	        JR C, $ + 4
048C: 26FF    	        LD H, 0FFH
048E: 7C      	        LD A, H
048F: 328BFB  	        LD (SY), A
              	        
0492: ED5388FB	        ld (ENDPT), DE
              	        
              	;dx =  abs(x1-x0)
0496: C5      	        PUSH BC
0497: 6A      	        LD L, D
0498: 2600    	        LD H, 0
049A: 48      	        LD C, B
049B: 0600    	        LD B, 0
049D: B7      	        OR A
049E: ED42    	        SBC HL, BC
04A0: CD0B05  	        CALL ABSHL
04A3: 228CFB  	        LD (DX), HL
04A6: C1      	        POP BC
              	        
              	;dy = -abs(y1-y0)
04A7: C5      	        PUSH BC
04A8: 6B      	        LD L, E
04A9: 2600    	        LD H, 0
04AB: 0600    	        LD B, 0
04AD: B7      	        OR A
04AE: ED42    	        SBC HL, BC
04B0: CD0B05  	        CALL ABSHL
04B3: AF      	        XOR A
04B4: 95      	        SUB L
04B5: 6F      	        LD L, A
04B6: 9F      	        SBC A, A
04B7: 94      	        SUB H
04B8: 67      	        LD H, A
04B9: 228EFB  	        LD (DY), HL
04BC: C1      	        POP BC
              	        
              	;err = dx+dy,
04BD: ED5B8CFB	        LD DE, (DX)
04C1: 19      	        ADD HL, DE
