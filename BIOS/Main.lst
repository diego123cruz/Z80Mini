10D0: CDF206  	            CALL sendCharToLCD
10D3: C9      	            RET
              	
              	; ============================================================
              	;  DUMP_CMD  -  Dump hex+ASCII
              	;  Sintaxe: DUMP xxxx
              	; ============================================================
10D4:         	DUMP_CMD:
              	            ; DE aponta para argumentos
10D4: CD4C13  	            CALL PARSE_HEX16_DE      ; HL = endereço
10D7: 3836    	            JR   C, DUMP_BAD_ADDR
10D9: 22FAFB  	            LD   (ADDR_TMP), HL
              	
10DC: 0608    	            LD   B, 8               ; 8 linhas de 5 bytes
              	
10DE:         	DUMP_LINE:
10DE: C5      	            PUSH BC
              	            ; Exibe endereço
10DF: 2AFAFB  	            LD   HL, (ADDR_TMP)
10E2: CDA313  	            CALL PRINT_HEX16
10E5: 3E3A    	            LD   A, ':'
10E7: CD8B03  	            CALL PUTCHAR
10EA: 3E20    	            LD   A, SPACE
10EC: CD8B03  	            CALL PUTCHAR
              	
              	            ; Exibe 16 bytes hex
10EF: 2AFAFB  	            LD   HL, (ADDR_TMP)
10F2: 0E05    	            LD   C, 5
10F4:         	DUMP_HEX:
10F4: 7E      	            LD   A, (HL)
10F5: CD8813  	            CALL PRINT_HEX8
10F8: 3E20    	            LD   A, SPACE
10FA: CD8B03  	            CALL PUTCHAR
10FD: 23      	            INC  HL
10FE: 0D      	            DEC  C
10FF: 20F3    	            JR   NZ, DUMP_HEX
              	
              	            ;CALL CRLF
              	            ; Avança endereço base
1101: 2AFAFB  	            LD   HL, (ADDR_TMP)
1104: 110500  	            LD   DE, 5
1107: 19      	            ADD  HL, DE
1108: 22FAFB  	            LD   (ADDR_TMP), HL
110B: C1      	            POP  BC
110C: 10D0    	            DJNZ DUMP_LINE
110E: C9      	            RET
              	
110F:         	DUMP_BAD_ADDR:
110F: 21D213  	            LD   HL, MSG_BAD_ADDR
1112: CD9703  	            CALL PUTS
1115: C9      	            RET
              	
              	; ============================================================
              	;  LOAD_CMD  -  Carrega bytes hex em endereço
              	;  Sintaxe: LOAD xxxx
              	;  Digitar pares hex separados por espaço; linha vazia encerra
              	; ============================================================
1116:         	LOAD_CMD:
1116: CD4C13  	            CALL PARSE_HEX16_DE
1119: 3848    	            JR   C, LOAD_BAD
111B: 22FAFB  	            LD   (ADDR_TMP), HL
111E: 21FC13  	            LD   HL, MSG_LOAD_HINT
1121: CD9703  	            CALL PUTS
              	
1124:         	LOAD_LOOP:
              	            ; Exibe endereço atual
1124: 2AFAFB  	            LD   HL, (ADDR_TMP)
1127: CDA313  	            CALL PRINT_HEX16
112A: 3E3A    	            LD   A, ':'
112C: CD8B03  	            CALL PUTCHAR
112F: 3E20    	            LD   A, SPACE
1131: CD8B03  	            CALL PUTCHAR
              	
1134: CD8912  	            CALL GETLINE             ; Lê linha
1137: 21A4FB  	            LD   HL, LINEBUF
113A: CDEB12  	            CALL SKIP_SPACES
              	
              	            ; Linha vazia = fim
113D: 7E      	            LD   A, (HL)
113E: FE0D    	            CP   CR
1140: C8      	            RET  Z
1141: FE00    	            CP   NUL
1143: C8      	            RET  Z
              	
              	            ; Processa pares hex na linha
1144:         	LOAD_BYTE:
1144: CD1A13  	            CALL PARSE_HEX8_HL       ; A = byte, HL avança
1147: 3818    	            JR   C, LOAD_NEXT_LINE
              	            ; Grava byte
1149: ED5BFAFB	            LD   DE, (ADDR_TMP)
114D: 12      	            LD   (DE), A
114E: 13      	            INC  DE
114F: ED53FAFB	            LD   (ADDR_TMP), DE
1153: CDF912  	            CALL SKIP_SPACES_HL
1156: 7E      	            LD   A, (HL)
1157: FE0D    	            CP   CR
1159: 28C9    	            JR   Z, LOAD_LOOP
115B: FE00    	            CP   NUL
115D: 28C5    	            JR   Z, LOAD_LOOP
115F: 18E3    	            JR   LOAD_BYTE
              	
1161:         	LOAD_NEXT_LINE:
1161: 18C1    	            JR   LOAD_LOOP
              	
1163:         	LOAD_BAD:
1163: 21D213  	            LD   HL, MSG_BAD_ADDR
1166: CD9703  	            CALL PUTS
1169: C9      	            RET
              	
              	; ============================================================
              	;  EDIT_CMD  -  Edita memória byte a byte
              	;  Sintaxe: EDIT xxxx
              	;  Exibe: XXXX: AA  _  (digitar novo valor ou Enter p/ manter)
              	;  '.' encerra
              	; ============================================================
116A:         	EDIT_CMD:
116A: CD4C13  	            CALL PARSE_HEX16_DE
116D: 3849    	            JR   C, EDIT_BAD
116F: 22FAFB  	            LD   (ADDR_TMP), HL
              	
1172:         	EDIT_LOOP:
1172: 2AFAFB  	            LD   HL, (ADDR_TMP)
1175: CDA313  	            CALL PRINT_HEX16
1178: 3E3A    	            LD   A, ':'
117A: CD8B03  	            CALL PUTCHAR
117D: 3E20    	            LD   A, SPACE
117F: CD8B03  	            CALL PUTCHAR
1182: 7E      	            LD   A, (HL)             ; Valor atual
1183: CD8813  	            CALL PRINT_HEX8
1186: 3E20    	            LD   A, SPACE
1188: CD8B03  	            CALL PUTCHAR
118B: 3E20    	            LD   A, SPACE
118D: CD8B03  	            CALL PUTCHAR
              	
              	            ; Lê até 3 chars (2 hex + CR)
1190: CD8912  	            CALL GETLINE
1193: 21A4FB  	            LD   HL, LINEBUF
1196: CDEB12  	            CALL SKIP_SPACES
              	
1199: 7E      	            LD   A, (HL)
119A: FE2E    	            CP   '.'                 ; '.' = sair
119C: C8      	            RET  Z
119D: FE0D    	            CP   CR
119F: 280E    	            JR   Z, EDIT_KEEP       ; Enter = mantém byte
11A1: FE00    	            CP   NUL
11A3: 280A    	            JR   Z, EDIT_KEEP
              	
              	            ; Tenta parsear novo byte
11A5: CD1A13  	            CALL PARSE_HEX8_HL
11A8: 38C8    	            JR   C, EDIT_LOOP       ; Hex inválido: repete
              	
              	            ; Grava novo byte
11AA: ED5BFAFB	            LD   DE, (ADDR_TMP)
11AE: 12      	            LD   (DE), A
              	
11AF:         	EDIT_KEEP:
11AF: 2AFAFB  	            LD   HL, (ADDR_TMP)
11B2: 23      	            INC  HL
11B3: 22FAFB  	            LD   (ADDR_TMP), HL
11B6: 18BA    	            JR   EDIT_LOOP
              	
11B8:         	EDIT_BAD:
11B8: 21D213  	            LD   HL, MSG_BAD_ADDR
11BB: CD9703  	            CALL PUTS
11BE: C9      	            RET
              	
              	; ============================================================
              	;  OUT_CMD  -  Escreve byte em porta de I/O
