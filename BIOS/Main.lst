              	;------------------------------------------------------------------------------
              	; Pegar 2 caracteres ASCII (0-9 A-F) converte em um byte em A
              	;------------------------------------------------------------------------------
1F9E: CD5816  	SERIAL_GET_HEX_A:   CALL GETCHR_S	; Get us a valid character to work with
1FA1: 47      	    LD   B,A	; Load it in B
1FA2: CD5816  	    CALL GETCHR_S	; Get us another character
1FA5: 4F      	    LD   C,A	; load it in C
1FA6: CD7416  	    CALL BCTOA	; Convert ASCII to byte
1FA9: C9      	    RET
              	
              	;------------------------------------------------------------------------------
              	; Pegar 4 caracteres ASCII (0-9 A-F) converte em HL
              	;------------------------------------------------------------------------------
1FAA:         	SERIAL_GET_HEX_HL:
1FAA: CD9E1F  	    CALL SERIAL_GET_HEX_A	        ; Endereco High -> H
1FAD: 67      		LD   H,A
1FAE: CD9E1F  		CALL SERIAL_GET_HEX_A	        ; Endereco Low -> L
1FB1: 6F      		LD   L,A
1FB2: C9      	    RET
              	
              	
              	
