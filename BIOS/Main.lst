1CB2: 78      	    LD A, B
1CB3: E607    	    AND $07
1CB5: 3239FC  	    LD (FS_BMPADDR+1), A    ; bit_index
              	
1CB8: 78      	    LD A, B
1CB9: CB3F    	    SRL A
1CBB: CB3F    	    SRL A
1CBD: CB3F    	    SRL A
1CBF: 5F      	    LD E, A                 ; E = byte_index
              	
