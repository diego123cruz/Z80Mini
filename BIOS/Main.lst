              	; --- SKIP_SPACES_DE: Avança DE sobre espaços ---
12F2:         	SKIP_SPACES_DE:
12F2: 1A      	            LD   A, (DE)
12F3: FE20    	            CP   SPACE
12F5: C0      	            RET  NZ
12F6: 13      	            INC  DE
12F7: 18F9    	            JR   SKIP_SPACES_DE
              	
              	; --- SKIP_SPACES_HL: Avança HL sobre espaços ---
12F9:         	SKIP_SPACES_HL:
12F9: 7E      	            LD   A, (HL)
12FA: FE20    	            CP   SPACE
12FC: C0      	            RET  NZ
12FD: 23      	            INC  HL
12FE: 18F9    	            JR   SKIP_SPACES_HL
              	
              	; --- IS_HEX: testa se A é dígito hex; retorna dígito em A (0-15), CY se inválido ---
1300:         	IS_HEX:
1300: FE30    	            CP   '0'
1302: 3814    	            JR   C, IS_HEX_BAD
1304: FE3A    	            CP   '9'+1
1306: 380D    	            JR   C, IS_HEX_DIG      ; '0'-'9'
1308: E6DF    	            AND  0DFH               ; Uppercase
130A: FE41    	            CP   'A'
130C: 380A    	            JR   C, IS_HEX_BAD
130E: FE47    	            CP   'F'+1
1310: 3006    	            JR   NC, IS_HEX_BAD
1312: D637    	            SUB  'A'-10             ; 'A'→10 ... 'F'→15
1314: C9      	            RET
1315:         	IS_HEX_DIG:
1315: D630    	            SUB  '0'
1317: C9      	            RET
1318:         	IS_HEX_BAD:
1318: 37      	            SCF
1319: C9      	            RET
              	
              	; --- PARSE_HEX8_HL: parseia 2 dígitos hex em (HL), resultado em A; HL avança 2 ---
              	;     Carry = erro
131A:         	PARSE_HEX8_HL:
131A: 7E      	            LD   A, (HL)
131B: CD0013  	            CALL IS_HEX
131E: D8      	            RET  C
131F: 0F      	            RRCA
1320: 0F      	            RRCA
1321: 0F      	            RRCA
1322: 0F      	            RRCA
1323: E6F0    	            AND  0F0H
1325: 47      	            LD   B, A
1326: 23      	            INC  HL
1327: 7E      	            LD   A, (HL)
1328: CD0013  	            CALL IS_HEX
132B: 3803    	            JR   C, PHX8_ERR
132D: B0      	            OR   B
132E: 23      	            INC  HL
132F: C9      	            RET
1330:         	PHX8_ERR:
1330: 2B      	            DEC  HL
1331: 37      	            SCF
1332: C9      	            RET
              	
              	; --- PARSE_HEX8_DE: igual mas com DE ---
1333:         	PARSE_HEX8_DE:
1333: 1A      	            LD   A, (DE)
1334: CD0013  	            CALL IS_HEX
1337: D8      	            RET  C
1338: 0F      	            RRCA
1339: 0F      	            RRCA
133A: 0F      	            RRCA
133B: 0F      	            RRCA
133C: E6F0    	            AND  0F0H
133E: 47      	            LD   B, A
133F: 13      	            INC  DE
1340: 1A      	            LD   A, (DE)
1341: CD0013  	            CALL IS_HEX
1344: 3803    	            JR   C, PHX8D_ERR
1346: B0      	            OR   B
1347: 13      	            INC  DE
1348: C9      	            RET
1349:         	PHX8D_ERR:
1349: 1B      	            DEC  DE
134A: 37      	            SCF
134B: C9      	            RET
              	
              	; --- PARSE_HEX16_DE: parseia 4 dígitos hex em (DE), resultado em HL; DE avança 4 ---
134C:         	PARSE_HEX16_DE:
134C: CD3313  	            CALL PARSE_HEX8_DE
134F: D8      	            RET  C
1350: 67      	            LD   H, A
1351: CD3313  	            CALL PARSE_HEX8_DE
1354: D8      	            RET  C
1355: 6F      	            LD   L, A
1356: C9      	            RET
              	
              	; --- UPCASE_TOKEN: copia token de (HL) em maiúscula para HEXBUF; HL avança após token ---
1357:         	UPCASE_TOKEN:
1357: 11F4FB  	            LD   DE, HEXBUF
135A: 060A    	            LD   B, 10
135C:         	UPCASE_LOOP:
135C: 7E      	            LD   A, (HL)
135D: FE20    	            CP   SPACE
135F: 2817    	            JR   Z, UPCASE_DONE
1361: FE0D    	            CP   CR
1363: 2813    	            JR   Z, UPCASE_DONE
1365: FE00    	            CP   NUL
1367: 280F    	            JR   Z, UPCASE_DONE
1369: FE61    	            CP   'a'
136B: 3806    	            JR   C, UPCASE_STORE
136D: FE7B    	            CP   'z'+1
136F: 3002    	            JR   NC, UPCASE_STORE
1371: E6DF    	            AND  0DFH               ; Converte para maiúscula
1373:         	UPCASE_STORE:
1373: 12      	            LD   (DE), A
1374: 23      	            INC  HL
1375: 13      	            INC  DE
1376: 10E4    	            DJNZ UPCASE_LOOP
1378:         	UPCASE_DONE:
1378: 3E00    	            LD   A, NUL
137A: 12      	            LD   (DE), A
137B: C9      	            RET
              	
              	; --- STRCMP: compara (HL) com (DE), Z=1 se iguais ---
137C:         	STRCMP:
137C: 7E      	            LD   A, (HL)
137D: 47      	            LD   B, A
137E: 1A      	            LD   A, (DE)
137F: B8      	            CP   B
1380: C0      	            RET  NZ
1381: FE00    	            CP   NUL
1383: C8      	            RET  Z
1384: 23      	            INC  HL
1385: 13      	            INC  DE
1386: 18F4    	            JR   STRCMP
              	
              	; ============================================================
              	;  SUBROTINAS DE SAÍDA HEX
              	; ============================================================
              	
              	; --- PRINT_HEX8: Imprime byte em A como 2 dígitos hex ---
1388:         	PRINT_HEX8:
1388: F5      	            PUSH AF
1389: 0F      	            RRCA
138A: 0F      	            RRCA
138B: 0F      	            RRCA
138C: 0F      	            RRCA
138D: CD9513  	            CALL PRINT_NIBBLE
1390: F1      	            POP  AF
1391: CD9513  	            CALL PRINT_NIBBLE
1394: C9      	            RET
              	
1395:         	PRINT_NIBBLE:
1395: E60F    	            AND  0FH
1397: C630    	            ADD  A, '0'
1399: FE3A    	            CP   '9'+1
139B: 3802    	            JR   C, PN_DONE
139D: C607    	            ADD  A, 07H              ; 'A'-'9'-1
139F:         	PN_DONE:
139F: CD8B03  	            CALL PUTCHAR
13A2: C9      	            RET
              	
              	; --- PRINT_HEX16: Imprime HL como 4 dígitos hex ---
13A3:         	PRINT_HEX16:
13A3: 7C      	            LD   A, H
13A4: CD8813  	            CALL PRINT_HEX8
13A7: 7D      	            LD   A, L
13A8: CD8813  	            CALL PRINT_HEX8
13AB: C9      	            RET
              	
