              	; ============================================================
              	; KEYMAPS
              	; ============================================================
              	
              	;	$FF - Capsloock
              	;	$FE - Shift left
              	;	$FD - Ctrl left
              	;	$FC - Windows
              	;	$FB - Alt left
              	;	$FA - Alt Gr    (Load intel hex - Serial A)
              	;	$F9 - LUZ   (CALL 8000H)
              	;	$F8 - Shift Right   (Display Scroll UP)
              	;	$F7 - Ctrl Right    (Display Scroll DOWN)
              	;	$F6 - Fn
              	;	$F5 - 
              	;	$F4 - 
              	
019F:         	KEYMAP_NORMAL:
019F: 1B09FFFE	    DB  $1B,  $09,  $FF,  $FE,  $FD,  $FC,  $FB,  $20
01A3: FDFCFB20	
01A7: 3171615C	    DB   '1', 'q',  'a',  '\',  $00,  $FA,  $F6,  $F9
01AB: 00FAF6F9	
01AF: 33656478	    DB   '3', 'e',  'd',  'x',  ',',  'l',  'o',  '9'
01B3: 2C6C6F39	
01B7: 34726663	    DB   '4', 'r',  'f',  'c',  '.',  'ç',  'p',  '0'
01BB: 2EE77030	
01BF: 36796862	    DB   '6', 'y',  'h',  'b',  $F8,  $F7,  0x0D, 0x08
01C3: F8F70D08	
01C7: 35746776	    DB   '5', 't',  'g',  'v',  ';',  '~', 	'`',  '-'
01CB: 3B7E602D	
01CF: 37756A6E	    DB   '7', 'u',  'j',  'n',  '/',  ']',  '[',  '='
01D3: 2F5D5B3D	
01D7: 3277737A	    DB   '2', 'w',  's',  'z',  'm',  'k',  'i',  '8'
01DB: 6D6B6938	
              	    
01DF:         	KEYMAP_SHIFT:
01DF: 1B09FFFE	    DB  $1B,  $09,  $FF,  $FE,  $FD,  $FC,  $FB,  $20
01E3: FDFCFB20	
01E7: 2151417C	    DB   '!', 'Q',  'A',  '|',  $00,  $FA,  $F6,  $F9
01EB: 00FAF6F9	
01EF: 23454458	    DB   '#', 'E',  'D',  'X',  '<',  'L',  'O',  '('
01F3: 3C4C4F28	
01F7: 24524643	    DB   '$', 'R',  'F',  'C',  '>',  'Ç',  'P',  ')'
01FB: 3EC75029	
01FF: A8594842	    DB   '¨', 'Y',  'H',  'B',  $F8,  $F7,  0x0D, 0x08
0203: F8F70D08	
0207: 25544756	    DB   '%', 'T',  'G',  'V',  ':',  '^', 	$22,  '_'
020B: 3A5E225F	
020F: 26554A4E	    DB   '&', 'U',  'J',  'N',  '?',  '}',  '{',  '+'
0213: 3F7D7B2B	
0217: 4057535A	    DB   '@', 'W',  'S',  'Z',  'M',  'K',  'I',  '*'
021B: 4D4B492A	
              	
              	
021F:         	INICIO:
              	    ; Set defult I2C device addess: 24LC256 (Copy from/to Mem)
021F: 3EA0    	    LD A, EEDRIVE_A
0221: 32FDFB  	    LD (I2CA_BLOCK), A        
              	
              	    ;CALL FS_CHK_SIG
              	    ;JP Z, INICIO1
              	    ;LD HL, str_notfmt
              	    ;CALL PUTS
0224:         	INICIO1:
              	
0224: 31F0FF  	    LD SP, SYSTEM_SP
              	
0227: 116400  	    LD DE, $0064 ; 100ms
022A: CD7A02  	    CALL H_Delay
              	
              	    ;Init Serial
022D: CD2C0F  	    CALL initSerial
              	
              	    ;Init Teclado
0230: 3EFF    	    LD      A, 0xFF
0232: D340    	    OUT     (KEYBOARD), A           ; Todas as colunas desativadas
              	
              	    ; Init LCD
0234: CDB106  	    CALL initTerminal
0237: CD0604  	    CALL setGrMode
023A: CDAC06  	    CALL setBufNoClear
              	
              	
              	    ; Show init string
023D: 010000  	    LD BC, $0000
0240: CD9E07  	    CALL setCursor
0243: 11C91F  	    LD DE, WELLCOME_LCD
              	    ; set cursor ON
0246: 3E00    	    LD A, 0
0248: 3294FB  	    LD (CURSOR_ON), A
              	    ; send cursor
024B: CD4E07  	    CALL sendStringToLCD
              	
              	
024E:         	MAIN_LOOP:
024E: CD5A02  	    CALL showCurrentDriver
              	
0251: CD7612  	    CALL GETLINE             ; Lê linha em LINEBUF
0254: CDC70F  	    CALL PARSE_CMD           ; Interpreta e executa
              	
0257: C34E02  	    JP      MAIN_LOOP
              	
              	
025A:         	showCurrentDriver:
025A: 3AFDFB  	    LD A, (I2CA_BLOCK)
025D: FEA0    	    CP EEDRIVE_A  ; Drive A
025F: 2805    	    JR Z, showDriveA
0261: FEAE    	    CP EEDRIVE_B  ; Drive B
0263: 2808    	    JR Z, showDriveB
0265: C9      	    RET
0266:         	showDriveA:
0266: 3E41    	    LD A, 'A'
0268: CDDE06  	    CALL sendCharToLCD
026B: 1807    	    JR showCursor
026D:         	showDriveB:
026D: 3E42    	    LD A, 'B'
026F: CDDE06  	    CALL sendCharToLCD
0272: 1800    	    JR showCursor
0274:         	showCursor:
0274: 3E3A    	    LD A, ':'
0276: CDDE06  	    CALL sendCharToLCD
0279: C9      	    RET
              	
              	
              	
              	
              	; **********************************************************************
              	; Delay by DE milliseconds
              	;   On entry: DE = Delay time in milliseconds
              	;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved
027A: F5      	H_Delay:    PUSH AF
027B: C5      	            PUSH BC
027C: D5      	            PUSH DE
              	; 1 ms loop, DE times...        ;[=36]   [=29]    Overhead for each 1ms
027D: 011A01  	LoopDE:    LD   BC, kDelayCnt   ;[10]    [9]
              	; Inner loop, BC times...       ;[=26]   [=20]    Loop time in Tcycles
0280: 0B      	LoopBC:    DEC  BC             ;[6]     [4]
0281: 79      	            LD   A,C            ;[4]     [4]
0282: B0      	            OR   B              ;[4]     [4]
0283: C28002  	            JP   NZ,LoopBC     ;[12/7]  [8/6] 
              	; Have we looped once for each millisecond requested?
0286: 1B      	            DEC  DE             ;[6]     [4]
0287: 7B      	            LD   A,E            ;[4]     [4]
0288: B2      	            OR   D              ;[4]     [4]
0289: 20F2    	            JR   NZ, LoopDE     ;[12/7]  [8/6]
028B: D1      	            POP  DE
028C: C1      	            POP  BC
028D: F1      	            POP  AF
028E: C9      	            RET
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	#include "TECLADO.asm"
0016:         	DB_OUTER    EQU     22          ; iterações externas
00F0:         	DB_INNER    EQU     240         ; iterações DJNZ internas
              	
              	
              	; -----------------------------------------------------------------------------
              	;   Check break key (Basic)
              	;       On exit: If press A = CTRLC and NZ flagged
              	;       BC DE HL preserved
              	; -----------------------------------------------------------------------------
028F:         	CHKKEY:
028F: 3EFE    	    LD      A, 0xFE             ; Máscara: bit 0 baixo = col 0
0291: D340    	    OUT     (KEYBOARD), A       ; Ativa coluna B
0293: 00      	    NOP                         ; ~270 ns de estabilização
0294: 00      	    NOP
0295: 00      	    NOP
0296: 00      	    NOP
0297: DB40    	    IN      A, (KEYBOARD)       ; Lê linhas
0299: 2F      	    CPL                         ; Pull-up: inverte (pressionado = 1)
029A: FE01    	    CP 1
029C: C2A402  	    jp nz, GRET
029F: 3E03    		LD  A, CTRLC
02A1: FE00    		CP	0
02A3: C9      		RET
02A4:         	GRET:
02A4: 3E00    		LD  A, 0
02A6: FE00    		CP 0
02A8: C9      		RET
              	
              	
              	;   CONIN: Lê um teclado → A
              	;       On exit: A = KEY
              	;       BC DE HL preserved
              	;       loop until key is pressed 
02A9:         	CONIN:
02A9: C5      	    PUSH BC
02AA: D5      	    PUSH DE
02AB: E5      	    PUSH HL
02AC: CDEC02  	    CALL readKeyboarWaitPressA
02AF: E1      	    POP HL
02B0: D1      	    POP DE
02B1: C1      	    POP BC
02B2: C9      	    RET
              	
              	
              	
              	;   CONIN: Lê um teclado → A
              	;       On exit: A = KEY
              	;       BC DE HL preserved
              	;       sem loop, Carry=1 se tecla
02B3:         	CONIN_NOT_LOOP:
02B3: C5      	    PUSH BC
02B4: D5      	    PUSH DE
02B5: E5      	    PUSH HL
02B6: CDBD02  	    CALL readKeyboarPressA
02B9: E1      	    POP HL
02BA: D1      	    POP DE
02BB: C1      	    POP BC
02BC: C9      	    RET
              	
              	
02BD:         	readKeyboarPressA;
02BD: AF      	    XOR A
02BE: 329EFB  	    LD (MEN_SHIFT), A ; reset shift
02C1: CD2A03  	    CALL    SCAN_MATRIX
02C4: D0      	    RET      NC
02C5: CDD002  	    CALl GetKeycode
02C8: CDD602  	    CALL checkShiftKey
02CB: 3A9FFB  	    LD A, (KEY_PRESS)
02CE: 37      	    SCF  ; Carry = 1
02CF: C9      	    RET
              	
              	
              	
              	; A = col*8 + row  (0x00 – 0x3F)
02D0:         	GetKeycode:
              	    ; --- Tecla confirmada: calcula keycode ---
              	    ; col*8 + row  (0x00 – 0x3F)
02D0: 78      	    LD      A, B                ; B = coluna
02D1: 87      	    ADD     A, A                ; ×2
02D2: 87      	    ADD     A, A                ; ×4
02D3: 87      	    ADD     A, A                ; ×8
02D4: 81      	    ADD     A, C                ; + linha (C) = keycode
02D5: C9      	    RET
              	
              	
              	; Verifica se shift e recupera ascii
              	;   Salva tecla em KEY_PRESS
02D6:         	checkShiftKey:
              	    ; Verifica Shift
02D6: 5F      	    LD E, A
02D7: 219F01  	    LD HL, KEYMAP_NORMAL
02DA: 3A9EFB  	    LD A, (MEN_SHIFT)
02DD: FE01    	    CP 1
02DF: C2E502  	    JP NZ, NO_SHIFT
02E2: 21DF01  	    LD HL, KEYMAP_SHIFT
02E5:         	NO_SHIFT:
02E5: CD2503  	    CALL 	DO_LOOKUP	; pega tecla
02E8: 329FFB  	    LD (KEY_PRESS), A
02EB: C9      	    RET
              	
              	
              	
              	; LER TECLADO
              	; Aguarda até uma teclad for pressionada e retorna em A
02EC:         	readKeyboarWaitPressA:
02EC: CD2A03  	    CALL    SCAN_MATRIX
02EF: D2EC02  	    JP      NC, readKeyboarWaitPressA       ; Nenhuma tecla, continua
              	
              	    ; --- Primeira leitura positiva: aguarda debounce ---
02F2: CD1903  	    CALL    DEBOUNCE
              	
              	    ; --- Confirma que a tecla ainda está pressionada ---
02F5: AF      	    XOR A
02F6: 329EFB  	    LD (MEN_SHIFT), A ; reset shift
02F9: CD2A03  	    CALL    SCAN_MATRIX
02FC: D2EC02  	    JP      NC, readKeyboarWaitPressA       ; Foi ruído, descarta
              	
02FF: CDD002  	    CALL GetKeycode
              	    
0302: CDD602  	    CALL checkShiftKey
              	    
              	    ; --- Aguarda soltar + debounce de release ---
0305:         	WAIT_RELEASE:
0305: CD2A03  	    CALL    SCAN_MATRIX
0308: DA0503  	    JP      C, WAIT_RELEASE     ; Ainda pressionada
030B: CD1903  	    CALL    DEBOUNCE            ; Debounce do soltar
030E: CD2A03  	    CALL    SCAN_MATRIX
0311: DA0503  	    JP      C, WAIT_RELEASE     ; Bounce no release, volta a esperar
              	
0314: 3A9FFB  	    LD A, (KEY_PRESS)
0317: B7      	    OR A
0318: C9      	    RET
              	
              	
              	
              	
              	
              	
              	; ============================================================
              	; DEBOUNCE  –  espera ~10 ms (calibrado para 7.3728 MHz)
              	;   Usa DE como contador, preserva BC
              	;   T-states totais ≈ 69.080  →  ~9.36 ms
              	; ============================================================
0319:         	DEBOUNCE:
0319: C5      	    PUSH    BC
031A: 0616    	    LD      B, DB_OUTER         ; B = contador externo
031C:         	DB_OUTER_LOOP:
031C: 0EF0    	    LD      C, DB_INNER         ; C = contador interno
031E:         	DB_INNER_LOOP:
031E: 0D      	    DEC     C                   ; 4 T
031F: 20FD    	    JR      NZ, DB_INNER_LOOP   ; 12 T (não salta) / 7 T (salta)
0321: 10F9    	    DJNZ    DB_OUTER_LOOP       ; 13 T (não salta) / 8 T (salta)
0323: C1      	    POP     BC
0324: C9      	    RET
              	
              	
              	; Pega char in table
0325:         	DO_LOOKUP:
0325: 1600    	    LD      D, 0
0327: 19      	    ADD     HL, DE
0328: 7E      	    LD      A, (HL)
0329: C9      	    RET
              	
              	
              	; ============================================================
              	; SCAN_MATRIX
              	;   Varre 8 colunas, uma por vez (bit baixo = ativo)
              	;   Saída: B = col (0-7), C = row (0-7), Carry=1 se tecla
              	; ============================================================
032A:         	SCAN_MATRIX:
032A: 0600    	    LD      B, 0                ; Coluna atual
032C: 16FE    	    LD      D, 0xFE             ; Máscara: bit 0 baixo = col 0
032E:         	SCAN_COL:
032E: 7A      	    LD      A, D
032F: D340    	    OUT     (KEYBOARD), A       ; Ativa coluna B
0331: 00      	    NOP                         ; ~270 ns de estabilização
0332: 00      	    NOP
0333: 00      	    NOP
0334: 00      	    NOP
0335: DB40    	    IN      A, (KEYBOARD)       ; Lê linhas
0337: 2F      	    CPL                         ; Pull-up: inverte (pressionado = 1)
              	    
              	    ; SHIFT
0338: F5      	    PUSH AF
0339: 7A      	    LD A, D
033A: FEFE    	    CP $FE
033C: C24F03  	    JP NZ, FIM
033F: F1      	    POP AF
0340: F5      	    PUSH AF
0341: FE08    	    CP $08
0343: C24F03  	    JP NZ, FIM
0346: 3E01    	    LD A, 1
0348: 329EFB  	    LD (MEN_SHIFT), A
034B: F1      	    POP AF
034C: 3E00    	    LD A, 0
034E: F5      	    PUSH AF
              	    
034F:         	FIM:
034F: F1      		POP AF
              	    
0350: E6FF    	    AND     0xFF
0352: 280E    	    JR      Z, NEXT_COL         ; Nenhuma linha nesta coluna
              	    
              	    ; Encontrou linha — identifica bit
0354: 0E00    	    LD      C, 0
0356:         	FIND_ROW:
0356: 1F      	    RRA
0357: 3803    	    JR      C, ROW_FOUND
0359: 0C      	    INC     C
035A: 18FA    	    JR      FIND_ROW
              	
035C:         	ROW_FOUND:
035C: 3EFF    	    LD      A, 0xFF
035E: D340    	    OUT     (KEYBOARD), A           ; Desativa colunas
0360: 37      	    SCF                         ; Carry = 1
0361: C9      	    RET
              	
0362:         	NEXT_COL:
0362: 04      	    INC     B
0363: 78      	    LD      A, B
0364: FE08    	    CP      8
0366: 2809    	    JR      Z, SCAN_NONE        ; Todas varridas, nada encontrado
              	
              	    ; Rotaciona máscara para próxima coluna
0368: 7A      	    LD      A, D
0369: 37      	    SCF
036A: CB17    	    RL      A                   ; Desloca bit baixo para esquerda
036C: F601    	    OR      0x01                ; Garante que o bit 0 volta alto (inativo)
036E: 57      	    LD      D, A
036F: 18BD    	    JR      SCAN_COL
              	
0371:         	SCAN_NONE:
0371: 3EFF    	    LD      A, 0xFF
0373: D340    	    OUT     (KEYBOARD), A
0375: B7      	    OR      A                   ; Limpa Carry
0376: C9      	    RET
              	
              	
              	    
              	    
              	    
              	#include "GLCD.asm"
              	; Graphical LCD 128 x 64 Library
              	; ------------------------------
              	; By B. Chiha May-2023
              	; Modificações para funcionar no Z80 Mini - 2026
              	;
              	; This is a native Z80 Graphics library to be used with 128x64 Graphical LCD Screens
              	;
              	; There are a few variants of these LCD screens, but they must all must use the ST7920
              	; LCD Controller.  The LCD Screen that I used is the QC12864B.  This screen has two
              	; ST7921 Panels (128 x 32) stacked one above the other.
              	;
              	; These screens have DDRAM (Graphics) and CGRAM (Text) areas.  Both RAM areas can 
              	; be displayed at the same time.
              	;
              	; The Pinout for the QC12864B board is as follows:
              	;
              	; Pin	Name	Desc                    Serial  Parallel
              	; ---   ----    -------------           ------  -------------
              	; 1     VSS     Ground                  GND     GND
              	; 2     VDD     Power                   5v      5v
              	; 3     V0      Contrast                N/A     N/A
              	; 4     D/I     IR/DR (CS)              5v      A7
              	; 5     R/W     R/W (SID)               D0      RD (inverted)
              	; 6     E       Enable (SCLK)           D1      Port 7 (inverted)
              	; 7     DB0     Data                    N/A     D0
              	; 8     DB1     Data                    N/A     D1
              	; 9     DB2     Data                    N/A     D2
              	; 10    DB3     Data                    N/A     D3
              	; 11    DB4     Data                    N/A     D4
              	; 12    DB5     Data                    N/A     D5
              	; 13    DB6     Data                    N/A     D6
              	; 14    DB7     Data                    N/A     D7
              	; 15    PSB     Serial/Para             GND     5v
              	; 16    NC
              	; 17    RST     Reset                   RST     RST
              	; 18    VEE     LCD Drive               N/A     N/A
              	; 19    A       Backlight               5v/NC   5v/NC
              	; 20    K       Backlight               GND/NC  GND/NC
              	;
              	;
              	        
              	        
              	; Modifiable values.  Thse three values can be modified to suit your own set up
              	; GLCD_INST and GLCD_DATA are the output ports to send an Instruction or Data value.
              	; V_DELAY_US is the minimum delay needed for a command to be processed by the
              	; LCD board.  If only some of the data is being sent, make this value larger
              	        
              	;Port 7 on TEC is connected to LCD Enable (Pin 6)
              	;A7 is connected to Register select (Pin 4).  (A7=0 for Instruction, A7=1 for Data)
0010:         	V_DELAY_US: .equ $0010   ;Delay for 76us on your system
              	
              	; Dont need to modify anything else below.
00F8:         	UP:     .equ $F8                 ; Up Arrow
00F7:         	DN:     .equ $F7                 ; Down Arrow
000C:         	FF:     .equ 0CH                 ; Form Feed
008F:         	CURSOR: .equ 8FH                 ; Cursor
              	        
              	
              	
              	
              	
              	; --- CONOUT: Envia byte em A ---
0377:         	PUTCHAR:
0377:         	CONOUT:
0377: F5      	        PUSH AF
0378: C5      	        PUSH BC
0379: D5      	        PUSH DE
037A: E5      	        PUSH HL
037B: CDDE06  	        CALL sendCharToLCD
037E: E1      	        POP HL
037F: D1      	        POP DE
0380: C1      	        POP BC
0381: F1      	        POP AF
0382: C9      	        RET
              	
              	
              	; --- PUTS: Envia string terminada em NUL apontada por HL ---
0383:         	PUTS:
0383: F5      	        PUSH AF
0384: C5      	        PUSH BC
0385: D5      	        PUSH DE
0386: E5      	        PUSH HL
0387: 545D    	        LD DE, HL
0389: 3E00    	        LD A, NUL
038B: CD4E07  	        CALL sendStringToLCD
038E: E1      	        POP HL
038F: D1      	        POP DE
0390: C1      	        POP BC
0391: F1      	        POP AF
0392: C9      	        RET
              	
              	; --- CRLF: Envia CR+LF ---
0393:         	CRLF:
0393: 3E0D    	        LD   A, CR
0395: CD7703  	        CALL PUTCHAR
0398: C9      	        RET
              	
              	
              	
              	; Initialise LCD
0399:         	initLCD:
0399: 212809  	        LD HL, INIT_BASIC       ;POINT HL TO LCD INITIALIZE TABLE
039C: 0604    	        LD B, 04H               ;B=4 BYTES
039E:         	NEXT_CMD:
039E: 7E      	        LD A, (HL)
039F: D370    	        OUT (GLCD_INST), A
03A1: CD9B06  	        CALL delayUS
03A4: 23      	        INC HL
03A5: 10F7    	        DJNZ NEXT_CMD
03A7: 114001  	        LD DE, 0140H            ;1.6 ms
03AA: CD9E06  	        CALL delayMS
              	        
03AD: 2180F7  	        LD HL,GBUF              ;Set viewport
03B0: 2280FB  	        LD (VPORT),HL           ;to GBUF
              	
03B3: CDC603  	        CALL clearGrLCD
              	        
              	; Clears the Graphics Memory Buffer
03B6:         	clearGBUF:
03B6: 2A80FB  	        LD HL, (VPORT)
03B9: ED5B80FB	        LD DE, (VPORT)
03BD: 13      	        INC DE
03BE: AF      	        XOR A
03BF: 77      	        LD (HL), A
03C0: 01FF03  	        LD BC, 03FFH
03C3: EDB0    	        LDIR
03C5: C9      	        RET
              	        
              	; Clears the Graphics LCD Buffer
03C6:         	clearGrLCD:
03C6: CD0604  	        CALL setGrMode
03C9: 0E00    	        LD C, 00H
03CB:         	CLR_X:
03CB: 3E80    	        LD A, 80H
03CD: B1      	        OR C
03CE: D370    	        OUT (GLCD_INST), A
03D0: CD9B06  	        CALL delayUS
03D3: 3E80    	        LD A, 80H
03D5: D370    	        OUT (GLCD_INST), A
03D7: CD9B06  	        CALL delayUS
03DA: AF      	        XOR A                   ;Clear Byte
03DB: 0610    	        LD B, 10H
03DD:         	CLR_Y:
03DD: D371    	        OUT (GLCD_DATA), A
03DF: CD9B06  	        CALL delayUS
03E2: D371    	        OUT (GLCD_DATA), A
03E4: CD9B06  	        CALL delayUS
03E7: 10F4    	        DJNZ CLR_Y
03E9: 0C      	        INC C
03EA: 79      	        LD A, C
03EB: FE20    	        CP 20H
03ED: 20DC    	        JR NZ, CLR_X        
03EF: C9      	        RET
              	
              	; Clears the ASCII Text LCD
03F0:         	clearTxtLCD:
03F0: CD1404  	        CALL setTxtMode
03F3: 3E80    	        LD A, 80H
03F5: D370    	        OUT (GLCD_INST), A
03F7: CD9B06  	        CALL delayUS
03FA: 0640    	        LD B, 40H
03FC:         	CLR_ROWS:
03FC: 3E20    	        LD A,  " "
03FE: D371    	        OUT (GLCD_DATA), A
0400: CD9B06  	        CALL delayUS
0403: 10F7    	        DJNZ CLR_ROWS
0405: C9      	        RET
              	        
              	; Set Graphics Mode
0406:         	setGrMode:
0406: 3E34    	        LD A, 34H
0408: D370    	        OUT (GLCD_INST), A
040A: CD9B06  	        CALL delayUS
040D: 3E36    	        LD A, 36H
040F: D370    	        OUT (GLCD_INST), A
0411: C39B06  	        JP delayUS
              	        
              	; Set Text Mode
0414:         	setTxtMode:
0414: 3E30    	        LD A, 30H
0416: D370    	        OUT (GLCD_INST), A
0418: C39B06  	        JP delayUS
              	        
              	;Draw Box
              	;Inputs: BC = X0,Y0
              	;        DE = X1,Y1
              	;Destroys: HL
041B:         	drawBox:
041B: C5      	        PUSH BC
041C:         	TOP:
041C: CDD605  	        CALL drawPixel
041F: 7A      	        LD A, D
0420: 04      	        INC B
0421: B8      	        CP B
0422: 30F8    	        JR NC, TOP
0424: C1      	        POP BC
              	        
0425: C5      	        PUSH BC
0426: 4B      	        LD C, E
0427:         	BOTTOM:
0427: CDD605  	        CALL drawPixel
042A: 7A      	        LD A, D
042B: 04      	        INC B
042C: B8      	        CP B
042D: 30F8    	        JR NC, BOTTOM
042F: C1      	        POP BC
              	        
0430: C5      	        PUSH BC
0431:         	B_LEFT:
0431: CDD605  	        CALL drawPixel
0434: 7B      	        LD A, E
0435: 0C      	        INC C
0436: B9      	        CP C
0437: 30F8    	        JR NC, B_LEFT
0439: C1      	        POP BC
              	        
043A: C5      	        PUSH BC
043B: 42      	        LD B, D
043C:         	B_RIGHT:
043C: CDD605  	        CALL drawPixel
043F: 7B      	        LD A, E
0440: 0C      	        INC C
0441: B9      	        CP C
0442: 30F8    	        JR NC, B_RIGHT
0444: C1      	        POP BC
0445: C9      	        RET
              	        
              	;Fill Box
              	;Draws vertical lines from X0,Y0 to X0,Y1 and increase X0 to X1 until X0=X1
              	;Inputs: BC = X0,Y0
              	;        DE = X1,Y1
              	;Destroys: HL
0446:         	fillBox:
0446: C5      	        PUSH BC
0447:         	NEXT_PIXEL:
0447: CDD605  	        CALL drawPixel
044A: 7B      	        LD A, E
044B: 0C      	        INC C
044C: B9      	        CP C
044D: 30F8    	        JR NC, NEXT_PIXEL
044F: C1      	        POP BC
0450: 7A      	        LD A, D
0451: 04      	        INC B
0452: B8      	        CP B
0453: 30F1    	        JR NC, fillBox
0455: C9      	        RET
              	        
              	;Draw a line between two points using Bresenham Line Algorithm
              	; void plotLine(int x0, int y0, int x1, int y1)
              	; {
              	;    int dx =  abs(x1-x0), sx = x0<x1 ? 1 : -1;
              	;    int dy = -abs(y1-y0), sy = y0<y1 ? 1 : -1;
              	;    int err = dx+dy, e2; /* error value e_xy */
              	        
              	;    for(;;){  /* loop */
              	;       setPixel(x0,y0);
              	;       if (x0==x1 && y0==y1) break;
              	;       e2 = 2*err;
              	;       if (e2 >= dy) { err += dy; x0 += sx; } /* e_xy+e_x > 0 */
              	;       if (e2 <= dx) { err += dx; y0 += sy; } /* e_xy+e_y < 0 */
              	;    }
              	; }
              	;Inputs: BC = X0,Y0
              	;        DE = X1,Y1
0456:         	drawLine:
              	;check that points are in range
0456: 79      	        LD A, C
0457: FE40    	        CP 40H
0459: D0      	        RET NC
045A: 78      	        LD A, B
045B: FE80    	        CP 80H
045D: D0      	        RET NC
045E: 7B      	        LD A, E
045F: FE40    	        CP 40H
0461: D0      	        RET NC
0462: 7A      	        LD A, D
0463: FE80    	        CP 80H
0465: D0      	        RET NC
              	        
              	;sx = x0<x1 ? 1 : -1
0466: 2601    	        LD H, 01H
0468: 78      	        LD A, B
0469: BA      	        CP D
046A: 3802    	        JR C, $ + 4
046C: 26FF    	        LD H, 0FFH
046E: 7C      	        LD A, H
046F: 3286FB  	        LD (SX), A
              	        
              	;sy = y0<y1 ? 1 : -1
0472: 2601    	        LD H, 01H
0474: 79      	        LD A, C
0475: BB      	        CP E
0476: 3802    	        JR C, $ + 4
0478: 26FF    	        LD H, 0FFH
047A: 7C      	        LD A, H
047B: 3287FB  	        LD (SY), A
              	        
047E: ED5384FB	        ld (ENDPT), DE
              	        
              	;dx =  abs(x1-x0)
0482: C5      	        PUSH BC
0483: 6A      	        LD L, D
0484: 2600    	        LD H, 0
0486: 48      	        LD C, B
0487: 0600    	        LD B, 0
0489: B7      	        OR A
048A: ED42    	        SBC HL, BC
048C: CDF704  	        CALL ABSHL
048F: 2288FB  	        LD (DX), HL
0492: C1      	        POP BC
              	        
              	;dy = -abs(y1-y0)
0493: C5      	        PUSH BC
0494: 6B      	        LD L, E
0495: 2600    	        LD H, 0
0497: 0600    	        LD B, 0
0499: B7      	        OR A
049A: ED42    	        SBC HL, BC
049C: CDF704  	        CALL ABSHL
049F: AF      	        XOR A
04A0: 95      	        SUB L
04A1: 6F      	        LD L, A
04A2: 9F      	        SBC A, A
04A3: 94      	        SUB H
04A4: 67      	        LD H, A
04A5: 228AFB  	        LD (DY), HL
04A8: C1      	        POP BC
              	        
              	;err = dx+dy,
04A9: ED5B88FB	        LD DE, (DX)
04AD: 19      	        ADD HL, DE
04AE: 228CFB  	        LD (ERR), HL
              	        
04B1:         	LINE_LOOP:
              	;setPixel(x0,y0)
04B1: CDD605  	        CALL drawPixel
              	        
              	;if (x0==x1 && y0==y1) break;
04B4: 3A85FB  	        LD A, (ENDPT + 1)
04B7: B8      	        CP B
04B8: 2005    	        JR NZ, $ + 7
04BA: 3A84FB  	        LD A, (ENDPT)
04BD: B9      	        CP C
04BE: C8      	        RET Z
              	        
              	;e2 = 2*err;
04BF: 2A8CFB  	        LD HL, (ERR)
04C2: 29      	        ADD HL, HL              ;E2
              	        
              	;if (e2 >= dy)  err += dy; x0 += sx;
04C3: ED5B8AFB	        LD DE, (DY)
04C7: B7      	        OR A
04C8: ED52    	        SBC HL, DE
04CA: 19      	        ADD HL, DE
04CB: FADC04  	        JP M, LL2
              	        
04CE: E5      	        PUSH HL
04CF: 2A8CFB  	        LD HL, (ERR)
04D2: 19      	        ADD HL, DE
04D3: 228CFB  	        LD (ERR), HL
04D6: 3A86FB  	        LD A, (SX)
04D9: 80      	        ADD A, B
04DA: 47      	        LD B, A
04DB: E1      	        POP HL
              	        
04DC:         	LL2:
              	;if (e2 <= dx)  err += dx; y0 += sy;
04DC: ED5B88FB	        LD DE, (DX)
04E0: B7      	        OR A
04E1: ED52    	        SBC HL, DE
04E3: 19      	        ADD HL, DE
