              	#include "IHEX.asm"
              	
              	
1550:         	loadInit:
1550: 3EFF    	    LD A, $FF
1552: 32F8FB  	    LD (LOAD_FIRST_FLAG), A
              	
1555: 211417  	    LD HL, MSG_LOAD_HELP
1558: CDB516  	    CALL SERIAL_A_PRINT_STRING
              	
155B: 111617  	    LD DE, MSG_LOAD_HELP_LCD
155E: CD4E07  	    CALL sendStringToLCD
              	
1561:         	loopHexLoad:
1561: CD9C0F  	    CALL RXDATA
              	
1564: FE3A    	    CP   ':'	; ":"?
1566: 20F9    		JR   NZ, loopHexLoad ; Aguarda :
              	
              	    ; Só inicializa o flag se for a primeira linha do carregamento
1568: 3AF8FB  		LD   A, (LOAD_FIRST_FLAG)
156B: FEFF    		CP   $FF                    ; $FF = virgem / sessão nova
156D: 2005    		JR   NZ, monitor_do_load    ; já está no meio de um carregamento
156F: 3E01    		LD   A, $01
1571: 32F8FB  		LD   (LOAD_FIRST_FLAG), A   ; sinaliza: próximo LOAD é o primeiro
              	
1574:         	monitor_do_load:
1574: CD8515  		CALL    LOAD
1577: CDBE16  		CALL SERIAL_A_TXCRLF
157A: C36115  	    JP loopHexLoad
              	
              	
157D:         	CALL_IHEX:
157D: 214E02  		LD HL, MAIN_LOOP
1580: E5      		PUSH HL
1581: CD5015  		CALL loadInit
1584: C9      		RET
              	
              	;------------------------------------------------------------------------------
              	; LOAD Intel Hex format file from the console.
              	; [Intel Hex Format is:
              	; 1) Colon (Frame 0)
              	; 2) Record Length Field (Frames 1 and 2)
              	; 3) Load Address Field (Frames 3,4,5,6)
              	; 4) Record Type Field (Frames 7 and 8)
              	; 5) Data Field (Frames 9 to 9+2*(Record Length)-1
              	; 6) Checksum Field - Sum of all byte values from Record Length to and 
              	;   including Checksum Field = 0 ]
              	;------------------------------------------------------------------------------	
1585:         	LOAD:
1585: 1E00    			LD   E,0	        ; Zera checksum
1587: CD6316  			CALL GET2	        ; Record Length -> D
158A: 57      			LD   D,A
158B: CD6316  			CALL GET2	        ; Endereco High -> H
158E: 67      			LD   H,A
158F: CD6316  			CALL GET2	        ; Endereco Low -> L
1592: 6F      			LD   L,A
1593: CD6316  			CALL GET2	        ; Record Type -> A
1596: FE01    			CP   $01	        ; EOF record?
1598: 2009    			JR   NZ,LOAD2	    ; Nao: processa dados
              	
              			; --- Record tipo 01: EOF ---
159A: CD6316  			CALL GET2	        ; Consome checksum do EOF
159D: 7B      			LD   A,E
159E: A7      			AND  A
159F: 2839    			JR   Z,LOAD00       ; Checksum OK: imprime resumo
15A1: 1829    			JR   LOADERR        ; Checksum falhou
              	
              			; --- Record tipo 00: Dados ---
15A3:         	LOAD2:
              			; Salva endereco inicial apenas na primeira linha
15A3: 3AF8FB  			LD   A, (LOAD_FIRST_FLAG)
15A6: FE01    			CP   $01                    ; e a primeira linha?
15A8: 2008    			JR   NZ, LOAD2_SKIP
15AA: 3E00    			LD   A, $00
15AC: 32F8FB  			LD   (LOAD_FIRST_FLAG), A   ; limpa flag
15AF: 22F9FB  			LD   (LOAD_START_ADDR), HL  ; salva endereco inicial
              	
15B2:         	LOAD2_SKIP:
15B2: 7A      			LD   A,D	        ; Contador de bytes da linha
15B3: A7      			AND  A
15B4: 280D    			JR   Z,LOAD3
              	
15B6: CD6316  			CALL GET2	        ; Le proximo byte
15B9: 77      			LD   (HL),A	        ; Grava na memoria
15BA: 23      			INC  HL
15BB: 3E2E    			LD   A,'.'
15BD: CD6F0F  			CALL OUTCH
15C0: 15      			DEC  D
15C1: 18EF    			JR   LOAD2_SKIP     ; (continua pelo loop sem re-checar o flag)
              	
15C3:         	LOAD3:
15C3: 22FBFB  			LD   (LOAD_END_ADDR), HL    ; Atualiza endereco final (apos ultimo byte)
15C6: CD6316  			CALL GET2	                ; Consome checksum da linha
15C9: 7B      			LD   A,E
15CA: A7      			AND  A
15CB: C8      			RET  Z                      ; Checksum OK: volta pro monitor
              	
15CC:         	LOADERR:
15CC: 21C916  			LD   HL,CKSUMERR
15CF: CDB516  			CALL SERIAL_A_PRINT_STRING
              	
              	        ;LCD
15D2: 11C916  	        LD   DE, CKSUMERR
15D5: CD4E07  	        CALL sendStringToLCD
              	
15D8: E1      	        POP HL
              	
15D9: C9      			RET
              	
15DA:         	LOAD00:
              			; --- Imprime resumo do carregamento ---
15DA: 21DA16  			LD   HL, LDETXT
15DD: CDB516  			CALL SERIAL_A_PRINT_STRING
              	
15E0: 21F916  			LD   HL, msg_load_start
15E3: CDB516  			CALL SERIAL_A_PRINT_STRING
15E6: 2AF9FB  			LD   HL, (LOAD_START_ADDR)
15E9: CD8D16  			CALL SERIAL_A_PRINT_HL_HEX
15EC: CDBE16  			CALL SERIAL_A_TXCRLF
              	
15EF: 210217  			LD   HL, msg_load_end
15F2: CDB516  			CALL SERIAL_A_PRINT_STRING
15F5: 2AFBFB  			LD   HL, (LOAD_END_ADDR)
15F8: 2B      			DEC  HL                     ; aponta para o ultimo byte gravado
15F9: CD8D16  			CALL SERIAL_A_PRINT_HL_HEX
15FC: CDBE16  			CALL SERIAL_A_TXCRLF
              	
15FF: 210B17  			LD   HL, msg_load_total
1602: CDB516  			CALL SERIAL_A_PRINT_STRING
1605: ED5BF9FB			LD   DE, (LOAD_START_ADDR)
1609: 2AFBFB  			LD   HL, (LOAD_END_ADDR)
160C: B7      			OR   A                      ; limpa carry flag
160D: ED52    			SBC  HL, DE                 ; HL = total de bytes
160F: CD8D16  			CALL SERIAL_A_PRINT_HL_HEX
1612: CDBE16  			CALL SERIAL_A_TXCRLF
              	
              	        ; Mostra status no lcd
1615: 11F316  	        LD   DE, LDETXTLCD
1618: CD4E07  	        CALL sendStringToLCD
              	
161B: 11F916  	        LD   DE, msg_load_start
161E: 0E00    	        LD   C, 0
1620: CD4E07  			CALL sendStringToLCD
1623: 2AF9FB  			LD   HL, (LOAD_START_ADDR)
1626: CD9207  			CALL sendHLToLCD
1629: CD9303  			CALL CRLF
              	
162C: 110217  			LD   DE, msg_load_end
162F: 0E00    	        LD   C, 0
1631: CD4E07  			CALL sendStringToLCD
1634: 2AFBFB  			LD   HL, (LOAD_END_ADDR)
1637: 2B      			DEC  HL                     ; aponta para o ultimo byte gravado
1638: CD9207  			CALL sendHLToLCD
163B: CD9303  			CALL CRLF
              	
163E: 110B17  			LD   DE, msg_load_total
1641: 0E00    	        LD   C, 0
1643: CD4E07  			CALL sendStringToLCD
1646: ED5BF9FB			LD   DE, (LOAD_START_ADDR)
164A: 2AFBFB  			LD   HL, (LOAD_END_ADDR)
164D: B7      			OR   A                      ; limpa carry flag
164E: ED52    			SBC  HL, DE                 ; HL = total de bytes
1650: CD9207  			CALL sendHLToLCD
              	
1653: CD9303  	        CALL CRLF
              	
1656: E1      	        POP HL 
1657: C9      			RET
              	
              	
              	
              	
              	;------------------------------------------------------------------------------
              	; Get a character from the console, must be $20-$7F to be valid (no control characters)
              	; <Ctrl-c> and <SPACE> breaks with the Zero Flag set
              	;------------------------------------------------------------------------------	
1658: CD750F  	GETCHR_S:	CALL INCH	; RX a Character
165B: FE03    			CP   $03	; <ctrl-c> User break?
165D: C8      			RET  Z			
165E: FE20    			CP   $20	; <space> or better?
1660: 38F6    			JR   C,GETCHR_S	; Do it again until we get something usable
1662: C9      			RET
              	
              	;------------------------------------------------------------------------------
              	; Gets two ASCII characters from the console (assuming them to be HEX 0-9 A-F)
              	; Moves them into B and C, converts them into a byte value in A and updates a
              	; Checksum value in E
              	;------------------------------------------------------------------------------
1663: CD5816  	GET2:   CALL GETCHR_S	; Get us a valid character to work with
1666: 47      			LD   B,A	; Load it in B
1667: CD5816  			CALL GETCHR_S	; Get us another character
166A: 4F      			LD   C,A	; load it in C
166B: CD7416  			CALL BCTOA	; Convert ASCII to byte
166E: 4F      			LD   C,A	; Build the checksum
166F: 7B      			LD   A,E
1670: 91      			SUB  C		; The checksum should always equal zero when checked
1671: 5F      			LD   E,A	; Save the checksum back where it came from
1672: 79      			LD   A,C	; Retrieve the byte and go back
1673: C9      			RET
              	
              	;------------------------------------------------------------------------------
              	; Convert ASCII characters in B C registers to a byte value in A
              	;------------------------------------------------------------------------------
1674: 78      	BCTOA		LD   A,B	; Move the hi order byte to A
1675: D630    			SUB  $30	; Take it down from Ascii
1677: FE0A    			CP   $0A	; Are we in the 0-9 range here?
1679: 3802    			JR   C,BCTOA1	; If so, get the next nybble
167B: D607    			SUB  $07	; But if A-F, take it down some more
167D: 07      	BCTOA1		RLCA		; Rotate the nybble from low to high
167E: 07      			RLCA		; One bit at a time
167F: 07      			RLCA		; Until we
1680: 07      			RLCA		; Get there with it
1681: 47      			LD   B,A	; Save the converted high nybble
1682: 79      			LD   A,C	; Now get the low order byte
1683: D630    			SUB  $30	; Convert it down from Ascii
1685: FE0A    			CP   $0A	; 0-9 at this point?
1687: 3802    			JR   C,BCTOA2	; Good enough then, but
1689: D607    			SUB  $07	; Take off 7 more if it's A-F
168B: 80      	BCTOA2		ADD  A,B	; Add in the high order nybble
168C: C9      			RET
              	
              	;------------------------------------------------------------------------------
              	; Imprime HL como 4 digitos hexadecimais
              	; Ex: HL=$80FF -> imprime "80FF"
              	;------------------------------------------------------------------------------
168D:         	SERIAL_A_PRINT_HL_HEX:
168D: 7C      			LD   A, H
168E: CD9616  			CALL SERIAL_A_PRINT_A_HEX
1691: 7D      			LD   A, L
1692: CD9616  			CALL SERIAL_A_PRINT_A_HEX
1695: C9      			RET
              	
              	
              	;------------------------------------------------------------------------------
              	; Imprime byte em A como 2 digitos hexadecimais
              	;------------------------------------------------------------------------------
1696:         	SERIAL_A_PRINT_A_HEX:
1696: F5      			PUSH AF
1697: 0F      			RRCA
1698: 0F      			RRCA
1699: 0F      			RRCA
169A: 0F      			RRCA
169B: CDA316  			CALL SERIAL_A_PRINT_NIBBLE
169E: F1      			POP  AF
169F: CDA316  			CALL SERIAL_A_PRINT_NIBBLE
16A2: C9      			RET
              	
16A3:         	SERIAL_A_PRINT_NIBBLE:
16A3: E60F    			AND  $0F
16A5: FE0A    			CP   $0A
16A7: 3806    			JR   C, SERIAL_A_PRINT_NIBBLE_09
16A9: C637    			ADD  A, $37             ; A-F  ('A'=41h, 41h-0Ah=37h)
16AB: CD6F0F  			CALL OUTCH
16AE: C9      			RET
16AF:         	SERIAL_A_PRINT_NIBBLE_09:
16AF: C630    			ADD  A, $30             ; 0-9
16B1: CD6F0F  			CALL OUTCH
16B4: C9      			RET
              	
              	
              	;------------------------------------------------------------------------------
              	; Print string of characters to Serial A until byte=$00, WITH CR, LF
              	;------------------------------------------------------------------------------
16B5:         	SERIAL_A_PRINT_STRING:
16B5: 7E      	        LD   A,(HL)	; Get character
16B6: B7      			OR   A		; Is it $00 ?
16B7: C8      			RET  Z		; Then RETurn on terminator
16B8: CD6F0F  			CALL OUTCH	; Print it
16BB: 23      			INC  HL		; Next Character
