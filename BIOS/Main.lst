FC01: 00      	I2CA_BLOCK:         .DB    $00   ; I2C device addess: 24LC256 (Copy from/to Mem) dir, del, save, load
FC02: 00      	I2C_RAMCPY:         .DB    $00   ; 1 byte - RAM copy of output port
FC03: 00      	I2C_ADDR            .DB    $00   ; 1 byte - device address
FC04: 00      	I2C_RR              .DB    $00   ; 1 byte - register
FC05: 00      	I2C_DD              .DB    $00   ; 1 byte - data
              	
              	; FS
FC06: 00      	FS_CUR:     .DB $00         ; 1b: entrada corrente do dir
FC07: FFFFFFFF	FS_WRKBUF:  .DS $20         ; 32b: buffer entrada dir
FC0B: FF...   	
FC27: FFFFFFFF	FS_NAMBUF:  .DS $0A         ; 9b: nome digitado
FC2B: FF...   	
FC31: 00      	FS_TMP1:    .DB $00         ; 1b: uso geral
FC32: 0000    	FS_TMPSZ:   .DW $0000       ; 2b: tamanho restante
FC34: 0000    	FS_TMPRAM:  .DW $0000       ; 2b: ponteiro RAM atual
FC36: 00      	FS_CURPG:   .DB $00         ; 1b: pagina corrente
FC37: 00      	FS_SLOTBK:  .DB $00         ; 1b: backup slot dir
FC38: 00      	FS_BMPADDR: .DB $00         ; 1b: endereco EEPROM do byte do bitmap
FC39: 00      	FS_INFOTMP: .DB $00         ; 1b: temp para FS_INFO (paginas livres)
              	; Buffer de pagina em RAM (256 bytes) - longe do codigo
FC3A: FFFFFFFF	PG_BUF:     .DS $FF
FC3E: FF...   	
              	
              	; pixel collision
FD39: 00      	DRAW_PIXEL_COLLISION .db $00 ; 0 - reset, 1 - set


