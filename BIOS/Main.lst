              	            ; DE → argumentos
11AD: CD1D13  	            CALL PARSE_HEX8_DE       ; A = número da porta
11B0: 3812    	            JR   C, OUT_BAD
11B2: 4F      	            LD   C, A                ; C = porta
              	
11B3: CDDC12  	            CALL SKIP_SPACES_DE
11B6: CD1D13  	            CALL PARSE_HEX8_DE       ; A = dado
11B9: 3809    	            JR   C, OUT_BAD
              	
              	            ; OUT (C), A
11BB: ED79    	            OUT  (C), A
11BD: 21E213  	            LD   HL, MSG_OK
11C0: CD8403  	            CALL PUTS
11C3: C9      	            RET
              	
11C4:         	OUT_BAD:
11C4: 21D013  	            LD   HL, MSG_SYNTAX
11C7: CD8403  	            CALL PUTS
11CA: C9      	            RET
              	
              	; ============================================================
