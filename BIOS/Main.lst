18AE: 7B      	            LD   A,E            ;Address (lo) in I2C memory
18AF: CD6117  	            CALL I2C_Write      ;Write address
18B2: 7E      	I2C_MemWrWrite:     LD   A,(HL)         ;Get data byte from CPU memory
18B3: CD6117  	            CALL I2C_Write      ;Read byte from I2C memory
18B6: 23      	            INC  HL             ;Increment CPU memory pointer
18B7: 13      	            INC  DE             ;Increment I2C memory pointer
18B8: 0B      	            DEC  BC             ;Decrement byte counter
18B9: 78      	            LD   A,B
18BA: B1      	            OR   C              ;Finished?
18BB: 2805    	            JR   Z,I2C_MemWrStore       ;Yes, so go store this page
18BD: 7B      	            LD   A,E            ;Get address in I2C memory (lo byte)
18BE: E63F    	            AND  63             ;64 byte page boundary?
18C0: 20F0    	            JR   NZ,I2C_MemWrWrite      ;No, so go write another byte
18C2: CDD617  	I2C_MemWrStore:     CALL I2C_Stop       ;Generate I2C stop
18C5: 78      	            LD   A,B
18C6: B1      	            OR   C              ;Finished?
18C7: 20CA    	            JR   NZ,I2C_MemWr   ;No, so go write some more
18C9: C9      	            RET   
              	
              	
              	; Hex byte output to console
              	;   On entry: A = Byte to be output in hex
              	;   On exit:  BC DE HL IX IY preserved
18CA: F5      	HexOut:     PUSH AF             ;Preserve byte to be output
18CB: 1F      	            RRA                 ;Shift top nibble to
18CC: 1F      	            RRA                 ;  botom four bits..
18CD: 1F      	            RRA
18CE: 1F      	            RRA
18CF: E60F    	            AND  $0F           ;Mask off unwanted bits
18D1: CDD718  	            CALL HexOutHex           ;Output hi nibble
18D4: F1      	            POP  AF             ;Restore byte to be output
18D5: E60F    	            AND  $0F           ;Mask off unwanted bits
              	; Output nibble as ascii character
18D7: FE0A    	HexOutHex:       CP   $0A           ;Nibble > 10 ?
18D9: 3802    	            JR   C,HexOutSkip        ;No, so skip
18DB: C607    	            ADD  A,7            ;Yes, so add 7
18DD: C630    	HexOutSkip:      ADD  A,$30         ;Add ASCII '0'
18DF: CD7803  	            CALL CONOUT       ;Write character
18E2: C9      	            RET
              	#include "FS.asm"
              	
              	; --- Constantes ---
