              	; ============================================================
              	;  CHANGE_DRIVE_A  -  Altera drive para device A - EEDRIVE_A
              	; ============================================================
10A4:         	CHANGE_DRIVE_A:
10A4: 3EA0    	    LD A, EEDRIVE_A
10A6: 32FDFB  	    LD (I2CA_BLOCK), A
10A9: C9      	    RET
              	
              	; ============================================================
              	;  CHANGE_DRIVE_B  -  Altera drive para device B - EEDRIVE_B
              	; ============================================================
10AA:         	CHANGE_DRIVE_B:
10AA: 3EAE    	    LD A, EEDRIVE_B
10AC: 32FDFB  	    LD (I2CA_BLOCK), A
10AF: C9      	    RET
              	
              	; ============================================================
              	;  LOAD_HEX_CMD  -  Carrega intel hex pela porta serial
              	; ============================================================
10B0:         	LOAD_HEX_CMD;
10B0: CD5015  	    CALL loadInit
10B3: C9      	    RET
              	
              	; ============================================================
              	;  CALL_8000  - Atalho - Call 8000H
              	; ============================================================
10B4:         	CALL_8000:
10B4: 114E02  	    LD DE, MAIN_LOOP ; endereço de retorno do CALL
10B7: D5      	    PUSH DE
10B8: C30080  	    JP  $8000
              	
              	
              	; ============================================================
              	;  CLS_CMD  -  Limpa tela via sequência ANSI
              	; ============================================================
10BB:         	CLS_CMD:
10BB: 3E0C    	            LD A, 0CH ; FF
10BD: CDDE06  	            CALL sendCharToLCD
10C0: C9      	            RET
              	
              	; ============================================================
              	;  DUMP_CMD  -  Dump hex+ASCII
              	;  Sintaxe: DUMP xxxx
              	; ============================================================
10C1:         	DUMP_CMD:
              	            ; DE aponta para argumentos
10C1: CD3513  	            CALL PARSE_HEX16_DE      ; HL = endereço
10C4: 3836    	            JR   C, DUMP_BAD_ADDR
10C6: 22F6FB  	            LD   (ADDR_TMP), HL
              	
10C9: 0608    	            LD   B, 8               ; 8 linhas de 5 bytes
              	
10CB:         	DUMP_LINE:
10CB: C5      	            PUSH BC
              	            ; Exibe endereço
10CC: 2AF6FB  	            LD   HL, (ADDR_TMP)
10CF: CD8C13  	            CALL PRINT_HEX16
10D2: 3E3A    	            LD   A, ':'
10D4: CD7703  	            CALL PUTCHAR
10D7: 3E20    	            LD   A, SPACE
10D9: CD7703  	            CALL PUTCHAR
              	
              	            ; Exibe 16 bytes hex
10DC: 2AF6FB  	            LD   HL, (ADDR_TMP)
10DF: 0E05    	            LD   C, 5
10E1:         	DUMP_HEX:
10E1: 7E      	            LD   A, (HL)
10E2: CD7113  	            CALL PRINT_HEX8
10E5: 3E20    	            LD   A, SPACE
10E7: CD7703  	            CALL PUTCHAR
10EA: 23      	            INC  HL
10EB: 0D      	            DEC  C
10EC: 20F3    	            JR   NZ, DUMP_HEX
              	
              	            ;CALL CRLF
              	            ; Avança endereço base
10EE: 2AF6FB  	            LD   HL, (ADDR_TMP)
10F1: 110500  	            LD   DE, 5
10F4: 19      	            ADD  HL, DE
10F5: 22F6FB  	            LD   (ADDR_TMP), HL
10F8: C1      	            POP  BC
10F9: 10D0    	            DJNZ DUMP_LINE
10FB: C9      	            RET
              	
10FC:         	DUMP_BAD_ADDR:
10FC: 21BB13  	            LD   HL, MSG_BAD_ADDR
10FF: CD8303  	            CALL PUTS
1102: C9      	            RET
              	
              	; ============================================================
              	;  LOAD_CMD  -  Carrega bytes hex em endereço
              	;  Sintaxe: LOAD xxxx
              	;  Digitar pares hex separados por espaço; linha vazia encerra
              	; ============================================================
1103:         	LOAD_CMD:
1103: CD3513  	            CALL PARSE_HEX16_DE
1106: 3848    	            JR   C, LOAD_BAD
1108: 22F6FB  	            LD   (ADDR_TMP), HL
110B: 21E513  	            LD   HL, MSG_LOAD_HINT
110E: CD8303  	            CALL PUTS
              	
1111:         	LOAD_LOOP:
              	            ; Exibe endereço atual
1111: 2AF6FB  	            LD   HL, (ADDR_TMP)
1114: CD8C13  	            CALL PRINT_HEX16
1117: 3E3A    	            LD   A, ':'
1119: CD7703  	            CALL PUTCHAR
111C: 3E20    	            LD   A, SPACE
111E: CD7703  	            CALL PUTCHAR
              	
1121: CD7612  	            CALL GETLINE             ; Lê linha
1124: 21A0FB  	            LD   HL, LINEBUF
1127: CDD412  	            CALL SKIP_SPACES
              	
              	            ; Linha vazia = fim
112A: 7E      	            LD   A, (HL)
112B: FE0D    	            CP   CR
112D: C8      	            RET  Z
112E: FE00    	            CP   NUL
1130: C8      	            RET  Z
              	
              	            ; Processa pares hex na linha
1131:         	LOAD_BYTE:
1131: CD0313  	            CALL PARSE_HEX8_HL       ; A = byte, HL avança
1134: 3818    	            JR   C, LOAD_NEXT_LINE
              	            ; Grava byte
1136: ED5BF6FB	            LD   DE, (ADDR_TMP)
113A: 12      	            LD   (DE), A
113B: 13      	            INC  DE
113C: ED53F6FB	            LD   (ADDR_TMP), DE
1140: CDE212  	            CALL SKIP_SPACES_HL
1143: 7E      	            LD   A, (HL)
1144: FE0D    	            CP   CR
1146: 28C9    	            JR   Z, LOAD_LOOP
1148: FE00    	            CP   NUL
114A: 28C5    	            JR   Z, LOAD_LOOP
114C: 18E3    	            JR   LOAD_BYTE
              	
114E:         	LOAD_NEXT_LINE:
114E: 18C1    	            JR   LOAD_LOOP
              	
1150:         	LOAD_BAD:
1150: 21BB13  	            LD   HL, MSG_BAD_ADDR
1153: CD8303  	            CALL PUTS
1156: C9      	            RET
              	
              	; ============================================================
              	;  EDIT_CMD  -  Edita memória byte a byte
              	;  Sintaxe: EDIT xxxx
              	;  Exibe: XXXX: AA  _  (digitar novo valor ou Enter p/ manter)
              	;  '.' encerra
              	; ============================================================
1157:         	EDIT_CMD:
1157: CD3513  	            CALL PARSE_HEX16_DE
115A: 3849    	            JR   C, EDIT_BAD
115C: 22F6FB  	            LD   (ADDR_TMP), HL
              	
115F:         	EDIT_LOOP:
115F: 2AF6FB  	            LD   HL, (ADDR_TMP)
1162: CD8C13  	            CALL PRINT_HEX16
1165: 3E3A    	            LD   A, ':'
1167: CD7703  	            CALL PUTCHAR
116A: 3E20    	            LD   A, SPACE
116C: CD7703  	            CALL PUTCHAR
116F: 7E      	            LD   A, (HL)             ; Valor atual
1170: CD7113  	            CALL PRINT_HEX8
1173: 3E20    	            LD   A, SPACE
1175: CD7703  	            CALL PUTCHAR
1178: 3E20    	            LD   A, SPACE
117A: CD7703  	            CALL PUTCHAR
              	
              	            ; Lê até 3 chars (2 hex + CR)
117D: CD7612  	            CALL GETLINE
1180: 21A0FB  	            LD   HL, LINEBUF
1183: CDD412  	            CALL SKIP_SPACES
              	
1186: 7E      	            LD   A, (HL)
1187: FE2E    	            CP   '.'                 ; '.' = sair
1189: C8      	            RET  Z
118A: FE0D    	            CP   CR
118C: 280E    	            JR   Z, EDIT_KEEP       ; Enter = mantém byte
118E: FE00    	            CP   NUL
1190: 280A    	            JR   Z, EDIT_KEEP
              	
              	            ; Tenta parsear novo byte
1192: CD0313  	            CALL PARSE_HEX8_HL
1195: 38C8    	            JR   C, EDIT_LOOP       ; Hex inválido: repete
              	
              	            ; Grava novo byte
1197: ED5BF6FB	            LD   DE, (ADDR_TMP)
119B: 12      	            LD   (DE), A
              	
119C:         	EDIT_KEEP:
119C: 2AF6FB  	            LD   HL, (ADDR_TMP)
119F: 23      	            INC  HL
11A0: 22F6FB  	            LD   (ADDR_TMP), HL
11A3: 18BA    	            JR   EDIT_LOOP
              	
11A5:         	EDIT_BAD:
11A5: 21BB13  	            LD   HL, MSG_BAD_ADDR
11A8: CD8303  	            CALL PUTS
11AB: C9      	            RET
              	
              	; ============================================================
              	;  OUT_CMD  -  Escreve byte em porta de I/O
              	;  Sintaxe: OUT pp dd   (porta pp, dado dd, ambos em hex)
              	; ============================================================
11AC:         	OUT_CMD:
              	            ; DE → argumentos
11AC: CD1C13  	            CALL PARSE_HEX8_DE       ; A = número da porta
11AF: 3812    	            JR   C, OUT_BAD
11B1: 4F      	            LD   C, A                ; C = porta
              	
11B2: CDDB12  	            CALL SKIP_SPACES_DE
11B5: CD1C13  	            CALL PARSE_HEX8_DE       ; A = dado
11B8: 3809    	            JR   C, OUT_BAD
              	
              	            ; OUT (C), A
11BA: ED79    	            OUT  (C), A
11BC: 21E113  	            LD   HL, MSG_OK
11BF: CD8303  	            CALL PUTS
11C2: C9      	            RET
              	
11C3:         	OUT_BAD:
11C3: 21CF13  	            LD   HL, MSG_SYNTAX
11C6: CD8303  	            CALL PUTS
11C9: C9      	            RET
              	
              	; ============================================================
              	;  IN_CMD  -  Lê byte de porta de I/O
              	;  Sintaxe: IN pp
              	; ============================================================
11CA:         	IN_CMD:
11CA: CD1C13  	            CALL PARSE_HEX8_DE
11CD: 380A    	            JR   C, IN_BAD
11CF: 4F      	            LD   C, A
11D0: ED78    	            IN   A, (C)
11D2: CD7113  	            CALL PRINT_HEX8
11D5: CD9303  	            CALL CRLF
11D8: C9      	            RET
              	
11D9:         	IN_BAD:
11D9: 21CF13  	            LD   HL, MSG_SYNTAX
11DC: CD8303  	            CALL PUTS
11DF: C9      	            RET
              	
              	; ============================================================
              	;  GO_CMD  -  Executa código a partir de endereço
              	;  Sintaxe: G xxxx
              	; ============================================================
11E0:         	GO_CMD:
11E0: CD3513  	            CALL PARSE_HEX16_DE
11E3: 3801    	            JR   C, GO_BAD
11E5: E9      	            JP   (HL)                ; Salta para endereço
              	
11E6:         	GO_BAD:
11E6: 21BB13  	            LD   HL, MSG_BAD_ADDR
11E9: CD8303  	            CALL PUTS
11EC: C9      	            RET
              	
              	
              	; ============================================================
              	;  CALL_CMD  -  Executa código a partir de endereço
              	;  Sintaxe: CALL xxxx
              	; ============================================================
11ED:         	CALL_CMD:
11ED: CD3513  	            CALL PARSE_HEX16_DE
11F0: 3805    	            JR   C, CALL_BAD
11F2: 114E02  	            LD DE, MAIN_LOOP ; endereço de retorno do CALL
11F5: D5      	            PUSH DE
11F6: E9      	            JP   (HL)                ; Salta para endereço
              	
11F7:         	CALL_BAD:
11F7: 21BB13  	            LD   HL, MSG_BAD_ADDR
11FA: CD8303  	            CALL PUTS
11FD: C9      	            RET
              	
              	
              	; ============================================================
              	;  HELP_CMD  -  Exibe ajuda
              	; ============================================================
11FE:         	HELP_CMD:
11FE: 111D14  	            LD   DE, MSG_HELP_L0
1201: CD4E07  	            CALL sendStringToLCD
              	
1204: 112714  	            LD   DE, MSG_HELP_L1
1207: CD4E07  	            CALL sendStringToLCD
              	
120A: 112E14  	            LD   DE, MSG_HELP_L2
120D: CD4E07  	            CALL sendStringToLCD
              	
1210: 113314  	            LD   DE, MSG_HELP_L3
1213: CD4E07  	            CALL sendStringToLCD
              	
1216: 113E14  	            LD   DE, MSG_HELP_L4
1219: CD4E07  	            CALL sendStringToLCD
              	
121C: 114A14  	            LD   DE, MSG_HELP_L5
121F: CD4E07  	            CALL sendStringToLCD
              	
1222: 115514  	            LD   DE, MSG_HELP_L6
1225: CD4E07  	            CALL sendStringToLCD
              	
1228: 116014  	            LD   DE, MSG_HELP_L7
122B: CD4E07  	            CALL sendStringToLCD
              	
122E: 116814  	            LD   DE, MSG_HELP_L8
1231: CD4E07  	            CALL sendStringToLCD
              	
1234: 117314  	            LD   DE, MSG_HELP_L9
1237: CD4E07  	            CALL sendStringToLCD
              	
123A: 117E14  	            LD   DE, MSG_HELP_L10
123D: CD4E07  	            CALL sendStringToLCD
              	
1240: 118B14  	            LD   DE, MSG_HELP_L11
1243: CD4E07  	            CALL sendStringToLCD
              	
1246: 119F14  	            LD   DE, MSG_HELP_L12
1249: CD4E07  	            CALL sendStringToLCD
              	
124C: 11B414  	            LD   DE, MSG_HELP_L13
124F: CD4E07  	            CALL sendStringToLCD
              	
1252: 11C614  	            LD   DE, MSG_HELP_L14
1255: CD4E07  	            CALL sendStringToLCD
              	
1258: 11D814  	            LD   DE, MSG_HELP_L15
125B: CD4E07  	            CALL sendStringToLCD
              	
125E: 11EA14  	            LD   DE, MSG_HELP_L16
1261: CD4E07  	            CALL sendStringToLCD
              	
1264: 11FD14  	            LD   DE, MSG_HELP_L17
1267: CD4E07  	            CALL sendStringToLCD
              	
126A: 111515  	            LD   DE, MSG_HELP_L18
126D: CD4E07  	            CALL sendStringToLCD
1270: C9      	            RET
              	
              	
1271:         	LCD_SCROLL:
1271: CD7703  	    CALL PUTCHAR
1274: 1805    	    JR GETLINE_LOOP
              	
              	
              	; --- GETLINE: Lê linha para LINEBUF; eco local ---
              	;     Termina em CR. Suporta BS/DEL para apagar.
1276:         	GETLINE:
1276: 21A0FB  	            LD   HL, LINEBUF
1279: 064F    	            LD   B, 79               ; Máx 79 chars + NUL
127B:         	GETLINE_LOOP:
127B: CDA902  	            CALL CONIN
127E: FE0D    	            CP   CR
1280: 2845    	            JR   Z, GETLINE_DONE
1282: FEF8    	            CP   $F8    ; ignora scroll up - GLCD
1284: 28EB    	            JR   Z, LCD_SCROLL
1286: FEF7    	            CP   $F7    ; ignora scroll down - GLCD
1288: 28E7    	            JR   Z, LCD_SCROLL
128A: FE0A    	            CP   LF
128C: 28ED    	            JR   Z, GETLINE_LOOP    ; Ignora LF
128E: FE08    	            CP   BkS
1290: 281D    	            JR   Z, GETLINE_BS
1292: FE7F    	            CP   DEL
1294: 2819    	            JR   Z, GETLINE_BS
1296: FEFA    	            CP   $FA ; AltGr
1298: CA7D15  	            JP   Z, CALL_IHEX
129B: FEF9    	            CP   $F9 ; LUZ
129D: CAB410  	            JP   Z, CALL_8000
12A0: 4F      	            LD   C, A
12A1: 78      	            LD   A, B
12A2: FE00    	            CP   0
12A4: 28D5    	            JR   Z, GETLINE_LOOP    ; Buffer cheio
12A6: 79      	            LD   A, C
12A7: 77      	            LD   (HL), A
12A8: 23      	            INC  HL
12A9: 05      	            DEC  B
12AA: CD7703  	            CALL PUTCHAR             ; Eco
12AD: 18CC    	            JR   GETLINE_LOOP
12AF:         	GETLINE_BS:
12AF: 78      	            LD   A, B
12B0: FE4F    	            CP   79
12B2: 28C7    	            JR   Z, GETLINE_LOOP    ; Início: ignora BS
12B4: 2B      	            DEC  HL
12B5: 04      	            INC  B
12B6: 3E08    	            LD   A, BkS
12B8: CD7703  	            CALL PUTCHAR
12BB: 3E20    	            LD   A, SPACE
12BD: CD7703  	            CALL PUTCHAR
12C0: 3E08    	            LD   A, BkS
12C2: CD7703  	            CALL PUTCHAR
12C5: 18B4    	            JR   GETLINE_LOOP
12C7:         	GETLINE_DONE:
12C7: 3600    	            LD   (HL), NUL           ; Termina string
12C9: CD9303  	            CALL CRLF
12CC: C9      	            RET
              	
              	; ============================================================
              	;  SUBROTINAS DE PARSE
              	; ============================================================
              	; --- SKIP_COMMAND_DE: Avança DE até o proximo espaço ---
12CD:         	SKIP_COMMAND_DE:
12CD: 1A      				LD A, (DE)
12CE: FE20    				CP SPACE
12D0: C8      				RET Z
12D1: 13      				INC DE
12D2: 18F9    				JR SKIP_COMMAND_DE
              	
              	
              	; --- SKIP_SPACES: Avança HL sobre espaços ---
12D4:         	SKIP_SPACES:
12D4: 7E      	            LD   A, (HL)
12D5: FE20    	            CP   SPACE
12D7: C0      	            RET  NZ
12D8: 23      	            INC  HL
12D9: 18F9    	            JR   SKIP_SPACES
              	
              	; --- SKIP_SPACES_DE: Avança DE sobre espaços ---
12DB:         	SKIP_SPACES_DE:
12DB: 1A      	            LD   A, (DE)
12DC: FE20    	            CP   SPACE
12DE: C0      	            RET  NZ
12DF: 13      	            INC  DE
12E0: 18F9    	            JR   SKIP_SPACES_DE
              	
              	; --- SKIP_SPACES_HL: Avança HL sobre espaços ---
12E2:         	SKIP_SPACES_HL:
12E2: 7E      	            LD   A, (HL)
12E3: FE20    	            CP   SPACE
12E5: C0      	            RET  NZ
12E6: 23      	            INC  HL
12E7: 18F9    	            JR   SKIP_SPACES_HL
              	
              	; --- IS_HEX: testa se A é dígito hex; retorna dígito em A (0-15), CY se inválido ---
12E9:         	IS_HEX:
12E9: FE30    	            CP   '0'
12EB: 3814    	            JR   C, IS_HEX_BAD
12ED: FE3A    	            CP   '9'+1
12EF: 380D    	            JR   C, IS_HEX_DIG      ; '0'-'9'
12F1: E6DF    	            AND  0DFH               ; Uppercase
12F3: FE41    	            CP   'A'
12F5: 380A    	            JR   C, IS_HEX_BAD
12F7: FE47    	            CP   'F'+1
12F9: 3006    	            JR   NC, IS_HEX_BAD
12FB: D637    	            SUB  'A'-10             ; 'A'→10 ... 'F'→15
12FD: C9      	            RET
12FE:         	IS_HEX_DIG:
12FE: D630    	            SUB  '0'
1300: C9      	            RET
1301:         	IS_HEX_BAD:
1301: 37      	            SCF
1302: C9      	            RET
              	
              	; --- PARSE_HEX8_HL: parseia 2 dígitos hex em (HL), resultado em A; HL avança 2 ---
              	;     Carry = erro
1303:         	PARSE_HEX8_HL:
1303: 7E      	            LD   A, (HL)
1304: CDE912  	            CALL IS_HEX
1307: D8      	            RET  C
1308: 0F      	            RRCA
1309: 0F      	            RRCA
130A: 0F      	            RRCA
130B: 0F      	            RRCA
130C: E6F0    	            AND  0F0H
130E: 47      	            LD   B, A
130F: 23      	            INC  HL
1310: 7E      	            LD   A, (HL)
1311: CDE912  	            CALL IS_HEX
1314: 3803    	            JR   C, PHX8_ERR
1316: B0      	            OR   B
1317: 23      	            INC  HL
1318: C9      	            RET
1319:         	PHX8_ERR:
1319: 2B      	            DEC  HL
131A: 37      	            SCF
131B: C9      	            RET
              	
              	; --- PARSE_HEX8_DE: igual mas com DE ---
131C:         	PARSE_HEX8_DE:
131C: 1A      	            LD   A, (DE)
131D: CDE912  	            CALL IS_HEX
1320: D8      	            RET  C
1321: 0F      	            RRCA
1322: 0F      	            RRCA
1323: 0F      	            RRCA
1324: 0F      	            RRCA
1325: E6F0    	            AND  0F0H
1327: 47      	            LD   B, A
1328: 13      	            INC  DE
1329: 1A      	            LD   A, (DE)
132A: CDE912  	            CALL IS_HEX
132D: 3803    	            JR   C, PHX8D_ERR
132F: B0      	            OR   B
1330: 13      	            INC  DE
1331: C9      	            RET
1332:         	PHX8D_ERR:
1332: 1B      	            DEC  DE
1333: 37      	            SCF
1334: C9      	            RET
              	
              	; --- PARSE_HEX16_DE: parseia 4 dígitos hex em (DE), resultado em HL; DE avança 4 ---
1335:         	PARSE_HEX16_DE:
1335: CD1C13  	            CALL PARSE_HEX8_DE
1338: D8      	            RET  C
1339: 67      	            LD   H, A
133A: CD1C13  	            CALL PARSE_HEX8_DE
133D: D8      	            RET  C
133E: 6F      	            LD   L, A
133F: C9      	            RET
              	
              	; --- UPCASE_TOKEN: copia token de (HL) em maiúscula para HEXBUF; HL avança após token ---
1340:         	UPCASE_TOKEN:
1340: 11F0FB  	            LD   DE, HEXBUF
1343: 060A    	            LD   B, 10
1345:         	UPCASE_LOOP:
1345: 7E      	            LD   A, (HL)
1346: FE20    	            CP   SPACE
1348: 2817    	            JR   Z, UPCASE_DONE
134A: FE0D    	            CP   CR
134C: 2813    	            JR   Z, UPCASE_DONE
134E: FE00    	            CP   NUL
1350: 280F    	            JR   Z, UPCASE_DONE
1352: FE61    	            CP   'a'
1354: 3806    	            JR   C, UPCASE_STORE
1356: FE7B    	            CP   'z'+1
1358: 3002    	            JR   NC, UPCASE_STORE
135A: E6DF    	            AND  0DFH               ; Converte para maiúscula
135C:         	UPCASE_STORE:
135C: 12      	            LD   (DE), A
135D: 23      	            INC  HL
135E: 13      	            INC  DE
135F: 10E4    	            DJNZ UPCASE_LOOP
1361:         	UPCASE_DONE:
1361: 3E00    	            LD   A, NUL
1363: 12      	            LD   (DE), A
1364: C9      	            RET
              	
              	; --- STRCMP: compara (HL) com (DE), Z=1 se iguais ---
1365:         	STRCMP:
1365: 7E      	            LD   A, (HL)
1366: 47      	            LD   B, A
1367: 1A      	            LD   A, (DE)
1368: B8      	            CP   B
1369: C0      	            RET  NZ
136A: FE00    	            CP   NUL
136C: C8      	            RET  Z
136D: 23      	            INC  HL
136E: 13      	            INC  DE
136F: 18F4    	            JR   STRCMP
              	
