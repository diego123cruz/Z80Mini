19E8: 2A30FC  	    LD HL, (FS_TMPRAM)
19EB: 09      	    ADD HL, BC
19EC: 2230FC  	    LD (FS_TMPRAM), HL
19EF: 2A2EFC  	    LD HL, (FS_TMPSZ)
19F2: B7      	    OR A                    ; limpa carry
19F3: ED42    	    SBC HL, BC
19F5: 222EFC  	    LD (FS_TMPSZ), HL
              	
