18AE: CD6017  	            CALL I2C_Write      ;Write address
18B1: 7E      	I2C_MemWrWrite:     LD   A,(HL)         ;Get data byte from CPU memory
18B2: CD6017  	            CALL I2C_Write      ;Read byte from I2C memory
18B5: 23      	            INC  HL             ;Increment CPU memory pointer
18B6: 13      	            INC  DE             ;Increment I2C memory pointer
18B7: 0B      	            DEC  BC             ;Decrement byte counter
18B8: 78      	            LD   A,B
18B9: B1      	            OR   C              ;Finished?
18BA: 2805    	            JR   Z,I2C_MemWrStore       ;Yes, so go store this page
18BC: 7B      	            LD   A,E            ;Get address in I2C memory (lo byte)
18BD: E63F    	            AND  63             ;64 byte page boundary?
18BF: 20F0    	            JR   NZ,I2C_MemWrWrite      ;No, so go write another byte
18C1: CDD517  	I2C_MemWrStore:     CALL I2C_Stop       ;Generate I2C stop
18C4: 78      	            LD   A,B
18C5: B1      	            OR   C              ;Finished?
18C6: 20CA    	            JR   NZ,I2C_MemWr   ;No, so go write some more
18C8: C9      	            RET   
              	
              	
              	; Hex byte output to console
              	;   On entry: A = Byte to be output in hex
              	;   On exit:  BC DE HL IX IY preserved
18C9: F5      	HexOut:     PUSH AF             ;Preserve byte to be output
18CA: 1F      	            RRA                 ;Shift top nibble to
18CB: 1F      	            RRA                 ;  botom four bits..
18CC: 1F      	            RRA
18CD: 1F      	            RRA
18CE: E60F    	            AND  $0F           ;Mask off unwanted bits
18D0: CDD618  	            CALL HexOutHex           ;Output hi nibble
18D3: F1      	            POP  AF             ;Restore byte to be output
18D4: E60F    	            AND  $0F           ;Mask off unwanted bits
              	; Output nibble as ascii character
18D6: FE0A    	HexOutHex:       CP   $0A           ;Nibble > 10 ?
18D8: 3802    	            JR   C,HexOutSkip        ;No, so skip
18DA: C607    	            ADD  A,7            ;Yes, so add 7
18DC: C630    	HexOutSkip:      ADD  A,$30         ;Add ASCII '0'
18DE: CD7703  	            CALL CONOUT       ;Write character
18E1: C9      	            RET
              	#include "FS.asm"
              	
              	; --- Constantes ---
