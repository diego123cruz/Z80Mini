06EF: 2004    	        JR NZ,DO_CR
06F1: 3E01    	        LD A,1
06F3: 18F2    	        JR $-12                 ;Move VPORT above
06F5:         	DO_CR:
              	        ;Key is now a drawing character, reset VPORT first
