              	    ; Salva C na RAM antes.
1CE0: 79      	    LD A, C
1CE1: 3239FC  	    LD (FS_BMPADDR+1), A    ; salva bit_index em FS_BMPADDR+1
              	
1CE4: 3A38FC  	    LD A, (FS_BMPADDR)
1CE7: 5F      	    LD E, A
1CE8: 1600    	    LD D, 0
1CEA: 2131FC  	    LD HL, FS_TMP1
1CED: 010100  	    LD BC, 1
1CF0: CD7018  	    CALL I2C_MemRd
1CF3: C21C1D  	    JP NZ, FS_FP_ERR
              	
