13B7: 3802    	            JR   C, PN_DONE
13B9: C607    	            ADD  A, 07H              ; 'A'-'9'-1
13BB:         	PN_DONE:
13BB: CD9B03  	            CALL PUTCHAR
13BE: C9      	            RET
              	
