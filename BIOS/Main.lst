011E: C3911F  	    JP SET_DEFAULT_SERIAL_B
0121: C36F0F  	    JP OUTCH
0124: C3750F  	    JP INCH
0127: C37B0F  	    JP SNDSTR
012A: C3BE16  	    JP SERIAL_A_TXCRLF
012D: C39616  	    JP SERIAL_A_PRINT_A_HEX
0130: C38D16  	    JP SERIAL_A_PRINT_HL_HEX
0133: C39E1F  	    JP SERIAL_GET_HEX_A
0136: C3AA1F  	    JP SERIAL_GET_HEX_HL
              	    ;   GLCD
0139: C39903  	    JP initLCD
