              	#include "I2C.asm"
              	; **********************************************************************
              	; I2C support functions
              	
              	; I2C bus open device
              	;   On entry: A = Device address (bit zero is read flag)
              	;             SCL = unknown, SDA = unknown
              	;   On exit:  If successfully A = 0 and Z flagged
              	;             If unsuccessfully A = Error and NZ flagged
              	;             BC DE HL IX IY preserved
1788: F5      	I2C_Open:   PUSH AF
1789: CDFC17  	            CALL I2C_Start      ;Output start condition
178C: F1      	            POP  AF
178D: 1803    	            JR   I2C_Write      ;Write data byte
              	
              	
              	; I2C bus close device
              	;   On entry: SCL = unknown, SDA = unknown
              	;   On exit:  If successfully A=0 and Z flagged
              	;             If unsuccessfully A=Error and NZ flagged
              	;             SCL = hi, SDA = hi
              	;             BC DE HL IX IY preserved
178F: C30718  	I2C_Close:  JP   I2C_Stop       ;Output stop condition
              	
              	
              	; **********************************************************************
              	; **********************************************************************
              	; I2C bus master driver
              	; **********************************************************************
              	; **********************************************************************
              	
              	; Functions provided are:
              	;     I2C_Start
              	;     I2C_Stop
              	;     I2C_Read
              	;     I2C_Write
              	;
              	; This code has delays between all I/O operations to ensure it works
              	; with the slowest I2C devices
              	;
              	; I2C transfer sequence
              	;   +-------+  +---------+  +---------+     +---------+  +-------+
              	;   | Start |  | Address |  | Data    | ... | Data    |  | Stop  |
              	;   |       |  | frame   |  | frame 1 |     | frame N |  |       |
              	;   +-------+  +---------+  +---------+     +---------+  +-------+
              	;
              	;
              	; Start condition                     Stop condition
              	; Output by master device             Output by master device
              	;       ----+                                      +----
              	; SDA       |                         SDA          |
              	;           +-------                        -------+
              	;       -------+                                +-------
              	; SCL          |                      SCL       |
              	;              +----                        ----+
              	;
              	;
              	; Address frame
              	; Clock and data output from master device
              	; Receiving device outputs acknowledge 
              	;        +-----+-----+-----+-----+-----+-----+-----+-----+     +---+
              	; SDA    | A 7 | A 6 | A 5 | A 4 | A 3 | A 2 | A 1 | R/W | ACK |   |
              	;     ---+-----+-----+-----+-----+-----+-----+-----+-----+-----+   +---
              	;          +-+   +-+   +-+   +-+   +-+   +-+   +-+   +-+   +-+
              	; SCL      | |   | |   | |   | |   | |   | |   | |   | |   | |
              	;     -----+ +---+ +---+ +---+ +---+ +---+ +---+ +---+ +---+ +---------
              	;
              	;
              	; Data frame 
              	; Clock output by master device
              	; Data output by transmitting device
              	; Receiving device outputs acknowledge 
              	;        +-----+-----+-----+-----+-----+-----+-----+-----+     +---+
              	; SDA    | D 7 | D 6 | D 5 | D 4 | D 3 | D 2 | D 1 | D 0 | ACK |   |
              	;     ---+-----+-----+-----+-----+-----+-----+-----+-----+-----+   +---
              	;          +-+   +-+   +-+   +-+   +-+   +-+   +-+   +-+   +-+
              	; SCL      | |   | |   | |   | |   | |   | |   | |   | |   | |
              	;     -----+ +---+ +---+ +---+ +---+ +---+ +---+ +---+ +---+ +---------
              	;
              	
              	
              	; **********************************************************************
              	; I2C constants
              	
              	
              	; I2C bus master interface
              	; The default device option is for SC126 or compatible
              	
0021:         	I2C_PORT:   .EQU $21           ;Host I2C port address
0007:         	I2C_SDA_WR: .EQU 7              ;Host I2C write SDA bit number
0007:         	I2C_SDA_RD: .EQU 7              ;Host I2C read SDA bit number
0000:         	I2C_SCL_WR: .EQU 0              ;Host I2C write SCL bit number
0000:         	I2C_SCL_RD: .EQU 0              ;Host I2C read SCL bit number 
0081:         	I2C_QUIES:  .EQU 0b10000001     ;Host I2C output port quiescent value
              	
              	
              	; I2C support constants
0000:         	ERR_NONE:   .EQU 0              ;Error = None
0001:         	ERR_JAM:    .EQU 1              ;Error = Bus jammed [not used]
0002:         	ERR_NOACK:  .EQU 2              ;Error = No ackonowledge
0003:         	ERR_TOUT:   .EQU 3              ;Error = Timeout
              	
              	
              	; **********************************************************************
              	; Hardware dependent I2C bus functions
              	
              	
              	; I2C bus transmit frame (address or data)
              	;   On entry: A = Data byte, or
              	;                 Address byte (bit zero is read flag)
              	;             SCL = low, SDA = low
              	;   On exit:  If successful A=0 and Z flagged
              	;                SCL = lo, SDA = lo
              	;             If unsuccessful A=Error and NZ flagged
              	;                SCL = high, SDA = high, I2C closed
              	;             BC DE HL IX IY preserved
1792: C5      	I2C_Write:  PUSH BC             ;Preserve registers
1793: D5      	            PUSH DE
1794: 57      	            LD   D,A            ;Store byte to be written
1795: 0608    	            LD   B,8            ;8 data bits, bit 7 first
1797: CB12    	I2C_WriteWr_Loop:   RL   D              ;Test M.S.Bit
1799: 3805    	            JR   C,I2C_WriteBit_Hi      ;High, so skip
179B: CD2E18  	            CALL I2C_SDA_LO     ;SDA low   (SCL lo, SDA = data bit)
179E: 1803    	            JR   I2C_WriteBit_Clk
17A0: CD2718  	I2C_WriteBit_Hi:    CALL I2C_SDA_HI     ;SDA high  (SCL lo, SDA = data bit)
17A3: CD1918  	I2C_WriteBit_Clk:   CALL I2C_SCL_HI     ;SCL high  (SCL hi, SDA = data bit)
17A6: CD2018  	            CALL I2C_SCL_LO     ;SCL low   (SCL lo, SDA = data bit)
17A9: 10EC    	            DJNZ I2C_WriteWr_Loop
              	; Test for acknowledge from slave (receiver)
              	; On arriving here, SCL = lo, SDA = data bit
17AB: CD2718  	            CALL I2C_SDA_HI     ;SDA high  (SCL lo, SDA hi/ack)
17AE: CD1918  	            CALL I2C_SCL_HI     ;SCL high  (SCL hi, SDA hi/ack)
17B1: CD3F18  	            CALL I2C_RdPort     ;Read SDA input
17B4: 47      	            LD   B,A
17B5: CD2018  	            CALL I2C_SCL_LO     ;SCL low   (SCL lo, SDA = hi)
17B8: CB78    	            BIT  I2C_SDA_RD,B
17BA: 2004    	            JR   NZ,I2C_WriteNoAck      ;Skip if no acknowledge
17BC: D1      	            POP  DE             ;Restore registers
17BD: C1      	            POP  BC
17BE: AF      	            XOR  A              ;Return success A=0 and Z flagged
17BF: C9      	            RET
              	; I2C STOP required as no acknowledge
              	; On arriving here, SCL = lo, SDA = hi
17C0: CD2E18  	I2C_WriteNoAck:     CALL I2C_SDA_LO     ;SDA low   (SCL lo, SDA = lo)
17C3: CD1918  	            CALL I2C_SCL_HI     ;SCL high  (SCL hi, SDA = lo)
17C6: CD2718  	            CALL I2C_SDA_HI     ;SDA low   (SCL hi, SDA = hi)
17C9: D1      	            POP  DE             ;Restore registers
17CA: C1      	            POP  BC
17CB: 3E02    	            LD   A,ERR_NOACK    ;Return error = No Acknowledge
17CD: B7      	            OR   A              ;  and NZ flagged
17CE: C9      	            RET
              	
              	
              	; I2C bus receive frame (data)
              	;   On entry: A = Acknowledge flag
              	;               If A != 0 the read is acknowledged
              	;             SCL low, SDA low
              	;   On exit:  If successful A = data byte and Z flagged
              	;               SCL = low, SDA = low
              	;             If unsuccessul* A = Error and NZ flagged
              	;               SCL = low, SDA = low
              	;             BC DE HL IX IY preserved
              	; *This function always returns successful
17CF: C5      	I2C_Read:   PUSH BC             ;Preserve registers
17D0: D5      	            PUSH DE
17D1: 5F      	            LD   E,A            ;Store acknowledge flag
17D2: 0608    	            LD   B,8            ;8 data bits, 7 first
17D4: CD2718  	            CALL I2C_SDA_HI     ;SDA high  (SCL lo, SDA hi/input)
17D7: CD1918  	I2C_ReadRd_Loop:   CALL I2C_SCL_HI     ;SCL high  (SCL hi, SDA hi/input)
17DA: CD3F18  	            CALL I2C_RdPort     ;Read SDA input bit
17DD: 37      	            SCF                 ;Set carry flag
17DE: CB7F    	            BIT  I2C_SDA_RD,A   ;SDA input high?
17E0: 2001    	            JR   NZ, I2C_ReadRotate     ;Yes, skip with carry flag set
17E2: 3F      	            CCF                 ;Clear carry flag
17E3: CB12    	I2C_ReadRotate:    RL   D              ;Rotate result into D
17E5: CD2018  	            CALL I2C_SCL_LO     ;SCL low   (SCL lo, SDA hi/input)
17E8: 10ED    	            DJNZ  I2C_ReadRd_Loop       ;Repeat for all 8 bits
              	; Acknowledge input byte
              	; On arriving here, SCL = lo, SDA = hi/input
17EA: 7B      	            LD   A,E            ;Get acknowledge flag
17EB: B7      	            OR   A              ;A = 0? (indicates no acknowledge)
17EC: 2803    	            JR   Z, I2C_ReadNoAck       ;Yes, so skip acknowledge
17EE: CD2E18  	            CALL I2C_SDA_LO     ;SDA low   (SCL lo, SDA lo)
17F1: CD1918  	I2C_ReadNoAck:     CALL I2C_SCL_HI     ;SCL hi    (SCL hi, SDA lo)
17F4: CD2018  	            CALL I2C_SCL_LO     ;SCL low   (SCL lo, SDA lo)
17F7: 7A      	            LD   A,D            ;Get data byte received
17F8: D1      	            POP  DE             ;Restore registers
17F9: C1      	            POP  BC
17FA: BF      	            CP   A              ;Return success Z flagged
17FB: C9      	            RET
              	
              	
              	; I2C bus start
              	;   On entry: SCL = unknown, SDA = unknown
              	;   On exit:  SCL = low, SDA = low
              	;             A = 0 and Z flagged as we always succeed
              	;             BC DE HL IX IY preserved
              	; First ensure SDA and SCL are high
17FC: CD1518  	I2C_Start:  CALL I2C_INIT       ;Initialise I2C control port
              	;           CALL I2C_SCL_HI     ;SCL high  (SCL hi, SDA ??)
              	;           CALL I2C_SDA_HI     ;SDA high  (SCL hi, SDA hi)
              	; Generate I2C start condition
17FF: CD2E18  	            CALL I2C_SDA_LO     ;SDA low   (SCL hi, SDA lo)
1802: CD2018  	            CALL I2C_SCL_LO     ;SCL low   (SCL lo, SDA lo)
1805: AF      	            XOR  A              ;Return success A=0 and Z flagged
1806: C9      	            RET
              	
              	
              	; I2C bus stop 
              	;   On entry: SCL = unknown, SDA = unknown
              	;   On exit:  SCL = high, SDA = high
              	;             A = 0 and Z flagged as we always succeed
              	;             BC DE HL IX IY preserved
              	; First ensure SDA and SCL are low
1807: CD2E18  	I2C_Stop:   CALL I2C_SDA_LO     ;SDA low   (SCL hi, SDA lo)
180A: CD2018  	            CALL I2C_SCL_LO     ;SCL low   (SCL lo, SDA lo)
              	; Generate stop condition
180D: CD1918  	            CALL I2C_SCL_HI     ;SCL high  (SCL hi, SDA lo)
1810: CD2718  	            CALL I2C_SDA_HI     ;SDA low   (SCL hi, SDA hi)
1813: AF      	            XOR  A              ;Return success A=0 and Z flagged
1814: C9      	            RET
              	
              	
              	; **********************************************************************
              	; I2C bus simple I/O functions
              	;   On entry: No parameters required
              	;   On exit:  BC DE HL IX IY preserved
              	
