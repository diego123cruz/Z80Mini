1C46: 3E03    	    LD A, ERR_TOUT
1C48: B7      	    OR A
1C49: C9      	    RET
              	
              	
              	
              	; FS_ALLOC_PG: Aloca primeira pagina livre (>=2) no bitmap
              	;   Registradores: B=pagina, C=bit_index, D=byte_bitmap, E=byte_index, HL=ptr
              	;   On exit: A=pagina (NZ=ok)   A=0 (Z=sem espaco)
1C4A:         	FS_ALLOC_PG:
              	    ; Le os 16 bytes do bitmap para PG_BUF
1C4A: 110100  	    LD DE, $0001
1C4D: 2136FC  	    LD HL, PG_BUF
1C50: 011000  	    LD BC, 16
1C53: CD5A18  	    CALL I2C_MemRd
1C56: C0      	    RET NZ
              	
1C57: 0602    	    LD B, 2                 ; B = pagina corrente
              	
1C59:         	FS_AP_LOOP:
1C59: 78      	    LD A, B
1C5A: E607    	    AND $07
1C5C: 4F      	    LD C, A                 ; C = bit_index
              	
1C5D: 78      	    LD A, B
1C5E: CB3F    	    SRL A
1C60: CB3F    	    SRL A
1C62: CB3F    	    SRL A
1C64: 5F      	    LD E, A                 ; E = byte_index
              	
1C65: 2136FC  	    LD HL, PG_BUF
1C68: 1600    	    LD D, 0
1C6A: 19      	    ADD HL, DE
1C6B: 56      	    LD D, (HL)              ; D = byte do bitmap
              	
1C6C: 3E01    	    LD A, 1
1C6E:         	FS_AP_TBIT:
1C6E: 0D      	    DEC C
1C6F: FA751C  	    JP M, FS_AP_TBIT_DONE
1C72: 07      	    RLCA
1C73: 18F9    	    JR FS_AP_TBIT
1C75:         	FS_AP_TBIT_DONE:
1C75: A2      	    AND D                   ; 0=ocupado, !=0=livre
1C76: 2008    	    JR NZ, FS_AP_FOUND
              	
1C78: 04      	    INC B
1C79: 78      	    LD A, B
1C7A: FE80    	    CP 128
1C7C: 38DB    	    JR C, FS_AP_LOOP
1C7E: AF      	    XOR A                   ; Z = sem espaco
1C7F: C9      	    RET
              	
1C80:         	FS_AP_FOUND:
              	    ; B = pagina livre. Salva bit_index e byte_index.
1C80: 78      	    LD A, B
1C81: E607    	    AND $07
1C83: 3235FC  	    LD (FS_BMPADDR+1), A    ; bit_index
              	
1C86: 78      	    LD A, B
1C87: CB3F    	    SRL A
1C89: CB3F    	    SRL A
1C8B: CB3F    	    SRL A
1C8D: 5F      	    LD E, A                 ; E = byte_index
              	
              	    ; HL = PG_BUF + byte_index
1C8E: 2136FC  	    LD HL, PG_BUF
1C91: 1600    	    LD D, 0
1C93: 19      	    ADD HL, DE
              	
              	    ; Mascara = ~(1 << bit_index) para zerar o bit
1C94: 3A35FC  	    LD A, (FS_BMPADDR+1)
1C97: 4F      	    LD C, A
1C98: 3E01    	    LD A, 1
1C9A:         	FS_AP_MKSHL:
1C9A: 0D      	    DEC C
1C9B: FAA11C  	    JP M, FS_AP_MKINV
1C9E: 07      	    RLCA
1C9F: 18F9    	    JR FS_AP_MKSHL
1CA1:         	FS_AP_MKINV:
1CA1: 2F      	    CPL                     ; ~mascara
              	
1CA2: A6      	    AND (HL)
1CA3: 77      	    LD (HL), A              ; atualiza PG_BUF
              	
              	    ; Salva numero da pagina antes do LD BC,1 destruir B
1CA4: 78      	    LD A, B
1CA5: 3234FC  	    LD (FS_BMPADDR), A
              	
              	    ; Grava byte atualizado na EEPROM: addr = byte_index + 1
1CA8: 1600    	    LD D, 0
1CAA: 1C      	    INC E                   ; E = byte_index + 1
1CAB: 010100  	    LD BC, 1
1CAE: CD9218  	    CALL I2C_MemWr
1CB1: C0      	    RET NZ
              	
1CB2: 3A34FC  	    LD A, (FS_BMPADDR)      ; A = pagina alocada
1CB5: B7      	    OR A                    ; NZ = sucesso
1CB6: C9      	    RET
              	
              	; FS_FREE_PG: Libera pagina A no bitmap (seta bit = 1)
              	;   On exit: Z=OK  NZ=erro I2C
1CB7:         	FS_FREE_PG:
1CB7: C5      	    PUSH BC
1CB8: D5      	    PUSH DE
1CB9: E5      	    PUSH HL
1CBA: F5      	    PUSH AF                 ; salva numero da pagina
              	
              	    ; bit_index = pagina mod 8
1CBB: E607    	    AND $07
1CBD: 4F      	    LD C, A                 ; C = bit_index
              	
              	    ; byte_index = pagina / 8 → endereco EEPROM = byte_index + 1
1CBE: F1      	    POP AF
1CBF: F5      	    PUSH AF
1CC0: CB3F    	    SRL A
1CC2: CB3F    	    SRL A
1CC4: CB3F    	    SRL A                   ; A = byte_index
1CC6: 3C      	    INC A                   ; A = endereco EEPROM (1..16)
1CC7: 3234FC  	    LD (FS_BMPADDR), A      ; salva endereco
              	
              	    ; Le byte atual do bitmap
              	    ; ATENCAO: LD BC,1 vai sobrescrever C (bit_index)!
              	    ; Salva C na RAM antes.
1CCA: 79      	    LD A, C
1CCB: 3235FC  	    LD (FS_BMPADDR+1), A    ; salva bit_index em FS_BMPADDR+1
              	
1CCE: 3A34FC  	    LD A, (FS_BMPADDR)
1CD1: 5F      	    LD E, A
1CD2: 1600    	    LD D, 0
1CD4: 212DFC  	    LD HL, FS_TMP1
1CD7: 010100  	    LD BC, 1
1CDA: CD5A18  	    CALL I2C_MemRd
1CDD: C2061D  	    JP NZ, FS_FP_ERR
              	
              	    ; Recupera bit_index
1CE0: 3A35FC  	    LD A, (FS_BMPADDR+1)
1CE3: 4F      	    LD C, A                 ; C = bit_index restaurado
              	
              	    ; Constroi mascara = 1 << bit_index
1CE4: 3E01    	    LD A, 1
1CE6:         	FS_FP_SHL:
1CE6: 0D      	    DEC C
1CE7: FAED1C  	    JP M, FS_FP_OR
1CEA: 07      	    RLCA
1CEB: 18F9    	    JR FS_FP_SHL
              	
1CED:         	FS_FP_OR:
1CED: 47      	    LD B, A
1CEE: 3A2DFC  	    LD A, (FS_TMP1)
1CF1: B0      	    OR B                    ; seta o bit (marca pagina como livre)
1CF2: 322DFC  	    LD (FS_TMP1), A
              	
              	    ; Grava
1CF5: 3A34FC  	    LD A, (FS_BMPADDR)
1CF8: 5F      	    LD E, A
1CF9: 1600    	    LD D, 0
1CFB: 212DFC  	    LD HL, FS_TMP1
1CFE: 010100  	    LD BC, 1
1D01: CD9218  	    CALL I2C_MemWr
1D04: 1808    	    JR FS_FP_DONE
              	
1D06:         	FS_FP_ERR:
1D06: F1      	    POP AF
1D07: E1      	    POP HL
1D08: D1      	    POP DE
1D09: C1      	    POP BC
1D0A: 3E01    	    LD A, 1
1D0C: B7      	    OR A
1D0D: C9      	    RET
              	
1D0E:         	FS_FP_DONE:
1D0E: F1      	    POP AF
1D0F: E1      	    POP HL
1D10: D1      	    POP DE
1D11: C1      	    POP BC
1D12: C9      	    RET
              	
              	; FS_FREE_CHAIN: Libera cadeia de paginas a partir da pagina A
              	;   On exit: Z=OK  NZ=erro
1D13:         	FS_FREE_CHAIN:
1D13: B7      	    OR A
1D14: C8      	    RET Z
              	
1D15:         	FS_FC_LP:
1D15: 3234FC  	    LD (FS_BMPADDR), A      ; salva pagina corrente
              	
              	    ; Primeiro le o next page (antes de liberar)
1D18: 57      	    LD D, A
1D19: 1E00    	    LD E, 0
1D1B: 212DFC  	    LD HL, FS_TMP1
1D1E: 010100  	    LD BC, 1
1D21: CD5A18  	    CALL I2C_MemRd
1D24: 201C    	    JR NZ, FS_FC_ERR
              	
              	    ; Salva next page no stack (FS_FREE_PG vai usar FS_BMPADDR/+1)
1D26: 3A2DFC  	    LD A, (FS_TMP1)
1D29: F5      	    PUSH AF                 ; [1] next page
              	
              	    ; Pequeno delay para o barramento I2C se estabilizar entre as operacoes
              	    ; Abre e fecha a EEPROM ate receber ACK (write cycle polling)
1D2A:         	FS_FC_WAIT:
1D2A: 3EAE    	    LD A, $AE
1D2C: CD5617  	    CALL I2C_Open
1D2F: CD5D17  	    CALL I2C_Close
1D32: 20F6    	    JR NZ, FS_FC_WAIT       ; aguarda EEPROM pronta
              	
              	    ; Libera a pagina
1D34: 3A34FC  	    LD A, (FS_BMPADDR)
1D37: CDB71C  	    CALL FS_FREE_PG
1D3A: 2010    	    JR NZ, FS_FC_ERR2
              	
1D3C: F1      	    POP AF                  ; [1] A = next page
1D3D: B7      	    OR A
1D3E: 20D5    	    JR NZ, FS_FC_LP         ; continua na proxima pagina
              	
1D40: AF      	    XOR A
1D41: C9      	    RET
              	
1D42:         	FS_FC_ERR:
1D42: 21571D  	    LD HL, str_fc_err
1D45: CD8303  	    CALL PUTS
1D48: 3E01    	    LD A, 1
1D4A: B7      	    OR A
1D4B: C9      	    RET
1D4C:         	FS_FC_ERR2:
1D4C: F1      	    POP AF                  ; [1]
1D4D: 21571D  	    LD HL, str_fc_err
1D50: CD8303  	    CALL PUTS
1D53: 3E01    	    LD A, 1
1D55: B7      	    OR A
1D56: C9      	    RET
              	
1D57: 46432045	str_fc_err:  .TEXT "FC ERRO!"
1D5B: 52524F21	
1D5F: 0D0A00  	             .DB CR, LF, 0
              	
              	
              	
              	; FS_WRITE_PG: Grava pagina A com dados de FS_TMPRAM
              	;   Grava min(FS_TMPSZ, 255) bytes. Atualiza FS_TMPRAM e FS_TMPSZ.
              	;   byte 0 da pagina = $00 (next=fim; FS_SET_NEXT corrige se necessario)
              	;   On exit: Z=OK  NZ=erro
              	;   Preserva: BC DE HL
1D62:         	FS_WRITE_PG:
1D62: C5      	    PUSH BC
1D63: D5      	    PUSH DE
1D64: E5      	    PUSH HL
1D65: F5      	    PUSH AF                 ; A = numero da pagina
              	
              	    ; Calcula quantos bytes gravar: min(FS_TMPSZ, 255)
1D66: 2A2EFC  	    LD HL, (FS_TMPSZ)
1D69: 7C      	    LD A, H
1D6A: B7      	    OR A
1D6B: 2005    	    JR NZ, FS_WP_USE255     ; HL >= 256: usa 255
1D6D: 7D      	    LD A, L
1D6E: FEFF    	    CP FS_DATAPG            ; L < 255?
1D70: 3804    	    JR C, FS_WP_USELT       ; sim: usa L
1D72:         	FS_WP_USE255:
1D72: 0EFF    	    LD C, FS_DATAPG         ; C = 255
1D74: 1801    	    JR FS_WP_COPY
1D76:         	FS_WP_USELT:
1D76: 4D      	    LD C, L                 ; C = L (< 255)
              	
1D77:         	FS_WP_COPY:
              	    ; C = bytes a gravar (1..255). Salva em D para nao perder.
1D77: 51      	    LD D, C                 ; D = bytes a gravar
              	
              	    ; Monta PG_BUF[0..$FF]:
              	    ;   [0]    = $00 (next page, sera corrigido por FS_SET_NEXT)
              	    ;   [1..C] = dados da RAM
              	    ;   [C+1..$FF] = $FF (padding)
1D78: 2136FC  	    LD HL, PG_BUF
1D7B: 3600    	    LD (HL), $00            ; byte 0 = next = $00
1D7D: 23      	    INC HL                  ; HL = PG_BUF + 1
              	
              	    ; Copia D bytes de FS_TMPRAM para PG_BUF+1
              	    ; Usa IX como ponteiro de origem (LD BC,(nn) pode nao funcionar no zasm)
1D7E: DD2A30FC	    LD IX, (FS_TMPRAM)      ; IX = ponteiro RAM origem
1D82: 5A      	    LD E, D                 ; E = contador de copia
1D83:         	FS_WP_CPLOOP:
1D83: DD7E00  	    LD A, (IX+0)            ; le da RAM origem
1D86: 77      	    LD (HL), A              ; grava no PG_BUF
1D87: DD23    	    INC IX
1D89: 23      	    INC HL
1D8A: 1D      	    DEC E
1D8B: 20F6    	    JR NZ, FS_WP_CPLOOP
              	
              	    ; Padding $FF ate completar 256 bytes (posicoes D+1 a 255)
              	    ; Bytes de padding = 255 - D
1D8D: 3EFF    	    LD A, FS_DATAPG         ; 255
1D8F: 92      	    SUB D                   ; A = 255 - D (bytes de padding)
1D90: 2807    	    JR Z, FS_WP_NOPAD       ; sem padding (D=255, pagina cheia)
1D92: 5F      	    LD E, A
1D93:         	FS_WP_PADLOOP:
1D93: 36FF    	    LD (HL), $FF
1D95: 23      	    INC HL
1D96: 1D      	    DEC E
1D97: 20FA    	    JR NZ, FS_WP_PADLOOP
1D99:         	FS_WP_NOPAD:
              	
              	    ; Grava PG_BUF inteiro (256 bytes) na EEPROM
              	    ; Endereco EEPROM = pagina * 256 (D = pagina, E = 0)
1D99: F1      	    POP AF                  ; A = numero da pagina
1D9A: F5      	    PUSH AF
1D9B: 57      	    LD D, A
1D9C: 1E00    	    LD E, 0
1D9E: 2136FC  	    LD HL, PG_BUF
1DA1: 010001  	    LD BC, 256
1DA4: CD9218  	    CALL I2C_MemWr
1DA7: C2D41D  	    JP NZ, FS_WP_ERR
              	
              	    ; Atualiza FS_TMPRAM += D_bytes_gravados
1DAA: F1      	    POP AF                  ; A = pagina (descarta)
1DAB: E1      	    POP HL                  ; restaura HL original
1DAC: D1      	    POP DE                  ; restaura DE original
1DAD: C1      	    POP BC                  ; restaura BC original
              	
              	    ; Recalcula com D = bytes gravados
              	    ; D foi preservado? Nao — foi sobrescrito por LD D, A (pagina).
              	    ; Usamos FS_TMPSZ antes e depois para calcular o que foi gravado:
              	    ; bytes_gravados = min(TMPSZ_antes, 255)
              	    ; Mais simples: relemos FS_TMPSZ e FS_TMPRAM e atualizamos
              	    ; Mas D foi sobrescrito... precisamos salvar D antes do I2C_MemWr.
              	    ; SOLUCAO: salvar D (bytes) em FS_TMP1 antes de gravar.
              	    ; Para nao refatorar todo o fluxo acima, usamos um truque:
              	    ; bytes_gravados = FS_TMPSZ se < 255, ou 255 se >= 255.
              	    ; Recalcula de FS_TMPSZ:
1DAE: 2A2EFC  	    LD HL, (FS_TMPSZ)
1DB1: 7C      	    LD A, H
1DB2: B7      	    OR A
1DB3: 2005    	    JR NZ, FS_WP_UPD255
1DB5: 7D      	    LD A, L
1DB6: FEFF    	    CP FS_DATAPG
1DB8: 3805    	    JR C, FS_WP_UPDLT
1DBA:         	FS_WP_UPD255:
1DBA: 01FF00  	    LD BC, FS_DATAPG        ; bytes gravados = 255
1DBD: 1803    	    JR FS_WP_UPDATE
1DBF:         	FS_WP_UPDLT:
1DBF: 0600    	    LD B, 0
1DC1: 4D      	    LD C, L                 ; bytes gravados = L
              	
1DC2:         	FS_WP_UPDATE:
              	    ; FS_TMPRAM += BC
1DC2: 2A30FC  	    LD HL, (FS_TMPRAM)
1DC5: 09      	    ADD HL, BC
1DC6: 2230FC  	    LD (FS_TMPRAM), HL
              	    ; FS_TMPSZ -= BC
1DC9: 2A2EFC  	    LD HL, (FS_TMPSZ)
1DCC: B7      	    OR A                    ; limpa carry
1DCD: ED42    	    SBC HL, BC
1DCF: 222EFC  	    LD (FS_TMPSZ), HL
1DD2: AF      	    XOR A                   ; Z = sucesso
1DD3: C9      	    RET
              	
1DD4:         	FS_WP_ERR:
1DD4: F1      	    POP AF
1DD5: E1      	    POP HL
1DD6: D1      	    POP DE
1DD7: C1      	    POP BC
1DD8: 3E01    	    LD A, 1
1DDA: B7      	    OR A
1DDB: C9      	    RET
              	
              	; FS_SET_NEXT: Escreve byte 0 da pagina A com valor B
              	;   On exit: Z=OK  NZ=erro
1DDC:         	FS_SET_NEXT:
1DDC: C5      	    PUSH BC
1DDD: D5      	    PUSH DE
1DDE: E5      	    PUSH HL
1DDF: 57      	    LD D, A
1DE0: 1E00    	    LD E, 0
1DE2: 78      	    LD A, B
1DE3: 322DFC  	    LD (FS_TMP1), A
1DE6: 212DFC  	    LD HL, FS_TMP1
1DE9: 010100  	    LD BC, 1
1DEC: CD9218  	    CALL I2C_MemWr
1DEF: E1      	    POP HL
1DF0: D1      	    POP DE
1DF1: C1      	    POP BC
1DF2: C9      	    RET
              	
              	
              	
              	; FS_FIND_NAME: Busca FS_NAMBUF no diretorio
              	;   On exit: Z=encontrado (FS_CUR=idx, FS_WRKBUF=entrada)
              	;            NZ=nao encontrado
1DF3:         	FS_FIND_NAME:
