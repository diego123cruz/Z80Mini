1272:         	LCD_SCROLL:
1272: CD7803  	    CALL PUTCHAR
1275: 1805    	    JR GETLINE_LOOP
              	
              	
              	; --- GETLINE: Lê linha para LINEBUF; eco local ---
              	;     Termina em CR. Suporta BS/DEL para apagar.
1277:         	GETLINE:
1277: 21A0FB  	            LD   HL, LINEBUF
127A: 064F    	            LD   B, 79               ; Máx 79 chars + NUL
127C:         	GETLINE_LOOP:
127C: CDAA02  	            CALL CONIN
127F: FE0D    	            CP   CR
1281: 2845    	            JR   Z, GETLINE_DONE
1283: FEF8    	            CP   $F8    ; ignora scroll up - GLCD
1285: 28EB    	            JR   Z, LCD_SCROLL
1287: FEF7    	            CP   $F7    ; ignora scroll down - GLCD
1289: 28E7    	            JR   Z, LCD_SCROLL
128B: FE0A    	            CP   LF
128D: 28ED    	            JR   Z, GETLINE_LOOP    ; Ignora LF
128F: FE08    	            CP   BkS
1291: 281D    	            JR   Z, GETLINE_BS
1293: FE7F    	            CP   DEL
1295: 2819    	            JR   Z, GETLINE_BS
1297: FEFA    	            CP   $FA ; AltGr
1299: CA7E15  	            JP   Z, CALL_IHEX
129C: FEF9    	            CP   $F9 ; LUZ
129E: CAB510  	            JP   Z, CALL_8000
12A1: 4F      	            LD   C, A
12A2: 78      	            LD   A, B
12A3: FE00    	            CP   0
12A5: 28D5    	            JR   Z, GETLINE_LOOP    ; Buffer cheio
12A7: 79      	            LD   A, C
12A8: 77      	            LD   (HL), A
12A9: 23      	            INC  HL
12AA: 05      	            DEC  B
12AB: CD7803  	            CALL PUTCHAR             ; Eco
12AE: 18CC    	            JR   GETLINE_LOOP
12B0:         	GETLINE_BS:
12B0: 78      	            LD   A, B
12B1: FE4F    	            CP   79
12B3: 28C7    	            JR   Z, GETLINE_LOOP    ; Início: ignora BS
12B5: 2B      	            DEC  HL
12B6: 04      	            INC  B
12B7: 3E08    	            LD   A, BkS
12B9: CD7803  	            CALL PUTCHAR
12BC: 3E20    	            LD   A, SPACE
12BE: CD7803  	            CALL PUTCHAR
12C1: 3E08    	            LD   A, BkS
12C3: CD7803  	            CALL PUTCHAR
12C6: 18B4    	            JR   GETLINE_LOOP
