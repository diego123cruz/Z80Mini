              	;             SCL = unknown, SDA = unknown
              	;   On exit:  If successfully A = 0 and Z flagged
              	;             If unsuccessfully A = Error and NZ flagged
              	;             IX IY preserved
              	; The 24LC64 requires blocks of data to be written in 64 byte (or less)
              	; pages.
18A8: C5      	I2C_MemWr:  PUSH BC
18A9: 011027  	            LD   BC,TIMEOUT     ;Timeout loop counter
18AC:         	I2C_MemWrRepeat:    
18AC: 3A01FC  	            LD   A, (I2CA_BLOCK)   ;I2C address to write to
18AF: CD6C17  	            CALL I2C_Open       ;Open for write
18B2: 280A    	            JR   Z,I2C_MemWrReady       ;If open okay then skip on
18B4: 0B      	            DEC  BC
18B5: 78      	            LD   A,B
18B6: B1      	            OR   C              ;Timeout?
18B7: 20F3    	            JR   NZ,I2C_MemWrRepeat     ;No, so go try again
18B9: C1      	            POP  BC
18BA: 3E03    	            LD   A,ERR_TOUT     ;Error code
18BC: B7      	            OR   A              ;Error, so NZ flagged
18BD: C9      	            RET                 ;Return with error
              	; Device opened okay
18BE: C1      	I2C_MemWrReady:     POP  BC             ;Restore byte counter
18BF: 7A      	I2C_MemWrBlock:     LD   A,D            ;Address (hi) in I2C memory
18C0: CD7617  	            CALL I2C_Write      ;Write address
18C3: 7B      	            LD   A,E            ;Address (lo) in I2C memory
18C4: CD7617  	            CALL I2C_Write      ;Write address
18C7: 7E      	I2C_MemWrWrite:     LD   A,(HL)         ;Get data byte from CPU memory
18C8: CD7617  	            CALL I2C_Write      ;Read byte from I2C memory
18CB: 23      	            INC  HL             ;Increment CPU memory pointer
18CC: 13      	            INC  DE             ;Increment I2C memory pointer
18CD: 0B      	            DEC  BC             ;Decrement byte counter
18CE: 78      	            LD   A,B
18CF: B1      	            OR   C              ;Finished?
18D0: 2805    	            JR   Z,I2C_MemWrStore       ;Yes, so go store this page
18D2: 7B      	            LD   A,E            ;Get address in I2C memory (lo byte)
18D3: E63F    	            AND  63             ;64 byte page boundary?
18D5: 20F0    	            JR   NZ,I2C_MemWrWrite      ;No, so go write another byte
18D7: CDEB17  	I2C_MemWrStore:     CALL I2C_Stop       ;Generate I2C stop
18DA: 78      	            LD   A,B
18DB: B1      	            OR   C              ;Finished?
18DC: 20CA    	            JR   NZ,I2C_MemWr   ;No, so go write some more
18DE: C9      	            RET   
              	
              	
              	; Hex byte output to console
              	;   On entry: A = Byte to be output in hex
              	;   On exit:  BC DE HL IX IY preserved
18DF: F5      	HexOut:     PUSH AF             ;Preserve byte to be output
18E0: 1F      	            RRA                 ;Shift top nibble to
18E1: 1F      	            RRA                 ;  botom four bits..
18E2: 1F      	            RRA
18E3: 1F      	            RRA
18E4: E60F    	            AND  $0F           ;Mask off unwanted bits
18E6: CDEC18  	            CALL HexOutHex           ;Output hi nibble
18E9: F1      	            POP  AF             ;Restore byte to be output
18EA: E60F    	            AND  $0F           ;Mask off unwanted bits
              	; Output nibble as ascii character
18EC: FE0A    	HexOutHex:       CP   $0A           ;Nibble > 10 ?
18EE: 3802    	            JR   C,HexOutSkip        ;No, so skip
18F0: C607    	            ADD  A,7            ;Yes, so add 7
18F2: C630    	HexOutSkip:      ADD  A,$30         ;Add ASCII '0'
18F4: CD8B03  	            CALL CONOUT       ;Write character
18F7: C9      	            RET
