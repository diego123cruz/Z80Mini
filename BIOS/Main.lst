1D63: 216D1D  	    LD HL, str_fc_err
1D66: CD9703  	    CALL PUTS
1D69: 3E01    	    LD A, 1
1D6B: B7      	    OR A
1D6C: C9      	    RET
              	
1D6D: 46432045	str_fc_err:  .TEXT "FC ERRO!"
1D71: 52524F21	
1D75: 0D0A00  	             .DB CR, LF, 0
              	
              	
              	
              	; FS_WRITE_PG: Grava pagina A com dados de FS_TMPRAM
              	;   Grava min(FS_TMPSZ, 255) bytes. Atualiza FS_TMPRAM e FS_TMPSZ.
              	;   byte 0 da pagina = $00 (next=fim; FS_SET_NEXT corrige se necessario)
              	;   On exit: Z=OK  NZ=erro
              	;   Preserva: BC DE HL
1D78:         	FS_WRITE_PG:
1D78: C5      	    PUSH BC
1D79: D5      	    PUSH DE
1D7A: E5      	    PUSH HL
1D7B: F5      	    PUSH AF                 ; A = numero da pagina
              	
              	    ; Calcula quantos bytes gravar: min(FS_TMPSZ, 255)
1D7C: 2A32FC  	    LD HL, (FS_TMPSZ)
1D7F: 7C      	    LD A, H
1D80: B7      	    OR A
1D81: 2005    	    JR NZ, FS_WP_USE255     ; HL >= 256: usa 255
1D83: 7D      	    LD A, L
1D84: FEFF    	    CP FS_DATAPG            ; L < 255?
1D86: 3804    	    JR C, FS_WP_USELT       ; sim: usa L
1D88:         	FS_WP_USE255:
1D88: 0EFF    	    LD C, FS_DATAPG         ; C = 255
1D8A: 1801    	    JR FS_WP_COPY
1D8C:         	FS_WP_USELT:
1D8C: 4D      	    LD C, L                 ; C = L (< 255)
              	
1D8D:         	FS_WP_COPY:
              	    ; C = bytes a gravar (1..255). Salva em D para nao perder.
1D8D: 51      	    LD D, C                 ; D = bytes a gravar
              	
              	    ; Monta PG_BUF[0..$FF]:
              	    ;   [0]    = $00 (next page, sera corrigido por FS_SET_NEXT)
              	    ;   [1..C] = dados da RAM
              	    ;   [C+1..$FF] = $FF (padding)
1D8E: 213AFC  	    LD HL, PG_BUF
1D91: 3600    	    LD (HL), $00            ; byte 0 = next = $00
1D93: 23      	    INC HL                  ; HL = PG_BUF + 1
              	
              	    ; Copia D bytes de FS_TMPRAM para PG_BUF+1
              	    ; Usa IX como ponteiro de origem (LD BC,(nn) pode nao funcionar no zasm)
1D94: DD2A34FC	    LD IX, (FS_TMPRAM)      ; IX = ponteiro RAM origem
1D98: 5A      	    LD E, D                 ; E = contador de copia
1D99:         	FS_WP_CPLOOP:
1D99: DD7E00  	    LD A, (IX+0)            ; le da RAM origem
1D9C: 77      	    LD (HL), A              ; grava no PG_BUF
1D9D: DD23    	    INC IX
1D9F: 23      	    INC HL
1DA0: 1D      	    DEC E
1DA1: 20F6    	    JR NZ, FS_WP_CPLOOP
              	
              	    ; Padding $FF ate completar 256 bytes (posicoes D+1 a 255)
              	    ; Bytes de padding = 255 - D
1DA3: 3EFF    	    LD A, FS_DATAPG         ; 255
1DA5: 92      	    SUB D                   ; A = 255 - D (bytes de padding)
1DA6: 2807    	    JR Z, FS_WP_NOPAD       ; sem padding (D=255, pagina cheia)
1DA8: 5F      	    LD E, A
1DA9:         	FS_WP_PADLOOP:
1DA9: 36FF    	    LD (HL), $FF
1DAB: 23      	    INC HL
1DAC: 1D      	    DEC E
1DAD: 20FA    	    JR NZ, FS_WP_PADLOOP
1DAF:         	FS_WP_NOPAD:
              	
              	    ; Grava PG_BUF inteiro (256 bytes) na EEPROM
              	    ; Endereco EEPROM = pagina * 256 (D = pagina, E = 0)
1DAF: F1      	    POP AF                  ; A = numero da pagina
1DB0: F5      	    PUSH AF
1DB1: 57      	    LD D, A
1DB2: 1E00    	    LD E, 0
1DB4: 213AFC  	    LD HL, PG_BUF
1DB7: 010001  	    LD BC, 256
1DBA: CDA818  	    CALL I2C_MemWr
1DBD: C2EA1D  	    JP NZ, FS_WP_ERR
              	
              	    ; Atualiza FS_TMPRAM += D_bytes_gravados
1DC0: F1      	    POP AF                  ; A = pagina (descarta)
1DC1: E1      	    POP HL                  ; restaura HL original
1DC2: D1      	    POP DE                  ; restaura DE original
1DC3: C1      	    POP BC                  ; restaura BC original
              	
              	    ; Recalcula com D = bytes gravados
              	    ; D foi preservado? Nao — foi sobrescrito por LD D, A (pagina).
              	    ; Usamos FS_TMPSZ antes e depois para calcular o que foi gravado:
              	    ; bytes_gravados = min(TMPSZ_antes, 255)
              	    ; Mais simples: relemos FS_TMPSZ e FS_TMPRAM e atualizamos
              	    ; Mas D foi sobrescrito... precisamos salvar D antes do I2C_MemWr.
              	    ; SOLUCAO: salvar D (bytes) em FS_TMP1 antes de gravar.
              	    ; Para nao refatorar todo o fluxo acima, usamos um truque:
              	    ; bytes_gravados = FS_TMPSZ se < 255, ou 255 se >= 255.
              	    ; Recalcula de FS_TMPSZ:
1DC4: 2A32FC  	    LD HL, (FS_TMPSZ)
1DC7: 7C      	    LD A, H
1DC8: B7      	    OR A
1DC9: 2005    	    JR NZ, FS_WP_UPD255
1DCB: 7D      	    LD A, L
1DCC: FEFF    	    CP FS_DATAPG
1DCE: 3805    	    JR C, FS_WP_UPDLT
1DD0:         	FS_WP_UPD255:
1DD0: 01FF00  	    LD BC, FS_DATAPG        ; bytes gravados = 255
1DD3: 1803    	    JR FS_WP_UPDATE
1DD5:         	FS_WP_UPDLT:
1DD5: 0600    	    LD B, 0
1DD7: 4D      	    LD C, L                 ; bytes gravados = L
              	
1DD8:         	FS_WP_UPDATE:
              	    ; FS_TMPRAM += BC
1DD8: 2A34FC  	    LD HL, (FS_TMPRAM)
1DDB: 09      	    ADD HL, BC
1DDC: 2234FC  	    LD (FS_TMPRAM), HL
              	    ; FS_TMPSZ -= BC
1DDF: 2A32FC  	    LD HL, (FS_TMPSZ)
1DE2: B7      	    OR A                    ; limpa carry
1DE3: ED42    	    SBC HL, BC
1DE5: 2232FC  	    LD (FS_TMPSZ), HL
1DE8: AF      	    XOR A                   ; Z = sucesso
1DE9: C9      	    RET
              	
