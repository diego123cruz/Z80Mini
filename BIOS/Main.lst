1CF6: 3A39FC  	    LD A, (FS_BMPADDR+1)
1CF9: 4F      	    LD C, A                 ; C = bit_index restaurado
              	
              	    ; Constroi mascara = 1 << bit_index
1CFA: 3E01    	    LD A, 1
1CFC:         	FS_FP_SHL:
