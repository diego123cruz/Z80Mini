1C6F: 78      	    LD A, B
1C70: E607    	    AND $07
1C72: 4F      	    LD C, A                 ; C = bit_index
              	
1C73: 78      	    LD A, B
1C74: CB3F    	    SRL A
1C76: CB3F    	    SRL A
1C78: CB3F    	    SRL A
1C7A: 5F      	    LD E, A                 ; E = byte_index
              	
1C7B: 213AFC  	    LD HL, PG_BUF
1C7E: 1600    	    LD D, 0
1C80: 19      	    ADD HL, DE
1C81: 56      	    LD D, (HL)              ; D = byte do bitmap
              	
1C82: 3E01    	    LD A, 1
