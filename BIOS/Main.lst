              	; Preenche FS_NAMBUF com NUL, depois copia buffer em DE até NUL(0) ou SPACE
              	; Nome não pode ter espaços e Diego != diego
1BCD:         	FS_COPY_NAME_FROM_BUFFER:
1BCD: 0609    	    LD B, FS_NAME_SZ + 1
1BCF: 2123FC  	    LD HL, FS_NAMBUF
1BD2: AF      	    XOR A
1BD3:         	FS_CLEAR_NUL:
1BD3: 77      	    LD (HL), A
1BD4: 23      	    INC HL
1BD5: 10FC    	    djnz FS_CLEAR_NUL
              	
1BD7: 0609    	    LD B, FS_NAME_SZ + 1
1BD9: 2123FC  	    LD HL, FS_NAMBUF
1BDC:         	FS_COPY_NAME_FROM_BUFFER_LOOP:
1BDC: 1A      	    LD A, (DE)
1BDD: FE00    	    CP NUL
1BDF: C8      	    RET Z
1BE0: FE20    	    CP SPACE
1BE2: C8      	    RET Z
1BE3: 77      	    LD (HL), A
1BE4: 23      	    INC HL
1BE5: 13      	    INC DE
1BE6: 10F4    	    djnz FS_COPY_NAME_FROM_BUFFER_LOOP
1BE8: C9      	    RET
              	
              	; FS_RD_ENTRY: Le entrada FS_CUR → FS_WRKBUF
              	;   EEPROM addr = $0100 + FS_CUR*32
              	;   On exit: Z=OK  NZ=erro
1BE9:         	FS_RD_ENTRY:
1BE9: C5      	    PUSH BC
1BEA: D5      	    PUSH DE
1BEB: E5      	    PUSH HL
1BEC: 3A02FC  	    LD A, (FS_CUR)
1BEF: 07      	    RLCA
1BF0: 07      	    RLCA
1BF1: 07      	    RLCA
1BF2: 07      	    RLCA
1BF3: 07      	    RLCA                    ; A = FS_CUR * 32
1BF4: 5F      	    LD E, A
1BF5: 1601    	    LD D, $01
1BF7: 2103FC  	    LD HL, FS_WRKBUF
1BFA: 012000  	    LD BC, FS_ENTRY_SZ
1BFD: CD5A18  	    CALL I2C_MemRd
1C00: E1      	    POP HL
1C01: D1      	    POP DE
1C02: C1      	    POP BC
1C03: C9      	    RET
              	
              	
              	; FS_WR_ENTRY: Grava FS_WRKBUF → EEPROM posicao FS_CUR
              	;   On exit: Z=OK  NZ=erro
1C04:         	FS_WR_ENTRY:
1C04: C5      	    PUSH BC
1C05: D5      	    PUSH DE
1C06: E5      	    PUSH HL
1C07: 3A02FC  	    LD A, (FS_CUR)
1C0A: 07      	    RLCA
1C0B: 07      	    RLCA
1C0C: 07      	    RLCA
1C0D: 07      	    RLCA
1C0E: 07      	    RLCA
1C0F: 5F      	    LD E, A
1C10: 1601    	    LD D, $01
1C12: 2103FC  	    LD HL, FS_WRKBUF
1C15: 012000  	    LD BC, FS_ENTRY_SZ
1C18: CD9218  	    CALL I2C_MemWr
1C1B: E1      	    POP HL
1C1C: D1      	    POP DE
1C1D: C1      	    POP BC
1C1E: C9      	    RET
              	
              	
              	; FS_FIND_FREE: Acha slot livre no diretorio
              	;   On exit: Z=encontrado (FS_CUR=idx)  NZ=cheio
1C1F:         	FS_FIND_FREE:
1C1F: AF      	    XOR A
1C20: 3202FC  	    LD (FS_CUR), A
1C23: 0608    	    LD B, FS_MAXFILES
1C25:         	FS_FF_LP:
1C25: C5      	    PUSH BC
1C26: CDE91B  	    CALL FS_RD_ENTRY
1C29: C2451C  	    JP NZ, FS_FF_ERR
1C2C: 3A10FC  	    LD A, (FS_WRKBUF + FS_O_FLAGS)
1C2F: FEFF    	    CP FS_FLAG_FREE
1C31: CA421C  	    JP Z, FS_FF_FOUND
1C34: 3A02FC  	    LD A, (FS_CUR)
1C37: 3C      	    INC A
1C38: 3202FC  	    LD (FS_CUR), A
1C3B: C1      	    POP BC
1C3C: 10E7    	    DJNZ FS_FF_LP
1C3E: 3E01    	    LD A, 1
1C40: B7      	    OR A
1C41: C9      	    RET
1C42:         	FS_FF_FOUND:
1C42: C1      	    POP BC
1C43: AF      	    XOR A
1C44: C9      	    RET
1C45:         	FS_FF_ERR:
