              	;------------------------------------------------------------------------------
              	; Pegar 2 caracteres ASCII (0-9 A-F) converte em um byte em A
              	;------------------------------------------------------------------------------
1FB4: CD6E16  	SERIAL_GET_HEX_A:   CALL GETCHR_S	; Get us a valid character to work with
1FB7: 47      	    LD   B,A	; Load it in B
1FB8: CD6E16  	    CALL GETCHR_S	; Get us another character
1FBB: 4F      	    LD   C,A	; load it in C
1FBC: CD8A16  	    CALL BCTOA	; Convert ASCII to byte
1FBF: C9      	    RET
              	
              	;------------------------------------------------------------------------------
              	; Pegar 4 caracteres ASCII (0-9 A-F) converte em HL
              	;------------------------------------------------------------------------------
1FC0:         	SERIAL_GET_HEX_HL:
1FC0: CDB41F  	    CALL SERIAL_GET_HEX_A	        ; Endereco High -> H
1FC3: 67      		LD   H,A
1FC4: CDB41F  		CALL SERIAL_GET_HEX_A	        ; Endereco Low -> L
1FC7: 6F      		LD   L,A
1FC8: C9      	    RET
              	
              	
              	
