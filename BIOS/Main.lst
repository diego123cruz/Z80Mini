1C06: D5      	    PUSH DE
1C07: E5      	    PUSH HL
1C08: 3A02FC  	    LD A, (FS_CUR)
1C0B: 07      	    RLCA
1C0C: 07      	    RLCA
1C0D: 07      	    RLCA
1C0E: 07      	    RLCA
1C0F: 07      	    RLCA
1C10: 5F      	    LD E, A
1C11: 1601    	    LD D, $01
1C13: 2103FC  	    LD HL, FS_WRKBUF
1C16: 012000  	    LD BC, FS_ENTRY_SZ
1C19: CD9318  	    CALL I2C_MemWr
1C1C: E1      	    POP HL
1C1D: D1      	    POP DE
1C1E: C1      	    POP BC
1C1F: C9      	    RET
              	
              	
              	; FS_FIND_FREE: Acha slot livre no diretorio
              	;   On exit: Z=encontrado (FS_CUR=idx)  NZ=cheio
1C20:         	FS_FIND_FREE:
