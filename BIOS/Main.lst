19B6: B7      	    OR A
19B7: 2848    	    JR Z, FS_DL_DONE
              	
              	    ; Le byte 0 (next page)
19B9: 57      	    LD D, A
19BA: 1E00    	    LD E, 0
19BC: 212DFC  	    LD HL, FS_TMP1
19BF: 010100  	    LD BC, 1
19C2: CD5B18  	    CALL I2C_MemRd
19C5: C0      	    RET NZ
              	
              	    ; min(FS_TMPSZ, 255) bytes a ler
19C6: 2A2EFC  	    LD HL, (FS_TMPSZ)
19C9: 7C      	    LD A, H
19CA: B7      	    OR A
19CB: 2005    	    JR NZ, FS_DL_255
19CD: 7D      	    LD A, L
19CE: FEFF    	    CP FS_DATAPG
19D0: 3805    	    JR C, FS_DL_LT
19D2:         	FS_DL_255:
19D2: 01FF00  	    LD BC, FS_DATAPG
19D5: 1803    	    JR FS_DL_RD
19D7:         	FS_DL_LT:
19D7: 0600    	    LD B, 0
19D9: 4D      	    LD C, L
              	
19DA:         	FS_DL_RD:
              	    ; BC=bytes, DE=pag*256+1, HL=destino
19DA: C5      	    PUSH BC
19DB: 3A32FC  	    LD A, (FS_CURPG)
19DE: 57      	    LD D, A
19DF: 1E01    	    LD E, 1
19E1: 2A30FC  	    LD HL, (FS_TMPRAM)
19E4: CD5B18  	    CALL I2C_MemRd
19E7: C1      	    POP BC
19E8: C0      	    RET NZ
              	
              	    ; Atualiza ponteiros
19E9: 2A30FC  	    LD HL, (FS_TMPRAM)
19EC: 09      	    ADD HL, BC
19ED: 2230FC  	    LD (FS_TMPRAM), HL
19F0: 2A2EFC  	    LD HL, (FS_TMPSZ)
19F3: B7      	    OR A                    ; limpa carry
19F4: ED42    	    SBC HL, BC
19F6: 222EFC  	    LD (FS_TMPSZ), HL
              	
              	    ; Proxima pagina
19F9: 3A2DFC  	    LD A, (FS_TMP1)
19FC: 3232FC  	    LD (FS_CURPG), A
19FF: 18B2    	    JR FS_DL_PG
              	
