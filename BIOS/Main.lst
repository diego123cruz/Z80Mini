1D08: 3231FC  	    LD (FS_TMP1), A
              	
              	    ; Grava
1D0B: 3A38FC  	    LD A, (FS_BMPADDR)
1D0E: 5F      	    LD E, A
1D0F: 1600    	    LD D, 0
1D11: 2131FC  	    LD HL, FS_TMP1
1D14: 010100  	    LD BC, 1
1D17: CDA818  	    CALL I2C_MemWr
1D1A: 1808    	    JR FS_FP_DONE
              	
1D1C:         	FS_FP_ERR:
1D1C: F1      	    POP AF
1D1D: E1      	    POP HL
1D1E: D1      	    POP DE
1D1F: C1      	    POP BC
1D20: 3E01    	    LD A, 1
1D22: B7      	    OR A
1D23: C9      	    RET
              	
1D24:         	FS_FP_DONE:
1D24: F1      	    POP AF
1D25: E1      	    POP HL
1D26: D1      	    POP DE
1D27: C1      	    POP BC
1D28: C9      	    RET
              	
              	; FS_FREE_CHAIN: Libera cadeia de paginas a partir da pagina A
              	;   On exit: Z=OK  NZ=erro
1D29:         	FS_FREE_CHAIN:
1D29: B7      	    OR A
1D2A: C8      	    RET Z
              	
1D2B:         	FS_FC_LP:
1D2B: 3238FC  	    LD (FS_BMPADDR), A      ; salva pagina corrente
              	
              	    ; Primeiro le o next page (antes de liberar)
1D2E: 57      	    LD D, A
1D2F: 1E00    	    LD E, 0
1D31: 2131FC  	    LD HL, FS_TMP1
1D34: 010100  	    LD BC, 1
1D37: CD7018  	    CALL I2C_MemRd
1D3A: 201C    	    JR NZ, FS_FC_ERR
              	
