1D4A: 3A38FC  	    LD A, (FS_BMPADDR)
1D4D: CDCD1C  	    CALL FS_FREE_PG
1D50: 2010    	    JR NZ, FS_FC_ERR2
              	
1D52: F1      	    POP AF                  ; [1] A = next page
1D53: B7      	    OR A
1D54: 20D5    	    JR NZ, FS_FC_LP         ; continua na proxima pagina
              	
1D56: AF      	    XOR A
1D57: C9      	    RET
              	
1D58:         	FS_FC_ERR:
1D58: 216D1D  	    LD HL, str_fc_err
