18A4: CD9217  	            CALL I2C_Write      ;Write address
18A7: 7B      	            LD   A,E            ;Address (lo) in I2C memory
18A8: CD9217  	            CALL I2C_Write      ;Write address
18AB: 3A01FC  	            LD   A, (I2CA_BLOCK) ;I2C device to be read from
18AE: 3C      	            INC  A              ; Device read equal DeviceId+1
18AF: CD8817  	            CALL I2C_Open       ;Open for read
18B2: C0      	            RET  NZ             ;Abort if error
18B3: 0B      	I2C_MemRdRead:      DEC  BC             ;Decrement byte counter
18B4: 78      	            LD   A,B
18B5: B1      	            OR   C              ;Last byte to be read?
18B6: CDCF17  	            CALL I2C_Read       ;Read byte with no ack on last byte
18B9: 77      	            LD   (HL),A         ;Write byte in CPU memory
18BA: 23      	            INC  HL             ;Increment CPU memory pointer
18BB: 78      	            LD   A,B
18BC: B1      	            OR   C              ;Finished?
18BD: 20F4    	            JR   NZ,I2C_MemRdRead       ;No, so go read next byte
18BF: CD0718  	            CALL I2C_Stop       ;Generate I2C stop
18C2: AF      	            XOR  A              ;Return with success (Z flagged)
18C3: C9      	            RET
              	
              	
              	; Copy a block from CPU memory to I2C memory
              	;   On entry: DE = First address in I2C memory
              	;             HL = First address in CPU memory
              	;             BC = Number of bytes to be copied
              	;             SCL = unknown, SDA = unknown
              	;   On exit:  If successfully A = 0 and Z flagged
              	;             If unsuccessfully A = Error and NZ flagged
              	;             IX IY preserved
              	; The 24LC64 requires blocks of data to be written in 64 byte (or less)
              	; pages.
18C4: C5      	I2C_MemWr:  PUSH BC
18C5: 011027  	            LD   BC,TIMEOUT     ;Timeout loop counter
18C8:         	I2C_MemWrRepeat:    
18C8: 3A01FC  	            LD   A, (I2CA_BLOCK)   ;I2C address to write to
18CB: CD8817  	            CALL I2C_Open       ;Open for write
18CE: 280A    	            JR   Z,I2C_MemWrReady       ;If open okay then skip on
18D0: 0B      	            DEC  BC
18D1: 78      	            LD   A,B
18D2: B1      	            OR   C              ;Timeout?
18D3: 20F3    	            JR   NZ,I2C_MemWrRepeat     ;No, so go try again
18D5: C1      	            POP  BC
18D6: 3E03    	            LD   A,ERR_TOUT     ;Error code
18D8: B7      	            OR   A              ;Error, so NZ flagged
18D9: C9      	            RET                 ;Return with error
              	; Device opened okay
18DA: C1      	I2C_MemWrReady:     POP  BC             ;Restore byte counter
18DB: 7A      	I2C_MemWrBlock:     LD   A,D            ;Address (hi) in I2C memory
18DC: CD9217  	            CALL I2C_Write      ;Write address
18DF: 7B      	            LD   A,E            ;Address (lo) in I2C memory
18E0: CD9217  	            CALL I2C_Write      ;Write address
18E3: 7E      	I2C_MemWrWrite:     LD   A,(HL)         ;Get data byte from CPU memory
18E4: CD9217  	            CALL I2C_Write      ;Read byte from I2C memory
18E7: 23      	            INC  HL             ;Increment CPU memory pointer
18E8: 13      	            INC  DE             ;Increment I2C memory pointer
18E9: 0B      	            DEC  BC             ;Decrement byte counter
18EA: 78      	            LD   A,B
18EB: B1      	            OR   C              ;Finished?
18EC: 2805    	            JR   Z,I2C_MemWrStore       ;Yes, so go store this page
18EE: 7B      	            LD   A,E            ;Get address in I2C memory (lo byte)
18EF: E63F    	            AND  63             ;64 byte page boundary?
18F1: 20F0    	            JR   NZ,I2C_MemWrWrite      ;No, so go write another byte
18F3: CD0718  	I2C_MemWrStore:     CALL I2C_Stop       ;Generate I2C stop
18F6: 78      	            LD   A,B
18F7: B1      	            OR   C              ;Finished?
18F8: 20CA    	            JR   NZ,I2C_MemWr   ;No, so go write some more
18FA: C9      	            RET   
              	
              	
              	; Hex byte output to console
              	;   On entry: A = Byte to be output in hex
              	;   On exit:  BC DE HL IX IY preserved
18FB: F5      	HexOut:     PUSH AF             ;Preserve byte to be output
18FC: 1F      	            RRA                 ;Shift top nibble to
18FD: 1F      	            RRA                 ;  botom four bits..
18FE: 1F      	            RRA
18FF: 1F      	            RRA
1900: E60F    	            AND  $0F           ;Mask off unwanted bits
1902: CD0819  	            CALL HexOutHex           ;Output hi nibble
1905: F1      	            POP  AF             ;Restore byte to be output
1906: E60F    	            AND  $0F           ;Mask off unwanted bits
              	; Output nibble as ascii character
1908: FE0A    	HexOutHex:       CP   $0A           ;Nibble > 10 ?
190A: 3802    	            JR   C,HexOutSkip        ;No, so skip
190C: C607    	            ADD  A,7            ;Yes, so add 7
190E: C630    	HexOutSkip:      ADD  A,$30         ;Add ASCII '0'
1910: CD9B03  	            CALL CONOUT       ;Write character
1913: C9      	            RET
