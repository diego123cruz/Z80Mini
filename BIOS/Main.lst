10BE: CDDF06  	            CALL sendCharToLCD
10C1: C9      	            RET
              	
              	; ============================================================
              	;  DUMP_CMD  -  Dump hex+ASCII
              	;  Sintaxe: DUMP xxxx
              	; ============================================================
10C2:         	DUMP_CMD:
              	            ; DE aponta para argumentos
10C2: CD3613  	            CALL PARSE_HEX16_DE      ; HL = endereço
10C5: 3836    	            JR   C, DUMP_BAD_ADDR
10C7: 22F6FB  	            LD   (ADDR_TMP), HL
              	
10CA: 0608    	            LD   B, 8               ; 8 linhas de 5 bytes
              	
10CC:         	DUMP_LINE:
10CC: C5      	            PUSH BC
              	            ; Exibe endereço
10CD: 2AF6FB  	            LD   HL, (ADDR_TMP)
10D0: CD8D13  	            CALL PRINT_HEX16
10D3: 3E3A    	            LD   A, ':'
10D5: CD7803  	            CALL PUTCHAR
10D8: 3E20    	            LD   A, SPACE
10DA: CD7803  	            CALL PUTCHAR
              	
              	            ; Exibe 16 bytes hex
10DD: 2AF6FB  	            LD   HL, (ADDR_TMP)
10E0: 0E05    	            LD   C, 5
10E2:         	DUMP_HEX:
10E2: 7E      	            LD   A, (HL)
10E3: CD7213  	            CALL PRINT_HEX8
10E6: 3E20    	            LD   A, SPACE
10E8: CD7803  	            CALL PUTCHAR
10EB: 23      	            INC  HL
10EC: 0D      	            DEC  C
10ED: 20F3    	            JR   NZ, DUMP_HEX
              	
              	            ;CALL CRLF
              	            ; Avança endereço base
10EF: 2AF6FB  	            LD   HL, (ADDR_TMP)
10F2: 110500  	            LD   DE, 5
10F5: 19      	            ADD  HL, DE
10F6: 22F6FB  	            LD   (ADDR_TMP), HL
10F9: C1      	            POP  BC
10FA: 10D0    	            DJNZ DUMP_LINE
10FC: C9      	            RET
              	
10FD:         	DUMP_BAD_ADDR:
10FD: 21BC13  	            LD   HL, MSG_BAD_ADDR
1100: CD8403  	            CALL PUTS
1103: C9      	            RET
              	
              	; ============================================================
              	;  LOAD_CMD  -  Carrega bytes hex em endereço
              	;  Sintaxe: LOAD xxxx
              	;  Digitar pares hex separados por espaço; linha vazia encerra
              	; ============================================================
1104:         	LOAD_CMD:
1104: CD3613  	            CALL PARSE_HEX16_DE
1107: 3848    	            JR   C, LOAD_BAD
1109: 22F6FB  	            LD   (ADDR_TMP), HL
110C: 21E613  	            LD   HL, MSG_LOAD_HINT
110F: CD8403  	            CALL PUTS
              	
1112:         	LOAD_LOOP:
              	            ; Exibe endereço atual
1112: 2AF6FB  	            LD   HL, (ADDR_TMP)
1115: CD8D13  	            CALL PRINT_HEX16
1118: 3E3A    	            LD   A, ':'
111A: CD7803  	            CALL PUTCHAR
111D: 3E20    	            LD   A, SPACE
111F: CD7803  	            CALL PUTCHAR
              	
1122: CD7712  	            CALL GETLINE             ; Lê linha
1125: 21A0FB  	            LD   HL, LINEBUF
1128: CDD512  	            CALL SKIP_SPACES
              	
              	            ; Linha vazia = fim
112B: 7E      	            LD   A, (HL)
112C: FE0D    	            CP   CR
112E: C8      	            RET  Z
112F: FE00    	            CP   NUL
1131: C8      	            RET  Z
              	
              	            ; Processa pares hex na linha
1132:         	LOAD_BYTE:
1132: CD0413  	            CALL PARSE_HEX8_HL       ; A = byte, HL avança
1135: 3818    	            JR   C, LOAD_NEXT_LINE
              	            ; Grava byte
1137: ED5BF6FB	            LD   DE, (ADDR_TMP)
113B: 12      	            LD   (DE), A
113C: 13      	            INC  DE
113D: ED53F6FB	            LD   (ADDR_TMP), DE
1141: CDE312  	            CALL SKIP_SPACES_HL
1144: 7E      	            LD   A, (HL)
1145: FE0D    	            CP   CR
1147: 28C9    	            JR   Z, LOAD_LOOP
1149: FE00    	            CP   NUL
114B: 28C5    	            JR   Z, LOAD_LOOP
114D: 18E3    	            JR   LOAD_BYTE
              	
114F:         	LOAD_NEXT_LINE:
114F: 18C1    	            JR   LOAD_LOOP
              	
1151:         	LOAD_BAD:
1151: 21BC13  	            LD   HL, MSG_BAD_ADDR
1154: CD8403  	            CALL PUTS
1157: C9      	            RET
              	
              	; ============================================================
              	;  EDIT_CMD  -  Edita memória byte a byte
              	;  Sintaxe: EDIT xxxx
              	;  Exibe: XXXX: AA  _  (digitar novo valor ou Enter p/ manter)
              	;  '.' encerra
              	; ============================================================
1158:         	EDIT_CMD:
1158: CD3613  	            CALL PARSE_HEX16_DE
115B: 3849    	            JR   C, EDIT_BAD
115D: 22F6FB  	            LD   (ADDR_TMP), HL
              	
1160:         	EDIT_LOOP:
1160: 2AF6FB  	            LD   HL, (ADDR_TMP)
1163: CD8D13  	            CALL PRINT_HEX16
1166: 3E3A    	            LD   A, ':'
1168: CD7803  	            CALL PUTCHAR
116B: 3E20    	            LD   A, SPACE
116D: CD7803  	            CALL PUTCHAR
1170: 7E      	            LD   A, (HL)             ; Valor atual
1171: CD7213  	            CALL PRINT_HEX8
1174: 3E20    	            LD   A, SPACE
1176: CD7803  	            CALL PUTCHAR
1179: 3E20    	            LD   A, SPACE
117B: CD7803  	            CALL PUTCHAR
              	
              	            ; Lê até 3 chars (2 hex + CR)
117E: CD7712  	            CALL GETLINE
1181: 21A0FB  	            LD   HL, LINEBUF
1184: CDD512  	            CALL SKIP_SPACES
              	
1187: 7E      	            LD   A, (HL)
1188: FE2E    	            CP   '.'                 ; '.' = sair
118A: C8      	            RET  Z
118B: FE0D    	            CP   CR
118D: 280E    	            JR   Z, EDIT_KEEP       ; Enter = mantém byte
118F: FE00    	            CP   NUL
1191: 280A    	            JR   Z, EDIT_KEEP
              	
              	            ; Tenta parsear novo byte
1193: CD0413  	            CALL PARSE_HEX8_HL
1196: 38C8    	            JR   C, EDIT_LOOP       ; Hex inválido: repete
              	
              	            ; Grava novo byte
1198: ED5BF6FB	            LD   DE, (ADDR_TMP)
119C: 12      	            LD   (DE), A
              	
119D:         	EDIT_KEEP:
119D: 2AF6FB  	            LD   HL, (ADDR_TMP)
11A0: 23      	            INC  HL
11A1: 22F6FB  	            LD   (ADDR_TMP), HL
11A4: 18BA    	            JR   EDIT_LOOP
              	
11A6:         	EDIT_BAD:
11A6: 21BC13  	            LD   HL, MSG_BAD_ADDR
11A9: CD8403  	            CALL PUTS
11AC: C9      	            RET
              	
              	; ============================================================
              	;  OUT_CMD  -  Escreve byte em porta de I/O
              	;  Sintaxe: OUT pp dd   (porta pp, dado dd, ambos em hex)
              	; ============================================================
