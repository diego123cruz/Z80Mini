              	; Preenche FS_NAMBUF com NUL, depois copia buffer em DE até NUL(0) ou SPACE
              	; Nome não pode ter espaços e Diego != diego
1BCE:         	FS_COPY_NAME_FROM_BUFFER:
1BCE: 0609    	    LD B, FS_NAME_SZ + 1
1BD0: 2123FC  	    LD HL, FS_NAMBUF
1BD3: AF      	    XOR A
1BD4:         	FS_CLEAR_NUL:
1BD4: 77      	    LD (HL), A
1BD5: 23      	    INC HL
1BD6: 10FC    	    djnz FS_CLEAR_NUL
              	
1BD8: 0609    	    LD B, FS_NAME_SZ + 1
1BDA: 2123FC  	    LD HL, FS_NAMBUF
1BDD:         	FS_COPY_NAME_FROM_BUFFER_LOOP:
1BDD: 1A      	    LD A, (DE)
1BDE: FE00    	    CP NUL
1BE0: C8      	    RET Z
1BE1: FE20    	    CP SPACE
1BE3: C8      	    RET Z
1BE4: 77      	    LD (HL), A
1BE5: 23      	    INC HL
1BE6: 13      	    INC DE
1BE7: 10F4    	    djnz FS_COPY_NAME_FROM_BUFFER_LOOP
1BE9: C9      	    RET
              	
              	; FS_RD_ENTRY: Le entrada FS_CUR → FS_WRKBUF
              	;   EEPROM addr = $0100 + FS_CUR*32
              	;   On exit: Z=OK  NZ=erro
1BEA:         	FS_RD_ENTRY:
1BEA: C5      	    PUSH BC
1BEB: D5      	    PUSH DE
1BEC: E5      	    PUSH HL
1BED: 3A02FC  	    LD A, (FS_CUR)
1BF0: 07      	    RLCA
1BF1: 07      	    RLCA
1BF2: 07      	    RLCA
1BF3: 07      	    RLCA
1BF4: 07      	    RLCA                    ; A = FS_CUR * 32
1BF5: 5F      	    LD E, A
1BF6: 1601    	    LD D, $01
1BF8: 2103FC  	    LD HL, FS_WRKBUF
1BFB: 012000  	    LD BC, FS_ENTRY_SZ
1BFE: CD5B18  	    CALL I2C_MemRd
1C01: E1      	    POP HL
1C02: D1      	    POP DE
1C03: C1      	    POP BC
1C04: C9      	    RET
              	
              	
