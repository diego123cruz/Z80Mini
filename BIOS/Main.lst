1828: ED78    	            IN   A,(C)          ;Read A from I/O port
182A: C1      	            POP  BC             ;Restore registers
182B: C9      	            RET
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
