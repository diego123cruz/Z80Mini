              	#include "IHEX.asm"
              	
              	
1582:         	loadInit:
1582: 3EFF    	    LD A, $FF
1584: 32FCFB  	    LD (LOAD_FIRST_FLAG), A
              	
1587: 214617  	    LD HL, MSG_LOAD_HELP
158A: CDE716  	    CALL SERIAL_A_PRINT_STRING
              	
158D: 114817  	    LD DE, MSG_LOAD_HELP_LCD
1590: CD7E07  	    CALL sendStringToLCD
              	
1593:         	loopHexLoad:
1593: CDCC0F  	    CALL RXDATA
              	
1596: FE3A    	    CP   ':'	; ":"?
1598: 20F9    		JR   NZ, loopHexLoad ; Aguarda :
              	
              	    ; Só inicializa o flag se for a primeira linha do carregamento
159A: 3AFCFB  		LD   A, (LOAD_FIRST_FLAG)
159D: FEFF    		CP   $FF                    ; $FF = virgem / sessão nova
159F: 2005    		JR   NZ, monitor_do_load    ; já está no meio de um carregamento
15A1: 3E01    		LD   A, $01
15A3: 32FCFB  		LD   (LOAD_FIRST_FLAG), A   ; sinaliza: próximo LOAD é o primeiro
              	
15A6:         	monitor_do_load:
15A6: CDB715  		CALL    LOAD
15A9: CDF016  		CALL SERIAL_A_TXCRLF
15AC: C39315  	    JP loopHexLoad
              	
              	
15AF:         	CALL_IHEX:
15AF: 216802  		LD HL, MAIN_LOOP
15B2: E5      		PUSH HL
15B3: CD8215  		CALL loadInit
15B6: C9      		RET
              	
              	;------------------------------------------------------------------------------
              	; LOAD Intel Hex format file from the console.
              	; [Intel Hex Format is:
              	; 1) Colon (Frame 0)
              	; 2) Record Length Field (Frames 1 and 2)
              	; 3) Load Address Field (Frames 3,4,5,6)
              	; 4) Record Type Field (Frames 7 and 8)
              	; 5) Data Field (Frames 9 to 9+2*(Record Length)-1
              	; 6) Checksum Field - Sum of all byte values from Record Length to and 
              	;   including Checksum Field = 0 ]
              	;------------------------------------------------------------------------------	
15B7:         	LOAD:
15B7: 1E00    			LD   E,0	        ; Zera checksum
15B9: CD9516  			CALL GET2	        ; Record Length -> D
15BC: 57      			LD   D,A
15BD: CD9516  			CALL GET2	        ; Endereco High -> H
15C0: 67      			LD   H,A
15C1: CD9516  			CALL GET2	        ; Endereco Low -> L
15C4: 6F      			LD   L,A
15C5: CD9516  			CALL GET2	        ; Record Type -> A
15C8: FE01    			CP   $01	        ; EOF record?
15CA: 2009    			JR   NZ,LOAD2	    ; Nao: processa dados
              	
              			; --- Record tipo 01: EOF ---
15CC: CD9516  			CALL GET2	        ; Consome checksum do EOF
15CF: 7B      			LD   A,E
15D0: A7      			AND  A
15D1: 2839    			JR   Z,LOAD00       ; Checksum OK: imprime resumo
15D3: 1829    			JR   LOADERR        ; Checksum falhou
              	
              			; --- Record tipo 00: Dados ---
15D5:         	LOAD2:
              			; Salva endereco inicial apenas na primeira linha
15D5: 3AFCFB  			LD   A, (LOAD_FIRST_FLAG)
15D8: FE01    			CP   $01                    ; e a primeira linha?
15DA: 2008    			JR   NZ, LOAD2_SKIP
15DC: 3E00    			LD   A, $00
15DE: 32FCFB  			LD   (LOAD_FIRST_FLAG), A   ; limpa flag
15E1: 22FDFB  			LD   (LOAD_START_ADDR), HL  ; salva endereco inicial
              	
15E4:         	LOAD2_SKIP:
15E4: 7A      			LD   A,D	        ; Contador de bytes da linha
15E5: A7      			AND  A
15E6: 280D    			JR   Z,LOAD3
              	
15E8: CD9516  			CALL GET2	        ; Le proximo byte
15EB: 77      			LD   (HL),A	        ; Grava na memoria
15EC: 23      			INC  HL
15ED: 3E2E    			LD   A,'.'
15EF: CD9F0F  			CALL OUTCH
15F2: 15      			DEC  D
15F3: 18EF    			JR   LOAD2_SKIP     ; (continua pelo loop sem re-checar o flag)
              	
15F5:         	LOAD3:
15F5: 22FFFB  			LD   (LOAD_END_ADDR), HL    ; Atualiza endereco final (apos ultimo byte)
15F8: CD9516  			CALL GET2	                ; Consome checksum da linha
15FB: 7B      			LD   A,E
15FC: A7      			AND  A
15FD: C8      			RET  Z                      ; Checksum OK: volta pro monitor
              	
15FE:         	LOADERR:
15FE: 21FB16  			LD   HL,CKSUMERR
1601: CDE716  			CALL SERIAL_A_PRINT_STRING
              	
              	        ;LCD
1604: 11FB16  	        LD   DE, CKSUMERR
1607: CD7E07  	        CALL sendStringToLCD
              	
160A: E1      	        POP HL
              	
160B: C9      			RET
              	
160C:         	LOAD00:
              			; --- Imprime resumo do carregamento ---
160C: 210C17  			LD   HL, LDETXT
160F: CDE716  			CALL SERIAL_A_PRINT_STRING
              	
1612: 212B17  			LD   HL, msg_load_start
1615: CDE716  			CALL SERIAL_A_PRINT_STRING
1618: 2AFDFB  			LD   HL, (LOAD_START_ADDR)
161B: CDBF16  			CALL SERIAL_A_PRINT_HL_HEX
161E: CDF016  			CALL SERIAL_A_TXCRLF
              	
1621: 213417  			LD   HL, msg_load_end
1624: CDE716  			CALL SERIAL_A_PRINT_STRING
1627: 2AFFFB  			LD   HL, (LOAD_END_ADDR)
162A: 2B      			DEC  HL                     ; aponta para o ultimo byte gravado
162B: CDBF16  			CALL SERIAL_A_PRINT_HL_HEX
162E: CDF016  			CALL SERIAL_A_TXCRLF
              	
1631: 213D17  			LD   HL, msg_load_total
1634: CDE716  			CALL SERIAL_A_PRINT_STRING
1637: ED5BFDFB			LD   DE, (LOAD_START_ADDR)
163B: 2AFFFB  			LD   HL, (LOAD_END_ADDR)
163E: B7      			OR   A                      ; limpa carry flag
163F: ED52    			SBC  HL, DE                 ; HL = total de bytes
1641: CDBF16  			CALL SERIAL_A_PRINT_HL_HEX
1644: CDF016  			CALL SERIAL_A_TXCRLF
              	
              	        ; Mostra status no lcd
1647: 112517  	        LD   DE, LDETXTLCD
164A: CD7E07  	        CALL sendStringToLCD
              	
164D: 112B17  	        LD   DE, msg_load_start
1650: 3E00    	        LD   A, 0
1652: CD7E07  			CALL sendStringToLCD
1655: 2AFDFB  			LD   HL, (LOAD_START_ADDR)
1658: CDC207  			CALL sendHLToLCD
165B: CDB703  			CALL CRLF
              	
165E: 113417  			LD   DE, msg_load_end
1661: 3E00    	        LD   A, 0
1663: CD7E07  			CALL sendStringToLCD
1666: 2AFFFB  			LD   HL, (LOAD_END_ADDR)
1669: 2B      			DEC  HL                     ; aponta para o ultimo byte gravado
166A: CDC207  			CALL sendHLToLCD
166D: CDB703  			CALL CRLF
              	
1670: 113D17  			LD   DE, msg_load_total
1673: 3E00    	        LD   A, 0
1675: CD7E07  			CALL sendStringToLCD
1678: ED5BFDFB			LD   DE, (LOAD_START_ADDR)
167C: 2AFFFB  			LD   HL, (LOAD_END_ADDR)
167F: B7      			OR   A                      ; limpa carry flag
1680: ED52    			SBC  HL, DE                 ; HL = total de bytes
1682: CDC207  			CALL sendHLToLCD
              	
1685: CDB703  	        CALL CRLF
              	
1688: E1      	        POP HL 
1689: C9      			RET
              	
              	
              	
              	
              	;------------------------------------------------------------------------------
              	; Get a character from the console, must be $20-$7F to be valid (no control characters)
              	; <Ctrl-c> and <SPACE> breaks with the Zero Flag set
              	;------------------------------------------------------------------------------	
168A: CDA50F  	GETCHR_S:	CALL INCH	; RX a Character
168D: FE03    			CP   $03	; <ctrl-c> User break?
168F: C8      			RET  Z			
1690: FE20    			CP   $20	; <space> or better?
1692: 38F6    			JR   C,GETCHR_S	; Do it again until we get something usable
1694: C9      			RET
              	
              	;------------------------------------------------------------------------------
              	; Gets two ASCII characters from the console (assuming them to be HEX 0-9 A-F)
              	; Moves them into B and C, converts them into a byte value in A and updates a
              	; Checksum value in E
              	;------------------------------------------------------------------------------
1695: CD8A16  	GET2:   CALL GETCHR_S	; Get us a valid character to work with
1698: 47      			LD   B,A	; Load it in B
1699: CD8A16  			CALL GETCHR_S	; Get us another character
169C: 4F      			LD   C,A	; load it in C
169D: CDA616  			CALL BCTOA	; Convert ASCII to byte
16A0: 4F      			LD   C,A	; Build the checksum
16A1: 7B      			LD   A,E
16A2: 91      			SUB  C		; The checksum should always equal zero when checked
16A3: 5F      			LD   E,A	; Save the checksum back where it came from
16A4: 79      			LD   A,C	; Retrieve the byte and go back
16A5: C9      			RET
              	
              	;------------------------------------------------------------------------------
              	; Convert ASCII characters in B C registers to a byte value in A
              	;------------------------------------------------------------------------------
16A6: 78      	BCTOA		LD   A,B	; Move the hi order byte to A
16A7: D630    			SUB  $30	; Take it down from Ascii
16A9: FE0A    			CP   $0A	; Are we in the 0-9 range here?
16AB: 3802    			JR   C,BCTOA1	; If so, get the next nybble
16AD: D607    			SUB  $07	; But if A-F, take it down some more
16AF: 07      	BCTOA1		RLCA		; Rotate the nybble from low to high
16B0: 07      			RLCA		; One bit at a time
16B1: 07      			RLCA		; Until we
16B2: 07      			RLCA		; Get there with it
16B3: 47      			LD   B,A	; Save the converted high nybble
16B4: 79      			LD   A,C	; Now get the low order byte
16B5: D630    			SUB  $30	; Convert it down from Ascii
16B7: FE0A    			CP   $0A	; 0-9 at this point?
16B9: 3802    			JR   C,BCTOA2	; Good enough then, but
16BB: D607    			SUB  $07	; Take off 7 more if it's A-F
16BD: 80      	BCTOA2		ADD  A,B	; Add in the high order nybble
16BE: C9      			RET
              	
              	;------------------------------------------------------------------------------
              	; Imprime HL como 4 digitos hexadecimais
              	; Ex: HL=$80FF -> imprime "80FF"
              	;------------------------------------------------------------------------------
16BF:         	SERIAL_A_PRINT_HL_HEX:
16BF: 7C      			LD   A, H
16C0: CDC816  			CALL SERIAL_A_PRINT_A_HEX
16C3: 7D      			LD   A, L
16C4: CDC816  			CALL SERIAL_A_PRINT_A_HEX
16C7: C9      			RET
              	
              	
              	;------------------------------------------------------------------------------
              	; Imprime byte em A como 2 digitos hexadecimais
              	;------------------------------------------------------------------------------
16C8:         	SERIAL_A_PRINT_A_HEX:
16C8: F5      			PUSH AF
16C9: 0F      			RRCA
16CA: 0F      			RRCA
16CB: 0F      			RRCA
16CC: 0F      			RRCA
16CD: CDD516  			CALL SERIAL_A_PRINT_NIBBLE
16D0: F1      			POP  AF
16D1: CDD516  			CALL SERIAL_A_PRINT_NIBBLE
16D4: C9      			RET
              	
16D5:         	SERIAL_A_PRINT_NIBBLE:
16D5: E60F    			AND  $0F
16D7: FE0A    			CP   $0A
16D9: 3806    			JR   C, SERIAL_A_PRINT_NIBBLE_09
16DB: C637    			ADD  A, $37             ; A-F  ('A'=41h, 41h-0Ah=37h)
16DD: CD9F0F  			CALL OUTCH
16E0: C9      			RET
16E1:         	SERIAL_A_PRINT_NIBBLE_09:
16E1: C630    			ADD  A, $30             ; 0-9
16E3: CD9F0F  			CALL OUTCH
16E6: C9      			RET
              	
              	
              	;------------------------------------------------------------------------------
              	; Print string of characters to Serial A until byte=$00, WITH CR, LF
              	;------------------------------------------------------------------------------
16E7:         	SERIAL_A_PRINT_STRING:
16E7: 7E      	        LD   A,(HL)	; Get character
16E8: B7      			OR   A		; Is it $00 ?
16E9: C8      			RET  Z		; Then RETurn on terminator
16EA: CD9F0F  			CALL OUTCH	; Print it
16ED: 23      			INC  HL		; Next Character
16EE: 18F7    			JR   SERIAL_A_PRINT_STRING	; Continue until $00
              	
16F0: 3E0D    	SERIAL_A_TXCRLF:	LD   A,$0D	; 
16F2: CD9F0F  			CALL OUTCH	; Print character 
16F5: 3E0A    			LD   A,$0A	; 
16F7: CD9F0F  			CALL OUTCH	; Print character
16FA: C9      			RET
              	
              	
              	
