              	; --- PRINT_HEX8: Imprime byte em A como 2 dígitos hex ---
1371:         	PRINT_HEX8:
1371: F5      	            PUSH AF
1372: 0F      	            RRCA
1373: 0F      	            RRCA
1374: 0F      	            RRCA
1375: 0F      	            RRCA
1376: CD7E13  	            CALL PRINT_NIBBLE
1379: F1      	            POP  AF
137A: CD7E13  	            CALL PRINT_NIBBLE
137D: C9      	            RET
              	
137E:         	PRINT_NIBBLE:
137E: E60F    	            AND  0FH
1380: C630    	            ADD  A, '0'
1382: FE3A    	            CP   '9'+1
1384: 3802    	            JR   C, PN_DONE
1386: C607    	            ADD  A, 07H              ; 'A'-'9'-1
1388:         	PN_DONE:
1388: CD7703  	            CALL PUTCHAR
138B: C9      	            RET
              	
              	; --- PRINT_HEX16: Imprime HL como 4 dígitos hex ---
138C:         	PRINT_HEX16:
138C: 7C      	            LD   A, H
138D: CD7113  	            CALL PRINT_HEX8
1390: 7D      	            LD   A, L
1391: CD7113  	            CALL PRINT_HEX8
1394: C9      	            RET
              	
