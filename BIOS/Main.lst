0705: B7      	        OR A
0706: F5      	        PUSH AF
0707: CCEA08  	        CALL Z,drawCursor
070A: F1      	        POP AF
070B: C40C09  	        CALL NZ,drawBlank          ;Clear cursor
070E: CDBD07  	        CALL INC_ROW
