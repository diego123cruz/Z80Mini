184A: D5      	LISTLOOP:      PUSH DE             ;Preserve DE
184B: 7A      	            LD   A,D            ;Get device address to be tested
184C: CD6718  	            CALL LISTTEST          ;Test if device is present
184F: D1      	            POP  DE             ;Restore DE
