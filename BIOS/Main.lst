              	;------------------------------------------------------------------------------
16AC:         	SERIAL_A_PRINT_A_HEX:
16AC: F5      			PUSH AF
16AD: 0F      			RRCA
16AE: 0F      			RRCA
16AF: 0F      			RRCA
16B0: 0F      			RRCA
16B1: CDB916  			CALL SERIAL_A_PRINT_NIBBLE
16B4: F1      			POP  AF
16B5: CDB916  			CALL SERIAL_A_PRINT_NIBBLE
16B8: C9      			RET
              	
16B9:         	SERIAL_A_PRINT_NIBBLE:
16B9: E60F    			AND  $0F
16BB: FE0A    			CP   $0A
16BD: 3806    			JR   C, SERIAL_A_PRINT_NIBBLE_09
16BF: C637    			ADD  A, $37             ; A-F  ('A'=41h, 41h-0Ah=37h)
16C1: CD830F  			CALL OUTCH
16C4: C9      			RET
16C5:         	SERIAL_A_PRINT_NIBBLE_09:
16C5: C630    			ADD  A, $30             ; 0-9
16C7: CD830F  			CALL OUTCH
16CA: C9      			RET
              	
              	
              	;------------------------------------------------------------------------------
              	; Print string of characters to Serial A until byte=$00, WITH CR, LF
              	;------------------------------------------------------------------------------
16CB:         	SERIAL_A_PRINT_STRING:
16CB: 7E      	        LD   A,(HL)	; Get character
16CC: B7      			OR   A		; Is it $00 ?
16CD: C8      			RET  Z		; Then RETurn on terminator
16CE: CD830F  			CALL OUTCH	; Print it
16D1: 23      			INC  HL		; Next Character
16D2: 18F7    			JR   SERIAL_A_PRINT_STRING	; Continue until $00
              	
16D4: 3E0D    	SERIAL_A_TXCRLF:	LD   A,$0D	; 
16D6: CD830F  			CALL OUTCH	; Print character 
16D9: 3E0A    			LD   A,$0A	; 
16DB: CD830F  			CALL OUTCH	; Print character
16DE: C9      			RET
              	
              	
              	
