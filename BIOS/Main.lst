              	#include "SERIAL.asm"
              	; Inicializa SIO/2 Serial 115200
0F2D:         	initSerial:
0F2D: 218A0F  	    LD    HL,TXDATA
0F30: 229AFB  	    LD    (PUTCH),HL ;USE THE BITBANG SERIAL TRANSMIT
0F33: 219D0F  	    LD    HL,RXDATA
0F36: 229CFB  	    LD    (GETCH),HL  ;USE THE BITBANG SERIAL RECEIVE
              	
              	
              	    ;	Initialise SIO/2 A - Onboard USB
0F39: 3E04    		LD	A,$04
0F3B: D302    		OUT	(SIOA_C),A
0F3D: 3EC4    		LD	A,$C4
0F3F: D302    		OUT	(SIOA_C),A
              	
0F41: 3E03    		LD	A,$03
0F43: D302    		OUT	(SIOA_C),A
0F45: 3EE1    		LD	A,$E1
0F47: D302    		OUT	(SIOA_C),A
              	
0F49: 3E05    		LD	A,$05
0F4B: D302    		OUT	(SIOA_C),A
0F4D: 3E68    		LD	A, $68
0F4F: D302    		OUT	(SIOA_C),A
              	
              	    ; Initialise SIO/2 B - Printer (P2 conector)
0F51: 3E04    		LD	A,$04
0F53: D303    		OUT	(SIOB_C),A
0F55: 3EC4    		LD	A,$C4
0F57: D303    		OUT	(SIOB_C),A
              	
0F59: 3E03    		LD	A,$03
0F5B: D303    		OUT	(SIOB_C),A
0F5D: 3EE1    		LD	A,$E1
0F5F: D303    		OUT	(SIOB_C),A
              	
0F61: 3E05    		LD	A,$05
0F63: D303    		OUT	(SIOB_C),A
0F65: 3E68    		LD	A, $68
0F67: D303    		OUT	(SIOB_C),A
              	
              	
              	    ; Print wellcome serial
0F69: 21B41F  	    LD HL, WELLCOME
0F6C: CD7C0F  	    CALL SNDSTR
              	
0F6F: C9      		RET
              	
              	
              	
              	;-----------------------------------
              	; OUTPUT A CHARACTER TO THE TERMINAL
              	;-----------------------------------       
0F70: DD2A9AFB	OUTCH:  LD   IX,(PUTCH)
0F74: DDE9    	       JP   (IX)
              	;------------------------------------
              	; INPUT A CHARACTER FROM THE TERMINAL
              	;------------------------------------
0F76: DD2A9CFB	INCH:  LD   IX,(GETCH)
0F7A: DDE9    	      JP   (IX)
              	
              	
              		
              	
              	;-----------------------------------------
              	; SEND AN ASCII STRING OUT THE SERIAL PORT
              	;-----------------------------------------
              	; 
              	; SENDS A ZERO TERMINATED STRING OR 
              	; 128 CHARACTERS MAX. OUT THE SERIAL PORT
              	;
              	;      ENTRY : HL = POINTER TO 00H TERMINATED STRING
              	;      EXIT  : NONE
              	;
              	;       MODIFIES : A,B,C
              	;          
0F7C: 0680    	SNDSTR: LD    B,128         ;128 CHARS MAX
0F7E: 7E      	SDMSG1: LD    A,(HL)        ;GET THE CHAR
0F7F: FE00    	       CP    00H          ;ZERO TERMINATOR?
0F81: 2806    	       JR    Z,SDMSG2      ;FOUND A ZERO TERMINATOR, EXIT  
0F83: CD700F  	       CALL  OUTCH         ;TRANSMIT THE CHAR
0F86: 23      	       INC   HL
0F87: 10F5    	       DJNZ  SDMSG1        ;128 CHARS MAX!    
0F89: C9      	SDMSG2: RET
              	
              	
              	;------------------------
              	; SERIAL A TRANSMIT ROUTINE
              	;------------------------
              	;TRANSMIT BYTE SERIALLY ON DOUT
              	;
              	; ENTRY : A = BYTE TO TRANSMIT
              	;  EXIT : NO REGISTERS MODIFIED
              	;
0F8A:         	TXDATA:		
0F8A: F5      			PUSH	AF		; Store character
0F8B: CD940F  	conoutA1:	CALL	CKSIOA		; See if SIO channel A is finished transmitting
0F8E: 28FB    			JR	Z,conoutA1	; Loop until SIO flag signals ready
0F90: F1      			POP	AF		; RETrieve character
0F91: D300    			OUT	(SIOA_D),A	; OUTput the character
0F93: C9      			RET
              	
              	
              	;------------------------------------------------------------------------------
              	; I/O status check routine
              	; Use the "primaryIO" flag to determine which port to check.
              	;------------------------------------------------------------------------------
0F94:         	CKSIOA
0F94: 97      			SUB	A
0F95: D302    			OUT 	(SIOA_C),A
0F97: DB02    			IN   	A,(SIOA_C)	; Status byte D2=TX Buff Empty, D0=RX char ready	
0F99: 0F      			RRCA			; Rotates RX status into Carry Flag,	
0F9A: CB4F    			BIT  	1,A		; Set Zero flag if still transmitting character	
0F9C: C9      	        RET
              	
              	    
              	;-----------------------
              	; SERIAL A RECEIVE ROUTINE
              	;-----------------------
              	;RECEIVE SERIAL BYTE FROM DIN
              	;
              	; ENTRY : NONE
              	;  EXIT : A= RECEIVED BYTE IF CARRY CLEAR
              	;
              	; REGISTERS MODIFIED A AND F
              	;
0F9D:         	RXDATA:	
0F9D:         	waitForChar:
              	        ; Check if there is a char in channel A
0F9D: 97      			SUB	A
0F9E: D302    			OUT 	(SIOA_C),A
0FA0: DB02    			IN   	A,(SIOA_C)	; Status byte D2=TX Buff Empty, D0=RX char ready	
0FA2: 0F      			RRCA			; Rotates RX status into Carry Flag,	
0FA3: 30F8    			JR	NC, waitForChar
0FA5: DB00    			IN	A,(SIOA_D)
0FA7: B7      			OR A ; clear carry
0FA8: C9      			RET
              	
              	
              	
              	;======================= Serial B ========================
              	;------------------------
              	; SERIAL B TRANSMIT ROUTINE
              	;------------------------
              	;TRANSMIT BYTE SERIALLY ON DOUT
              	;
              	; ENTRY : A = BYTE TO TRANSMIT
              	;  EXIT : NO REGISTERS MODIFIED
              	;
0FA9:         	TXDATA_B:		
0FA9: F5      			PUSH	AF		; Store character
0FAA: CDB30F  	conoutB1:	CALL	CKSIOB		; See if SIO channel A is finished transmitting
0FAD: 28FB    			JR	Z,conoutB1	; Loop until SIO flag signals ready
0FAF: F1      			POP	AF		; RETrieve character
0FB0: D301    			OUT	(SIOB_D),A	; OUTput the character
0FB2: C9      			RET
              	
              	
              	;------------------------------------------------------------------------------
              	; I/O status check routine
              	; Use the "primaryIO" flag to determine which port to check.
              	;------------------------------------------------------------------------------
0FB3:         	CKSIOB
0FB3: 97      			SUB	A
0FB4: D303    			OUT 	(SIOB_C),A
0FB6: DB03    			IN   	A,(SIOB_C)	; Status byte D2=TX Buff Empty, D0=RX char ready	
0FB8: 0F      			RRCA			; Rotates RX status into Carry Flag,	
0FB9: CB4F    			BIT  	1,A		; Set Zero flag if still transmitting character	
0FBB: C9      	        RET
              	
              	    
              	;-----------------------
              	; SERIAL B RECEIVE ROUTINE
              	;-----------------------
              	;RECEIVE SERIAL BYTE FROM DIN
              	;
              	; ENTRY : NONE
              	;  EXIT : A= RECEIVED BYTE IF CARRY CLEAR
              	;
              	; REGISTERS MODIFIED A AND F
              	;
0FBC:         	RXDATA_B:	
0FBC:         	waitForCharB:
              	        ; Check if there is a char in channel A
0FBC: 97      			SUB	A
0FBD: D303    			OUT 	(SIOB_C),A
0FBF: DB03    			IN   	A,(SIOB_C)	; Status byte D2=TX Buff Empty, D0=RX char ready	
0FC1: 0F      			RRCA			; Rotates RX status into Carry Flag,	
0FC2: 30F8    			JR	NC, waitForCharB
0FC4: DB01    			IN	A,(SIOB_D)
0FC6: B7      			OR A ; clear carry
0FC7: C9      			RET
              	
              	#include "COMANDOS.asm"
              	
              	; -------- Constantes gerais --------
000D:         	CR          EQU  0DH
000A:         	LF          EQU  0AH
0008:         	BkS          EQU  08H
007F:         	DEL         EQU  7FH
001B:         	ESC         EQU  1BH
0020:         	SPACE       EQU  20H
0000:         	NUL         EQU  00H
              	
              	
              	
              	; ============================================================
              	;  PARSE_CMD  -  Analisa LINEBUF e despacha comando
              	; ============================================================
0FC8:         	PARSE_CMD:
0FC8: 21A0FB  	            LD   HL, LINEBUF
0FCB: CDD512  	            CALL SKIP_SPACES
              	            ; Verifica linha vazia
0FCE: 7E      	            LD   A, (HL)
0FCF: FE0D    	            CP   CR
0FD1: C8      	            RET  Z
0FD2: FE00    	            CP   NUL
0FD4: C8      	            RET  Z
              	
              	            ; Copia token do comando para comparação (uppercase)
0FD5: CD4113  	            CALL UPCASE_TOKEN        ; HL aponta após token, DE=token
              	
              	            ; Compara com cada comando conhecido
0FD8: 211110  	            LD   HL, CMD_TABLE
0FDB:         	CMD_SCAN:
0FDB: 7E      	            LD   A, (HL)
0FDC: FE00    	            CP   NUL
0FDE: CA0A10  	            JP   Z, CMD_UNKNOWN
              	            ; Compara string
0FE1: E5      	            PUSH HL
0FE2: 11F0FB  	            LD   DE, HEXBUF          ; token gravado aqui por UPCASE_TOKEN
0FE5: CD6613  	            CALL STRCMP
0FE8: E1      	            POP  HL
0FE9: 280B    	            JR   Z, CMD_DISPATCH
              	            ; Avança para próxima entrada da tabela
              	            ; Formato: [str NUL] [addr 2 bytes]
0FEB:         	SKIP_ENTRY:
0FEB: 7E      	            LD   A, (HL)
0FEC: 23      	            INC  HL
0FED: FE00    	            CP   NUL
0FEF: 20FA    	            JR   NZ, SKIP_ENTRY
0FF1: 23      	            INC  HL                  ; pula high byte do endereço
0FF2: 23      	            INC  HL                  ; pula low  byte do endereço
0FF3: C3DB0F  	            JP   CMD_SCAN
              	
0FF6:         	CMD_DISPATCH:
              	            ; Pula string do nome para chegar ao endereço
0FF6: 7E      	            LD   A, (HL)
0FF7: 23      	            INC  HL
0FF8: FE00    	            CP   NUL
0FFA: 20FA    	            JR   NZ, CMD_DISPATCH
              	            ; (HL) = low byte do handler, (HL+1) = high byte
0FFC: 7E      	            LD   A, (HL)
0FFD: 23      	            INC  HL
0FFE: 66      	            LD   H, (HL)
0FFF: 6F      	            LD   L, A
              	            ; HL = endereço do handler; HL aponta para resto da linha
              	            ; Precisamos salvar o ponteiro de argumento
              	            ; Reposiciona ponteiro de argumento
1000: 11A0FB  	            LD   DE, LINEBUF		 ; Inicio o buffer
1003: CDCE12  	            CALL SKIP_COMMAND_DE	 ; pula comando e DE aponta para o primeiro espaço
1006: CDDC12  	            CALL SKIP_SPACES_DE      ; DE aponta para args
1009: E9      	            JP   (HL)                ; chama handler
              	
100A:         	CMD_UNKNOWN:
100A: 219B13  	            LD   HL, MSG_UNKNOWN
100D: CD8403  	            CALL PUTS
1010: C9      	            RET
              	
