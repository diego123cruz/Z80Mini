12CA: CD9403  	            CALL CRLF
12CD: C9      	            RET
              	
              	; ============================================================
              	;  SUBROTINAS DE PARSE
              	; ============================================================
              	; --- SKIP_COMMAND_DE: Avança DE até o proximo espaço ---
12CE:         	SKIP_COMMAND_DE:
12CE: 1A      				LD A, (DE)
12CF: FE20    				CP SPACE
12D1: C8      				RET Z
12D2: 13      				INC DE
12D3: 18F9    				JR SKIP_COMMAND_DE
              	
              	
              	; --- SKIP_SPACES: Avança HL sobre espaços ---
12D5:         	SKIP_SPACES:
12D5: 7E      	            LD   A, (HL)
12D6: FE20    	            CP   SPACE
12D8: C0      	            RET  NZ
12D9: 23      	            INC  HL
12DA: 18F9    	            JR   SKIP_SPACES
              	
              	; --- SKIP_SPACES_DE: Avança DE sobre espaços ---
12DC:         	SKIP_SPACES_DE:
12DC: 1A      	            LD   A, (DE)
12DD: FE20    	            CP   SPACE
12DF: C0      	            RET  NZ
12E0: 13      	            INC  DE
12E1: 18F9    	            JR   SKIP_SPACES_DE
              	
              	; --- SKIP_SPACES_HL: Avança HL sobre espaços ---
12E3:         	SKIP_SPACES_HL:
12E3: 7E      	            LD   A, (HL)
12E4: FE20    	            CP   SPACE
12E6: C0      	            RET  NZ
12E7: 23      	            INC  HL
12E8: 18F9    	            JR   SKIP_SPACES_HL
              	
              	; --- IS_HEX: testa se A é dígito hex; retorna dígito em A (0-15), CY se inválido ---
12EA:         	IS_HEX:
12EA: FE30    	            CP   '0'
12EC: 3814    	            JR   C, IS_HEX_BAD
12EE: FE3A    	            CP   '9'+1
12F0: 380D    	            JR   C, IS_HEX_DIG      ; '0'-'9'
12F2: E6DF    	            AND  0DFH               ; Uppercase
12F4: FE41    	            CP   'A'
12F6: 380A    	            JR   C, IS_HEX_BAD
12F8: FE47    	            CP   'F'+1
12FA: 3006    	            JR   NC, IS_HEX_BAD
12FC: D637    	            SUB  'A'-10             ; 'A'→10 ... 'F'→15
12FE: C9      	            RET
12FF:         	IS_HEX_DIG:
12FF: D630    	            SUB  '0'
1301: C9      	            RET
1302:         	IS_HEX_BAD:
1302: 37      	            SCF
1303: C9      	            RET
              	
              	; --- PARSE_HEX8_HL: parseia 2 dígitos hex em (HL), resultado em A; HL avança 2 ---
              	;     Carry = erro
1304:         	PARSE_HEX8_HL:
1304: 7E      	            LD   A, (HL)
1305: CDEA12  	            CALL IS_HEX
1308: D8      	            RET  C
1309: 0F      	            RRCA
130A: 0F      	            RRCA
130B: 0F      	            RRCA
130C: 0F      	            RRCA
130D: E6F0    	            AND  0F0H
130F: 47      	            LD   B, A
1310: 23      	            INC  HL
1311: 7E      	            LD   A, (HL)
1312: CDEA12  	            CALL IS_HEX
1315: 3803    	            JR   C, PHX8_ERR
1317: B0      	            OR   B
1318: 23      	            INC  HL
1319: C9      	            RET
131A:         	PHX8_ERR:
131A: 2B      	            DEC  HL
131B: 37      	            SCF
131C: C9      	            RET
              	
              	; --- PARSE_HEX8_DE: igual mas com DE ---
131D:         	PARSE_HEX8_DE:
131D: 1A      	            LD   A, (DE)
131E: CDEA12  	            CALL IS_HEX
1321: D8      	            RET  C
1322: 0F      	            RRCA
1323: 0F      	            RRCA
1324: 0F      	            RRCA
1325: 0F      	            RRCA
1326: E6F0    	            AND  0F0H
1328: 47      	            LD   B, A
1329: 13      	            INC  DE
132A: 1A      	            LD   A, (DE)
132B: CDEA12  	            CALL IS_HEX
132E: 3803    	            JR   C, PHX8D_ERR
1330: B0      	            OR   B
1331: 13      	            INC  DE
1332: C9      	            RET
1333:         	PHX8D_ERR:
1333: 1B      	            DEC  DE
1334: 37      	            SCF
1335: C9      	            RET
              	
              	; --- PARSE_HEX16_DE: parseia 4 dígitos hex em (DE), resultado em HL; DE avança 4 ---
1336:         	PARSE_HEX16_DE:
1336: CD1D13  	            CALL PARSE_HEX8_DE
1339: D8      	            RET  C
133A: 67      	            LD   H, A
133B: CD1D13  	            CALL PARSE_HEX8_DE
133E: D8      	            RET  C
133F: 6F      	            LD   L, A
1340: C9      	            RET
              	
              	; --- UPCASE_TOKEN: copia token de (HL) em maiúscula para HEXBUF; HL avança após token ---
1341:         	UPCASE_TOKEN:
1341: 11F0FB  	            LD   DE, HEXBUF
1344: 060A    	            LD   B, 10
1346:         	UPCASE_LOOP:
1346: 7E      	            LD   A, (HL)
1347: FE20    	            CP   SPACE
1349: 2817    	            JR   Z, UPCASE_DONE
134B: FE0D    	            CP   CR
134D: 2813    	            JR   Z, UPCASE_DONE
134F: FE00    	            CP   NUL
1351: 280F    	            JR   Z, UPCASE_DONE
1353: FE61    	            CP   'a'
1355: 3806    	            JR   C, UPCASE_STORE
1357: FE7B    	            CP   'z'+1
1359: 3002    	            JR   NC, UPCASE_STORE
135B: E6DF    	            AND  0DFH               ; Converte para maiúscula
135D:         	UPCASE_STORE:
135D: 12      	            LD   (DE), A
135E: 23      	            INC  HL
135F: 13      	            INC  DE
1360: 10E4    	            DJNZ UPCASE_LOOP
1362:         	UPCASE_DONE:
1362: 3E00    	            LD   A, NUL
1364: 12      	            LD   (DE), A
1365: C9      	            RET
              	
              	; --- STRCMP: compara (HL) com (DE), Z=1 se iguais ---
1366:         	STRCMP:
1366: 7E      	            LD   A, (HL)
1367: 47      	            LD   B, A
1368: 1A      	            LD   A, (DE)
1369: B8      	            CP   B
136A: C0      	            RET  NZ
136B: FE00    	            CP   NUL
136D: C8      	            RET  Z
136E: 23      	            INC  HL
136F: 13      	            INC  DE
1370: 18F4    	            JR   STRCMP
              	
