              	; --------------------------------------
              	; zasm: assemble "Main.asm"
              	; date: 2026-06-11 00:06:47
              	; --------------------------------------


              	; Z80Mini   -   Maio de 2026
              	
              	; Sistema Monitor basico v1
              	;
              	; Z80 @7.372800Mhz
              	; ROM 32Kb @28C256      0000-7FFF
              	; RAM 32kb @62256       8000-FFFF
              	;
              	; Teclado Mecânico :) Custom    -   0x40 (Read/Write)
              	; I2C EEPROM (Drivers A: B: etc...)
              	; I2C RTC - ricoh223    -   0x64
              	; I2C Display 4x 7seg, Leds(5), Sons   -   0x0E
              	; In/Out generic    -   0xC0 (Read/Write)
              	; Leds  -   0x10
              	; GLCD 128x64   -   0x70
              	; USB-SERIAL SIO/2 A    -   0x00
              	; P2-SERIAL (Printer) SIO/2 B   -   0x00
              	;
              	;
              	; Compilação: zasm --z80 -w -u --bin  Main.asm
              	;
              	;
              	;   Comandos suportados:
              	;       H / ?       -   Mostra menu de ajuda, listando os comandos.
              	;       CLS         -   Limpa a tela lcd.
              	;       IHEX        -   Aguarda recebimento intel hex via serial_A (USB-SERIAL) Ex: :0C800000CDF4.........
              	;       OUT         -   Escreve byte na saida. (OUT 10 01) Liga led 1 da porta 0x10
              	;       IN          -   Lê byte da entrada. (IN 0c) Lê byte da entrada 0xC0
              	;       JUMP        -   Desvia PC para endereço. (JUMP 8000)
              	;       CALL        -   Salva monitor como retorno e desvia para endereço. (CALL 8000) o programa pode use RET e voltar para o Monitor.
              	;       DUMP        -   Mostra 40 bytes a partir do endereço atual da ram. (DUMP 8000)
              	;       WRITE       -   Escreve bytes a partir do endereço. (WRITE 8000) Linha vazia para inserção.
              	;       EDIT        -   Edita bytes a partir do endereço. (EDIT 8000) Linha vazia não alterar valor atual, "." para edição.
              	;       I2CLIST     -   Lista dispositivos i2c conectados no barramento.
              	;       FORMAT      -   Formata eeprom no drive atual.
              	;       DIR         -   Lista arquivos do driver atual.
              	;       LOAD        -   Carrega arquivo do drive atual. (LOAD NAME)
              	;       EXEC        -   Carrega e execulta arquivo do drive atual. (EXEC NAME)
              	;       DEL         -   Deleta arquivo no drive atual. (DEL NAME)
              	;       SAVE        -   Salva arquivo no drive atual. Name max 8 chars. (SAVE NAME RAM_ADDR_XXXX SIZE_XXXX) -> save blink 8000 004f
              	;       
              	;
              	;   API Z80Mini:
              	;       delay500ms          equ     0x0100  ;   Delay 500ms
              	;       delay               equ     0x0103  ;   On entry: DE = Delay time in milliseconds
              	;       I2C_Open            equ     0x0106  ;   On entry: A = Device address (bit zero is read flag)
              	;       I2C_Close           equ     0x0109  ;   Close
              	;       I2C_Read            equ     0x010C  ;   On exit: If successful A = data byte and Z flagged
              	;       I2C_Write           equ     0x010F  ;   On entry: A = Data byte, or Address byte (bit zero is read flag)
              	;       keyboardIsEsc       equ     0x0112  ;   Verifica se ESC foi precionada. On exit: If press A = CTRLC and NZ flagged
              	;       keyboardWaitA       equ     0x0115  ;   Aguarda tecla, letra em A. (BC DE HL preserved)
              	;       keyboardA           equ     0x0118  ;   Lê teclado, Se tecla Carry=1. Letra em A. (BC DE HL preserved)
              	;       setDefaultSerialA   equ     0x011B  ;   Seta terminal padrao porta A, Quando reinicia volta para A.
              	;       setDefaultSerialB   equ     0x011E  ;   Seta terminal padrao porta B (P2), Quando reinicia volta para A.
              	;       serialPrintA        equ     0x0121  ;   Imprime char in A no terminal setado.
              	;       serialInputA        equ     0x0124  ;   Aguarda receber char no terminal setado. Retorno em A.
              	;       serialPrintStr      equ     0x0127  ;   Imprime string (HL) terminado em 0 no terminal setado. MAX 128 chars. MODIFIES : A,B,C
              	;       serialCRLF          equ     0x012A  ;   Imprime CR e LF no terminal setado.
              	;       serialHexA          equ     0x012D  ;   Imprime byte em A no formato HEX, no terminal setado. Ex: 'D' = 44
              	;       serialHexHL         equ     0x0130  ;   Imprime HL como 4 digitos hexadecimais, no terminal setado. Ex: HL=$80FF -> imprime "80FF"
              	;       serialInHexA        equ     0x0133  ;   Pegar 2 caracteres ASCII (0-9 A-F), do terminal setado e converte em um byte em A. SEM ECHO
              	;       serialInHexHL       equ     0x0136  ;   Pegar 4 caracteres ASCII (0-9 A-F), do terminal setado e converte em HL. SEM ECHO
              	
              	;       initLCD             equ     0x0139  ;   Inicializa GLCD
              	;       clearGBUF           equ     0x013C  ;   Limpa buffer da memoria de grafico. Precisa do plotToLCD para refletir no lcd.
              	;       clearGrLCD          equ     0x013F  ;   Limpa memoria grafico do GLCD. Sem o plotToLCD.
              	;       clearTxtLCD         equ     0x0142  ;   Limpar caracteres do LCD
              	;       setGrMode           equ     0x0145  ;   Seta modo Grafico. 128x64
              	;       setTxtMode          equ     0x0148  ;   Seta mode Text. 16x4 equivalente
              	;       drawBox             equ     0x014B  ;   Desenha caixa. Entradas: BC = X0,Y0 - DE = X1,Y1    Destroys: HL
              	;       drawLine            equ     0x014E  ;   Desenha linha.  Entradas: BC = X0,Y0 - DE = X1,Y1
              	;       drawCircle          equ     0x0151  ;   Desenha circulo. Entradas BC = xm,ym (Ponro do Meio) - E = radius
              	;       drawPixel           equ     0x0154  ;   Desenha um pixel em X Y.  Entrada B = column/X (0-127), C = row/Y (0-63)   Destroys: HL
              	;       fillBox             equ     0x0157  ;   Desenha caixa preenchida. Entradas: BC = X0,Y0 - DE = X1,Y1    Destroys: HL
              	;       fillCircle          equ     0x015A  ;   Desenha circulo preenchido. Entradas BC = xm,ym (Ponro do Meio) - E = radius
              	;       plotToLCD           equ     0x015D  ;   Rotina principal de desenho. Move GBUF para o LCD e limpa o buffer ou não (setBufClear, setBufNoClear).  Destroys: ALL
              	;       printString         equ     0x0160  ;   Imprimir texto ASCII em uma determinada linha. Entradas: A = 0 a 3 Número da linha. .db "String" na próxima linha, terminar com 0
              	;       printChars          equ     0x0163  ;   (Ver detalhes) Imprimir caracteres na posição X,Y. Entrada B = coluna/X (0-7), C = linha/Y (0-3). HL = Endereço inicial do texto a ser exibido, termina com 0
              	;       setInt38            equ     0x0166  ;   Seta vetor de interrupcao int38. Entradas HL = RST38_ADDR
              	;       setint66            equ     0x0169  ;   Seta vetor de interrupcao int66. Entradas HL = RST66_ADDR
              	;       setBufClear         equ     0x016C  ;   Configura limpeza do buffer após a saída para o LCD e vai para clearGBUF.
              	;       setBufNoClear       equ     0x016F  ;   Configura para não limpar o buffer após a saída para o LCD.
              	;       clearPixel          equ     0x0172  ;   Limpa um pixel X Y.  Input B = column/X (0-127), C = row/Y (0-63)    Destroy HL
              	;       flipPixel           equ     0x0175  ;   Inverte um pixel X Y.  Input B = column/X (0-127), C = row/Y (0-63)    Destroy HL
              	;       drawGraphic         equ     0x0178  ;   Desenha no buffer. Entrada: A = número ASCII ou se A=0 Então  HL = Endereço dos dados gráficos. B = largura do gráfico em pixels (1-128). C = altura do gráfico em pixels (1-64). Destroy: ALL
              	;       invGraphic          equ     0x017B  ;   Altera a flag de desenho inverso. (não inverte grafico atual) Destroy A
              	;       initTerminal        equ     0x017E  ;   Inicializa o Terminal GLCD. Cursor 0,0 e limpa buffer.
              	;       sendCharToLCD       equ     0x0181  ;   Envia ou manipula caracteres ASCII para a tela GLCD (Terminal). Entrada: A = caractere ASCII a ser enviado para a tela GLCD. A = somente cursor desenhado.
              	;       sendStringToLCD     equ     0x0184  ;   Imprime string no terminal GLCD. DE = inicio da string. A = caractere para parar a impressão. A impressão para e retorna quando um CR é impresso. Destroy ALL
              	;       sendRegToLCD        equ     0x0187  ;   Imprime byte em A no formato HEX, no GLCD. Ex: 'D' = 44
              	;       sendHLToLCD         equ     0x018A  ;   Imprime HL como 4 digitos hexadecimais, no GLCD. Ex: HL=$80FF -> imprime "80FF"
              	;       setCursor           equ     0x018D  ;   Define a posição do cursor gráfico. Entradas: BC = X,Y onde X = 0..127, Y = 0..63   Destroy A
              	;       getCursor           equ     0x0190  ;   Obter a posição do cursor. Saídas: BC = X,Y onde X = 0..127, Y = 0..63
              	;       displayCursor       equ     0x0193  ;   Exibir Cursor. Entrada: A = 0, Ativar cursor, A = diferente de zero, Desativar cursor.
              	;       autoLF              equ     0x0196  ;   Avanço de linha automático quando o cursor atinge o final da linha (Terminal). Entrada: A = 0, Avanço de linha automático; A = diferente de zero, Sem avanço de linha automático. Padrao LIGADO.
              	;       underline           equ     0x0199  ;   Exibir sublinhado no caractere (Terminal). O estado inicial é sem sublinhado. Chamar esta rotina irá ALTERAR/DESLIGAR o sinalizador de sublinhado.
              	;       plotAlways          equ     0x019C  ;   Quando sendCharToLCD é chamado, Atualiza GLCD ou não. Se Desativado plotToLCD deve ser chamado atualizar o GLCD. Entrada: A=0, Plotar sempre; A>0, Não plotar. O padrão é Plotar sempre.
              	;       resetCollisionPixel equ     0x0294  ;   Limpa flag de colisao
              	;       checkCollisionPixel equ     0x0299  ;   Check se um pixel ja estava ligado quando tenta ligar. JP Z, SEM_COLISAO. JP NZ, COLISAO.
              	
              	
              	; -----------------------------------------------------------------------------
              	; H_Delay CONFIG
              	; -----------------------------------------------------------------------------
708000:         	kCPUClock:          .EQU 7372800       ;CPU clock speed in Hz
0024:         	kDelayOH:           .EQU 36             ;Overhead for each 1ms in Tcycles
001A:         	kDelayLP:           .EQU 26             ;Inner loop time in Tcycles
1CCC:         	kDelayTA:           .EQU kCPUClock / 1000 ;CPU clock cycles per millisecond
1CA8:         	kDelayTB:           .EQU kDelayTA - kDelayOH  ;Cycles required for inner loop
011A:         	kDelayCnt:          .EQU kDelayTB / kDelayLP  ;Loop counter for inner loop
              	
              	
              	; -----------------------------------------------------------------------------
              	; SYSTEM SETTINGS
              	; -----------------------------------------------------------------------------
FFF0:         	SYSTEM_SP:	        .EQU 	$FFF0	;INITIAL STACK POINTER
              	
              	; -----------------------------------------------------------------------------
              	; SIO/2 - SERIAL
              	; -----------------------------------------------------------------------------
0000:         	SIOA_D		        .EQU	$00
0002:         	SIOA_C		        .EQU	$02
0001:         	SIOB_D		        .EQU	$01 ; Conector P2
0003:         	SIOB_C		        .EQU	$03 ; Conector P2
              	
              	
              	; -----------------------------------------------------------------------------
              	; I2C SETTINGS
              	; -----------------------------------------------------------------------------
2710:         	TIMEOUT:        .EQU    10000      ; Timeout loop counter
00A0:         	EEDRIVE_A       .EQU    $A0        ; Drive A
00AE:         	EEDRIVE_B       .EQU    $AE        ; Drive B
              	
              	; -----------------------------------------------------------------------------
              	; PORTS
              	; -----------------------------------------------------------------------------
0070:         	GLCD_INST           .EQU    $70
0071:         	GLCD_DATA           .EQU    $71
              	
0040:         	KEYBOARD		    .EQU	$40
              	
              	
              	
              	
0008:         	BKSP:   EQU 08H                 ; Back space 08H
0009:         	TAB:    EQU 09H                 ; Horizontal TAB
000A:         	LF:     EQU 0AH                 ; Line feed
000C:         	CS:     EQU 0CH                 ; Clear screen
000D:         	CR:     EQU 0DH                 ; Carriage return
0020:         	SPACE:  EQU 20H                 ; Space
008F:         	CURSOR: EQU 8FH                 ; Cursor
              	
              	
              	
0000:         	    .ORG $0000
0000: C33002  	    JP INICIO
              	
              	    .ORG $0008
0008: C39B03  	RST08:	JP	CONOUT
              	
              	    .ORG $0010
0010: C3CD02  	RST10:	JP	CONIN
              	
              	    .ORG 0018H ; check break - BASIC
0018: C3B302  	RST18   JP CHKKEY
              	
              	
              		.ORG	0038H
0038: E5      		PUSH	HL
0039: 2A00F0  		LD	HL,(RST38)
003C: E9      		JP	(HL)
              	
              	;
              	; RESTART 66H NMI VECTOR
              	; SAME AS ABOVE BUT NMI CANNOT BE DISABLED.
              	;
              		.ORG	0066H
0066: E5      		PUSH	HL
0067: 2A02F0  		LD	HL,(RST66)
006A: E9      		JP	(HL)
              	
              	
              	    .ORG $0100
              	    ;   Delay
0100: C3AD1F  	    JP DELAY_500MS
0103: C39E02  	    JP H_Delay
              	    ;   I2C
0106: C38817  	    JP I2C_Open
0109: C38F17  	    JP I2C_Close
010C: C3CF17  	    JP I2C_Read
010F: C39217  	    JP I2C_Write
              	    ;   Keyboard
0112: C3B302  	    JP CHKKEY
0115: C3CD02  	    JP CONIN
0118: C3D702  	    JP CONIN_NOT_LOOP
              	    ;   Serial
011B: C3B61F  	    JP SET_DEFAULT_SERIAL_A
011E: C3C31F  	    JP SET_DEFAULT_SERIAL_B
0121: C39F0F  	    JP OUTCH
0124: C3A50F  	    JP INCH
0127: C3AB0F  	    JP SNDSTR
012A: C3F016  	    JP SERIAL_A_TXCRLF
012D: C3C816  	    JP SERIAL_A_PRINT_A_HEX
0130: C3BF16  	    JP SERIAL_A_PRINT_HL_HEX
0133: C3D01F  	    JP SERIAL_GET_HEX_A
0136: C3DC1F  	    JP SERIAL_GET_HEX_HL
              	    ;   GLCD
0139: C3BD03  	    JP initLCD
013C: C3DA03  	    JP clearGBUF
013F: C3EA03  	    JP clearGrLCD
0142: C31404  	    JP clearTxtLCD
0145: C32A04  	    JP setGrMode
0148: C33804  	    JP setTxtMode
014B: C33F04  	    JP drawBox
014E: C37A04  	    JP drawLine
0151: C32505  	    JP drawCircle
0154: C3FA05  	    JP drawPixel
0157: C36A04  	    JP fillBox
015A: C3EC05  	    JP fillCircle
015D: C35906  	    JP plotToLCD
0160: C38C06  	    JP printString
0163: C3AD06  	    JP printChars
0166: C3A501  	    JP SET_INT38
0169: C3A901  	    JP SET_INT66
016C: C3D406  	    JP setBufClear
016F: C3DC06  	    JP setBufNoClear
0172: C31706  	    JP clearPixel
0175: C32906  	    JP flipPixel
0178: C3AB08  	    JP drawGraphic
017B: C39308  	    JP invGraphic
017E: C3E106  	    JP initTerminal
0181: C30E07  	    JP sendCharToLCD
0184: C37E07  	    JP sendStringToLCD
0187: C3A507  	    JP sendRegToLCD
018A: C3C207  	    JP sendHLToLCD
018D: C3CE07  	    JP setCursor
0190: C38408  	    JP getCursor
0193: C38908  	    JP displayCursor
0196: C3A308  	    JP autoLF
0199: C39B08  	    JP underline
019C: C3A708  	    JP plotAlways
019F: C39402  	    JP resetCollisionPixel
01A2: C39902  	    JP checkCollisionPixel
              	
              	
01A5:         	SET_INT38:
01A5: 2200F0  	    LD (RST38), HL
01A8: C9      	    RET
              	
01A9:         	SET_INT66:
01A9: 2202F0  	    LD (RST66), HL
01AC: C9      	    RET
              	
              	; exemplo de uso de interrupcao
              	; IM 1
              	; EI
              	; RETI
01AD:         	INT_DEFAULT:
01AD: E1      	    POP HL ; sempre usar o POP HL
              	    ; faz alguma coisa
              	    ; EI
01AE: ED4D    	    RETI
              	
              	
              	
              	
              	
              	
              	
              	; ============================================================
              	; KEYMAPS
              	; ============================================================
              	
              	;	$FF - Capsloock
              	;	$FE - Shift left
              	;	$FD - Ctrl left
              	;	$FC - Windows
              	;	$FB - Alt left
              	;	$FA - Alt Gr    (Load intel hex - Serial A)
              	;	$F9 - LUZ   (CALL 8000H)
              	;	$F8 - Shift Right   (Display Scroll UP)
              	;	$F7 - Ctrl Right    (Display Scroll DOWN)
              	;	$F6 - Fn
              	;	$F5 - 
              	;	$F4 - 
              	
01B0:         	KEYMAP_NORMAL:
01B0: 1B09FFFE	    DB  $1B,  $09,  $FF,  $FE,  $FD,  $FC,  $FB,  $20
01B4: FDFCFB20	
01B8: 3171615C	    DB   '1', 'q',  'a',  '\',  $00,  $FA,  $F6,  $F9
01BC: 00FAF6F9	
01C0: 33656478	    DB   '3', 'e',  'd',  'x',  ',',  'l',  'o',  '9'
01C4: 2C6C6F39	
01C8: 34726663	    DB   '4', 'r',  'f',  'c',  '.',  'ç',  'p',  '0'
01CC: 2EE77030	
01D0: 36796862	    DB   '6', 'y',  'h',  'b',  $F8,  $F7,  0x0D, 0x08
01D4: F8F70D08	
01D8: 35746776	    DB   '5', 't',  'g',  'v',  ';',  '~', 	'`',  '-'
01DC: 3B7E602D	
01E0: 37756A6E	    DB   '7', 'u',  'j',  'n',  '/',  ']',  '[',  '='
01E4: 2F5D5B3D	
01E8: 3277737A	    DB   '2', 'w',  's',  'z',  'm',  'k',  'i',  '8'
01EC: 6D6B6938	
              	    
01F0:         	KEYMAP_SHIFT:
01F0: 1B09FFFE	    DB  $1B,  $09,  $FF,  $FE,  $FD,  $FC,  $FB,  $20
01F4: FDFCFB20	
01F8: 2151417C	    DB   '!', 'Q',  'A',  '|',  $00,  $FA,  $F6,  $F9
01FC: 00FAF6F9	
0200: 23454458	    DB   '#', 'E',  'D',  'X',  '<',  'L',  'O',  '('
0204: 3C4C4F28	
0208: 24524643	    DB   '$', 'R',  'F',  'C',  '>',  'Ç',  'P',  ')'
020C: 3EC75029	
0210: A8594842	    DB   '¨', 'Y',  'H',  'B',  $F8,  $F7,  0x0D, 0x08
0214: F8F70D08	
0218: 25544756	    DB   '%', 'T',  'G',  'V',  ':',  '^', 	$22,  '_'
021C: 3A5E225F	
0220: 26554A4E	    DB   '&', 'U',  'J',  'N',  '?',  '}',  '{',  '+'
0224: 3F7D7B2B	
0228: 4057535A	    DB   '@', 'W',  'S',  'Z',  'M',  'K',  'I',  '*'
022C: 4D4B492A	
              	
              	
0230:         	INICIO:
0230: 21AD01  	    LD HL, INT_DEFAULT
0233: 2200F0  	    LD (RST38), HL
0236: 2202F0  	    LD (RST66), HL
              	
              	    ; Set defult I2C device addess: 24LC256 (Copy from/to Mem)
0239: 3EA0    	    LD A, EEDRIVE_A
023B: 3201FC  	    LD (I2CA_BLOCK), A        
              	
              	    ;CALL FS_CHK_SIG
              	    ;JP Z, INICIO1
              	    ;LD HL, str_notfmt
              	    ;CALL PUTS
023E:         	INICIO1:
              	
023E: 31F0FF  	    LD SP, SYSTEM_SP
              	
0241: 116400  	    LD DE, $0064 ; 100ms
0244: CD9E02  	    CALL H_Delay
              	
              	    ;Init Serial
0247: CD5C0F  	    CALL initSerial
              	
              	    ;Init Teclado
024A: 3EFF    	    LD      A, 0xFF
024C: D340    	    OUT     (KEYBOARD), A           ; Todas as colunas desativadas
              	
              	    ; Init LCD
024E: CDE106  	    CALL initTerminal
0251: CD2A04  	    CALL setGrMode
0254: CDDC06  	    CALL setBufNoClear
              	
              	
              	    ; Show init string
0257: 010000  	    LD BC, $0000
025A: CDCE07  	    CALL setCursor
025D: 11FB1F  	    LD DE, WELLCOME_LCD
              	    ; set cursor ON
0260: 3E00    	    LD A, 0
0262: 3298FB  	    LD (CURSOR_ON), A
              	    ; send cursor
0265: CD7E07  	    CALL sendStringToLCD
              	
              	
0268:         	MAIN_LOOP:
0268: CD7402  	    CALL showCurrentDriver
              	
026B: CDA512  	    CALL GETLINE             ; Lê linha em LINEBUF
026E: CDF70F  	    CALL PARSE_CMD           ; Interpreta e executa
              	
0271: C36802  	    JP      MAIN_LOOP
              	
              	
0274:         	showCurrentDriver:
0274: 3A01FC  	    LD A, (I2CA_BLOCK)
0277: FEA0    	    CP EEDRIVE_A  ; Drive A
0279: 2805    	    JR Z, showDriveA
027B: FEAE    	    CP EEDRIVE_B  ; Drive B
027D: 2808    	    JR Z, showDriveB
027F: C9      	    RET
0280:         	showDriveA:
0280: 3E41    	    LD A, 'A'
0282: CD0E07  	    CALL sendCharToLCD
0285: 1807    	    JR showCursor
0287:         	showDriveB:
0287: 3E42    	    LD A, 'B'
0289: CD0E07  	    CALL sendCharToLCD
028C: 1800    	    JR showCursor
028E:         	showCursor:
028E: 3E3A    	    LD A, ':'
0290: CD0E07  	    CALL sendCharToLCD
0293: C9      	    RET
              	
              	
              	
0294:         	resetCollisionPixel:
0294: AF      	    XOR A
0295: 3239FD  	    LD (DRAW_PIXEL_COLLISION), A
0298: C9      	    RET
              	
              	; FLAG ZERO, 
              	; JP Z, SEM_COLISAO. 
              	; JP NZ, COLISAO.
0299:         	checkCollisionPixel:
0299: 3A39FD  	    LD A, (DRAW_PIXEL_COLLISION)
029C: B7      	    OR A
029D: C9      	    RET
              	
              	
              	
              	; **********************************************************************
              	; Delay by DE milliseconds
              	;   On entry: DE = Delay time in milliseconds
              	;   On exit:  AF BC DE HL IX IY I AF' BC' DE' HL' preserved
029E: F5      	H_Delay:    PUSH AF
029F: C5      	            PUSH BC
02A0: D5      	            PUSH DE
              	; 1 ms loop, DE times...        ;[=36]   [=29]    Overhead for each 1ms
02A1: 011A01  	LoopDE:    LD   BC, kDelayCnt   ;[10]    [9]
              	; Inner loop, BC times...       ;[=26]   [=20]    Loop time in Tcycles
02A4: 0B      	LoopBC:    DEC  BC             ;[6]     [4]
02A5: 79      	            LD   A,C            ;[4]     [4]
02A6: B0      	            OR   B              ;[4]     [4]
02A7: C2A402  	            JP   NZ,LoopBC     ;[12/7]  [8/6] 
              	; Have we looped once for each millisecond requested?
02AA: 1B      	            DEC  DE             ;[6]     [4]
02AB: 7B      	            LD   A,E            ;[4]     [4]
02AC: B2      	            OR   D              ;[4]     [4]
02AD: 20F2    	            JR   NZ, LoopDE     ;[12/7]  [8/6]
02AF: D1      	            POP  DE
02B0: C1      	            POP  BC
02B1: F1      	            POP  AF
02B2: C9      	            RET
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	
              	#include "TECLADO.asm"
0016:         	DB_OUTER    EQU     22          ; iterações externas
00F0:         	DB_INNER    EQU     240         ; iterações DJNZ internas
              	
              	
              	; -----------------------------------------------------------------------------
              	;   Check break key (Basic)
              	;       On exit: If press A = CTRLC and NZ flagged
              	;       BC DE HL preserved
              	; -----------------------------------------------------------------------------
02B3:         	CHKKEY:
02B3: 3EFE    	    LD      A, 0xFE             ; Máscara: bit 0 baixo = col 0
02B5: D340    	    OUT     (KEYBOARD), A       ; Ativa coluna B
02B7: 00      	    NOP                         ; ~270 ns de estabilização
02B8: 00      	    NOP
02B9: 00      	    NOP
02BA: 00      	    NOP
02BB: DB40    	    IN      A, (KEYBOARD)       ; Lê linhas
02BD: 2F      	    CPL                         ; Pull-up: inverte (pressionado = 1)
02BE: FE01    	    CP 1
02C0: C2C802  	    jp nz, GRET
02C3: 3E03    		LD  A, CTRLC
02C5: FE00    		CP	0
02C7: C9      		RET
02C8:         	GRET:
02C8: 3E00    		LD  A, 0
02CA: FE00    		CP 0
02CC: C9      		RET
              	
              	
              	;   CONIN: Lê um teclado → A
              	;       On exit: A = KEY
              	;       BC DE HL preserved
              	;       loop until key is pressed 
02CD:         	CONIN:
02CD: C5      	    PUSH BC
02CE: D5      	    PUSH DE
02CF: E5      	    PUSH HL
02D0: CD1003  	    CALL readKeyboarWaitPressA
02D3: E1      	    POP HL
02D4: D1      	    POP DE
02D5: C1      	    POP BC
02D6: C9      	    RET
              	
              	
              	
              	;   CONIN: Lê um teclado → A
              	;       On exit: A = KEY
              	;       BC DE HL preserved
              	;       sem loop, Carry=1 se tecla
02D7:         	CONIN_NOT_LOOP:
02D7: C5      	    PUSH BC
02D8: D5      	    PUSH DE
02D9: E5      	    PUSH HL
02DA: CDE102  	    CALL readKeyboarPressA
02DD: E1      	    POP HL
02DE: D1      	    POP DE
02DF: C1      	    POP BC
02E0: C9      	    RET
              	
              	
02E1:         	readKeyboarPressA;
02E1: AF      	    XOR A
02E2: 32A2FB  	    LD (MEN_SHIFT), A ; reset shift
02E5: CD4E03  	    CALL    SCAN_MATRIX
02E8: D0      	    RET      NC
02E9: CDF402  	    CALl GetKeycode
02EC: CDFA02  	    CALL checkShiftKey
02EF: 3AA3FB  	    LD A, (KEY_PRESS)
02F2: 37      	    SCF  ; Carry = 1
02F3: C9      	    RET
              	
              	
              	
              	; A = col*8 + row  (0x00 – 0x3F)
02F4:         	GetKeycode:
              	    ; --- Tecla confirmada: calcula keycode ---
              	    ; col*8 + row  (0x00 – 0x3F)
02F4: 78      	    LD      A, B                ; B = coluna
02F5: 87      	    ADD     A, A                ; ×2
02F6: 87      	    ADD     A, A                ; ×4
02F7: 87      	    ADD     A, A                ; ×8
02F8: 81      	    ADD     A, C                ; + linha (C) = keycode
02F9: C9      	    RET
              	
              	
              	; Verifica se shift e recupera ascii
              	;   Salva tecla em KEY_PRESS
02FA:         	checkShiftKey:
              	    ; Verifica Shift
02FA: 5F      	    LD E, A
02FB: 21B001  	    LD HL, KEYMAP_NORMAL
02FE: 3AA2FB  	    LD A, (MEN_SHIFT)
0301: FE01    	    CP 1
0303: C20903  	    JP NZ, NO_SHIFT
0306: 21F001  	    LD HL, KEYMAP_SHIFT
0309:         	NO_SHIFT:
0309: CD4903  	    CALL 	DO_LOOKUP	; pega tecla
030C: 32A3FB  	    LD (KEY_PRESS), A
030F: C9      	    RET
              	
              	
              	
              	; LER TECLADO
              	; Aguarda até uma teclad for pressionada e retorna em A
0310:         	readKeyboarWaitPressA:
0310: CD4E03  	    CALL    SCAN_MATRIX
0313: D21003  	    JP      NC, readKeyboarWaitPressA       ; Nenhuma tecla, continua
              	
              	    ; --- Primeira leitura positiva: aguarda debounce ---
0316: CD3D03  	    CALL    DEBOUNCE
              	
              	    ; --- Confirma que a tecla ainda está pressionada ---
0319: AF      	    XOR A
031A: 32A2FB  	    LD (MEN_SHIFT), A ; reset shift
031D: CD4E03  	    CALL    SCAN_MATRIX
0320: D21003  	    JP      NC, readKeyboarWaitPressA       ; Foi ruído, descarta
              	
0323: CDF402  	    CALL GetKeycode
              	    
0326: CDFA02  	    CALL checkShiftKey
              	    
              	    ; --- Aguarda soltar + debounce de release ---
0329:         	WAIT_RELEASE:
0329: CD4E03  	    CALL    SCAN_MATRIX
032C: DA2903  	    JP      C, WAIT_RELEASE     ; Ainda pressionada
032F: CD3D03  	    CALL    DEBOUNCE            ; Debounce do soltar
0332: CD4E03  	    CALL    SCAN_MATRIX
0335: DA2903  	    JP      C, WAIT_RELEASE     ; Bounce no release, volta a esperar
              	
0338: 3AA3FB  	    LD A, (KEY_PRESS)
033B: B7      	    OR A
033C: C9      	    RET
              	
              	
              	
              	
              	
              	
              	; ============================================================
              	; DEBOUNCE  –  espera ~10 ms (calibrado para 7.3728 MHz)
              	;   Usa DE como contador, preserva BC
              	;   T-states totais ≈ 69.080  →  ~9.36 ms
              	; ============================================================
033D:         	DEBOUNCE:
033D: C5      	    PUSH    BC
033E: 0616    	    LD      B, DB_OUTER         ; B = contador externo
0340:         	DB_OUTER_LOOP:
0340: 0EF0    	    LD      C, DB_INNER         ; C = contador interno
0342:         	DB_INNER_LOOP:
0342: 0D      	    DEC     C                   ; 4 T
0343: 20FD    	    JR      NZ, DB_INNER_LOOP   ; 12 T (não salta) / 7 T (salta)
0345: 10F9    	    DJNZ    DB_OUTER_LOOP       ; 13 T (não salta) / 8 T (salta)
0347: C1      	    POP     BC
0348: C9      	    RET
              	
              	
              	; Pega char in table
0349:         	DO_LOOKUP:
0349: 1600    	    LD      D, 0
034B: 19      	    ADD     HL, DE
034C: 7E      	    LD      A, (HL)
034D: C9      	    RET
              	
              	
              	; ============================================================
              	; SCAN_MATRIX
              	;   Varre 8 colunas, uma por vez (bit baixo = ativo)
              	;   Saída: B = col (0-7), C = row (0-7), Carry=1 se tecla
              	; ============================================================
034E:         	SCAN_MATRIX:
034E: 0600    	    LD      B, 0                ; Coluna atual
0350: 16FE    	    LD      D, 0xFE             ; Máscara: bit 0 baixo = col 0
0352:         	SCAN_COL:
0352: 7A      	    LD      A, D
0353: D340    	    OUT     (KEYBOARD), A       ; Ativa coluna B
0355: 00      	    NOP                         ; ~270 ns de estabilização
0356: 00      	    NOP
0357: 00      	    NOP
0358: 00      	    NOP
0359: DB40    	    IN      A, (KEYBOARD)       ; Lê linhas
035B: 2F      	    CPL                         ; Pull-up: inverte (pressionado = 1)
              	    
              	    ; SHIFT
035C: F5      	    PUSH AF
035D: 7A      	    LD A, D
035E: FEFE    	    CP $FE
0360: C27303  	    JP NZ, FIM
0363: F1      	    POP AF
0364: F5      	    PUSH AF
0365: FE08    	    CP $08
0367: C27303  	    JP NZ, FIM
036A: 3E01    	    LD A, 1
036C: 32A2FB  	    LD (MEN_SHIFT), A
036F: F1      	    POP AF
0370: 3E00    	    LD A, 0
0372: F5      	    PUSH AF
              	    
0373:         	FIM:
0373: F1      		POP AF
              	    
0374: E6FF    	    AND     0xFF
0376: 280E    	    JR      Z, NEXT_COL         ; Nenhuma linha nesta coluna
              	    
              	    ; Encontrou linha — identifica bit
0378: 0E00    	    LD      C, 0
037A:         	FIND_ROW:
037A: 1F      	    RRA
037B: 3803    	    JR      C, ROW_FOUND
037D: 0C      	    INC     C
037E: 18FA    	    JR      FIND_ROW
              	
0380:         	ROW_FOUND:
0380: 3EFF    	    LD      A, 0xFF
0382: D340    	    OUT     (KEYBOARD), A           ; Desativa colunas
0384: 37      	    SCF                         ; Carry = 1
0385: C9      	    RET
              	
0386:         	NEXT_COL:
0386: 04      	    INC     B
0387: 78      	    LD      A, B
0388: FE08    	    CP      8
038A: 2809    	    JR      Z, SCAN_NONE        ; Todas varridas, nada encontrado
              	
              	    ; Rotaciona máscara para próxima coluna
038C: 7A      	    LD      A, D
038D: 37      	    SCF
038E: CB17    	    RL      A                   ; Desloca bit baixo para esquerda
0390: F601    	    OR      0x01                ; Garante que o bit 0 volta alto (inativo)
0392: 57      	    LD      D, A
0393: 18BD    	    JR      SCAN_COL
              	
0395:         	SCAN_NONE:
0395: 3EFF    	    LD      A, 0xFF
0397: D340    	    OUT     (KEYBOARD), A
0399: B7      	    OR      A                   ; Limpa Carry
039A: C9      	    RET
              	
              	
              	    
              	    
              	    
              	#include "GLCD.asm"
              	; Graphical LCD 128 x 64 Library
              	; ------------------------------
              	; By B. Chiha May-2023
              	; Modificações para funcionar no Z80 Mini - 2026
              	;
              	; This is a native Z80 Graphics library to be used with 128x64 Graphical LCD Screens
              	;
              	; There are a few variants of these LCD screens, but they must all must use the ST7920
              	; LCD Controller.  The LCD Screen that I used is the QC12864B.  This screen has two
              	; ST7921 Panels (128 x 32) stacked one above the other.
              	;
              	; These screens have DDRAM (Graphics) and CGRAM (Text) areas.  Both RAM areas can 
              	; be displayed at the same time.
              	;
              	; The Pinout for the QC12864B board is as follows:
              	;
              	; Pin	Name	Desc                    Serial  Parallel
              	; ---   ----    -------------           ------  -------------
              	; 1     VSS     Ground                  GND     GND
              	; 2     VDD     Power                   5v      5v
              	; 3     V0      Contrast                N/A     N/A
              	; 4     D/I     IR/DR (CS)              5v      A7
              	; 5     R/W     R/W (SID)               D0      RD (inverted)
              	; 6     E       Enable (SCLK)           D1      Port 7 (inverted)
              	; 7     DB0     Data                    N/A     D0
              	; 8     DB1     Data                    N/A     D1
              	; 9     DB2     Data                    N/A     D2
              	; 10    DB3     Data                    N/A     D3
              	; 11    DB4     Data                    N/A     D4
              	; 12    DB5     Data                    N/A     D5
              	; 13    DB6     Data                    N/A     D6
              	; 14    DB7     Data                    N/A     D7
              	; 15    PSB     Serial/Para             GND     5v
              	; 16    NC
              	; 17    RST     Reset                   RST     RST
              	; 18    VEE     LCD Drive               N/A     N/A
              	; 19    A       Backlight               5v/NC   5v/NC
              	; 20    K       Backlight               GND/NC  GND/NC
              	;
              	;
              	        
              	        
              	; Modifiable values.  Thse three values can be modified to suit your own set up
              	; GLCD_INST and GLCD_DATA are the output ports to send an Instruction or Data value.
              	; V_DELAY_US is the minimum delay needed for a command to be processed by the
              	; LCD board.  If only some of the data is being sent, make this value larger
              	        
              	;Port 7 on TEC is connected to LCD Enable (Pin 6)
              	;A7 is connected to Register select (Pin 4).  (A7=0 for Instruction, A7=1 for Data)
0010:         	V_DELAY_US: .equ $0010   ;Delay for 76us on your system
              	
              	; Dont need to modify anything else below.
00F8:         	UP:     .equ $F8                 ; Up Arrow
00F7:         	DN:     .equ $F7                 ; Down Arrow
000C:         	FF:     .equ 0CH                 ; Form Feed
008F:         	CURSOR: .equ 8FH                 ; Cursor
              	        
              	
              	
              	
              	
              	; --- CONOUT: Envia byte em A ---
039B:         	PUTCHAR:
039B:         	CONOUT:
039B: F5      	        PUSH AF
039C: C5      	        PUSH BC
039D: D5      	        PUSH DE
039E: E5      	        PUSH HL
039F: CD0E07  	        CALL sendCharToLCD
03A2: E1      	        POP HL
03A3: D1      	        POP DE
03A4: C1      	        POP BC
03A5: F1      	        POP AF
03A6: C9      	        RET
              	
              	
              	; --- PUTS: Envia string terminada em NUL apontada por HL ---
03A7:         	PUTS:
03A7: F5      	        PUSH AF
03A8: C5      	        PUSH BC
03A9: D5      	        PUSH DE
03AA: E5      	        PUSH HL
03AB: 545D    	        LD DE, HL
03AD: 3E00    	        LD A, NUL
03AF: CD7E07  	        CALL sendStringToLCD
03B2: E1      	        POP HL
03B3: D1      	        POP DE
03B4: C1      	        POP BC
03B5: F1      	        POP AF
03B6: C9      	        RET
              	
              	; --- CRLF: Envia CR+LF ---
03B7:         	CRLF:
03B7: 3E0D    	        LD   A, CR
03B9: CD9B03  	        CALL PUTCHAR
03BC: C9      	        RET
              	
              	
              	
              	; Initialise LCD
03BD:         	initLCD:
03BD: 215809  	        LD HL, INIT_BASIC       ;POINT HL TO LCD INITIALIZE TABLE
03C0: 0604    	        LD B, 04H               ;B=4 BYTES
03C2:         	NEXT_CMD:
03C2: 7E      	        LD A, (HL)
03C3: D370    	        OUT (GLCD_INST), A
03C5: CDCB06  	        CALL delayUS
03C8: 23      	        INC HL
03C9: 10F7    	        DJNZ NEXT_CMD
03CB: 114001  	        LD DE, 0140H            ;1.6 ms
03CE: CDCE06  	        CALL delayMS
              	        
03D1: 2184F7  	        LD HL,GBUF              ;Set viewport
03D4: 2284FB  	        LD (VPORT),HL           ;to GBUF
              	
03D7: CDEA03  	        CALL clearGrLCD
              	        
              	; Clears the Graphics Memory Buffer
03DA:         	clearGBUF:
03DA: 2A84FB  	        LD HL, (VPORT)
03DD: ED5B84FB	        LD DE, (VPORT)
03E1: 13      	        INC DE
03E2: AF      	        XOR A
03E3: 77      	        LD (HL), A
03E4: 01FF03  	        LD BC, 03FFH
03E7: EDB0    	        LDIR
03E9: C9      	        RET
              	        
              	; Clears the Graphics LCD Buffer
03EA:         	clearGrLCD:
03EA: CD2A04  	        CALL setGrMode
03ED: 0E00    	        LD C, 00H
03EF:         	CLR_X:
03EF: 3E80    	        LD A, 80H
03F1: B1      	        OR C
03F2: D370    	        OUT (GLCD_INST), A
03F4: CDCB06  	        CALL delayUS
03F7: 3E80    	        LD A, 80H
03F9: D370    	        OUT (GLCD_INST), A
03FB: CDCB06  	        CALL delayUS
03FE: AF      	        XOR A                   ;Clear Byte
03FF: 0610    	        LD B, 10H
0401:         	CLR_Y:
0401: D371    	        OUT (GLCD_DATA), A
0403: CDCB06  	        CALL delayUS
0406: D371    	        OUT (GLCD_DATA), A
0408: CDCB06  	        CALL delayUS
040B: 10F4    	        DJNZ CLR_Y
040D: 0C      	        INC C
040E: 79      	        LD A, C
040F: FE20    	        CP 20H
0411: 20DC    	        JR NZ, CLR_X        
0413: C9      	        RET
              	
              	; Clears the ASCII Text LCD
0414:         	clearTxtLCD:
0414: CD3804  	        CALL setTxtMode
0417: 3E80    	        LD A, 80H
0419: D370    	        OUT (GLCD_INST), A
041B: CDCB06  	        CALL delayUS
041E: 0640    	        LD B, 40H
0420:         	CLR_ROWS:
0420: 3E20    	        LD A,  " "
0422: D371    	        OUT (GLCD_DATA), A
0424: CDCB06  	        CALL delayUS
0427: 10F7    	        DJNZ CLR_ROWS
0429: C9      	        RET
              	        
              	; Set Graphics Mode
042A:         	setGrMode:
042A: 3E34    	        LD A, 34H
042C: D370    	        OUT (GLCD_INST), A
042E: CDCB06  	        CALL delayUS
0431: 3E36    	        LD A, 36H
0433: D370    	        OUT (GLCD_INST), A
0435: C3CB06  	        JP delayUS
              	        
              	; Set Text Mode
0438:         	setTxtMode:
0438: 3E30    	        LD A, 30H
043A: D370    	        OUT (GLCD_INST), A
043C: C3CB06  	        JP delayUS
              	        
              	;Draw Box
              	;Inputs: BC = X0,Y0
              	;        DE = X1,Y1
              	;Destroys: HL
043F:         	drawBox:
043F: C5      	        PUSH BC
0440:         	TOP:
0440: CDFA05  	        CALL drawPixel
0443: 7A      	        LD A, D
0444: 04      	        INC B
0445: B8      	        CP B
0446: 30F8    	        JR NC, TOP
0448: C1      	        POP BC
              	        
0449: C5      	        PUSH BC
044A: 4B      	        LD C, E
044B:         	BOTTOM:
044B: CDFA05  	        CALL drawPixel
044E: 7A      	        LD A, D
044F: 04      	        INC B
0450: B8      	        CP B
0451: 30F8    	        JR NC, BOTTOM
0453: C1      	        POP BC
              	        
0454: C5      	        PUSH BC
0455:         	B_LEFT:
0455: CDFA05  	        CALL drawPixel
0458: 7B      	        LD A, E
0459: 0C      	        INC C
045A: B9      	        CP C
045B: 30F8    	        JR NC, B_LEFT
045D: C1      	        POP BC
              	        
045E: C5      	        PUSH BC
045F: 42      	        LD B, D
0460:         	B_RIGHT:
0460: CDFA05  	        CALL drawPixel
0463: 7B      	        LD A, E
0464: 0C      	        INC C
0465: B9      	        CP C
0466: 30F8    	        JR NC, B_RIGHT
0468: C1      	        POP BC
0469: C9      	        RET
              	        
              	;Fill Box
              	;Draws vertical lines from X0,Y0 to X0,Y1 and increase X0 to X1 until X0=X1
              	;Inputs: BC = X0,Y0
              	;        DE = X1,Y1
              	;Destroys: HL
046A:         	fillBox:
046A: C5      	        PUSH BC
046B:         	NEXT_PIXEL:
046B: CDFA05  	        CALL drawPixel
046E: 7B      	        LD A, E
046F: 0C      	        INC C
0470: B9      	        CP C
0471: 30F8    	        JR NC, NEXT_PIXEL
0473: C1      	        POP BC
0474: 7A      	        LD A, D
0475: 04      	        INC B
0476: B8      	        CP B
0477: 30F1    	        JR NC, fillBox
0479: C9      	        RET
              	        
              	;Draw a line between two points using Bresenham Line Algorithm
              	; void plotLine(int x0, int y0, int x1, int y1)
              	; {
              	;    int dx =  abs(x1-x0), sx = x0<x1 ? 1 : -1;
              	;    int dy = -abs(y1-y0), sy = y0<y1 ? 1 : -1;
              	;    int err = dx+dy, e2; /* error value e_xy */
              	        
              	;    for(;;){  /* loop */
              	;       setPixel(x0,y0);
              	;       if (x0==x1 && y0==y1) break;
              	;       e2 = 2*err;
              	;       if (e2 >= dy) { err += dy; x0 += sx; } /* e_xy+e_x > 0 */
              	;       if (e2 <= dx) { err += dx; y0 += sy; } /* e_xy+e_y < 0 */
              	;    }
              	; }
              	;Inputs: BC = X0,Y0
              	;        DE = X1,Y1
047A:         	drawLine:
              	;check that points are in range
047A: 79      	        LD A, C
047B: FE40    	        CP 40H
047D: D0      	        RET NC
047E: 78      	        LD A, B
047F: FE80    	        CP 80H
0481: D0      	        RET NC
0482: 7B      	        LD A, E
0483: FE40    	        CP 40H
0485: D0      	        RET NC
0486: 7A      	        LD A, D
0487: FE80    	        CP 80H
0489: D0      	        RET NC
              	        
              	;sx = x0<x1 ? 1 : -1
048A: 2601    	        LD H, 01H
048C: 78      	        LD A, B
048D: BA      	        CP D
048E: 3802    	        JR C, $ + 4
0490: 26FF    	        LD H, 0FFH
0492: 7C      	        LD A, H
0493: 328AFB  	        LD (SX), A
              	        
              	;sy = y0<y1 ? 1 : -1
0496: 2601    	        LD H, 01H
0498: 79      	        LD A, C
0499: BB      	        CP E
049A: 3802    	        JR C, $ + 4
049C: 26FF    	        LD H, 0FFH
049E: 7C      	        LD A, H
049F: 328BFB  	        LD (SY), A
              	        
04A2: ED5388FB	        ld (ENDPT), DE
              	        
              	;dx =  abs(x1-x0)
04A6: C5      	        PUSH BC
04A7: 6A      	        LD L, D
04A8: 2600    	        LD H, 0
04AA: 48      	        LD C, B
04AB: 0600    	        LD B, 0
04AD: B7      	        OR A
04AE: ED42    	        SBC HL, BC
04B0: CD1B05  	        CALL ABSHL
04B3: 228CFB  	        LD (DX), HL
04B6: C1      	        POP BC
              	        
              	;dy = -abs(y1-y0)
04B7: C5      	        PUSH BC
04B8: 6B      	        LD L, E
04B9: 2600    	        LD H, 0
