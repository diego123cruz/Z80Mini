11E6: E9      	            JP   (HL)                ; Salta para endereço
              	
11E7:         	GO_BAD:
11E7: 21BC13  	            LD   HL, MSG_BAD_ADDR
11EA: CD8403  	            CALL PUTS
11ED: C9      	            RET
              	
              	
              	; ============================================================
              	;  CALL_CMD  -  Executa código a partir de endereço
              	;  Sintaxe: CALL xxxx
