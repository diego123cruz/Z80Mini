1CBE: 1600    	    LD D, 0
1CC0: 1C      	    INC E                   ; E = byte_index + 1
1CC1: 010100  	    LD BC, 1
1CC4: CDA818  	    CALL I2C_MemWr
1CC7: C0      	    RET NZ
              	
1CC8: 3A38FC  	    LD A, (FS_BMPADDR)      ; A = pagina alocada
1CCB: B7      	    OR A                    ; NZ = sucesso
1CCC: C9      	    RET
              	
              	; FS_FREE_PG: Libera pagina A no bitmap (seta bit = 1)
              	;   On exit: Z=OK  NZ=erro I2C
1CCD:         	FS_FREE_PG:
1CCD: C5      	    PUSH BC
1CCE: D5      	    PUSH DE
1CCF: E5      	    PUSH HL
1CD0: F5      	    PUSH AF                 ; salva numero da pagina
              	
              	    ; bit_index = pagina mod 8
1CD1: E607    	    AND $07
1CD3: 4F      	    LD C, A                 ; C = bit_index
              	
              	    ; byte_index = pagina / 8 → endereco EEPROM = byte_index + 1
1CD4: F1      	    POP AF
1CD5: F5      	    PUSH AF
1CD6: CB3F    	    SRL A
1CD8: CB3F    	    SRL A
1CDA: CB3F    	    SRL A                   ; A = byte_index
