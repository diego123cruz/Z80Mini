0F2B: 01      	        .db 00000001b   ;      #
              	#include "SERIAL.asm"
              	; Inicializa SIO/2 Serial 115200
0F2C:         	initSerial:
0F2C: 21890F  	    LD    HL,TXDATA
0F2F: 229AFB  	    LD    (PUTCH),HL ;USE THE BITBANG SERIAL TRANSMIT
0F32: 219C0F  	    LD    HL,RXDATA
0F35: 229CFB  	    LD    (GETCH),HL  ;USE THE BITBANG SERIAL RECEIVE
              	
              	
              	    ;	Initialise SIO/2 A - Onboard USB
0F38: 3E04    		LD	A,$04
0F3A: D302    		OUT	(SIOA_C),A
0F3C: 3EC4    		LD	A,$C4
0F3E: D302    		OUT	(SIOA_C),A
              	
0F40: 3E03    		LD	A,$03
0F42: D302    		OUT	(SIOA_C),A
0F44: 3EE1    		LD	A,$E1
0F46: D302    		OUT	(SIOA_C),A
              	
0F48: 3E05    		LD	A,$05
0F4A: D302    		OUT	(SIOA_C),A
0F4C: 3E68    		LD	A, $68
0F4E: D302    		OUT	(SIOA_C),A
              	
              	    ; Initialise SIO/2 B - Printer (P2 conector)
0F50: 3E04    		LD	A,$04
0F52: D303    		OUT	(SIOB_C),A
0F54: 3EC4    		LD	A,$C4
0F56: D303    		OUT	(SIOB_C),A
              	
0F58: 3E03    		LD	A,$03
0F5A: D303    		OUT	(SIOB_C),A
0F5C: 3EE1    		LD	A,$E1
0F5E: D303    		OUT	(SIOB_C),A
              	
0F60: 3E05    		LD	A,$05
0F62: D303    		OUT	(SIOB_C),A
0F64: 3E68    		LD	A, $68
0F66: D303    		OUT	(SIOB_C),A
              	
              	
              	    ; Print wellcome serial
0F68: 21B31F  	    LD HL, WELLCOME
0F6B: CD7B0F  	    CALL SNDSTR
              	
0F6E: C9      		RET
              	
              	
              	
              	;-----------------------------------
              	; OUTPUT A CHARACTER TO THE TERMINAL
              	;-----------------------------------       
0F6F: DD2A9AFB	OUTCH:  LD   IX,(PUTCH)
0F73: DDE9    	       JP   (IX)
              	;------------------------------------
              	; INPUT A CHARACTER FROM THE TERMINAL
              	;------------------------------------
0F75: DD2A9CFB	INCH:  LD   IX,(GETCH)
0F79: DDE9    	      JP   (IX)
              	
              	
              		
              	
              	;-----------------------------------------
              	; SEND AN ASCII STRING OUT THE SERIAL PORT
              	;-----------------------------------------
              	; 
              	; SENDS A ZERO TERMINATED STRING OR 
              	; 128 CHARACTERS MAX. OUT THE SERIAL PORT
              	;
              	;      ENTRY : HL = POINTER TO 00H TERMINATED STRING
              	;      EXIT  : NONE
              	;
              	;       MODIFIES : A,B,C
              	;          
0F7B: 0680    	SNDSTR: LD    B,128         ;128 CHARS MAX
0F7D: 7E      	SDMSG1: LD    A,(HL)        ;GET THE CHAR
0F7E: FE00    	       CP    00H          ;ZERO TERMINATOR?
0F80: 2806    	       JR    Z,SDMSG2      ;FOUND A ZERO TERMINATOR, EXIT  
0F82: CD6F0F  	       CALL  OUTCH         ;TRANSMIT THE CHAR
0F85: 23      	       INC   HL
0F86: 10F5    	       DJNZ  SDMSG1        ;128 CHARS MAX!    
0F88: C9      	SDMSG2: RET
              	
              	
              	;------------------------
              	; SERIAL A TRANSMIT ROUTINE
              	;------------------------
              	;TRANSMIT BYTE SERIALLY ON DOUT
              	;
              	; ENTRY : A = BYTE TO TRANSMIT
              	;  EXIT : NO REGISTERS MODIFIED
              	;
0F89:         	TXDATA:		
0F89: F5      			PUSH	AF		; Store character
0F8A: CD930F  	conoutA1:	CALL	CKSIOA		; See if SIO channel A is finished transmitting
0F8D: 28FB    			JR	Z,conoutA1	; Loop until SIO flag signals ready
0F8F: F1      			POP	AF		; RETrieve character
0F90: D300    			OUT	(SIOA_D),A	; OUTput the character
0F92: C9      			RET
              	
              	
              	;------------------------------------------------------------------------------
              	; I/O status check routine
              	; Use the "primaryIO" flag to determine which port to check.
              	;------------------------------------------------------------------------------
0F93:         	CKSIOA
0F93: 97      			SUB	A
0F94: D302    			OUT 	(SIOA_C),A
0F96: DB02    			IN   	A,(SIOA_C)	; Status byte D2=TX Buff Empty, D0=RX char ready	
0F98: 0F      			RRCA			; Rotates RX status into Carry Flag,	
0F99: CB4F    			BIT  	1,A		; Set Zero flag if still transmitting character	
0F9B: C9      	        RET
              	
              	    
              	;-----------------------
              	; SERIAL A RECEIVE ROUTINE
              	;-----------------------
              	;RECEIVE SERIAL BYTE FROM DIN
              	;
              	; ENTRY : NONE
              	;  EXIT : A= RECEIVED BYTE IF CARRY CLEAR
              	;
              	; REGISTERS MODIFIED A AND F
              	;
0F9C:         	RXDATA:	
0F9C:         	waitForChar:
              	        ; Check if there is a char in channel A
0F9C: 97      			SUB	A
0F9D: D302    			OUT 	(SIOA_C),A
0F9F: DB02    			IN   	A,(SIOA_C)	; Status byte D2=TX Buff Empty, D0=RX char ready	
0FA1: 0F      			RRCA			; Rotates RX status into Carry Flag,	
0FA2: 30F8    			JR	NC, waitForChar
0FA4: DB00    			IN	A,(SIOA_D)
0FA6: B7      			OR A ; clear carry
0FA7: C9      			RET
              	
              	
              	
              	;======================= Serial B ========================
              	;------------------------
              	; SERIAL B TRANSMIT ROUTINE
              	;------------------------
              	;TRANSMIT BYTE SERIALLY ON DOUT
              	;
              	; ENTRY : A = BYTE TO TRANSMIT
              	;  EXIT : NO REGISTERS MODIFIED
              	;
0FA8:         	TXDATA_B:		
0FA8: F5      			PUSH	AF		; Store character
0FA9: CDB20F  	conoutB1:	CALL	CKSIOB		; See if SIO channel A is finished transmitting
0FAC: 28FB    			JR	Z,conoutB1	; Loop until SIO flag signals ready
0FAE: F1      			POP	AF		; RETrieve character
0FAF: D301    			OUT	(SIOB_D),A	; OUTput the character
0FB1: C9      			RET
              	
              	
              	;------------------------------------------------------------------------------
              	; I/O status check routine
              	; Use the "primaryIO" flag to determine which port to check.
              	;------------------------------------------------------------------------------
0FB2:         	CKSIOB
0FB2: 97      			SUB	A
0FB3: D303    			OUT 	(SIOB_C),A
0FB5: DB03    			IN   	A,(SIOB_C)	; Status byte D2=TX Buff Empty, D0=RX char ready	
0FB7: 0F      			RRCA			; Rotates RX status into Carry Flag,	
0FB8: CB4F    			BIT  	1,A		; Set Zero flag if still transmitting character	
0FBA: C9      	        RET
              	
              	    
              	;-----------------------
              	; SERIAL B RECEIVE ROUTINE
              	;-----------------------
              	;RECEIVE SERIAL BYTE FROM DIN
              	;
              	; ENTRY : NONE
              	;  EXIT : A= RECEIVED BYTE IF CARRY CLEAR
              	;
              	; REGISTERS MODIFIED A AND F
              	;
0FBB:         	RXDATA_B:	
0FBB:         	waitForCharB:
              	        ; Check if there is a char in channel A
0FBB: 97      			SUB	A
0FBC: D303    			OUT 	(SIOB_C),A
0FBE: DB03    			IN   	A,(SIOB_C)	; Status byte D2=TX Buff Empty, D0=RX char ready	
0FC0: 0F      			RRCA			; Rotates RX status into Carry Flag,	
0FC1: 30F8    			JR	NC, waitForCharB
0FC3: DB01    			IN	A,(SIOB_D)
0FC5: B7      			OR A ; clear carry
0FC6: C9      			RET
              	
              	#include "COMANDOS.asm"
              	
              	; -------- Constantes gerais --------
000D:         	CR          EQU  0DH
000A:         	LF          EQU  0AH
0008:         	BkS          EQU  08H
007F:         	DEL         EQU  7FH
001B:         	ESC         EQU  1BH
0020:         	SPACE       EQU  20H
0000:         	NUL         EQU  00H
              	
              	
              	
              	; ============================================================
              	;  PARSE_CMD  -  Analisa LINEBUF e despacha comando
              	; ============================================================
0FC7:         	PARSE_CMD:
0FC7: 21A0FB  	            LD   HL, LINEBUF
0FCA: CDD412  	            CALL SKIP_SPACES
              	            ; Verifica linha vazia
0FCD: 7E      	            LD   A, (HL)
0FCE: FE0D    	            CP   CR
0FD0: C8      	            RET  Z
0FD1: FE00    	            CP   NUL
0FD3: C8      	            RET  Z
              	
              	            ; Copia token do comando para comparação (uppercase)
0FD4: CD4013  	            CALL UPCASE_TOKEN        ; HL aponta após token, DE=token
              	
              	            ; Compara com cada comando conhecido
0FD7: 211010  	            LD   HL, CMD_TABLE
0FDA:         	CMD_SCAN:
0FDA: 7E      	            LD   A, (HL)
0FDB: FE00    	            CP   NUL
0FDD: CA0910  	            JP   Z, CMD_UNKNOWN
              	            ; Compara string
0FE0: E5      	            PUSH HL
0FE1: 11F0FB  	            LD   DE, HEXBUF          ; token gravado aqui por UPCASE_TOKEN
0FE4: CD6513  	            CALL STRCMP
0FE7: E1      	            POP  HL
0FE8: 280B    	            JR   Z, CMD_DISPATCH
              	            ; Avança para próxima entrada da tabela
              	            ; Formato: [str NUL] [addr 2 bytes]
0FEA:         	SKIP_ENTRY:
0FEA: 7E      	            LD   A, (HL)
0FEB: 23      	            INC  HL
0FEC: FE00    	            CP   NUL
0FEE: 20FA    	            JR   NZ, SKIP_ENTRY
0FF0: 23      	            INC  HL                  ; pula high byte do endereço
0FF1: 23      	            INC  HL                  ; pula low  byte do endereço
0FF2: C3DA0F  	            JP   CMD_SCAN
              	
0FF5:         	CMD_DISPATCH:
              	            ; Pula string do nome para chegar ao endereço
0FF5: 7E      	            LD   A, (HL)
0FF6: 23      	            INC  HL
0FF7: FE00    	            CP   NUL
0FF9: 20FA    	            JR   NZ, CMD_DISPATCH
              	            ; (HL) = low byte do handler, (HL+1) = high byte
0FFB: 7E      	            LD   A, (HL)
0FFC: 23      	            INC  HL
0FFD: 66      	            LD   H, (HL)
0FFE: 6F      	            LD   L, A
              	            ; HL = endereço do handler; HL aponta para resto da linha
              	            ; Precisamos salvar o ponteiro de argumento
              	            ; Reposiciona ponteiro de argumento
0FFF: 11A0FB  	            LD   DE, LINEBUF		 ; Inicio o buffer
1002: CDCD12  	            CALL SKIP_COMMAND_DE	 ; pula comando e DE aponta para o primeiro espaço
1005: CDDB12  	            CALL SKIP_SPACES_DE      ; DE aponta para args
1008: E9      	            JP   (HL)                ; chama handler
              	
1009:         	CMD_UNKNOWN:
1009: 219A13  	            LD   HL, MSG_UNKNOWN
100C: CD8303  	            CALL PUTS
100F: C9      	            RET
              	
              	; -------- Tabela de comandos --------
1010:         	CMD_TABLE:
1010: 434C5300	            DB   "CLS",  NUL
1014: BB10    	            DW   CLS_CMD
1016: 44554D50	            DB   "DUMP", NUL
101A: 00      	
