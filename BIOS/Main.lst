              	#include "IHEX.asm"
              	
              	
1551:         	loadInit:
1551: 3EFF    	    LD A, $FF
1553: 32F8FB  	    LD (LOAD_FIRST_FLAG), A
              	
1556: 211517  	    LD HL, MSG_LOAD_HELP
1559: CDB616  	    CALL SERIAL_A_PRINT_STRING
              	
155C: 111717  	    LD DE, MSG_LOAD_HELP_LCD
155F: CD4F07  	    CALL sendStringToLCD
              	
1562:         	loopHexLoad:
1562: CD9D0F  	    CALL RXDATA
              	
1565: FE3A    	    CP   ':'	; ":"?
1567: 20F9    		JR   NZ, loopHexLoad ; Aguarda :
              	
              	    ; Só inicializa o flag se for a primeira linha do carregamento
1569: 3AF8FB  		LD   A, (LOAD_FIRST_FLAG)
156C: FEFF    		CP   $FF                    ; $FF = virgem / sessão nova
156E: 2005    		JR   NZ, monitor_do_load    ; já está no meio de um carregamento
1570: 3E01    		LD   A, $01
1572: 32F8FB  		LD   (LOAD_FIRST_FLAG), A   ; sinaliza: próximo LOAD é o primeiro
              	
1575:         	monitor_do_load:
1575: CD8615  		CALL    LOAD
1578: CDBF16  		CALL SERIAL_A_TXCRLF
157B: C36215  	    JP loopHexLoad
              	
              	
157E:         	CALL_IHEX:
157E: 214F02  		LD HL, MAIN_LOOP
1581: E5      		PUSH HL
1582: CD5115  		CALL loadInit
1585: C9      		RET
              	
              	;------------------------------------------------------------------------------
              	; LOAD Intel Hex format file from the console.
              	; [Intel Hex Format is:
              	; 1) Colon (Frame 0)
              	; 2) Record Length Field (Frames 1 and 2)
              	; 3) Load Address Field (Frames 3,4,5,6)
              	; 4) Record Type Field (Frames 7 and 8)
              	; 5) Data Field (Frames 9 to 9+2*(Record Length)-1
              	; 6) Checksum Field - Sum of all byte values from Record Length to and 
              	;   including Checksum Field = 0 ]
              	;------------------------------------------------------------------------------	
1586:         	LOAD:
1586: 1E00    			LD   E,0	        ; Zera checksum
1588: CD6416  			CALL GET2	        ; Record Length -> D
158B: 57      			LD   D,A
158C: CD6416  			CALL GET2	        ; Endereco High -> H
158F: 67      			LD   H,A
1590: CD6416  			CALL GET2	        ; Endereco Low -> L
1593: 6F      			LD   L,A
1594: CD6416  			CALL GET2	        ; Record Type -> A
1597: FE01    			CP   $01	        ; EOF record?
1599: 2009    			JR   NZ,LOAD2	    ; Nao: processa dados
              	
              			; --- Record tipo 01: EOF ---
159B: CD6416  			CALL GET2	        ; Consome checksum do EOF
159E: 7B      			LD   A,E
159F: A7      			AND  A
15A0: 2839    			JR   Z,LOAD00       ; Checksum OK: imprime resumo
15A2: 1829    			JR   LOADERR        ; Checksum falhou
              	
              			; --- Record tipo 00: Dados ---
15A4:         	LOAD2:
              			; Salva endereco inicial apenas na primeira linha
15A4: 3AF8FB  			LD   A, (LOAD_FIRST_FLAG)
15A7: FE01    			CP   $01                    ; e a primeira linha?
15A9: 2008    			JR   NZ, LOAD2_SKIP
15AB: 3E00    			LD   A, $00
15AD: 32F8FB  			LD   (LOAD_FIRST_FLAG), A   ; limpa flag
15B0: 22F9FB  			LD   (LOAD_START_ADDR), HL  ; salva endereco inicial
              	
15B3:         	LOAD2_SKIP:
15B3: 7A      			LD   A,D	        ; Contador de bytes da linha
15B4: A7      			AND  A
15B5: 280D    			JR   Z,LOAD3
              	
15B7: CD6416  			CALL GET2	        ; Le proximo byte
15BA: 77      			LD   (HL),A	        ; Grava na memoria
15BB: 23      			INC  HL
15BC: 3E2E    			LD   A,'.'
15BE: CD700F  			CALL OUTCH
15C1: 15      			DEC  D
15C2: 18EF    			JR   LOAD2_SKIP     ; (continua pelo loop sem re-checar o flag)
              	
15C4:         	LOAD3:
15C4: 22FBFB  			LD   (LOAD_END_ADDR), HL    ; Atualiza endereco final (apos ultimo byte)
15C7: CD6416  			CALL GET2	                ; Consome checksum da linha
15CA: 7B      			LD   A,E
15CB: A7      			AND  A
15CC: C8      			RET  Z                      ; Checksum OK: volta pro monitor
              	
15CD:         	LOADERR:
15CD: 21CA16  			LD   HL,CKSUMERR
15D0: CDB616  			CALL SERIAL_A_PRINT_STRING
              	
              	        ;LCD
15D3: 11CA16  	        LD   DE, CKSUMERR
15D6: CD4F07  	        CALL sendStringToLCD
              	
15D9: E1      	        POP HL
              	
15DA: C9      			RET
              	
15DB:         	LOAD00:
              			; --- Imprime resumo do carregamento ---
15DB: 21DB16  			LD   HL, LDETXT
15DE: CDB616  			CALL SERIAL_A_PRINT_STRING
              	
15E1: 21FA16  			LD   HL, msg_load_start
15E4: CDB616  			CALL SERIAL_A_PRINT_STRING
15E7: 2AF9FB  			LD   HL, (LOAD_START_ADDR)
15EA: CD8E16  			CALL SERIAL_A_PRINT_HL_HEX
15ED: CDBF16  			CALL SERIAL_A_TXCRLF
              	
15F0: 210317  			LD   HL, msg_load_end
15F3: CDB616  			CALL SERIAL_A_PRINT_STRING
15F6: 2AFBFB  			LD   HL, (LOAD_END_ADDR)
15F9: 2B      			DEC  HL                     ; aponta para o ultimo byte gravado
15FA: CD8E16  			CALL SERIAL_A_PRINT_HL_HEX
15FD: CDBF16  			CALL SERIAL_A_TXCRLF
              	
1600: 210C17  			LD   HL, msg_load_total
1603: CDB616  			CALL SERIAL_A_PRINT_STRING
1606: ED5BF9FB			LD   DE, (LOAD_START_ADDR)
160A: 2AFBFB  			LD   HL, (LOAD_END_ADDR)
160D: B7      			OR   A                      ; limpa carry flag
160E: ED52    			SBC  HL, DE                 ; HL = total de bytes
1610: CD8E16  			CALL SERIAL_A_PRINT_HL_HEX
1613: CDBF16  			CALL SERIAL_A_TXCRLF
              	
              	        ; Mostra status no lcd
1616: 11F416  	        LD   DE, LDETXTLCD
1619: CD4F07  	        CALL sendStringToLCD
              	
161C: 11FA16  	        LD   DE, msg_load_start
161F: 3E00    	        LD   A, 0
1621: CD4F07  			CALL sendStringToLCD
1624: 2AF9FB  			LD   HL, (LOAD_START_ADDR)
1627: CD9307  			CALL sendHLToLCD
162A: CD9403  			CALL CRLF
              	
162D: 110317  			LD   DE, msg_load_end
1630: 3E00    	        LD   A, 0
1632: CD4F07  			CALL sendStringToLCD
1635: 2AFBFB  			LD   HL, (LOAD_END_ADDR)
1638: 2B      			DEC  HL                     ; aponta para o ultimo byte gravado
1639: CD9307  			CALL sendHLToLCD
163C: CD9403  			CALL CRLF
              	
163F: 110C17  			LD   DE, msg_load_total
1642: 3E00    	        LD   A, 0
1644: CD4F07  			CALL sendStringToLCD
1647: ED5BF9FB			LD   DE, (LOAD_START_ADDR)
164B: 2AFBFB  			LD   HL, (LOAD_END_ADDR)
164E: B7      			OR   A                      ; limpa carry flag
164F: ED52    			SBC  HL, DE                 ; HL = total de bytes
1651: CD9307  			CALL sendHLToLCD
              	
1654: CD9403  	        CALL CRLF
              	
1657: E1      	        POP HL 
1658: C9      			RET
              	
              	
              	
              	
              	;------------------------------------------------------------------------------
              	; Get a character from the console, must be $20-$7F to be valid (no control characters)
              	; <Ctrl-c> and <SPACE> breaks with the Zero Flag set
              	;------------------------------------------------------------------------------	
1659: CD760F  	GETCHR_S:	CALL INCH	; RX a Character
165C: FE03    			CP   $03	; <ctrl-c> User break?
165E: C8      			RET  Z			
165F: FE20    			CP   $20	; <space> or better?
1661: 38F6    			JR   C,GETCHR_S	; Do it again until we get something usable
1663: C9      			RET
              	
              	;------------------------------------------------------------------------------
              	; Gets two ASCII characters from the console (assuming them to be HEX 0-9 A-F)
              	; Moves them into B and C, converts them into a byte value in A and updates a
              	; Checksum value in E
              	;------------------------------------------------------------------------------
1664: CD5916  	GET2:   CALL GETCHR_S	; Get us a valid character to work with
1667: 47      			LD   B,A	; Load it in B
1668: CD5916  			CALL GETCHR_S	; Get us another character
166B: 4F      			LD   C,A	; load it in C
166C: CD7516  			CALL BCTOA	; Convert ASCII to byte
166F: 4F      			LD   C,A	; Build the checksum
1670: 7B      			LD   A,E
1671: 91      			SUB  C		; The checksum should always equal zero when checked
1672: 5F      			LD   E,A	; Save the checksum back where it came from
1673: 79      			LD   A,C	; Retrieve the byte and go back
1674: C9      			RET
              	
              	;------------------------------------------------------------------------------
              	; Convert ASCII characters in B C registers to a byte value in A
              	;------------------------------------------------------------------------------
1675: 78      	BCTOA		LD   A,B	; Move the hi order byte to A
1676: D630    			SUB  $30	; Take it down from Ascii
1678: FE0A    			CP   $0A	; Are we in the 0-9 range here?
167A: 3802    			JR   C,BCTOA1	; If so, get the next nybble
167C: D607    			SUB  $07	; But if A-F, take it down some more
167E: 07      	BCTOA1		RLCA		; Rotate the nybble from low to high
167F: 07      			RLCA		; One bit at a time
1680: 07      			RLCA		; Until we
1681: 07      			RLCA		; Get there with it
1682: 47      			LD   B,A	; Save the converted high nybble
1683: 79      			LD   A,C	; Now get the low order byte
1684: D630    			SUB  $30	; Convert it down from Ascii
1686: FE0A    			CP   $0A	; 0-9 at this point?
1688: 3802    			JR   C,BCTOA2	; Good enough then, but
168A: D607    			SUB  $07	; Take off 7 more if it's A-F
168C: 80      	BCTOA2		ADD  A,B	; Add in the high order nybble
168D: C9      			RET
              	
              	;------------------------------------------------------------------------------
              	; Imprime HL como 4 digitos hexadecimais
              	; Ex: HL=$80FF -> imprime "80FF"
              	;------------------------------------------------------------------------------
168E:         	SERIAL_A_PRINT_HL_HEX:
168E: 7C      			LD   A, H
168F: CD9716  			CALL SERIAL_A_PRINT_A_HEX
1692: 7D      			LD   A, L
1693: CD9716  			CALL SERIAL_A_PRINT_A_HEX
1696: C9      			RET
              	
              	
              	;------------------------------------------------------------------------------
              	; Imprime byte em A como 2 digitos hexadecimais
              	;------------------------------------------------------------------------------
1697:         	SERIAL_A_PRINT_A_HEX:
1697: F5      			PUSH AF
1698: 0F      			RRCA
1699: 0F      			RRCA
169A: 0F      			RRCA
169B: 0F      			RRCA
169C: CDA416  			CALL SERIAL_A_PRINT_NIBBLE
169F: F1      			POP  AF
16A0: CDA416  			CALL SERIAL_A_PRINT_NIBBLE
16A3: C9      			RET
              	
16A4:         	SERIAL_A_PRINT_NIBBLE:
16A4: E60F    			AND  $0F
16A6: FE0A    			CP   $0A
16A8: 3806    			JR   C, SERIAL_A_PRINT_NIBBLE_09
16AA: C637    			ADD  A, $37             ; A-F  ('A'=41h, 41h-0Ah=37h)
16AC: CD700F  			CALL OUTCH
16AF: C9      			RET
16B0:         	SERIAL_A_PRINT_NIBBLE_09:
16B0: C630    			ADD  A, $30             ; 0-9
16B2: CD700F  			CALL OUTCH
16B5: C9      			RET
              	
              	
              	;------------------------------------------------------------------------------
              	; Print string of characters to Serial A until byte=$00, WITH CR, LF
              	;------------------------------------------------------------------------------
16B6:         	SERIAL_A_PRINT_STRING:
16B6: 7E      	        LD   A,(HL)	; Get character
16B7: B7      			OR   A		; Is it $00 ?
