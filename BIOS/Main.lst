1C8C: 2008    	    JR NZ, FS_AP_FOUND
              	
1C8E: 04      	    INC B
1C8F: 78      	    LD A, B
1C90: FE80    	    CP 128
1C92: 38DB    	    JR C, FS_AP_LOOP
1C94: AF      	    XOR A                   ; Z = sem espaco
1C95: C9      	    RET
              	
1C96:         	FS_AP_FOUND:
              	    ; B = pagina livre. Salva bit_index e byte_index.
1C96: 78      	    LD A, B
1C97: E607    	    AND $07
1C99: 3239FC  	    LD (FS_BMPADDR+1), A    ; bit_index
              	
1C9C: 78      	    LD A, B
1C9D: CB3F    	    SRL A
1C9F: CB3F    	    SRL A
1CA1: CB3F    	    SRL A
1CA3: 5F      	    LD E, A                 ; E = byte_index
              	
              	    ; HL = PG_BUF + byte_index
1CA4: 213AFC  	    LD HL, PG_BUF
1CA7: 1600    	    LD D, 0
1CA9: 19      	    ADD HL, DE
              	
              	    ; Mascara = ~(1 << bit_index) para zerar o bit
1CAA: 3A39FC  	    LD A, (FS_BMPADDR+1)
1CAD: 4F      	    LD C, A
1CAE: 3E01    	    LD A, 1
1CB0:         	FS_AP_MKSHL:
1CB0: 0D      	    DEC C
1CB1: FAB71C  	    JP M, FS_AP_MKINV
1CB4: 07      	    RLCA
1CB5: 18F9    	    JR FS_AP_MKSHL
1CB7:         	FS_AP_MKINV:
1CB7: 2F      	    CPL                     ; ~mascara
              	
1CB8: A6      	    AND (HL)
1CB9: 77      	    LD (HL), A              ; atualiza PG_BUF
              	
              	    ; Salva numero da pagina antes do LD BC,1 destruir B
1CBA: 78      	    LD A, B
1CBB: 3238FC  	    LD (FS_BMPADDR), A
              	
