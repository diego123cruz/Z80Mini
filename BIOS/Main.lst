              	;------------------------------------------------------------------------------
              	; Pegar 2 caracteres ASCII (0-9 A-F) converte em um byte em A
              	;------------------------------------------------------------------------------
1F9F: CD5916  	SERIAL_GET_HEX_A:   CALL GETCHR_S	; Get us a valid character to work with
1FA2: 47      	    LD   B,A	; Load it in B
1FA3: CD5916  	    CALL GETCHR_S	; Get us another character
1FA6: 4F      	    LD   C,A	; load it in C
1FA7: CD7516  	    CALL BCTOA	; Convert ASCII to byte
1FAA: C9      	    RET
              	
              	;------------------------------------------------------------------------------
              	; Pegar 4 caracteres ASCII (0-9 A-F) converte em HL
              	;------------------------------------------------------------------------------
1FAB:         	SERIAL_GET_HEX_HL:
1FAB: CD9F1F  	    CALL SERIAL_GET_HEX_A	        ; Endereco High -> H
1FAE: 67      		LD   H,A
1FAF: CD9F1F  		CALL SERIAL_GET_HEX_A	        ; Endereco Low -> L
1FB2: 6F      		LD   L,A
1FB3: C9      	    RET
              	
              	
              	
