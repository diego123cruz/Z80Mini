              	; FS_DO_LOAD - carrega arquivo (FS_WRKBUF preenchido)
              	;   On exit: Z=OK  NZ=erro
1997:         	FS_DO_LOAD:
1997: 3A0EFC  	    LD A, (FS_WRKBUF + FS_O_RADRH)
