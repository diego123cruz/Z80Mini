1C2A: C2461C  	    JP NZ, FS_FF_ERR
1C2D: 3A10FC  	    LD A, (FS_WRKBUF + FS_O_FLAGS)
1C30: FEFF    	    CP FS_FLAG_FREE
1C32: CA431C  	    JP Z, FS_FF_FOUND
1C35: 3A02FC  	    LD A, (FS_CUR)
1C38: 3C      	    INC A
1C39: 3202FC  	    LD (FS_CUR), A
1C3C: C1      	    POP BC
1C3D: 10E7    	    DJNZ FS_FF_LP
1C3F: 3E01    	    LD A, 1
1C41: B7      	    OR A
1C42: C9      	    RET
1C43:         	FS_FF_FOUND:
