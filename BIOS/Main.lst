              	;==============================================================================
              	;==============================================================================
              	;==============================================================================
              	;===================       FUNCTIONS    =======================================
              	;==============================================================================
              	;==============================================================================
              	
              	
              	
              	
              	; **********************************************************************
              	; List devices found on the I2C bus
              	;
              	; Test each I2C device address and reports any that acknowledge
              	
185E: 214818  	I2CLIST:    LD   HL, I2C_LIST_MSG        ;Address of message string
              	            ;XOR A ; A = character to stop printing.
1861: CDA703  	            CALL PUTS         ;Output string
1864: 1600    	            LD   D,0            ;First I2C device address to test
1866: D5      	LISTLOOP:      PUSH DE             ;Preserve DE
1867: 7A      	            LD   A,D            ;Get device address to be tested
1868: CD8318  	            CALL LISTTEST          ;Test if device is present
186B: D1      	            POP  DE             ;Restore DE
186C: 2009    	            JR   NZ,LISTNEXT       ;Skip if no acknowledge
186E: 7A      	            LD   A,D            ;Get address of device tested
186F: CDFB18  	            CALL HexOut         ;Output as two character hex 
1872: 3E20    	            LD A, ' '; space
1874: CD9B03  	            CALL PUTCHAR       ;Output space character
1877: 14      	LISTNEXT:      INC  D              ;Get next write address
1878: 14      	            INC  D
1879: 7A      	            LD   A,D            ;Address of next device to test
187A: B7      	            OR   A              ;Have we tested all addresses?
187B: 20E9    	            JR   NZ,LISTLOOP       ;No, so loop again
187D: 3E0D    	            LD A, CR; enter
