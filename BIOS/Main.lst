10B8: D5      	    PUSH DE
10B9: C30080  	    JP  $8000
              	
              	
              	; ============================================================
              	;  CLS_CMD  -  Limpa tela via sequência ANSI
              	; ============================================================
10BC:         	CLS_CMD:
