19C4: C0      	    RET NZ
              	
              	    ; min(FS_TMPSZ, 255) bytes a ler
19C5: 2A2EFC  	    LD HL, (FS_TMPSZ)
19C8: 7C      	    LD A, H
19C9: B7      	    OR A
19CA: 2005    	    JR NZ, FS_DL_255
19CC: 7D      	    LD A, L
19CD: FEFF    	    CP FS_DATAPG
