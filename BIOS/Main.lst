              	#include "SERIAL.asm"
              	; Inicializa SIO/2 Serial 115200
0F40:         	initSerial:
0F40: 219D0F  	    LD    HL,TXDATA
0F43: 229EFB  	    LD    (PUTCH),HL ;USE THE BITBANG SERIAL TRANSMIT
0F46: 21B00F  	    LD    HL,RXDATA
0F49: 22A0FB  	    LD    (GETCH),HL  ;USE THE BITBANG SERIAL RECEIVE
              	
              	
              	    ;	Initialise SIO/2 A - Onboard USB
0F4C: 3E04    		LD	A,$04
0F4E: D302    		OUT	(SIOA_C),A
0F50: 3EC4    		LD	A,$C4
0F52: D302    		OUT	(SIOA_C),A
              	
0F54: 3E03    		LD	A,$03
0F56: D302    		OUT	(SIOA_C),A
0F58: 3EE1    		LD	A,$E1
0F5A: D302    		OUT	(SIOA_C),A
              	
0F5C: 3E05    		LD	A,$05
0F5E: D302    		OUT	(SIOA_C),A
0F60: 3E68    		LD	A, $68
0F62: D302    		OUT	(SIOA_C),A
              	
              	    ; Initialise SIO/2 B - Printer (P2 conector)
0F64: 3E04    		LD	A,$04
0F66: D303    		OUT	(SIOB_C),A
0F68: 3EC4    		LD	A,$C4
0F6A: D303    		OUT	(SIOB_C),A
              	
0F6C: 3E03    		LD	A,$03
0F6E: D303    		OUT	(SIOB_C),A
0F70: 3EE1    		LD	A,$E1
0F72: D303    		OUT	(SIOB_C),A
              	
0F74: 3E05    		LD	A,$05
0F76: D303    		OUT	(SIOB_C),A
0F78: 3E68    		LD	A, $68
0F7A: D303    		OUT	(SIOB_C),A
              	
              	
              	    ; Print wellcome serial
0F7C: 21C91F  	    LD HL, WELLCOME
0F7F: CD8F0F  	    CALL SNDSTR
              	
0F82: C9      		RET
              	
              	
              	
              	;-----------------------------------
              	; OUTPUT A CHARACTER TO THE TERMINAL
              	;-----------------------------------       
0F83: DD2A9EFB	OUTCH:  LD   IX,(PUTCH)
0F87: DDE9    	       JP   (IX)
              	;------------------------------------
              	; INPUT A CHARACTER FROM THE TERMINAL
              	;------------------------------------
0F89: DD2AA0FB	INCH:  LD   IX,(GETCH)
0F8D: DDE9    	      JP   (IX)
              	
              	
              		
              	
              	;-----------------------------------------
              	; SEND AN ASCII STRING OUT THE SERIAL PORT
              	;-----------------------------------------
              	; 
              	; SENDS A ZERO TERMINATED STRING OR 
              	; 128 CHARACTERS MAX. OUT THE SERIAL PORT
              	;
              	;      ENTRY : HL = POINTER TO 00H TERMINATED STRING
              	;      EXIT  : NONE
              	;
              	;       MODIFIES : A,B,C
              	;          
0F8F: 0680    	SNDSTR: LD    B,128         ;128 CHARS MAX
0F91: 7E      	SDMSG1: LD    A,(HL)        ;GET THE CHAR
0F92: FE00    	       CP    00H          ;ZERO TERMINATOR?
0F94: 2806    	       JR    Z,SDMSG2      ;FOUND A ZERO TERMINATOR, EXIT  
0F96: CD830F  	       CALL  OUTCH         ;TRANSMIT THE CHAR
0F99: 23      	       INC   HL
0F9A: 10F5    	       DJNZ  SDMSG1        ;128 CHARS MAX!    
0F9C: C9      	SDMSG2: RET
              	
              	
              	;------------------------
              	; SERIAL A TRANSMIT ROUTINE
              	;------------------------
              	;TRANSMIT BYTE SERIALLY ON DOUT
              	;
              	; ENTRY : A = BYTE TO TRANSMIT
              	;  EXIT : NO REGISTERS MODIFIED
              	;
0F9D:         	TXDATA:		
0F9D: F5      			PUSH	AF		; Store character
0F9E: CDA70F  	conoutA1:	CALL	CKSIOA		; See if SIO channel A is finished transmitting
0FA1: 28FB    			JR	Z,conoutA1	; Loop until SIO flag signals ready
0FA3: F1      			POP	AF		; RETrieve character
0FA4: D300    			OUT	(SIOA_D),A	; OUTput the character
0FA6: C9      			RET
              	
              	
              	;------------------------------------------------------------------------------
              	; I/O status check routine
              	; Use the "primaryIO" flag to determine which port to check.
              	;------------------------------------------------------------------------------
0FA7:         	CKSIOA
0FA7: 97      			SUB	A
0FA8: D302    			OUT 	(SIOA_C),A
0FAA: DB02    			IN   	A,(SIOA_C)	; Status byte D2=TX Buff Empty, D0=RX char ready	
0FAC: 0F      			RRCA			; Rotates RX status into Carry Flag,	
0FAD: CB4F    			BIT  	1,A		; Set Zero flag if still transmitting character	
0FAF: C9      	        RET
              	
              	    
              	;-----------------------
              	; SERIAL A RECEIVE ROUTINE
              	;-----------------------
              	;RECEIVE SERIAL BYTE FROM DIN
              	;
              	; ENTRY : NONE
              	;  EXIT : A= RECEIVED BYTE IF CARRY CLEAR
              	;
              	; REGISTERS MODIFIED A AND F
              	;
0FB0:         	RXDATA:	
0FB0:         	waitForChar:
              	        ; Check if there is a char in channel A
0FB0: 97      			SUB	A
0FB1: D302    			OUT 	(SIOA_C),A
0FB3: DB02    			IN   	A,(SIOA_C)	; Status byte D2=TX Buff Empty, D0=RX char ready	
0FB5: 0F      			RRCA			; Rotates RX status into Carry Flag,	
0FB6: 30F8    			JR	NC, waitForChar
0FB8: DB00    			IN	A,(SIOA_D)
0FBA: B7      			OR A ; clear carry
0FBB: C9      			RET
              	
              	
              	
              	;======================= Serial B ========================
              	;------------------------
              	; SERIAL B TRANSMIT ROUTINE
              	;------------------------
              	;TRANSMIT BYTE SERIALLY ON DOUT
              	;
              	; ENTRY : A = BYTE TO TRANSMIT
              	;  EXIT : NO REGISTERS MODIFIED
              	;
0FBC:         	TXDATA_B:		
0FBC: F5      			PUSH	AF		; Store character
0FBD: CDC60F  	conoutB1:	CALL	CKSIOB		; See if SIO channel A is finished transmitting
0FC0: 28FB    			JR	Z,conoutB1	; Loop until SIO flag signals ready
0FC2: F1      			POP	AF		; RETrieve character
0FC3: D301    			OUT	(SIOB_D),A	; OUTput the character
0FC5: C9      			RET
              	
              	
              	;------------------------------------------------------------------------------
              	; I/O status check routine
              	; Use the "primaryIO" flag to determine which port to check.
              	;------------------------------------------------------------------------------
0FC6:         	CKSIOB
0FC6: 97      			SUB	A
0FC7: D303    			OUT 	(SIOB_C),A
0FC9: DB03    			IN   	A,(SIOB_C)	; Status byte D2=TX Buff Empty, D0=RX char ready	
0FCB: 0F      			RRCA			; Rotates RX status into Carry Flag,	
0FCC: CB4F    			BIT  	1,A		; Set Zero flag if still transmitting character	
0FCE: C9      	        RET
              	
              	    
              	;-----------------------
              	; SERIAL B RECEIVE ROUTINE
              	;-----------------------
              	;RECEIVE SERIAL BYTE FROM DIN
              	;
              	; ENTRY : NONE
              	;  EXIT : A= RECEIVED BYTE IF CARRY CLEAR
              	;
              	; REGISTERS MODIFIED A AND F
              	;
0FCF:         	RXDATA_B:	
0FCF:         	waitForCharB:
              	        ; Check if there is a char in channel A
0FCF: 97      			SUB	A
0FD0: D303    			OUT 	(SIOB_C),A
0FD2: DB03    			IN   	A,(SIOB_C)	; Status byte D2=TX Buff Empty, D0=RX char ready	
0FD4: 0F      			RRCA			; Rotates RX status into Carry Flag,	
0FD5: 30F8    			JR	NC, waitForCharB
0FD7: DB01    			IN	A,(SIOB_D)
0FD9: B7      			OR A ; clear carry
0FDA: C9      			RET
              	
              	#include "COMANDOS.asm"
              	
              	; -------- Constantes gerais --------
000D:         	CR          EQU  0DH
000A:         	LF          EQU  0AH
0008:         	BkS          EQU  08H
007F:         	DEL         EQU  7FH
001B:         	ESC         EQU  1BH
0020:         	SPACE       EQU  20H
0000:         	NUL         EQU  00H
              	
              	
              	
              	; ============================================================
              	;  PARSE_CMD  -  Analisa LINEBUF e despacha comando
              	; ============================================================
0FDB:         	PARSE_CMD:
0FDB: 21A4FB  	            LD   HL, LINEBUF
0FDE: CDEB12  	            CALL SKIP_SPACES
              	            ; Verifica linha vazia
0FE1: 7E      	            LD   A, (HL)
0FE2: FE0D    	            CP   CR
0FE4: C8      	            RET  Z
0FE5: FE00    	            CP   NUL
0FE7: C8      	            RET  Z
              	
              	            ; Copia token do comando para comparação (uppercase)
0FE8: CD5713  	            CALL UPCASE_TOKEN        ; HL aponta após token, DE=token
              	
              	            ; Compara com cada comando conhecido
0FEB: 212410  	            LD   HL, CMD_TABLE
0FEE:         	CMD_SCAN:
0FEE: 7E      	            LD   A, (HL)
0FEF: FE00    	            CP   NUL
0FF1: CA1D10  	            JP   Z, CMD_UNKNOWN
              	            ; Compara string
0FF4: E5      	            PUSH HL
0FF5: 11F4FB  	            LD   DE, HEXBUF          ; token gravado aqui por UPCASE_TOKEN
0FF8: CD7C13  	            CALL STRCMP
0FFB: E1      	            POP  HL
0FFC: 280B    	            JR   Z, CMD_DISPATCH
              	            ; Avança para próxima entrada da tabela
              	            ; Formato: [str NUL] [addr 2 bytes]
0FFE:         	SKIP_ENTRY:
0FFE: 7E      	            LD   A, (HL)
0FFF: 23      	            INC  HL
1000: FE00    	            CP   NUL
1002: 20FA    	            JR   NZ, SKIP_ENTRY
1004: 23      	            INC  HL                  ; pula high byte do endereço
1005: 23      	            INC  HL                  ; pula low  byte do endereço
1006: C3EE0F  	            JP   CMD_SCAN
              	
1009:         	CMD_DISPATCH:
              	            ; Pula string do nome para chegar ao endereço
1009: 7E      	            LD   A, (HL)
100A: 23      	            INC  HL
100B: FE00    	            CP   NUL
100D: 20FA    	            JR   NZ, CMD_DISPATCH
              	            ; (HL) = low byte do handler, (HL+1) = high byte
100F: 7E      	            LD   A, (HL)
1010: 23      	            INC  HL
1011: 66      	            LD   H, (HL)
1012: 6F      	            LD   L, A
              	            ; HL = endereço do handler; HL aponta para resto da linha
              	            ; Precisamos salvar o ponteiro de argumento
              	            ; Reposiciona ponteiro de argumento
1013: 11A4FB  	            LD   DE, LINEBUF		 ; Inicio o buffer
1016: CDE412  	            CALL SKIP_COMMAND_DE	 ; pula comando e DE aponta para o primeiro espaço
1019: CDF212  	            CALL SKIP_SPACES_DE      ; DE aponta para args
101C: E9      	            JP   (HL)                ; chama handler
              	
101D:         	CMD_UNKNOWN:
101D: 21B113  	            LD   HL, MSG_UNKNOWN
1020: CD9703  	            CALL PUTS
1023: C9      	            RET
              	
