0020:         	FS_ENTRY_SZ:.EQU 32
0008:         	FS_NAME_SZ: .EQU 8
00FF:         	FS_DATAPG:  .EQU 255        ; bytes uteis por pagina
              	
00FF:         	FS_FLAG_FREE: .EQU $FF
0001:         	FS_FLAG_USED: .EQU $01
              	
