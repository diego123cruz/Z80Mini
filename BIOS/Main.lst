0F5B: 01      	        .db 00000001b   ;      #
              	#include "SERIAL.asm"
              	; Inicializa SIO/2 Serial 115200
0F5C:         	initSerial:
0F5C: 21B90F  	    LD    HL,TXDATA
0F5F: 229EFB  	    LD    (PUTCH),HL ;USE THE BITBANG SERIAL TRANSMIT
0F62: 21CC0F  	    LD    HL,RXDATA
0F65: 22A0FB  	    LD    (GETCH),HL  ;USE THE BITBANG SERIAL RECEIVE
              	
              	
              	    ;	Initialise SIO/2 A - Onboard USB
0F68: 3E04    		LD	A,$04
0F6A: D302    		OUT	(SIOA_C),A
0F6C: 3EC4    		LD	A,$C4
0F6E: D302    		OUT	(SIOA_C),A
              	
0F70: 3E03    		LD	A,$03
0F72: D302    		OUT	(SIOA_C),A
0F74: 3EE1    		LD	A,$E1
0F76: D302    		OUT	(SIOA_C),A
              	
0F78: 3E05    		LD	A,$05
0F7A: D302    		OUT	(SIOA_C),A
0F7C: 3E68    		LD	A, $68
0F7E: D302    		OUT	(SIOA_C),A
              	
              	    ; Initialise SIO/2 B - Printer (P2 conector)
0F80: 3E04    		LD	A,$04
0F82: D303    		OUT	(SIOB_C),A
0F84: 3EC4    		LD	A,$C4
0F86: D303    		OUT	(SIOB_C),A
              	
0F88: 3E03    		LD	A,$03
0F8A: D303    		OUT	(SIOB_C),A
0F8C: 3EE1    		LD	A,$E1
0F8E: D303    		OUT	(SIOB_C),A
              	
0F90: 3E05    		LD	A,$05
0F92: D303    		OUT	(SIOB_C),A
0F94: 3E68    		LD	A, $68
0F96: D303    		OUT	(SIOB_C),A
              	
              	
              	    ; Print wellcome serial
0F98: 21E51F  	    LD HL, WELLCOME
0F9B: CDAB0F  	    CALL SNDSTR
              	
0F9E: C9      		RET
              	
              	
              	
              	;-----------------------------------
              	; OUTPUT A CHARACTER TO THE TERMINAL
              	;-----------------------------------       
0F9F: DD2A9EFB	OUTCH:  LD   IX,(PUTCH)
0FA3: DDE9    	       JP   (IX)
              	;------------------------------------
              	; INPUT A CHARACTER FROM THE TERMINAL
              	;------------------------------------
0FA5: DD2AA0FB	INCH:  LD   IX,(GETCH)
0FA9: DDE9    	      JP   (IX)
              	
              	
              		
              	
              	;-----------------------------------------
              	; SEND AN ASCII STRING OUT THE SERIAL PORT
              	;-----------------------------------------
              	; 
              	; SENDS A ZERO TERMINATED STRING OR 
              	; 128 CHARACTERS MAX. OUT THE SERIAL PORT
              	;
              	;      ENTRY : HL = POINTER TO 00H TERMINATED STRING
              	;      EXIT  : NONE
              	;
              	;       MODIFIES : A,B,C
              	;          
0FAB: 0680    	SNDSTR: LD    B,128         ;128 CHARS MAX
0FAD: 7E      	SDMSG1: LD    A,(HL)        ;GET THE CHAR
0FAE: FE00    	       CP    00H          ;ZERO TERMINATOR?
0FB0: 2806    	       JR    Z,SDMSG2      ;FOUND A ZERO TERMINATOR, EXIT  
0FB2: CD9F0F  	       CALL  OUTCH         ;TRANSMIT THE CHAR
0FB5: 23      	       INC   HL
0FB6: 10F5    	       DJNZ  SDMSG1        ;128 CHARS MAX!    
0FB8: C9      	SDMSG2: RET
              	
              	
              	;------------------------
              	; SERIAL A TRANSMIT ROUTINE
              	;------------------------
              	;TRANSMIT BYTE SERIALLY ON DOUT
              	;
              	; ENTRY : A = BYTE TO TRANSMIT
              	;  EXIT : NO REGISTERS MODIFIED
              	;
0FB9:         	TXDATA:		
0FB9: F5      			PUSH	AF		; Store character
0FBA: CDC30F  	conoutA1:	CALL	CKSIOA		; See if SIO channel A is finished transmitting
0FBD: 28FB    			JR	Z,conoutA1	; Loop until SIO flag signals ready
0FBF: F1      			POP	AF		; RETrieve character
0FC0: D300    			OUT	(SIOA_D),A	; OUTput the character
0FC2: C9      			RET
              	
              	
              	;------------------------------------------------------------------------------
              	; I/O status check routine
              	; Use the "primaryIO" flag to determine which port to check.
              	;------------------------------------------------------------------------------
0FC3:         	CKSIOA
0FC3: 97      			SUB	A
0FC4: D302    			OUT 	(SIOA_C),A
0FC6: DB02    			IN   	A,(SIOA_C)	; Status byte D2=TX Buff Empty, D0=RX char ready	
0FC8: 0F      			RRCA			; Rotates RX status into Carry Flag,	
0FC9: CB4F    			BIT  	1,A		; Set Zero flag if still transmitting character	
0FCB: C9      	        RET
              	
              	    
              	;-----------------------
              	; SERIAL A RECEIVE ROUTINE
              	;-----------------------
              	;RECEIVE SERIAL BYTE FROM DIN
              	;
              	; ENTRY : NONE
              	;  EXIT : A= RECEIVED BYTE IF CARRY CLEAR
              	;
              	; REGISTERS MODIFIED A AND F
              	;
0FCC:         	RXDATA:	
0FCC:         	waitForChar:
              	        ; Check if there is a char in channel A
0FCC: 97      			SUB	A
0FCD: D302    			OUT 	(SIOA_C),A
0FCF: DB02    			IN   	A,(SIOA_C)	; Status byte D2=TX Buff Empty, D0=RX char ready	
0FD1: 0F      			RRCA			; Rotates RX status into Carry Flag,	
0FD2: 30F8    			JR	NC, waitForChar
0FD4: DB00    			IN	A,(SIOA_D)
0FD6: B7      			OR A ; clear carry
0FD7: C9      			RET
              	
              	
              	
              	;======================= Serial B ========================
              	;------------------------
              	; SERIAL B TRANSMIT ROUTINE
              	;------------------------
              	;TRANSMIT BYTE SERIALLY ON DOUT
              	;
              	; ENTRY : A = BYTE TO TRANSMIT
              	;  EXIT : NO REGISTERS MODIFIED
              	;
0FD8:         	TXDATA_B:		
0FD8: F5      			PUSH	AF		; Store character
0FD9: CDE20F  	conoutB1:	CALL	CKSIOB		; See if SIO channel A is finished transmitting
0FDC: 28FB    			JR	Z,conoutB1	; Loop until SIO flag signals ready
0FDE: F1      			POP	AF		; RETrieve character
0FDF: D301    			OUT	(SIOB_D),A	; OUTput the character
0FE1: C9      			RET
              	
              	
              	;------------------------------------------------------------------------------
              	; I/O status check routine
              	; Use the "primaryIO" flag to determine which port to check.
              	;------------------------------------------------------------------------------
0FE2:         	CKSIOB
0FE2: 97      			SUB	A
0FE3: D303    			OUT 	(SIOB_C),A
0FE5: DB03    			IN   	A,(SIOB_C)	; Status byte D2=TX Buff Empty, D0=RX char ready	
0FE7: 0F      			RRCA			; Rotates RX status into Carry Flag,	
0FE8: CB4F    			BIT  	1,A		; Set Zero flag if still transmitting character	
0FEA: C9      	        RET
              	
              	    
              	;-----------------------
              	; SERIAL B RECEIVE ROUTINE
              	;-----------------------
              	;RECEIVE SERIAL BYTE FROM DIN
              	;
              	; ENTRY : NONE
              	;  EXIT : A= RECEIVED BYTE IF CARRY CLEAR
              	;
              	; REGISTERS MODIFIED A AND F
              	;
0FEB:         	RXDATA_B:	
0FEB:         	waitForCharB:
              	        ; Check if there is a char in channel A
0FEB: 97      			SUB	A
0FEC: D303    			OUT 	(SIOB_C),A
0FEE: DB03    			IN   	A,(SIOB_C)	; Status byte D2=TX Buff Empty, D0=RX char ready	
0FF0: 0F      			RRCA			; Rotates RX status into Carry Flag,	
0FF1: 30F8    			JR	NC, waitForCharB
0FF3: DB01    			IN	A,(SIOB_D)
0FF5: B7      			OR A ; clear carry
0FF6: C9      			RET
              	
              	#include "COMANDOS.asm"
              	
              	; -------- Constantes gerais --------
000D:         	CR          EQU  0DH
000A:         	LF          EQU  0AH
0008:         	BkS          EQU  08H
007F:         	DEL         EQU  7FH
001B:         	ESC         EQU  1BH
0020:         	SPACE       EQU  20H
0000:         	NUL         EQU  00H
              	
              	
              	
              	; ============================================================
              	;  PARSE_CMD  -  Analisa LINEBUF e despacha comando
              	; ============================================================
0FF7:         	PARSE_CMD:
0FF7: 21A4FB  	            LD   HL, LINEBUF
0FFA: CD0713  	            CALL SKIP_SPACES
              	            ; Verifica linha vazia
0FFD: 7E      	            LD   A, (HL)
0FFE: FE0D    	            CP   CR
1000: C8      	            RET  Z
1001: FE00    	            CP   NUL
1003: C8      	            RET  Z
              	
              	            ; Copia token do comando para comparação (uppercase)
1004: CD7313  	            CALL UPCASE_TOKEN        ; HL aponta após token, DE=token
              	
              	            ; Compara com cada comando conhecido
1007: 214010  	            LD   HL, CMD_TABLE
100A:         	CMD_SCAN:
100A: 7E      	            LD   A, (HL)
100B: FE00    	            CP   NUL
100D: CA3910  	            JP   Z, CMD_UNKNOWN
              	            ; Compara string
1010: E5      	            PUSH HL
1011: 11F4FB  	            LD   DE, HEXBUF          ; token gravado aqui por UPCASE_TOKEN
1014: CD9813  	            CALL STRCMP
1017: E1      	            POP  HL
1018: 280B    	            JR   Z, CMD_DISPATCH
              	            ; Avança para próxima entrada da tabela
              	            ; Formato: [str NUL] [addr 2 bytes]
101A:         	SKIP_ENTRY:
101A: 7E      	            LD   A, (HL)
101B: 23      	            INC  HL
101C: FE00    	            CP   NUL
101E: 20FA    	            JR   NZ, SKIP_ENTRY
1020: 23      	            INC  HL                  ; pula high byte do endereço
1021: 23      	            INC  HL                  ; pula low  byte do endereço
1022: C30A10  	            JP   CMD_SCAN
              	
1025:         	CMD_DISPATCH:
              	            ; Pula string do nome para chegar ao endereço
1025: 7E      	            LD   A, (HL)
1026: 23      	            INC  HL
1027: FE00    	            CP   NUL
1029: 20FA    	            JR   NZ, CMD_DISPATCH
              	            ; (HL) = low byte do handler, (HL+1) = high byte
102B: 7E      	            LD   A, (HL)
102C: 23      	            INC  HL
102D: 66      	            LD   H, (HL)
102E: 6F      	            LD   L, A
              	            ; HL = endereço do handler; HL aponta para resto da linha
              	            ; Precisamos salvar o ponteiro de argumento
              	            ; Reposiciona ponteiro de argumento
102F: 11A4FB  	            LD   DE, LINEBUF		 ; Inicio o buffer
1032: CD0013  	            CALL SKIP_COMMAND_DE	 ; pula comando e DE aponta para o primeiro espaço
1035: CD0E13  	            CALL SKIP_SPACES_DE      ; DE aponta para args
1038: E9      	            JP   (HL)                ; chama handler
              	
1039:         	CMD_UNKNOWN:
1039: 21CD13  	            LD   HL, MSG_UNKNOWN
103C: CDA703  	            CALL PUTS
103F: C9      	            RET
              	
              	; -------- Tabela de comandos --------
1040:         	CMD_TABLE:
1040: 434C5300	            DB   "CLS",  NUL
1044: EA10    	            DW   CLS_CMD
1046: 44554D50	            DB   "DUMP", NUL
104A: 00      	
104B: F010    	            DW   DUMP_CMD
104D: 57524954	            DB   "WRITE", NUL
1051: 4500    	
1053: 3211    	            DW   LOAD_CMD
1055: 45444954	            DB   "EDIT", NUL
1059: 00      	
105A: 8611    	            DW   EDIT_CMD
105C: 4F555400	            DB   "OUT",  NUL
1060: DB11    	            DW   OUT_CMD
1062: 494E00  	            DB   "IN",   NUL
1065: F911    	            DW   IN_CMD
1067: 4A554D50	            DB   "JUMP",    NUL
106B: 00      	
106C: 0F12    	            DW   GO_CMD
106E: 43414C4C	            DB   "CALL",    NUL
1072: 00      	
1073: 1C12    	            DW   CALL_CMD
1075: 4800    	            DB   "H",    NUL
1077: 2D12    	            DW   HELP_CMD
1079: 3F00    	            DB   "?",    NUL
107B: 2D12    	            DW   HELP_CMD
107D: 49484558	            DB   "IHEX",    NUL
1081: 00      	
1082: DF10    	            DW   LOAD_HEX_CMD
1084: 4932434C	            DB   "I2CLIST",    NUL
1088: 49535400	
108C: 5E18    	            DW   I2CLIST
108E: 44495200	            DB   "DIR",    NUL
1092: 1419    	            DW   FS_DIR
1094: 52554E00	            DB   "RUN",    NUL
1098: FA1A    	            DW   FS_EXEC
109A: 53415645	            DB   "SAVE",    NUL
109E: 00      	
109F: 341A    	            DW   FS_SAVE
10A1: 44454C00	            DB   "DEL",    NUL
10A5: 2B1B    	            DW   FS_ERASE
10A7: 464F524D	            DB   "FORMAT",    NUL
10AB: 415400  	
10AE: 8A1B    	            DW   FS_FORMAT
10B0: 4C4F4144	            DB   "LOAD",    NUL
10B4: 00      	
10B5: 9319    	            DW   FS_LOAD_CMD
10B7: 42415349	            DB   "BASIC",    NUL
10BB: 4300    	
10BD: 0060    	            DW   COLD
10BF: 57424153	            DB   "WBASIC",    NUL
10C3: 494300  	
10C6: 0360    	            DW   WARM
10C8: 413A00  	            DB   "A:",    NUL
10CB: D310    	            DW   CHANGE_DRIVE_A
10CD: 423A00  	            DB   "B:",    NUL
10D0: D910    	            DW   CHANGE_DRIVE_B
              	
10D2: 00      	            DB   NUL                 ; fim da tabela
              	
              	
              	; ============================================================
              	;  CHANGE_DRIVE_A  -  Altera drive para device A - EEDRIVE_A
              	; ============================================================
10D3:         	CHANGE_DRIVE_A:
10D3: 3EA0    	    LD A, EEDRIVE_A
10D5: 3201FC  	    LD (I2CA_BLOCK), A
10D8: C9      	    RET
              	
              	; ============================================================
              	;  CHANGE_DRIVE_B  -  Altera drive para device B - EEDRIVE_B
              	; ============================================================
10D9:         	CHANGE_DRIVE_B:
10D9: 3EAE    	    LD A, EEDRIVE_B
10DB: 3201FC  	    LD (I2CA_BLOCK), A
10DE: C9      	    RET
              	
              	; ============================================================
              	;  LOAD_HEX_CMD  -  Carrega intel hex pela porta serial
              	; ============================================================
10DF:         	LOAD_HEX_CMD;
10DF: CD8215  	    CALL loadInit
10E2: C9      	    RET
              	
              	; ============================================================
              	;  CALL_8000  - Atalho - Call 8000H
              	; ============================================================
10E3:         	CALL_8000:
10E3: 116802  	    LD DE, MAIN_LOOP ; endereço de retorno do CALL
10E6: D5      	    PUSH DE
10E7: C30080  	    JP  $8000
              	
              	
              	; ============================================================
              	;  CLS_CMD  -  Limpa tela via sequência ANSI
              	; ============================================================
10EA:         	CLS_CMD:
10EA: 3E0C    	            LD A, 0CH ; FF
10EC: CD0E07  	            CALL sendCharToLCD
10EF: C9      	            RET
              	
              	; ============================================================
              	;  DUMP_CMD  -  Dump hex+ASCII
              	;  Sintaxe: DUMP xxxx
              	; ============================================================
10F0:         	DUMP_CMD:
              	            ; DE aponta para argumentos
10F0: CD6813  	            CALL PARSE_HEX16_DE      ; HL = endereço
10F3: 3836    	            JR   C, DUMP_BAD_ADDR
10F5: 22FAFB  	            LD   (ADDR_TMP), HL
              	
10F8: 0608    	            LD   B, 8               ; 8 linhas de 5 bytes
              	
10FA:         	DUMP_LINE:
10FA: C5      	            PUSH BC
              	            ; Exibe endereço
10FB: 2AFAFB  	            LD   HL, (ADDR_TMP)
10FE: CDBF13  	            CALL PRINT_HEX16
1101: 3E3A    	            LD   A, ':'
1103: CD9B03  	            CALL PUTCHAR
1106: 3E20    	            LD   A, SPACE
1108: CD9B03  	            CALL PUTCHAR
              	
              	            ; Exibe 16 bytes hex
110B: 2AFAFB  	            LD   HL, (ADDR_TMP)
110E: 0E05    	            LD   C, 5
1110:         	DUMP_HEX:
1110: 7E      	            LD   A, (HL)
1111: CDA413  	            CALL PRINT_HEX8
1114: 3E20    	            LD   A, SPACE
1116: CD9B03  	            CALL PUTCHAR
1119: 23      	            INC  HL
111A: 0D      	            DEC  C
111B: 20F3    	            JR   NZ, DUMP_HEX
              	
              	            ;CALL CRLF
              	            ; Avança endereço base
111D: 2AFAFB  	            LD   HL, (ADDR_TMP)
1120: 110500  	            LD   DE, 5
1123: 19      	            ADD  HL, DE
1124: 22FAFB  	            LD   (ADDR_TMP), HL
1127: C1      	            POP  BC
1128: 10D0    	            DJNZ DUMP_LINE
112A: C9      	            RET
              	
112B:         	DUMP_BAD_ADDR:
112B: 21EE13  	            LD   HL, MSG_BAD_ADDR
112E: CDA703  	            CALL PUTS
1131: C9      	            RET
              	
              	; ============================================================
              	;  LOAD_CMD  -  Carrega bytes hex em endereço
              	;  Sintaxe: LOAD xxxx
              	;  Digitar pares hex separados por espaço; linha vazia encerra
              	; ============================================================
1132:         	LOAD_CMD:
1132: CD6813  	            CALL PARSE_HEX16_DE
1135: 3848    	            JR   C, LOAD_BAD
1137: 22FAFB  	            LD   (ADDR_TMP), HL
113A: 211814  	            LD   HL, MSG_LOAD_HINT
113D: CDA703  	            CALL PUTS
              	
1140:         	LOAD_LOOP:
              	            ; Exibe endereço atual
1140: 2AFAFB  	            LD   HL, (ADDR_TMP)
1143: CDBF13  	            CALL PRINT_HEX16
1146: 3E3A    	            LD   A, ':'
1148: CD9B03  	            CALL PUTCHAR
114B: 3E20    	            LD   A, SPACE
114D: CD9B03  	            CALL PUTCHAR
              	
1150: CDA512  	            CALL GETLINE             ; Lê linha
1153: 21A4FB  	            LD   HL, LINEBUF
1156: CD0713  	            CALL SKIP_SPACES
              	
              	            ; Linha vazia = fim
1159: 7E      	            LD   A, (HL)
115A: FE0D    	            CP   CR
115C: C8      	            RET  Z
115D: FE00    	            CP   NUL
115F: C8      	            RET  Z
              	
              	            ; Processa pares hex na linha
1160:         	LOAD_BYTE:
1160: CD3613  	            CALL PARSE_HEX8_HL       ; A = byte, HL avança
1163: 3818    	            JR   C, LOAD_NEXT_LINE
              	            ; Grava byte
1165: ED5BFAFB	            LD   DE, (ADDR_TMP)
1169: 12      	            LD   (DE), A
116A: 13      	            INC  DE
116B: ED53FAFB	            LD   (ADDR_TMP), DE
116F: CD1513  	            CALL SKIP_SPACES_HL
1172: 7E      	            LD   A, (HL)
1173: FE0D    	            CP   CR
1175: 28C9    	            JR   Z, LOAD_LOOP
1177: FE00    	            CP   NUL
1179: 28C5    	            JR   Z, LOAD_LOOP
117B: 18E3    	            JR   LOAD_BYTE
              	
117D:         	LOAD_NEXT_LINE:
117D: 18C1    	            JR   LOAD_LOOP
              	
117F:         	LOAD_BAD:
117F: 21EE13  	            LD   HL, MSG_BAD_ADDR
1182: CDA703  	            CALL PUTS
1185: C9      	            RET
              	
              	; ============================================================
              	;  EDIT_CMD  -  Edita memória byte a byte
              	;  Sintaxe: EDIT xxxx
              	;  Exibe: XXXX: AA  _  (digitar novo valor ou Enter p/ manter)
              	;  '.' encerra
              	; ============================================================
1186:         	EDIT_CMD:
1186: CD6813  	            CALL PARSE_HEX16_DE
1189: 3849    	            JR   C, EDIT_BAD
118B: 22FAFB  	            LD   (ADDR_TMP), HL
              	
118E:         	EDIT_LOOP:
118E: 2AFAFB  	            LD   HL, (ADDR_TMP)
1191: CDBF13  	            CALL PRINT_HEX16
1194: 3E3A    	            LD   A, ':'
1196: CD9B03  	            CALL PUTCHAR
1199: 3E20    	            LD   A, SPACE
119B: CD9B03  	            CALL PUTCHAR
119E: 7E      	            LD   A, (HL)             ; Valor atual
119F: CDA413  	            CALL PRINT_HEX8
11A2: 3E20    	            LD   A, SPACE
11A4: CD9B03  	            CALL PUTCHAR
11A7: 3E20    	            LD   A, SPACE
11A9: CD9B03  	            CALL PUTCHAR
              	
              	            ; Lê até 3 chars (2 hex + CR)
11AC: CDA512  	            CALL GETLINE
11AF: 21A4FB  	            LD   HL, LINEBUF
11B2: CD0713  	            CALL SKIP_SPACES
              	
11B5: 7E      	            LD   A, (HL)
11B6: FE2E    	            CP   '.'                 ; '.' = sair
11B8: C8      	            RET  Z
11B9: FE0D    	            CP   CR
11BB: 280E    	            JR   Z, EDIT_KEEP       ; Enter = mantém byte
11BD: FE00    	            CP   NUL
11BF: 280A    	            JR   Z, EDIT_KEEP
              	
              	            ; Tenta parsear novo byte
11C1: CD3613  	            CALL PARSE_HEX8_HL
11C4: 38C8    	            JR   C, EDIT_LOOP       ; Hex inválido: repete
              	
              	            ; Grava novo byte
11C6: ED5BFAFB	            LD   DE, (ADDR_TMP)
11CA: 12      	            LD   (DE), A
              	
11CB:         	EDIT_KEEP:
11CB: 2AFAFB  	            LD   HL, (ADDR_TMP)
11CE: 23      	            INC  HL
11CF: 22FAFB  	            LD   (ADDR_TMP), HL
11D2: 18BA    	            JR   EDIT_LOOP
              	
11D4:         	EDIT_BAD:
11D4: 21EE13  	            LD   HL, MSG_BAD_ADDR
11D7: CDA703  	            CALL PUTS
11DA: C9      	            RET
              	
              	; ============================================================
              	;  OUT_CMD  -  Escreve byte em porta de I/O
              	;  Sintaxe: OUT pp dd   (porta pp, dado dd, ambos em hex)
              	; ============================================================
11DB:         	OUT_CMD:
              	            ; DE → argumentos
11DB: CD4F13  	            CALL PARSE_HEX8_DE       ; A = número da porta
11DE: 3812    	            JR   C, OUT_BAD
11E0: 4F      	            LD   C, A                ; C = porta
              	
11E1: CD0E13  	            CALL SKIP_SPACES_DE
11E4: CD4F13  	            CALL PARSE_HEX8_DE       ; A = dado
11E7: 3809    	            JR   C, OUT_BAD
              	
              	            ; OUT (C), A
11E9: ED79    	            OUT  (C), A
11EB: 211414  	            LD   HL, MSG_OK
11EE: CDA703  	            CALL PUTS
11F1: C9      	            RET
              	
11F2:         	OUT_BAD:
11F2: 210214  	            LD   HL, MSG_SYNTAX
11F5: CDA703  	            CALL PUTS
11F8: C9      	            RET
              	
              	; ============================================================
              	;  IN_CMD  -  Lê byte de porta de I/O
              	;  Sintaxe: IN pp
              	; ============================================================
11F9:         	IN_CMD:
11F9: CD4F13  	            CALL PARSE_HEX8_DE
11FC: 380A    	            JR   C, IN_BAD
11FE: 4F      	            LD   C, A
11FF: ED78    	            IN   A, (C)
1201: CDA413  	            CALL PRINT_HEX8
1204: CDB703  	            CALL CRLF
1207: C9      	            RET
              	
1208:         	IN_BAD:
1208: 210214  	            LD   HL, MSG_SYNTAX
120B: CDA703  	            CALL PUTS
120E: C9      	            RET
              	
              	; ============================================================
              	;  GO_CMD  -  Executa código a partir de endereço
              	;  Sintaxe: G xxxx
              	; ============================================================
120F:         	GO_CMD:
120F: CD6813  	            CALL PARSE_HEX16_DE
1212: 3801    	            JR   C, GO_BAD
1214: E9      	            JP   (HL)                ; Salta para endereço
              	
1215:         	GO_BAD:
1215: 21EE13  	            LD   HL, MSG_BAD_ADDR
1218: CDA703  	            CALL PUTS
121B: C9      	            RET
              	
              	
              	; ============================================================
              	;  CALL_CMD  -  Executa código a partir de endereço
              	;  Sintaxe: CALL xxxx
              	; ============================================================
121C:         	CALL_CMD:
121C: CD6813  	            CALL PARSE_HEX16_DE
121F: 3805    	            JR   C, CALL_BAD
1221: 116802  	            LD DE, MAIN_LOOP ; endereço de retorno do CALL
1224: D5      	            PUSH DE
1225: E9      	            JP   (HL)                ; Salta para endereço
              	
1226:         	CALL_BAD:
1226: 21EE13  	            LD   HL, MSG_BAD_ADDR
1229: CDA703  	            CALL PUTS
122C: C9      	            RET
              	
              	
              	; ============================================================
              	;  HELP_CMD  -  Exibe ajuda
              	; ============================================================
122D:         	HELP_CMD:
122D: 115014  	            LD   DE, MSG_HELP_L0
1230: CD7E07  	            CALL sendStringToLCD
              	
1233: 115A14  	            LD   DE, MSG_HELP_L1
1236: CD7E07  	            CALL sendStringToLCD
              	
1239: 116114  	            LD   DE, MSG_HELP_L2
123C: CD7E07  	            CALL sendStringToLCD
              	
123F: 116614  	            LD   DE, MSG_HELP_L3
1242: CD7E07  	            CALL sendStringToLCD
              	
1245: 117114  	            LD   DE, MSG_HELP_L4
1248: CD7E07  	            CALL sendStringToLCD
              	
124B: 117D14  	            LD   DE, MSG_HELP_L5
124E: CD7E07  	            CALL sendStringToLCD
              	
1251: 118814  	            LD   DE, MSG_HELP_L6
1254: CD7E07  	            CALL sendStringToLCD
              	
1257: 119314  	            LD   DE, MSG_HELP_L7
125A: CD7E07  	            CALL sendStringToLCD
              	
125D: 119B14  	            LD   DE, MSG_HELP_L8
1260: CD7E07  	            CALL sendStringToLCD
              	
1263: 11A614  	            LD   DE, MSG_HELP_L9
1266: CD7E07  	            CALL sendStringToLCD
              	
1269: 11B114  	            LD   DE, MSG_HELP_L10
126C: CD7E07  	            CALL sendStringToLCD
              	
126F: 11BE14  	            LD   DE, MSG_HELP_L11
1272: CD7E07  	            CALL sendStringToLCD
              	
1275: 11D214  	            LD   DE, MSG_HELP_L12
1278: CD7E07  	            CALL sendStringToLCD
              	
127B: 11E714  	            LD   DE, MSG_HELP_L13
127E: CD7E07  	            CALL sendStringToLCD
              	
1281: 11F914  	            LD   DE, MSG_HELP_L14
1284: CD7E07  	            CALL sendStringToLCD
              	
1287: 110A15  	            LD   DE, MSG_HELP_L15
128A: CD7E07  	            CALL sendStringToLCD
              	
128D: 111C15  	            LD   DE, MSG_HELP_L16
1290: CD7E07  	            CALL sendStringToLCD
              	
1293: 112F15  	            LD   DE, MSG_HELP_L17
1296: CD7E07  	            CALL sendStringToLCD
              	
1299: 114715  	            LD   DE, MSG_HELP_L18
129C: CD7E07  	            CALL sendStringToLCD
129F: C9      	            RET
              	
              	
12A0:         	LCD_SCROLL:
12A0: CD9B03  	    CALL PUTCHAR
12A3: 1805    	    JR GETLINE_LOOP
              	
              	
              	; --- GETLINE: Lê linha para LINEBUF; eco local ---
              	;     Termina em CR. Suporta BS/DEL para apagar.
12A5:         	GETLINE:
12A5: 21A4FB  	            LD   HL, LINEBUF
12A8: 064F    	            LD   B, 79               ; Máx 79 chars + NUL
12AA:         	GETLINE_LOOP:
12AA: CDCD02  	            CALL CONIN
12AD: FE0D    	            CP   CR
12AF: 2849    	            JR   Z, GETLINE_DONE
12B1: FEF8    	            CP   $F8    ; ignora scroll up - GLCD
12B3: 28EB    	            JR   Z, LCD_SCROLL
12B5: FEF7    	            CP   $F7    ; ignora scroll down - GLCD
12B7: 28E7    	            JR   Z, LCD_SCROLL
12B9: FE0A    	            CP   LF
12BB: 28ED    	            JR   Z, GETLINE_LOOP    ; Ignora LF
12BD: FE1B    	            CP   ESC
12BF: 28E9    	            JR   Z, GETLINE_LOOP    ; Ignora
12C1: FE08    	            CP   BkS
12C3: 281D    	            JR   Z, GETLINE_BS
12C5: FE7F    	            CP   DEL
12C7: 2819    	            JR   Z, GETLINE_BS
12C9: FEFA    	            CP   $FA ; AltGr
12CB: CAAF15  	            JP   Z, CALL_IHEX
12CE: FEF9    	            CP   $F9 ; LUZ
12D0: CAE310  	            JP   Z, CALL_8000
12D3: 4F      	            LD   C, A
12D4: 78      	            LD   A, B
12D5: FE00    	            CP   0
12D7: 28D1    	            JR   Z, GETLINE_LOOP    ; Buffer cheio
12D9: 79      	            LD   A, C
12DA: 77      	            LD   (HL), A
12DB: 23      	            INC  HL
12DC: 05      	            DEC  B
12DD: CD9B03  	            CALL PUTCHAR             ; Eco
12E0: 18C8    	            JR   GETLINE_LOOP
12E2:         	GETLINE_BS:
12E2: 78      	            LD   A, B
12E3: FE4F    	            CP   79
12E5: 28C3    	            JR   Z, GETLINE_LOOP    ; Início: ignora BS
12E7: 2B      	            DEC  HL
12E8: 04      	            INC  B
12E9: 3E08    	            LD   A, BkS
12EB: CD9B03  	            CALL PUTCHAR
12EE: 3E20    	            LD   A, SPACE
12F0: CD9B03  	            CALL PUTCHAR
12F3: 3E08    	            LD   A, BkS
12F5: CD9B03  	            CALL PUTCHAR
12F8: 18B0    	            JR   GETLINE_LOOP
12FA:         	GETLINE_DONE:
12FA: 3600    	            LD   (HL), NUL           ; Termina string
12FC: CDB703  	            CALL CRLF
12FF: C9      	            RET
              	
              	; ============================================================
              	;  SUBROTINAS DE PARSE
              	; ============================================================
              	; --- SKIP_COMMAND_DE: Avança DE até o proximo espaço ---
1300:         	SKIP_COMMAND_DE:
1300: 1A      				LD A, (DE)
1301: FE20    				CP SPACE
1303: C8      				RET Z
1304: 13      				INC DE
1305: 18F9    				JR SKIP_COMMAND_DE
              	
              	
              	; --- SKIP_SPACES: Avança HL sobre espaços ---
1307:         	SKIP_SPACES:
1307: 7E      	            LD   A, (HL)
1308: FE20    	            CP   SPACE
130A: C0      	            RET  NZ
130B: 23      	            INC  HL
130C: 18F9    	            JR   SKIP_SPACES
              	
              	; --- SKIP_SPACES_DE: Avança DE sobre espaços ---
130E:         	SKIP_SPACES_DE:
130E: 1A      	            LD   A, (DE)
130F: FE20    	            CP   SPACE
1311: C0      	            RET  NZ
1312: 13      	            INC  DE
1313: 18F9    	            JR   SKIP_SPACES_DE
              	
              	; --- SKIP_SPACES_HL: Avança HL sobre espaços ---
1315:         	SKIP_SPACES_HL:
1315: 7E      	            LD   A, (HL)
1316: FE20    	            CP   SPACE
1318: C0      	            RET  NZ
1319: 23      	            INC  HL
131A: 18F9    	            JR   SKIP_SPACES_HL
              	
              	; --- IS_HEX: testa se A é dígito hex; retorna dígito em A (0-15), CY se inválido ---
131C:         	IS_HEX:
131C: FE30    	            CP   '0'
131E: 3814    	            JR   C, IS_HEX_BAD
1320: FE3A    	            CP   '9'+1
1322: 380D    	            JR   C, IS_HEX_DIG      ; '0'-'9'
1324: E6DF    	            AND  0DFH               ; Uppercase
1326: FE41    	            CP   'A'
1328: 380A    	            JR   C, IS_HEX_BAD
132A: FE47    	            CP   'F'+1
132C: 3006    	            JR   NC, IS_HEX_BAD
132E: D637    	            SUB  'A'-10             ; 'A'→10 ... 'F'→15
1330: C9      	            RET
1331:         	IS_HEX_DIG:
1331: D630    	            SUB  '0'
1333: C9      	            RET
1334:         	IS_HEX_BAD:
1334: 37      	            SCF
1335: C9      	            RET
              	
              	; --- PARSE_HEX8_HL: parseia 2 dígitos hex em (HL), resultado em A; HL avança 2 ---
              	;     Carry = erro
1336:         	PARSE_HEX8_HL:
1336: 7E      	            LD   A, (HL)
1337: CD1C13  	            CALL IS_HEX
133A: D8      	            RET  C
133B: 0F      	            RRCA
133C: 0F      	            RRCA
133D: 0F      	            RRCA
133E: 0F      	            RRCA
133F: E6F0    	            AND  0F0H
1341: 47      	            LD   B, A
1342: 23      	            INC  HL
1343: 7E      	            LD   A, (HL)
1344: CD1C13  	            CALL IS_HEX
1347: 3803    	            JR   C, PHX8_ERR
1349: B0      	            OR   B
134A: 23      	            INC  HL
134B: C9      	            RET
134C:         	PHX8_ERR:
134C: 2B      	            DEC  HL
134D: 37      	            SCF
134E: C9      	            RET
              	
              	; --- PARSE_HEX8_DE: igual mas com DE ---
134F:         	PARSE_HEX8_DE:
134F: 1A      	            LD   A, (DE)
1350: CD1C13  	            CALL IS_HEX
1353: D8      	            RET  C
1354: 0F      	            RRCA
1355: 0F      	            RRCA
1356: 0F      	            RRCA
1357: 0F      	            RRCA
1358: E6F0    	            AND  0F0H
135A: 47      	            LD   B, A
135B: 13      	            INC  DE
135C: 1A      	            LD   A, (DE)
135D: CD1C13  	            CALL IS_HEX
1360: 3803    	            JR   C, PHX8D_ERR
1362: B0      	            OR   B
1363: 13      	            INC  DE
1364: C9      	            RET
1365:         	PHX8D_ERR:
1365: 1B      	            DEC  DE
1366: 37      	            SCF
1367: C9      	            RET
              	
              	; --- PARSE_HEX16_DE: parseia 4 dígitos hex em (DE), resultado em HL; DE avança 4 ---
1368:         	PARSE_HEX16_DE:
1368: CD4F13  	            CALL PARSE_HEX8_DE
136B: D8      	            RET  C
136C: 67      	            LD   H, A
136D: CD4F13  	            CALL PARSE_HEX8_DE
1370: D8      	            RET  C
1371: 6F      	            LD   L, A
1372: C9      	            RET
              	
              	; --- UPCASE_TOKEN: copia token de (HL) em maiúscula para HEXBUF; HL avança após token ---
1373:         	UPCASE_TOKEN:
1373: 11F4FB  	            LD   DE, HEXBUF
1376: 060A    	            LD   B, 10
1378:         	UPCASE_LOOP:
1378: 7E      	            LD   A, (HL)
1379: FE20    	            CP   SPACE
137B: 2817    	            JR   Z, UPCASE_DONE
137D: FE0D    	            CP   CR
137F: 2813    	            JR   Z, UPCASE_DONE
1381: FE00    	            CP   NUL
1383: 280F    	            JR   Z, UPCASE_DONE
1385: FE61    	            CP   'a'
1387: 3806    	            JR   C, UPCASE_STORE
1389: FE7B    	            CP   'z'+1
138B: 3002    	            JR   NC, UPCASE_STORE
138D: E6DF    	            AND  0DFH               ; Converte para maiúscula
138F:         	UPCASE_STORE:
138F: 12      	            LD   (DE), A
1390: 23      	            INC  HL
1391: 13      	            INC  DE
1392: 10E4    	            DJNZ UPCASE_LOOP
1394:         	UPCASE_DONE:
1394: 3E00    	            LD   A, NUL
1396: 12      	            LD   (DE), A
1397: C9      	            RET
              	
              	; --- STRCMP: compara (HL) com (DE), Z=1 se iguais ---
1398:         	STRCMP:
1398: 7E      	            LD   A, (HL)
1399: 47      	            LD   B, A
139A: 1A      	            LD   A, (DE)
139B: B8      	            CP   B
139C: C0      	            RET  NZ
139D: FE00    	            CP   NUL
139F: C8      	            RET  Z
13A0: 23      	            INC  HL
13A1: 13      	            INC  DE
13A2: 18F4    	            JR   STRCMP
              	
