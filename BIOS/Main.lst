              	;------------------------------------------------------------------------------
              	; Pegar 2 caracteres ASCII (0-9 A-F) converte em um byte em A
              	;------------------------------------------------------------------------------
1FD0: CD8A16  	SERIAL_GET_HEX_A:   CALL GETCHR_S	; Get us a valid character to work with
1FD3: 47      	    LD   B,A	; Load it in B
1FD4: CD8A16  	    CALL GETCHR_S	; Get us another character
1FD7: 4F      	    LD   C,A	; load it in C
1FD8: CDA616  	    CALL BCTOA	; Convert ASCII to byte
1FDB: C9      	    RET
              	
              	;------------------------------------------------------------------------------
              	; Pegar 4 caracteres ASCII (0-9 A-F) converte em HL
              	;------------------------------------------------------------------------------
1FDC:         	SERIAL_GET_HEX_HL:
1FDC: CDD01F  	    CALL SERIAL_GET_HEX_A	        ; Endereco High -> H
1FDF: 67      		LD   H,A
1FE0: CDD01F  		CALL SERIAL_GET_HEX_A	        ; Endereco Low -> L
1FE3: 6F      		LD   L,A
1FE4: C9      	    RET
              	
              	
              	
