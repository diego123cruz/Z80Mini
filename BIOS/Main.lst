              	; Generate stop condition
17DB: CDE717  	            CALL I2C_SCL_HI     ;SCL high  (SCL hi, SDA lo)
17DE: CDF517  	            CALL I2C_SDA_HI     ;SDA low   (SCL hi, SDA hi)
17E1: AF      	            XOR  A              ;Return success A=0 and Z flagged
17E2: C9      	            RET
              	
              	
